    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "关羽",
        "甘夫人",
        "糜夫人"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（甘夫人、糜夫人同上。）"
        },
        {
          "character": "甘夫人",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "二人闷坐深庭院，"
        },
        {
          "character": "糜夫人",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "思念皇叔泪涟涟。"
        },
        {
          "character": "甘夫人",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "夫妻徐州遭失散，"
        },
        {
          "character": "糜夫人",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不知何日得团圆。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽上。）"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "思念桃园挂心间，不知二嫂驾可安？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见二位嫂嫂。"
        },
        {
          "character": "甘夫人、糜夫人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "二弟少礼，请坐。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有座。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "糜夫人 （同哭） 喂呀！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位嫂嫂长叹落泪，所为何事？"
        },
        {
          "character": "甘夫人、糜夫人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "想我姊妹二人，自从在徐州与皇叔失散，来到曹营，一不知皇叔生死存亡，二\n不知何日才能出离许昌，因此落泪。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位嫂嫂但放宽心，弟虽在曹营，无日不思想兄长，也曾命人各处打探，若得\n大哥音信，定要保护二位嫂嫂出离许昌。"
        },
        {
          "character": "甘夫人、糜夫人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "那曹操待你十分恩厚，只恐他未必叫你走脱。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹公虽然待弟恩厚，奈弟桃园结义，誓同生死。小弟心如铁石，曹公虽有百计\n千方，怎能打动关某之心也。"
        },
        {
          "character": "关羽",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "二皇嫂休得要泪悲淋，\n细听小弟说分明：\n他怎知我桃园义共死生。\n保定二皇嫂离曹营。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "糜夫人 （同西皮摇板） 听一言来喜在心，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "寻访皇叔莫因循。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（甘夫人、糜夫人同下、关羽自上场门下。）"
        }
      ],
      "interactions": [
        {
          "edge": "甘夫人→糜夫人",
          "turns": 2
        },
        {
          "edge": "糜夫人→甘夫人",
