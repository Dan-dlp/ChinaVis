        {
          "character": "曹操",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "老夫兴兵鬼神愁，刘备兵败在徐州。关羽被困土山口，张辽顺说把吾投。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫曹操，官居首相。昨日带兵袭了徐州，杀得刘备打败，不知生死存亡。那\n关羽被吾困在土山之上，进退两难，也曾命张辽顺说来降。这般时候，为何还\n不见到来？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张辽上。）"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽可曾到来？"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "已离营门不远。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位将军，随同文远，一同迎接。"
        },
        {
          "character": "曹仁、李典、徐晃、夏侯惇、乐进、许褚、曹洪",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带马。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
