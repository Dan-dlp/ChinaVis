      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、曹操、曹仁、李典、徐晃、夏侯惇、乐进、许褚、曹洪、张辽、程昱、郭嘉同上。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "关羽行事人钦仰，\n秉烛达旦世无双。\n再与程昱计端详。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "程昱听令，现有锦袍一件，命你去到关羽馆舍，就说老夫赠与他锦袍，明日在\n演武厅中与诸将贺功，请他前来赴宴。不得有误。"
        },
        {
          "character": "将身且坐宝帐上、程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程昱下。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将听令！明日在演武厅中饮宴，文武官员，俱要各穿红袍，不得有误。"
        },
        {
          "character": "曹仁、李典、徐晃、夏侯惇、乐进、许褚、曹洪、张辽",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。关羽上。）"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "自从下邳来归曹，思想兄长泪双抛。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程昱上。）"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，将军。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请坐。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有座。今奉丞相之命，有锦袍一件，送与将军。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某当拜领。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日丞相与诸位将军贺功，请将军前去赴宴。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官告辞。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恕不远送。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽下。）"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "程昱",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "丞相用尽千般计，打动关羽一片心。"
        }
      ],
