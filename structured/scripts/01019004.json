    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "周瑜"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、四大铠引周瑜同上。）"
        },
        {
          "character": "周瑜",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "幼习兵机，智谋无敌，逞雄威，制胜出奇，名震东吴地。"
        },
        {
          "character": "周瑜",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "甘罗十二智谋高，少年拜相美名标。男儿须抱凌云志，治国安邦立功劳。"
        },
        {
          "character": "周瑜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾，姓周名瑜字公瑾。吴侯驾前为臣，镇守柴桑一带等处。昨日有书信到来，"
        },
        {
          "character": "周瑜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唤吾到东吴议事。"
        },
        {
          "character": "周瑜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！众将官：兵发南徐去者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂同允。〖泣颜回〗。众人同转场下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 4
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
        0.0,
        0.2,
        0.6,
        0.2,
        0.0,
        1,
        0.0,
        0.0
      ]
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "严畯",
        "功勋卓著立战绩",
        "因此当阳败了阵",
        "张昭",
        "旷野荒郊哭声震",
        "步骘",
        "薛琮",
        "虞翻",
        "诸葛亮",
        "陆绩",
        "难民倒有数万整",
        "鲁肃"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张昭、虞翻、步骘、薛琮、陆绩、严畯同上。）"
        },
        {
          "character": "张昭、虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "衣冠楚楚珮玱玱，朝臣待漏五更忙。九天阊阖开宫殿，万里山河赛帝邦。"
        },
        {
          "character": "张昭、虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "下官——"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "张昭。"
        },
        {
          "character": "虞翻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "虞翻。"
        },
        {
          "character": "步骘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "步骘。"
        },
        {
          "character": "薛琮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛琮。"
        },
        {
          "character": "陆绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "陆绩。"
        },
        {
          "character": "严畯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "严畯。"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有诸葛孔明过江来见主公，定是前来游说。今日曹操领兵，欲战刘备，那孔"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明欲借我东吴之兵以敌曹操，幸勿使吴侯中他的诡计。待他到来，我等须要与"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他辩论一番。"
        },
        {
          "character": "虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": "鲁肃",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "诸葛先生到！"
        },
        {
          "character": "张昭、虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鲁肃引诸葛亮同上。）"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，众位大夫请了！"
        },
        {
          "character": "张昭、虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请坐！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告坐。"
        },
        {
          "character": "张昭、虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "先生驾到，吾等不曾远迎，当面恕罪！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢！小人来得仓猝，列位海涵。"
        },
        {
          "character": "张昭、虞翻、步骘、薛琮、陆绩、严畯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "好说！"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "久闻先生隐居南阳、高卧隆中，自比管仲、乐毅，不胜钦仰之至。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此亮平生小可之比也，何劳大夫挂齿。"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那刘豫州，曾三顾茅庐聘请先生，言听计从，就该席卷荆、襄；今日荆、襄诸"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "郡尽属曹操，不知是何意见？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想吾主刘豫州，自出世以来，以仁德为本，以信义为先。若取汉上之地，易如"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "反掌。怎奈荆襄王刘表，亦是汉室之胄，吾主不忍取同宗之基业，故力辞不受。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那刘琮小儿，妄听蔡瑁等之谗言，将荆、襄各郡尽献于曹操，使曹操得以猖"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "獗。今吾主兵屯江夏，别有良图；非君等所知也。"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生自比管、乐。想当日，管仲相桓公，霸诸侯，一匡天下；乐毅扶保燕国，"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下齐邦七十二城，名震当时，皆天下之奇才。今刘豫州聘请先生下山，必能兴"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "利除害、抑强扶弱。刘豫州未得先生之前，尚且占据城池、纵横宇内；既得先"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "生之后，则曹兵一出，抛戈弃甲、望风而逃，乃弃新野、走樊城、败当阳、奔"
        },
        {
          "character": "张昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夏口，竟无容身之地！若有管仲、乐毅，必不至此。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（诸葛亮讪笑。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "喝喝哈哈哈哈。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万里鹏飞，群鸟难及；鸿鹄之志，燕雀难知。譬如人，身染重病，必先用粥糜"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "调养，复用药剂医治，待其脏腑充盈、形骸平服，然后再用肉食以补之、猛药"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "以投之，则病根除矣。若不待气脉和缓，即投以猛药、厚味，则病人断无生理！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾主刘豫州，自汝南兵败之后，暂依刘表，兵不过千人，将则只有关、张、"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵云等，这正如病势尪羸已极之时也。想那新野之地，乃是山僻小县，生民既"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少，粮草无多，城郭未修，军马未练，器械不足，辎重不备；而能博望烧屯、"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "白河决水，使曹仁、夏侯惇辈，心胆俱裂、弃甲而逃。当日管、乐之用兵，未"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "必能过此。夫军家胜败，乃古之常理，昔日汉高皇帝与项羽争雄，屡战屡败，"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到后来垓下一战成功，岂非韩信之良谋乎？"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "吾主行事多义信，"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "打从新野赴江陵。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "吾主不肯两离分。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一日只行数里程。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "曹操得胜逞其能。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "自古兵家岂常胜？"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "征战全在主谋人。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "难民倒有数万整"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "旷野荒郊哭声震"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "因此当阳败了阵"
        },
        {
          "character": "虞翻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今曹公带领雄兵百万、勇将千员，蜂拥而来，夺取江夏，不知先生当以何计？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹操得冀州、幽州袁绍蝼蚁之兵，聚荆州刘表乌合之众，虽有数百万，何足惧"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哉！"
        },
        {
          "character": "虞翻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你主刘豫州，兵败当阳，逃奔夏口，几无容身之地；今将求救于人，尚言“不"
        },
        {
          "character": "虞翻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "惧曹兵”，可谓大言欺人也。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾主当阳之败，乃因携带数十万赴义难民，扶老携幼、号泣相随，吾主不忍舍"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "而去之，一日只行十数里；身旁只有数千仁义之兵，岂能敌曹操百万残暴之众？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今日你东吴兵有数万，将有百员，且据长江之险，你等竟欲使其主屈膝降曹，"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贻笑天下！以此比之，吾主则真“不惧曹操”矣！"
        },
        {
          "character": "步骘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孔明！你今日过江，莫非要学那苏秦、张仪之辈，游说我东吴么？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你道苏秦、张仪为舌辩游说之辈；岂知那苏、张亦是豪杰英雄。苏秦解散各国"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "“合纵连横”之谋，六国封相；张仪相秦，匡扶人国，并非畏强凌弱、避刀怕"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "剑之流。你等今日只信曹操诡诈之言，万分畏惧，贪生怕死，劝主投降，还敢"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "笑苏秦、张仪，真真不知羞耻！"
        },
        {
          "character": "薛琮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，孔明！你道曹操是何等样人？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹操名为汉相，实为汉贼。人人皆知，又何必问！"
        },
        {
          "character": "薛琮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你此言差矣！汉室衰微，气运已尽。曹公应天之运，天下归心；你主不知时务，"
        },
        {
          "character": "薛琮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "强欲相争，如同以卵投石，抱薪救火！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛敬文！你怎么竟出此无父无君之言来了？那曹操宗祖，累食汉朝爵禄，理应"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "忠心为国，报效朝廷。哪知他心怀叛逆，常怀篡汉之心，天下之人，无不痛恨！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你今竟以“天命”归之，真无父无君之人也！幸勿多言！"
        },
        {
          "character": "陆绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想那曹操，虽然“挟天子以令诸侯”，他本是开国丞相曹参之后；刘豫州虽说"
        },
        {
          "character": "陆绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是中山靖王之后，却不可考，他织席卖履，人人尽知，似难与曹操抗衡。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你莫非在袁绍座前怀橘遗亲之陆郎乎？请坐，听山人讲来：那曹操身为相国曹"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参之后，世为汉臣，为何霸持朝政，上欺天子，下压群臣，不但无君并且蔑祖！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不但是汉室之乱臣，真乃是曹氏门中之贼子！吾主刘豫州，堂堂帝室之胄，"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "当今天子也曾按谱稽查，当殿赐爵，怎道无可稽考？汉室高皇帝，以亭长出身，"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "终有天下；则织席卖履，何足耻哉？"
        },
        {
          "character": "严畯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听你之言，可谓强词夺理！但不知你所治，是何经典？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "引经据典，乃腐儒耳。昔日伊尹耕于有莘之野，太公钓于渭水之滨；陈平、张"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "良之流，耿弇、邓禹之辈，经文纬武，治国安邦，图画凌烟，名标青史，并不"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曾闻治何典。岂似尔等，下士书生，徒守笔砚，专尚虚文，并无实学，终日戏"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "墨弄文而已哉呀！"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "自古功臣扶社稷，"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "经纶抱负定出奇。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "岂似你书生念文词。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "功勋卓著立战绩"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "诸君不必纷纷论，"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "先生快见吾主君。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "江东文臣将我问，"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一个个俱怀降曹心。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "管叫他认识我南阳孔明。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鲁肃下，诸葛亮随下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "严畯 （同西皮摇板） 人言孔明才学广，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "今日见来果然强。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "倒叫我等脸无光。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
