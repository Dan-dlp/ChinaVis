      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（诸葛亮上。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "昨日里与周郎夸下海口，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鲁肃上。）"
        },
        {
          "character": "鲁肃",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "一腔心腹事，说与知心人。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大夫来了。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大夫请坐。南屏山“七星坛”可曾筑起？"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俱已齐备，就请先生前往。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此大夫一同前去。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "肃还有要事在身，不能奉陪。我有一言，先生你要牢牢紧记！"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "未曾开言我的泪难忍，"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生吓！"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "下台之后要小心！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鲁肃下。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "好一个鲁子敬忠信厚道，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（诸葛亮下。）"
