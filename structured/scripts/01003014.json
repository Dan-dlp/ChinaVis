          "character": "陈魁",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "看看黄道好吉日。"
        },
        {
          "character": "周翠屏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "初四、十五、廿七，"
