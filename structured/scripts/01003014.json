        {
          "character": "陈魁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "姐姐搭膊可曾缝完？"
        },
        {
          "character": "周翠屏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "还有几针，未曾缝完。你我伙缝了罢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（行上弦。周翠屏咬线。）"
