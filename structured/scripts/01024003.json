        {
          "character": "安禄山",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "见了贵妃把本参。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（安禄山下。）"
        },
        {
          "character": "二书童",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启爷，安禄山回去了！"
        },
        {
          "character": "贺知章",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看他此番前去定要上殿奏本。"
        },
        {
          "character": "李白",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他纵然奏本，他又岂奈我何？"
