        {
          "character": "安禄山",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "恼恨李白太不端，\n主仆竟敢出恶言。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四大铠、四校尉、二将同下。）"
