    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "四黑龙套",
        "张飞",
        "马岱"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖急急风〗。四黑龙套、马夫引张飞同上。）"
        },
        {
          "character": "张飞",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "身穿铁甲玲珑胄，双双环眼虎豹头。跨下一骑乌骓马，掌中丈八神鬼愁。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，汉将张飞，字翼德。奉了哥哥将令，命俺带领三千人马，夺取葭萌关，大\n战西凉马超。\n三军的！"
        },
        {
          "character": "四黑龙套",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "起兵前往，带马！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马夫带马。四白龙套引马岱同上。）"
        },
        {
          "character": "马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔。马前来的，可是张飞？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "然，来将通名上来！"
        },
        {
          "character": "马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺乃马岱在此。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马岱快快回去，叫那马超出马，与俺老子交战，赏儿一枪去罢！"
        },
        {
          "character": "马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一派胡言，看枪！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞、马岱同开打。马岱败下。）"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "追！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞、四黑龙套、马夫同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "张飞→四黑龙套",
          "turns": 1
