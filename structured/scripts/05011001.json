    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "刘基",
        "四大铠",
        "洪武帝",
        "老道"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（老道上。）"
        },
        {
          "character": "老道",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "扫地恐丧蝼蚁命，爱惜飞蛾罩纱灯。"
        },
        {
          "character": "老道",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道武庙住持。圣驾游幸，不免打扫清洁。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（左摆赵云、伍员，中设姜尚、张良，右摆王勇、韩信。）"
        },
        {
          "character": "老道",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "远远望见圣驾来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。四太监、大太监、四大铠、刘基、洪武帝同上。）"
        },
        {
          "character": "四大铠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来此武庙。"
        },
        {
          "character": "洪武帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "驻辇。"
        },
        {
          "character": "洪武帝",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "武庙驻辇马停蹄，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "保驾的将军是刘基。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看一看前朝古今奇。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤登基未曾游此地"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "金梁玉柱瓦琉璃，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "玉石栏杆摆列在丹墀。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "站立庙外用目觑，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一位将军庙外立。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "身穿白甲似雪飞。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "方天画戟手中提。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "右桶狼牙箭几枝。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "马后威风八百余。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好像哪里得胜回。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "那位将军他是谁？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "头戴白盔双凤翅"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "跨下一骑白龙马"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "左手弯弓秋月样"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "马前威风高万丈"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "脸面笑容真可喜"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回头便把先生问"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刘基拱手忙奏启，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "启奏我主圣驾知："
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "赵云名儿天下知。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杀得那曹兵无对敌。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "反说忠良把君欺。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "反将神像立丹墀。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他家住常山真定地"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "长坂坡前救后主"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "皆因糜妃自跳井"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宋室王爷修武庙"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "太祖闻言心中气，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "史官错把忠良欺。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "单人独骑逞雄威。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可叹糜妃投井死。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "还有何人保华夷？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一阵清风往内吹。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "面如枣红五绺须。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "斩将的大刀手内提。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他的功劳在哪里？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这位将军他是谁？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "万马营中救后主"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "曹兵暗放无情箭"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这等臣子不入庙"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤王传旨往内请"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回头又见一员将"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "跨下一骑红鬃马"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这是哪朝安邦将"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回言便把先生问"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "姓王名勇字伯党，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "文武全才世间稀。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "左遮右挡护主体。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "断密涧下命归西。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "唐兵暗放无情箭"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不幸李密带箭死"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听奏言来皱双眉，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "史官竟把忠良欺。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "保主尽忠命归西。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "反说忠良把主欺。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "还有何人保华夷？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一阵清风往内吹。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "唐兵暗放无情箭"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "金牛压死娄金狗"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这等臣子不入庙"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤王传旨请进庙"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叫内臣与孤摆下祭奠礼"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "焚香祭奠酒三杯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。）"
        },
        {
          "character": "洪武帝",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "上坐斩将封神姜吕望，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "下坐着箕子、微子、闻太师。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "兵吞六国名王翦，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "呼风唤雨燕孙膑。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "英布、彭越与韩信，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "岑彭、马武和姚期。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "独行千里关圣帝，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "喝断坝桥是张飞。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "跨海征东薛仁贵，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "李存孝倒有托天力。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "威镇三关杨家将，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这都是前朝忠良将尽人皆知。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见几个头戴双凤翅，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见几个身穿紫罗衣。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见几个横须赛太岁，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见几个怀抱令箭和令旗。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "观前观后观仔细，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "问左问右问刘基。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刘基拱手忙奏启，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不敢隐瞒惹是非。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回头又见一员将，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "白盔白甲五绺须。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这一位将军他是谁？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回头便把先生问"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刘基拱手忙奏启，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "启奏我主听端的："
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "平王驾前算第一。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他与秦楚做过媒。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "姓伍名员字子胥"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "临潼会上曾斗宝"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听奏言来怒冲起，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "骂声伍员不忠的。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "错斩你父命归西。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为臣反上把君欺。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不该鞭打主的尸。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（洪武帝转头。）"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将身又到二殿里。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "身穿一件大红衣。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这位神像他是谁？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回头又见一员将"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回言便把先生问"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他是汉朝的韩信，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "暗度陈仓少人知。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "逼死霸王一管笛。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "九里山摆下埋伏阵"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听奏言来怒火起，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "骂一声不忠不孝贼。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不该埋母在秦西；"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你不该乌江把主逼。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你不该想夺主社稷。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "未央宫中命归西。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "武庙难容你这不忠贼。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将身来在后殿里。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "身穿一件八卦衣。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "右边插面令字旗。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "威风凛凛透九霄。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这位道长他是谁？"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你不该受那汉王拜"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你不该问路把樵夫斩"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你不该杀那陈仓女"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "报应丧在阴人手"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "仔细思量难容你"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "喝骂一声赶出庙去"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "上面坐的一员将"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "左边儿童捧宝剑"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "行兵布阵如反掌"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回言便把先生问"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "姓张名良字子房，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "出在春秋战国时。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "才封他天祭地祭与神祭。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "勒逼项羽乌江丧"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听说张良皱双眉，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "反复不定把君欺。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "汉王无道你就离。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "割肉熬油剥他皮。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "骂罢张良回头看……"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "汉王有道你就保"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "眼前若有张良在"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳！"
        },
        {
          "character": "洪武帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "错出一言悔不及。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "万岁骂臣不妨骂，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "指骂张良臣是谁。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一点不到有是非。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘基转头。）"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "身上脱下紫罗衣。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "望万岁赦臣归故里。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "把武庙当做了金銮殿"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "说什么告老归故里，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你不言来朕心知。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "错出一言你心疑。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "同行半步也难离。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可与孤王保华夷。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤不该今日到此地"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "先生与孤把江山定"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "先生去了又有谁"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老牛老马中何用，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "年迈之人枉费力。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "眼花难把兵来提。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "望万岁将臣赦了罢！"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤不该今日到此地"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "先生与孤把江山定"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "先生去了又有谁"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀万岁吓！"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤不该今日到此地"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生与孤把江山定"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生去了又有谁"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "臣到深山修道去。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "耳聋了，听不见"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "先生要去真要去，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "留你不住枉费心机。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "逢州过府把粮支。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "先生牢牢记在心里："
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "那时要与孤做主意。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "朕封你云游真人去访道"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "赐卿一把白玉扇"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哪里一旦烟尘起"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁。"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "朕封你云游真人去访道"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐卿一把白玉扇"
        },
        {
          "character": "刘基",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里一旦烟尘起"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叩头谢恩辞万岁，"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "对着相府泪悲啼。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "说什么朝中挂紫衣。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "说什么训教子与媳。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大限来时各自飞。"
        },
        {
          "character": "刘基",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "朝中大事再不提。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘基下。）"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "自古出言要谨慎，"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "今日武庙走刘基。"
        },
        {
          "character": "洪武帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍，摆驾回宫。"
        },
        {
          "character": "洪武帝",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "去了擎天一军师。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
