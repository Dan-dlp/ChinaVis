    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "李刚",
        "李虎"
      ],
      "lines": [
        {
          "character": "李刚",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "李刚坐二堂，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李虎上。）"
        },
        {
          "character": "李虎",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "李虎报端详。"
        },
        {
          "character": "李虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启二王爷大事不好了！"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事惊慌？"
        },
        {
          "character": "李虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王爷不知身犯何罪，推出午门问斩。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你待怎讲？"
        },
        {
          "character": "李虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "推出午门问斩。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不好了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "李虎听令，吩咐大小三军，辕门伺候。"
        },
        {
          "character": "李虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下面听者：王爷有令，大小三军，辕门伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李虎下，李刚下。）"
        }
      ],
      "interactions": [
