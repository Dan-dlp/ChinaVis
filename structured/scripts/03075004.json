    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "周泰",
        "太史慈",
        "孙策",
        "张勇"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程普、黄盖、韩当、周泰引孙策同上。）"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "带领众将探贼巢，"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "威风凛凛逞英豪。"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "层层密密摆枪刀。"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "远望贼营旌旗绕"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "程普"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "黄盖"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "韩当"
        },
        {
          "character": "周泰",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "主公！降香已毕，就该回去。"
        },
        {
          "character": "孙策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺今到此，焉能空回也！"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "准备金钩把鳌鱼钓，"
        },
        {
          "character": "太史慈",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "孙策哪里走！"
        },
        {
          "character": "孙策",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看是何人逞英豪？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张勇、太史慈同上。）"
        },
        {
