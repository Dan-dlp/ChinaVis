    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "刘繇",
        "太史慈",
        "张勇",
        "张英",
        "报子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖发点〗。四龙套、张英、三将官引刘繇同上。）"
        },
        {
          "character": "刘繇",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "金鼓齐鸣，旌旗掩映，威风凛，将士纷纷，镇守扬州郡。"
        },
        {
          "character": "张英、三将官",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见君侯！"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "站立两厢！"
        },
        {
          "character": "张英、三将官",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢君侯。"
        },
        {
          "character": "刘繇",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "统领貔貅气概雄，连环战甲扣玲珑。将军怀抱安邦志，逐鹿中原立大功。"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某、扬州刺史刘繇。镇守牛渚，被孙策一战，杀过江来，因此兵撤神亭岭。如"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今深沟高垒，闭营不战。也曾命张勇前去哨探，未见回报。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张勇上。）"
        },
        {
          "character": "张勇",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忙将军情事，报与君侯知。"
        },
        {
          "character": "张勇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见君侯。末将交令。"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "收令。张将军，命你打探军情，怎么样了？"
        },
        {
          "character": "张勇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "末将巡哨，探得孙策带领数骑，前来窥探我营。特来报知。"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！今有孙策带领数骑，前来窥探我营！"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "张英听令！"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传我将令：满营将官不许出战，违令者斩！"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令，令出！"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下面听者！君侯有令：满营将官不许出战，违令者斩！"
        },
        {
          "character": "太史慈",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何人阻令？"
        },
        {
          "character": "太史慈",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "太史慈。"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "随令进帐！"
        },
        {
          "character": "太史慈",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太史慈上。）"
        },
        {
          "character": "太史慈",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不准出战真好笑，"
        },
        {
          "character": "太史慈",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "特到宝帐问根苗。"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯在上，恕俺太史慈有甲胄在身，不能全礼，君侯莫怪！"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军免礼。进帐何事？"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方才君侯传下将令，不准众将出战，是何道理？"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那孙策带领数骑，前来窥探我营，恐怕中了他的诱兵之计。、"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那孙策乃是一勇之夫，有什么“诱兵之计”？君侯赐俺太史慈一支将令，匹马"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "单枪，生擒那孙策进帐！"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且听探马一报！"
        },
        {
          "character": "报子",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "报！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有孙策带领数骑，直奔我营而来！"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探！"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。）"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "紧闭营门！"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯，那孙策分明自来送死，为何紧闭营门？"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那孙策有霸王之勇，范增之才，故尔紧闭营门。"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那孙策纵有霸王之勇，范增之才，俺也要会他一会。"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将听者！哪个有胆量者，随俺太史慈大战那孙策！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张英、三将官同不应。）"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无人应声。你出帐去吧！"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳！俱是无能之辈！"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！我把你个大胆的太史慈！你敢违抗君侯的将令？呸！吃我一拳！"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你个无知匹夫！少时擒来孙策，报效君侯，叫你等见识见识。俺去也！"
        },
        {
          "character": "太史慈",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "临阵怯敌实可恼，"
        },
        {
          "character": "太史慈",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "何惧孙策小儿曹！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太史慈下。）"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀君侯哇，我把那太史慈好有一比！"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "比做何来？"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "初生牛犊不怕虎。我看他定死在孙策之手。"
        },
        {
          "character": "张勇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住了！我看那太史慈是个英雄好汉，你们不来相助，反而笑骂于他。待俺张勇"
        },
        {
          "character": "张勇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "助他一阵便了！"
        },
        {
          "character": "张勇",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "怒气不息出帐道，"
        },
        {
          "character": "张勇",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "帮助太史走一遭。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张勇下。）"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊老将军，何计安排？"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯！你我去到两军阵前观阵，那太史慈若是得胜过孙策，你我就一拥而上。"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若胜不过呢？"
        },
        {
          "character": "张英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我就溜了吧！"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老将军高见。"
        },
        {
          "character": "刘繇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，带马阵前去者！"
        },
        {
          "character": "三将官、四龙套",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "刘繇",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "人来带马战场到，"
        },
        {
          "character": "刘繇",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "两军阵前看根苗。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
