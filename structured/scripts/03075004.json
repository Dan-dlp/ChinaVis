        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请令出战。正是："
        },
        {
          "character": "太史慈",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "英雄志气比天高，刘繇无目识英豪。帐中若得一支令，拔剑要斩海底蛟。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太史慈下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 4,
          "念": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
