        {
          "character": "孙策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太史慈！尔有多大本领，竟敢前来对敌？你二人放马过来，俺孙伯符何惧？"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将你所带之将，一起放马过来，俺太史慈何惧！"
