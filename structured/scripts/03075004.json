        {
          "character": "孙策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！你是何人，敢叫孙伯符的名讳？"
        },
        {
          "character": "太史慈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "东莱黄县太史慈在此！"
