      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手、黄祖同上）"
        },
        {
          "character": "黄祖",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "威震东江，统貔貅，谁人敢当。"
        },
        {
          "character": "黄祖",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "自幼生来性鲁莽，带领甲兵逞刚强。哪怕东吴兵将广，谅他不敢窥边墙。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫，大将黄祖。奉了主公之命，镇守江夏，今日升帐，不知有何军情来报。"
        },
        {
          "character": "报子",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "报。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启爷：主公有令，命祢衡来见。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我闻祢衡乃天下有名之士，今日远来，好幸会也。有请。"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗻。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我迎接。"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请祢先生。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。祢衡上，黄祖出迎。）"
        },
        {
          "character": "祢衡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "黄将军。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祢先生，你来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "黄祖 （同笑） 哈哈哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（祢衡、黄祖同进，揖坐。）"
        },
        {
          "character": "黄租",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生远路驾临，未去恭迎，多有得罪。"
        },
        {
          "character": "祢衡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好说。岂敢劳动将军。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生，老夫久闻大名，今日相见，真乃幸会也。中军，安排酒宴伺候。"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（中军摆酒。）"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请。"
        },
        {
          "character": "祢衡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祢先生，我闻先生从曹丞相处转荐而来。曹丞相部下，有些什么人才，讲来一\n听。"
        },
        {
          "character": "祢衡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军听了。"
        },
        {
          "character": "祢衡",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "曹营中俱都是无能之辈，\n唯杨修与孔融人才出奇。\n比到我也只算大儿小儿。"
        },
        {
          "character": "他二人虽然是天下名士、黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "比老夫如何？"
        },
        {
          "character": "祢衡",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "论到了老将军本无可比，\n俺祢衡说实话恕不恭维。\n虽然是受香烟却少灵机。"
        },
        {
          "character": "公好比庙堂中神圣牌位、黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好匹夫。"
        },
        {
          "character": "公好比庙堂中神圣牌位、黄祖",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "进帐来老夫我款待于你，\n你竟敢宴席前把我来欺。\n一霎时定把他首级来提。"
        },
        {
          "character": "叫军士快与我推出营去、祢衡",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈哈！"
        },
        {
          "character": "叫军士快与我推出营去、祢衡",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "俺祢衡自生来无忧无惧，\n我把那千年事看作须臾。"
        },
        {
          "character": "未来时早已经料定于你、黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你料我什么？"
        },
        {
          "character": "祢衡",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我料你这盗跎难容仲尼。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好个祢衡越发无礼，你藐视世人，全不如你，你把你的本领说来我听，如果近\n乎情理，我便饶你不死。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（祢衡冷笑。）"
        },
        {
          "character": "祢衡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嘿嘿嘿，你且听了。"
        },
        {
          "character": "祢衡",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "祢衡生来志气豪，"
        },
        {
          "character": "祢衡",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "读诗书明礼义道德崇高。\n曾学三略与六韬。\n上欺天子下压群僚。\n才借击鼓骂曹操。\n彩凤焉能住鹊巢。\n哪有好言对尔曹。"
        },
        {
          "character": "诸子百家我尽晓、都只为佞臣出专权当道、我有心替主爷把奸贼扫、前去荆州见刘表、我今到此大数到、黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "真乃大言不惭。"
        },
        {
          "character": "祢衡",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我好比在天仁义鸟，\n贼好比食母野鸱枭。\n贼好比野火遍地烧。"
        },
        {
          "character": "我好比雷鸣天下晓、黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你便有有天大本领，人家不用，也是枉然。"
        },
        {
          "character": "祢衡",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我不戴乱臣乌纱帽，\n我不穿贼子的蟒龙袍。\n我只要能为忠和孝。\n落一个青史美名标。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你就不怕死么？"
        },
        {
          "character": "祢衡",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "常言道三寸气在千般好。\n一旦无常万事抛。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（祢衡狂笑。）"
        },
        {
          "character": "祢衡",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈哈哈！"
        },
        {
          "character": "祢衡",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "叫黄祖休迟疑请你开刀。"
        },
        {
          "character": "黄祖",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "好个大胆祢正平，\n说出话来理不通。\n识时务者为英雄。\n不如把你问斩刑。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此人一味倔强，终非有为之士，斩就斩了罢。\n军士们，推出去斩首。"
        },
        {
          "character": "明哲保身有古训、留你这狂生有何用、四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二下手押祢衡同下。黄射上。）"
        },
        {
          "character": "黄射",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听说要斩祢先生，\n后帐来了讲情人。\n父亲面前说分明。"
        },
        {
          "character": "黄射",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见父亲。"
        },
        {
          "character": "迈步且把大帐进、黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿不在后帐，到此何事？"
        },
        {
          "character": "黄射",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿在后帐。闻听父亲要斩祢衡。想那祢衡乃是天下知名之士，曹丞相，刘主\n公尚且容他，父亲如要将他斩了，岂不被天下人笑骂？"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿讲得有理。快快传令，将祢先生放回。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二下手提祢衡首级同上。）"
        },
        {
          "character": "二下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "献头。"
        },
        {
          "character": "黄祖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿一步来迟，叫为父将他错杀，只好吩咐军士，以礼埋葬便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄祖下。）"
        },
        {
          "character": "黄射",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿遵命。\n军士们！"
        },
        {
          "character": "四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "黄射",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好好将祢先生尸体用棺椁盛殓，葬在鹦鹉洲，听候祭奠。"
        },
        {
          "character": "四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": "黄射",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "黄射",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "可怜此名流，性命一旦休。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄射、四下手同下。）"
        }
      ],
