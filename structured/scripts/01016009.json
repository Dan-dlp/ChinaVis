    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "土地",
        "大鹏",
        "白象",
        "观音",
        "青狮"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四云童、观音同上。土地上。）"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启菩萨：妖魔宝贝，已被小仙打碎，但是她十分厉害，小仙道法不高，难以收\n服。"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "归位去罢。"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢菩萨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（土地下。观音转场。）"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天灵灵，地灵灵，三弟子速现。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖急急风〗。四风旗、四天将、大鹏、青狮、白象同上。〖点绛唇〗。）"
        },
        {
          "character": "大鹏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃大鹏金翅大仙是也。"
        },
        {
          "character": "青狮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "青狮大仙是也。"
        },
        {
          "character": "白象",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "白象大仙是也。"
        },
        {
          "character": "大鹏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "青狮、白象",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "大鹏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "菩萨见召，一同驾云前往。"
        },
        {
          "character": "青狮、白象",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹牌子〗。四风旗、四天将、大鹏、青狮、白象同大转场。）"
        },
        {
          "character": "大鹏、青狮、白象",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "菩萨在上，弟子稽首。"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有旱魃扰害黎民，速速降妖者。"
        },
        {
          "character": "大鹏、青狮、白象",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（观音、四云童同下。四风旗、八怪、王大娘同上。对阵，起打，十二股荡，四连环。）"
        }
      ],
