          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "家远愁看花姊妹，病多难配药君臣。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛宝钗上。）"
