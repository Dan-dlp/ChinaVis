    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "你我前去将他问",
        "元直胸中不可料",
        "可叹刘备无才调",
        "徐庶",
        "我今将他来收了",
        "曹操",
        "程昱",
        "若得元直忠心顺",
        "院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操上。）"
        },
        {
          "character": "曹操",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "安下天罗地网，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程昱上。）"
        },
        {
          "character": "程昱",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "难逃袖里机关。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "主公。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闻听徐庶归家。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我前去看看。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有理。"
        },
        {
          "character": "曹操、程昱",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只为求贤到臣门，"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回转头来叫先生："
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "管叫刘备走无门。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看看元直是怎生？"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "若得元直忠心顺"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你我前去将他问"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是，主公站立一时，待臣前去看来。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "门上哪位在？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子上。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么人？"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前去通报，说丞相同我要见。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "主人有请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐庶上。）"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹丞相与程老爷在外。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐庶迎接丞相。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢，先生请。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请。丞相驾到，徐庶又制在身，未曾远迎，望乞恕罪。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好说，老夫来得莽撞，幸勿见怪。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "元直，丞相特来拜请，同扶汉室，平定天下，命登廊庙，未知尊意如何？"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐庶有何德能，敢劳丞相驾临，何以克当，只是徐庶庸才，有负丞相、先生之"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "意耳！"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好说，如果不嫌，便请同行。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "当得遵命。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相请。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一见先生喜眉梢，"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "曹操马上仔细瞧。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "韬略必定比人高。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这样人儿放他逃。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "胜似得了龙一条。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "元直胸中不可料"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可叹刘备无才调"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我今将他来收了"
        },
        {
          "character": "徐庶",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "徐庶心中闷悠悠，"
        },
        {
          "character": "徐庶",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不忠不孝骂名留。"
        },
        {
          "character": "徐庶",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "谁知反逼母命休。"
        },
        {
          "character": "徐庶",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他想元直把他投。"
        },
        {
          "character": "徐庶",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "终身再不设一谋。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操、徐庶、程昱同下。）"
        }
      ],
