      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、鲁肃同上。）"
        },
        {
          "character": "鲁肃",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "只为荆州忧闷，终日不展愁眉。"
        },
        {
          "character": "鲁肃",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忆昔当年赤壁，火攻天下称奇。英雄沉于水底，曹瞒魄散魂飞。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官，鲁肃。只为桃园弟兄借去我国荆州屯兵养马，是我从中作保。昔日言明：\n得了东西两川，即刻归还。如今他等东西两川俱得，全然不提荆州二字。吾\n主为了此事，终日忧闷，有所谓：食君之禄，当报君恩。我想乔太尉乃是三朝\n元老，胸中必有高见。不免去往乔府，求一妙计，讨回荆州。\n左右，开道乔府。"
        },
        {
          "character": "四文堂",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "三国英雄纷纷闹，\n天地人和刘、孙、曹。\n岁岁征战血染袍。\n铜雀台上气概高。\n吾主终日把心焦。\n准备金钩钓海鳌。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、鲁肃同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "四文堂→鲁肃",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 4,
          "同白": 1,
          "唱": 1
        },
        "singing_ratio": 0.5,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮原板"
        ]
      }
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "一取荆州损粮草",
