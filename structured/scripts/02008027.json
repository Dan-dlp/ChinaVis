      "净": 1,
      "外": 1
    },
    "narrative_curve": [
      0.122
    ],
    "musical_arc": [
      null
    ],
    "cooccurrence": {
      "童子|赵匡胤": 1,
      "童子|陈抟": 1,
      "赵匡胤|陈抟": 1
    }
  },
  "scenes": [
    {
      "scene_index": 1,
      "label": "全剧",
      "characters_present": [
        "在马上观不尽华山胜地",
        "往日下棋盘盘胜",
        "无奈何下一个当头炮",
        "无奈何下一个马后炮",
        "没奈何撒个虎势赖",
        "童子",
        "赵匡胤",
        "这边厢摆的是春夏秋冬分四季",
        "这边厢李存孝猛捉虎尾",
        "陈抟"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（童子引陈抟同上。）"
        },
        {
          "character": "陈抟",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "修仙慕道，不恋红尘，道法高。"
        },
        {
          "character": "陈抟",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "鹿吃山上草，鱼戏水中花。修仙长在外，处处是吾家。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道陈抟，在这华山修炼，数百馀年，未成正果。今有真主在此经过，不免讨\n一封赠，有何不可。\n童儿。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将棋盘摆开。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（陈抟下棋。）"
        },
        {
          "character": "陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "蓬莱海岛一洞仙，\n华山修炼数百年。\n等候真主到此间。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤上。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有豪杰催坐骑闯走关西，\n又只见青的山绿的水杨柳夹溪。\n那边厢摆的是四老四少一般齐。\n那边厢许真人得道高飞。\n又只见二道人潇洒弈棋。"
        },
        {
          "character": "这边厢摆的是春夏秋冬分四季、这边厢李存孝猛捉虎尾、在马上观不尽华山胜地、陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "道友，这棋你输了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他还没有输呢。"
        },
        {
          "character": "陈抟",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "观棋不语真君子，"
        },
        {
          "character": "赵匡胤",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "见死不救非丈夫。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想必君子也会下棋。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "棋么，略知一二。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但有一说，华山棋不空下。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要下什么？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要下金银。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少待。\n我想身边还有三两盘费银子，不免与他下上一盘，倘若赢了，弄几两银子，以\n为路费。\n老道，我这里还有三两银子，与你下上一盘，奈无坐位。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君子爱下棋，贫道让位就是。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好吓，红棋与你摆上。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君子乃是客位。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这是在下三两。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少待。\n想我出家之人，哪来的银子？不免点石化金。天灵灵，地灵灵，点石为金。\n这是贫道三两。棋是一盘为准。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "举手不许后悔。请。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君子请。"
        },
        {
          "character": "陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "霎时间就把祥光掩，\n看他知情不知情。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，老道。在下上得山来，红日高照，霎时间为何云雾腾腾？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才有大仙，在此经过。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在下一路而来，闻知此山，有一陈抟老师，不知是哪一位？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢，就是贫道。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "久仰大名。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不过是外实内虚。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不管你外实内虚，内实外虚。在下爱你的棋下得好。请吓！"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": "陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四四方方一座城，"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "内无粮草外无兵。"
        },
        {
          "character": "陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "内无粮草犹自可，"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "外无救兵怎困人。"
        },
        {
          "character": "无奈何下一个当头炮、陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "当头炮打死了老将军。"
        },
        {
          "character": "无奈何下一个当头炮、陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "童儿，将银子收过了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，老道。为何将我银子拿去？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这棋是你输了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我还未曾输。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎见得？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马还走得这里。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那是拐脚马。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是我输了。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢，我也不赖。你来来来，我与你空下一盘。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先前讲过，棋不空下。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少待。\n三两银，被他赢去。不免把这件衣服，押当几两银子与他，再下一盘。倘或赢\n了，银子衣服，岂不都转来了？\n老道，我把这件衣服与你押当几两银子，再下上一盘你意下如何？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但不知当多少？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "五两罢。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只当得三两。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢，就是三两。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这是君子三两，这是贫道三两。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好吓，请！"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请吓！"
        },
        {
          "character": "陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四个士好比萧何丞相，"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四个相好比樊哙大将。"
        },
        {
          "character": "陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这黑棋好比那韩信将，"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这红棋好比楚霸王。"
        },
        {
          "character": "无奈何下一个马后炮、陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你的将军阵头亡。"
        },
        {
          "character": "无奈何下一个马后炮、陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "童儿，将银子收过了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老道，为何又将我的银子收去？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这棋又是君子输了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我还未曾输。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎见得？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "象还未过河。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "象原不过河。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天气炎热，过河吃水。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "笑话了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，来，来，我与你空下一盘。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原说过棋不空下。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤怒。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗，你这野道，一个人衣服银子，都被你赢去了，只管在此棋不空下，叫人把\n些什么与你下？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君子不要性急，又道龙行带宝，虎行有山。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住，这老道好大的口气，但不知他幼年出家，中年出家。若是幼年出家，再\n休理论。若是中年出家，不免假冒山主，把这华山卖了与他，再下几盘。若是\n赢了，衣服银子，岂不都转来了？\n老道。我且问你，你还是幼年出家，中年出家？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道乃中年出家。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我把你这野道，就骂你一双眼睛，都不放在脸上。山主到了，还在此大模大样，\n我这里不容你在此居住。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不知山主驾到，望乞恕罪。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你既不知，我也不怪罪与你。意欲把这华山卖了与你，再下一盘，你意下如何？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好倒好，但不知要卖多少？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要卖这些。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤手比。）"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想是要卖五百两？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少待。\n我想别人家，华山也不要。只卖五十两罢。\n老道，只卖五十两。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好倒好，只是要个字迹。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要字迹，倒也不难，奈无纸笔。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "石案上现有。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此待我来写吓！"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "上写着赵玄郎三十二岁，\n西罗县里有家门。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君子停笔。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为何。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你乃山西人氏，为何到陕西来卖人的华山？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祖居山西，自幼儿到陕西，又到陕山俱同一里。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来如此，写吓。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我的华山多胜景，\n还有四个小树林。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老道，我把华山卖与你，还有四个小树林，一概卖与你罢。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有银子可以赎得转。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，莫道有银子，也可以赎得转。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好吓，待我写来。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一张卖契写完了，\n回手交与老道人。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "写完了，拿去。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我看来。唔，写倒写得好，少一个凭证之人。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要中人到也不难，这山前山后，凭你寻一个来。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这山前山后，漫说一个，十个都不中用。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要怎么样？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要君子心腹的人，写一个上来。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我心腹上的人，你也不知，也是枉然。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道知道的，就写一个。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好吓，待我写来。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "提笔就写柴子耀，"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不要。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "张光远来罗彦成。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不知。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "石守能来石守信，"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不晓。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "打卦算命的苗先生。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "山西有个榆茨县，\n姓郑名恩字子明。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想是卖油的老官。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你怎认得他？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他在我这里卖过油的，故尔认得，就把他写上去。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "提笔就写郑子明，\n他与我两下作凭证。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "写完了，拿去。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "童儿，看银子五十两与君子。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这是贫道五十两。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请吓！"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": "陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四个车来两将军，"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "两国不和动刀兵。\n今日下棋不得赢。"
        },
        {
          "character": "往日下棋盘盘胜、没奈何撒个虎势赖、陈抟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "君子为何乱胡行？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，老道，为何又将我的银子拿去？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这棋又是你输了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我还未曾输。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎见得？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军还未曾会面。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军原不会面。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是我输了。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢，我也不赖，你来来来，我与你空下一盘。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不耐烦了，要睡觉了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小道友，来来来，我与你下上一盘。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我也不耐烦了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你也不耐烦了？\n老道，在下爱你的棋下得好，再来下上一盘。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "实在不耐烦了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我劝你耐烦些好。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "实实不耐烦。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我把你这瞎了双眼的野道，你道我是甚等样人？"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道不知。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃赌博场中赵匡胤。输打赢要。你赢我的，我赢谁的。好好拿衣服银子还我\n便罢，如若不还，一顿好打。"
        },
        {
          "character": "陈抟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道不知赵公子驾到，望乞恕罪。\n童儿，拿衣服银子还他。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "快些拿来，你这样棋，只管在此与俺下，下得俺一肚子气。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤下。）"
        }
      ],
