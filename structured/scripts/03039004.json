          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "难行！"
        },
        {
          "character": "张龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你怨天？"
        },
        {
          "character": "傅氏",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "尊长官我怎敢将天怨恨，"
        },
        {
          "character": "傅氏",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我怨天也不过枉费舍唇。"
        },
        {
          "character": "郭仪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你怨地？"
        },
        {
          "character": "傅氏",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "尊长官我怎敢将地来恨，"
        },
        {
          "character": "傅氏",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "我恨地也不能缩减途程。"
        },
        {
          "character": "傅氏",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "你、你、你、你可怜我年衰迈寸步难行。"
        },
        {
          "character": "傅氏",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "无奈何我这里埃尘跪定"
        },
        {
          "character": "张龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "郭贤弟！"
        },
        {
          "character": "郭仪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥！"
        },
        {
          "character": "张龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这犯妇不走，我在前面拉，你在后边赶，咱们拉着走！"
        },
        {
          "character": "郭仪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "走！"
        },
        {
          "character": "傅氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀！"
        },
        {
          "character": "莫文禄",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "娘啊！"
