    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "玉珍公主",
        "高能"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四手下、高能同上。）"
        },
        {
          "character": "高能",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "兄弟三人要争功，"
        },
        {
          "character": "高能",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不知谁雌与谁雄？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四女兵引玉珍公主同上，会阵，杀，对把子。）"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来将通名。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺乃天朝大将高能是也。"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高将军，你我这么交战为什么？"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为主江山。"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "江山得了，还是你坐我坐？"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪有臣坐君位之礼？"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "却又来。你我都不能坐，为什样这么冤呢？"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "依你便怎么样。"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "依我你且收兵回去，晚上我在帐中等你。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你的帐房在哪里？"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你看黄罗帐。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是哪个的？"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是我们驸马的。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可是张天龙？"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是了。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我去杀了他。"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用杀他。你要成功全在我哪！"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你的帐房呢？"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你看那红罗帐。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今晚到你帐房去。"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来者君子。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不来呢？"
        },
        {
          "character": "玉珍公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不来者小人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（高能、四手下、玉珍公主、四女兵同下。）"
        }
