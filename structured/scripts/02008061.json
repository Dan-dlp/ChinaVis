        },
        {
          "character": "张天龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎，又跑了。扫兴。"
        },
        {
          "character": "张天龙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "天龙败了神法宝。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卫小申上。）"
        },
        {
          "character": "卫小申",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "流星断送你一命消。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张天龙下，卫小申追下。）"
