          "character": "卫小申",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一来一往各逞强。"
        },
        {
          "character": "张天龙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "霸王逞强乌江丧，"
        },
        {
          "character": "卫小申",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "韩信丧命在未央。"
        },
        {
          "character": "张天龙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "天龙祭起神法宝，"
