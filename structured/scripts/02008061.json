    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "卫小申",
        "杨仙童"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四手下、杨仙童同上。〖水底鱼〗。卫小申上。）"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "表兄回来了？"
        },
        {
          "character": "卫小申",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回来了。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可曾见过阵了？"
        },
        {
          "character": "卫小申",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "见过了。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人有多高？"
        },
        {
          "character": "卫小申",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有天高。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马呢？"
        },
        {
          "character": "卫小申",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有象大。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兵器呢？"
        },
        {
          "character": "卫小申",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "都是丈七丈八的。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他叫什么名字？"
        },
        {
          "character": "卫小申",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人才驸马张天龙。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "胜败如何？"
        },
        {
          "character": "卫小申",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "变狗而逃。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么变犬败回？如今怎么样？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卫小申虚白。）"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "杨仙童",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可笑表兄太无能，"
        },
        {
          "character": "杨仙童",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "待俺前去看分明。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨仙童、四手下同下，卫小申下。）"
        }
      ],
      "interactions": [
