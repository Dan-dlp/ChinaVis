    {
      "scene_index": 12,
      "label": "第十场",
      "characters_present": [
        "杨宗保",
        "狄青"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同上，杨宗保上。）"
        },
        {
          "character": "杨宗保",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "营门鼓声响，探马报端详。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（狄青抱二婴孩上。）"
        },
        {
          "character": "狄青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启元帅：我妻双阳，产生二子。请元帅观看。"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫与他起名，叫做狄文、狄武便了。"
        },
        {
          "character": "狄青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢元帅。我妻现在帐外，请元帅定夺。"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "后帐摆宴，与你夫妻贺功。待本帅奏明圣上便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吹牌子。众人同下。）"
        }
      ],
