        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌上。）"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现有金牌一面，去至沙漠，速调狄先行回营。掩门！"
