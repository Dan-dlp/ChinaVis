        {
          "character": "高俊保",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "辞别师父下仙山。"
        },
        {
          "character": "高俊保",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奴与他定然结姻缘。"
