    {
      "scene_index": 7,
      "label": "第七场",
      "characters_present": [
        "刘金定",
        "土地"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘金定上。）"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "小将武艺时可夸，"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杀得奴家两眼花。"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "遣来了六丁合六甲。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小鬼持风旗同上。）"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "山前来了高俊保，"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "命你前去将他拿。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小鬼同下。）"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回头再把土地叫，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（土地上。）"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见道姑。"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将小将吊在半山崖。"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他本是栋梁保皇家。"
        },
        {
          "character": "刘金定",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奴再与他动杀法。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘金定下。）"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "道姑已去，待吾变来。"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一变二变，樵夫出现。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（土地扮樵夫。）"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这还无有柴担，待我用拐杖变来。"
        }
      ],
      "interactions": [
        {
          "edge": "刘金定→土地",
          "turns": 2
