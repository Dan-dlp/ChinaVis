    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "杨排凤"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨排凤上）"
        },
        {
          "character": "杨排凤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住，看焦二爷，藐视于我，要与我比试。等他到来，不免用法术打他便了。"
        },
        {
          "character": "杨排凤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "杨排凤",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "准备焰火棍，单打志高人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨排凤下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
        0.0,
        0.0,
        0.6667,
        0.3333,
        0.0,
        1,
