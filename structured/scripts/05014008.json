    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "报子",
        "赵云"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、赵云同上，赵云起霸。）"
        },
        {
          "character": "赵云",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "大将生来盖世奇，长坂坡前抖雄威。单人独骑扶幼主，杀气冲霄向空飞。"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，赵云。主公领兵攻取西川，俺奉军师将令，把守江口，远远望见哨探来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有娘娘，私抱太子，回转东吴！"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可曾报过军师？"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "未曾。"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三将军？"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也无有。"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "速去通报。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。）"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！娘娘私抱幼主，回转东吴，定是周郎奸计。俺不免驾舟追赶。\n众将官，带马！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、赵云上马同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "赵云→报子",
          "turns": 3
        },
        {
          "edge": "报子→赵云",
          "turns": 3
        }
      ],
      "stats": {
        "line_counts": {
