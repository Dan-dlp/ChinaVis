        {
          "character": "马周、程万牛、罗章、李敬犹",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "闻陛下谪贬湖广房州，臣等进宫保奏。"
        },
        {
          "character": "李显",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀众卿吓，朕母后传旨，但有文武保本，即便提头来见。"
