    {
      "scene_index": 3,
      "label": "第九场",
      "characters_present": [
        "为此事终日里忧成疾病",
        "二次里命孟良番营来进",
        "佘太君",
        "八贤王",
        "我与你一无仇来二无有怨恨",
        "我与你好亲眷无有仇恨",
        "我前番命孟良骸骨搬请",
        "杨宗保",
        "杨延昭",
        "柴氏",
        "猛然间睁开了昏花眼",
        "真骸骨移在那洪羊洞",
        "老军报他二人在洪羊洞丧命"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨宗保搀杨延昭同上。）"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "叹杨家投宋主心血用尽，"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "真可叹焦、孟将命丧番营。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "怕只怕熬不过尺寸光阴。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监、御林军引八贤王同上。）"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "来至在郡马府忙下金蹬，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监、御林军同下。）"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "迎接千岁！"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "宗保免礼且平身。"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "问宗保你的父何处养病？"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在病房。"
        },
        {
          "character": "八贤王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带路！"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "又只见御妹夫瞌睡沉沉。"
        },
        {
          "character": "八贤王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "醒来！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "方才郊外闲游散闷，"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "遇见了一官长放雕翎。"
        },
        {
          "character": "八贤王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "对着我前心放一箭，"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "险些丧了命残生。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "抬头只见放箭之人。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "你、你、你……为什么放雕翎射我前心？"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "猛然间睁开了昏花眼"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "我与你一无仇来二无有怨恨"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听罢言来才知情，"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "他病体沉重神志不清。"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "休把孤当做了放箭之人。"
        },
        {
          "character": "八贤王",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我与你好亲眷无有仇恨"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "听说贤爷驾到临，"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "宗保儿向前去请罪负荆。"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见千岁！"
        },
        {
          "character": "八贤王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千千岁！"
        },
        {
          "character": "八贤王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐坐。"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。"
        },
        {
          "character": "八贤王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，御妹夫，你此病从何而起？"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！贤爷……呀！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "自那日朝罢归安然睡定，"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "三更时梦见了年迈爹尊。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "那乃是萧天佐以假成真。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "望乡台第三层那才是真。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "又谁知焦克明他私自后跟。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "失了我左右膀难以飞行。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "因此上臣的病重加十分，千岁爷呀！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "我前番命孟良骸骨搬请"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "真骸骨移在那洪羊洞"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "二次里命孟良番营来进"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "老军报他二人在洪羊洞丧命"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄中三眼",
          "musical_style": "二黄中三眼",
          "style_family": "二黄",
          "text": "为此事终日里忧成疾病"
        },
        {
          "character": "八贤王",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "御妹夫休得要珠泪淋淋，"
        },
        {
          "character": "八贤王",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "哪有个人死后又能复生。"
        },
        {
          "character": "八贤王",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "请出了儿祖母与儿娘亲。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（八贤王下。）"
        },
        {
          "character": "杨宗保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请祖母、娘亲！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（佘太君、柴氏同上。）"
        },
        {
          "character": "佘太君",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "听说宗保一声请，"
        },
        {
          "character": "柴氏",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "急忙上前看分明。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿醒来！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "我方才朦胧将养静，"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "耳边厢又听得有人声。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "抬头只见儿的老娘亲。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "到如今白发人反送了黑发人，儿的娘！好不伤情。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杨宗保 （夹白） 爹爹啊！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "宗保儿必须要服人的教训，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "柴氏 （夹白） 喂呀！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "实难舍柴夫人夫妇之情。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "一家人跪埃尘叩谢圣恩。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "恕为臣再不能扶保乾坤。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "我、我面前站定了有许多的鬼魂。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "那孟、孟、孟伯苍他那里拱手相迎。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "抬头只见老严亲。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "佘太君 （夹白） 保重了！"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "无常到万事休去见先人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延昭闭眼向后仰身而死，杨宗保、祡氏、佘太君同急扶住，同痛哭。）"
        }
      ],
