    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "丁岳",
        "丙岳",
        "乙岳",
        "卫士",
        "尧帝",
        "甲岳",
        "许由"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许由上。）"
        },
        {
          "character": "许由",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "笑世人口圣贤心同贼盗，"
        },
        {
          "character": "许由",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "或争权或夺利不让分毫。"
        },
        {
          "character": "许由",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "一霎时冰山倒火灭烟消。"
        },
        {
          "character": "许由",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "位愈尊身愈险你可知道？"
        },
        {
          "character": "许由",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "又何必争天下糜烂同胞？"
        },
        {
          "character": "许由",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "终日间无忧虑自在逍遥。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四御林军、四内侍、四岳引尧帝同上。）"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "离都城访箕山眼前到了，"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为访贤朕不辞路远山遥。"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "从此后一身轻免把心操。"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "但愿得让贤人修明政教"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "向前去叩柴扉急忙通报"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "忽听得柴门外有人喊叫。"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "马蹄乱人声众谁来寻找？"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "朕亲身迎贤者同驾入朝。"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听此言不由我心惊肉跳，"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我怎肯自由身坠入笼牢？"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "重君权民不利烦恼自招。"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "这虚名真误人徒惹风潮。"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "且将这闭门羹款待帝尧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许由暗从后门逃出，下。）"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "半晌时不见人开门来到，"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "转面来问群臣事有蹊跷！"
        },
        {
          "character": "尧帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "朕立侍许久，因何不开门相见？"
        },
        {
          "character": "甲岳、乙岳、丙岳、丁岳",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "那许由品行孤高，从不交结富贵之人，或闻车马声喧，从后门逃走，也未可知！"
        },
        {
          "character": "尧帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卫士，看他家可有后门？"
        },
        {
          "character": "卫士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有后门如今大开。"
        },
        {
          "character": "尧帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好好替许先生看守门户。众卿随朕家追赶先生回来便了！"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "许先生果然是性情高傲，"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为访贤顾不得跋涉勤劳。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "许由→尧帝",
          "turns": 3
        },
        {
          "edge": "尧帝→许由",
