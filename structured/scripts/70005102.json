    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "尧帝",
        "许由"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许由上。）"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "借羽毛任翱翔出笼飞鸟，"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "笑燕雀怎知道鸿鹄高超。"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "天子尊百姓卑何必结交？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四御林军、四内侍、四岳引尧帝同上。）"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "请先生且留步有事相邀。"
        },
        {
          "character": "尧帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "许先生，慢走！"
        },
        {
          "character": "许由",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是天子下降，待小民参拜。"
        },
        {
          "character": "尧帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生乃当世名贤，何拘这君臣俗礼？"
        },
        {
          "character": "许由",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小民无德无才，何贤之有？不过虚名误人而已。"
        },
        {
          "character": "尧帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生不必太谦，朕年已迈，生子不肖，诚恐误国殃民。故别求贤君，以继大位。"
        },
        {
          "character": "尧帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "询于群臣，共举先生，先生当以苍生为重，幸勿固辞，天下幸甚。"
        },
        {
          "character": "许由",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁此言差矣。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "闻此言不由我微微冷笑，"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "为什么圣天子下询刍荛？"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "有什么滔天祸如此心焦？"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "在我看皇帝位不值分毫："
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "遭兵旱又恨你无有略韬；"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "外国侵便说你不重邦交。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "哪一个帝王家富贵长保？"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "反惹起普天下乱动枪刀。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "争权利自相残害死同胞。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "居皇宫终日里如坐监牢。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "心也惊胆也怕魂魄皆消。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "到后来祸临头公理不饶。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "落一个无忧无虑、无是无非、无权无利、无仇无恨、无灾无祸、终日之间饮酒"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "看花乐陶陶。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "请寻那非常人替你代劳。"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "万岁你一席话太过谦了"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "你只当皇帝位有如重宝"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "遇荒旱就怨你赈济太少"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "逢水灾总怪你治河未好"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "自古来成者王败者强盗"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "似这等危险位我不入圈套"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "出宫门众文武前后围绕"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "以一人压天下原非正道"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "不如我隐林泉烟霞啸傲"
        },
        {
          "character": "许由",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "为君难你让天下我许由不要"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "你休学厌世人山林高蹈，"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "做一个救世者再莫辞劳。"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我平生最恨那英雄自命，"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "有几个圣贤君救济苍生？"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "似这等污秽话掩耳不听。"
        },
        {
          "character": "许由",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "从此后风马牛各奔途程。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许由下。）"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我一心让天下他不受任，"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "莫非是无实学徒有虚名？"
        },
        {
          "character": "尧帝",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "与群臣商议定再访贤人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
