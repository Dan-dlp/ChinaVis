      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众士卒、传令官、郭英、李文忠、胡大海、常遇春同上。）"
        },
        {
          "character": "郭英",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "俺本是豪杰，"
        },
        {
          "character": "李文忠",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "儿郎个个烈。"
        },
        {
          "character": "胡大海",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "虎帐领将令，"
        },
        {
          "character": "常遇春",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "要把元兵灭。"
        },
        {
          "character": "郭英、李文忠、胡大海、常遇春",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。我等奉元帅将令，带领人马，先抢牛石渚，后破采石矶，来此一块平坦\n之地，正好操演，就此扎下行营。"
        },
        {
          "character": "郭英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，"
        },
        {
          "character": "传令官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "郭英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传弓箭手开操。"
        },
        {
          "character": "传令官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弓箭手走上。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众士卒同上。）"
        },
        {
          "character": "众士卒",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "弓箭手参。"
        },
        {
          "character": "郭英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "演！"
        },
        {
          "character": "众士卒",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众士卒同射箭。）"
        },
        {
          "character": "众士卒",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "操演已毕。"
        },
        {
          "character": "郭英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "退下。"
        },
        {
          "character": "众士卒",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
