          "style_family": null,
          "text": "吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（常遇春下。）"
        },
        {
          "character": "徐达",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "中军，"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "徐达",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将台撤至江口。"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。\n呔！众将官！"
        },
        {
          "character": "众士卒",
