        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（胡大海下。）"
        },
        {
          "character": "徐达",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "常遇春听令！"
        },
        {
          "character": "胡大海",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "徐达",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你带领三千火炮手，五十号战船，先抢牛石渚，后破采石矶，听我一令！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（江儿水） 拚将忠义相酬，自送头颅，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "怎惜血溅沙场。"
        },
        {
          "character": "常遇春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。\n令出，唗，带马！"
        },
        {
          "character": "众士卒",
          "line_type": "同白",
