  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "家院",
        "这几日我未曾参见王上",
        "闵觉",
        "院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子扶闵觉同上。）"
        },
        {
          "character": "闵觉",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "自那日朝驾归精神不爽，\n因此上染重病睡卧在床。\n宫闱内出刺客扰乱朝纲。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫，闵觉。晋王驾前为臣，官拜刑部尚书之职。只因我朝出了刺客，在粉宫\n楼前，剌王杀驾，不料被御前侍卫拿获。万岁命我审问。今日病体稍愈，不免\n到朝房走走。"
        },
        {
          "character": "这几日我未曾参见王上、家院、院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带你老爷朝服，去往朝房走走。"
        },
        {
          "character": "闵觉",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "晋王爷坐江山人称有道，\n普天下众黎民快乐逍遥。\n宫闱内出刺客混乱九朝。\n看一看审刺客是怎样开销？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（闵觉、院子同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "闵觉→院子",
          "turns": 1
        },
        {
          "edge": "院子→闵觉",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "内白": 1,
          "stage_direction": 4,
          "唱": 1,
          "白": 2
        },
        "singing_ratio": 0.25,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮原板"
        ]
      }
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "三朝臣",
        "下位来我这里把话来论",
        "刺客",
        "四朝臣",
        "太监",
        "怒冲冲将大丞相抓下公案",
        "招实供史娘娘感你的恩德非浅",
        "施一礼众大人听我审判",
        "无奈何下位来将他来劝",
        "朝臣丁",
        "朝臣丙",
        "朝臣乙",
        "朝臣甲",
        "自幼儿出娘胎未受此难",
        "衙役",
        "贺道庵",
        "闵觉"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四朝臣同上。）"
        },
        {
          "character": "朝臣甲",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "如今事儿颠倒颠，"
        },
        {
          "character": "朝臣乙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "朝中出了贺道庵。"
        },
        {
          "character": "朝臣丙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "列位不信从头看，"
        },
        {
          "character": "朝臣丁",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "谁是忠来谁是奸！"
        },
        {
          "character": "朝臣甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位请了！"
        },
        {
          "character": "三朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "朝臣甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁命我等会审刺客，你我同到朝房。"
        },
        {
          "character": "三朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": "朝臣甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "远远望见，大丞相来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺道庵、太监、衙役同上。）"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位请了！"
        },
        {
          "character": "四朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大丞相！"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有闵觉，染病在床。刺客一案，何人审问？"
        },
        {
          "character": "四朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "闵大人染病，我等不敢审问。"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既是列位大人，不肯审问，大丞相何不审问？"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫可以审问得么？"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你身为宰相，焉有不能审问之理？"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此，老夫有僭了！\n来，带刺客。"
        },
        {
          "character": "衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "带刺客！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（衙役押刺客同上。刺客跪。）"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺客。"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是何人？将你带进宫去刺王杀驾，从实招来。免得皮肉受苦！"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相客禀：小人名叫史龙，后宫史娘娘，是小人姑母，小人是他的内侄。那日\n将小人唤进宫去，在酒席筵前，叙来叙去，赐与小人短刀一把，叫小人在粉官\n楼前，刺王杀驾，她想要作一朝女王皇帝。不料被御前侍卫拿住。这就是亲供\n实招。"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可有虚言？"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "句句实言。"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，叫他画供。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（衙役交纸令刺客画供，押刺客下。闵觉暗上。）"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大人，请来画押。"
        },
        {
          "character": "四朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "闵大人未到，我等不敢画押。"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们既不肯画押，待咱家，替你都画上罢！"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怪道吓，怪道！"
        },
        {
          "character": "闵觉",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "来至在朝房内用目观看，\n审刺客何用你宰相专权？"
        },
        {
          "character": "闵觉",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我问你审刺客是哪部官员？"
        },
        {
          "character": "怒冲冲将大丞相抓下公案、贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "胆大闵觉，你来在朝房，抓袍掠带，敢是轻慢我当朝首相？"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你待怎讲？"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "轻慢我当朝首相！"
        },
        {
          "character": "闵觉",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈，哈哈，吓哈哈哈哈！"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你道我轻慢你当朝首相，想你宰相之家，表率天下文武百官，为内外大小臣工\n之领袖，无非是燮理阴阳，调和鼎鼐。想那翰林之家，考取文章，兼放天下主\n考，开科取士。选拔人材，其余：吏、户、礼、兵、工、刑六部大堂，各有专\n司，各有专责。吏部：掌管百官职爵，升迁调补，以至提选咨留，参革简放，\n考功稽动，验封文选，征辟选举，论秀书升，才能参见当今的万岁；户部：掌\n管内务府库金银，天下一十八省，丁漕赋税，各项钱粮；礼部：掌管礼仪祭祀，\n祭坛祭庙，庵观寺院，陵寝庙宇。天地三界，十方万灵，春夏秋冬，祭祀的\n典礼；兵部：掌管副参游都守，千把外委，兵丁将士，人马口粮；工部：掌管\n三宫六院，五府六部，九卿科道，城池营垒，桥梁道路，天下大小工程。惟有\n我这刑部：督理刑名，掌生杀之大权，凡有人命攸关，私杀、擅杀、逼杀、格\n杀、谋杀、斗杀、故杀、误杀，各等案件，俱是我刑部所管。况杀君之徒，乃\n朝廷中第一要犯，理当我刑部所审，理当我刑部所问，何劳你大丞相审问。大\n丞相你要审问，却也不难，你我同到晋王驾前，奏上一本，圣上言道六部，你\n须奏道：不要六部，只要五部。圣上问道；哪部可裁，哪部可减？你须要奏道：\n刑部可裁，刑部可减。圣上准了你的本章，裁了我这刑部，你方审得，你方\n问得；圣上准不了你的本章，裁不了我这刑部，你也审不得，你也问不得。此\n乃刑部法堂之地，非是你大丞相议事之所，你要与我端端正正坐定了！"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "难道说你不念同朝情面么？"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "闵觉",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "非是我不念你同朝情面，\n审刺客本是我刑部在先。"
        },
        {
          "character": "闵觉",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "审不清问不明启奏龙颜，"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带刺客！"
        },
        {
          "character": "施一礼众大人听我审判、衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "带刺客。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（衙役押刺客同上。）"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见大人！"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺客。"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺客！"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有！"
        },
        {
          "character": "衙役",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你要低声些。"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，要低声些。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺客，你是哪位大人，将你带进宫去，藏在粉宫楼前，刺王杀驾，被御前侍卫\n拿住？你要从实招来，免得皮肉受苦！"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人容禀：小人名叫史龙，乃是后宫史娘娘的内侄，史娘娘是小人的姑母。那\n日将小人唤进宫去，在酒席筵前，叙来叙去，她赐俺短刀一把，叫小人藏在粉\n宫楼前，刺王杀驾，要坐一朝女王皇帝。不料被御前侍卫拿住。这就是亲口实\n招。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你待怎讲？"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这就是亲口实招。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "尔就该掌嘴！"
        },
        {
          "character": "闵觉",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "朝房内比不得荒野小县，\n本部堂岂容你信口胡言。\n少时间管叫你皮肉难全。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（衙役打。）"
        },
        {
          "character": "衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "一十！二十！三十！四十！"
        },
        {
          "character": "刺客",
          "line_type": "西皮摇扳",
          "musical_style": "西皮摇扳",
          "style_family": "西皮",
          "text": "上堂来先打我四十大板，\n打得我这两腿鲜血不干。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有招无招？"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无有什么招的！"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大胆！"
        },
        {
          "character": "闵觉",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "好一个小刺客真真大胆，\n上堂来他竟敢信口胡言。\n一霎时管叫你性命不全。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（衙役上夹板。）"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有招无招？"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无有什么招的。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "收！"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦呀！哦呀！"
        },
        {
          "character": "刺客",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "铜夹板夹的我高声叫喊，"
        },
        {
          "character": "刺客",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不由得灵魂儿飞上九天。\n要叫我招口供难上加难。"
        },
        {
          "character": "自幼儿出娘胎未受此难、闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住口！"
        },
        {
          "character": "自幼儿出娘胎未受此难、闵觉",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "这件事倒叫我难以审断，\n用尽了百般刑不吐真言。\n叫刺客进前来细听我言。"
        },
        {
          "character": "自幼儿出娘胎未受此难、闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺客。"
        },
        {
          "character": "无奈何下位来将他来劝、刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺客！"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有！"
        },
        {
          "character": "衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "要低声些。"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，低声些。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是何人将你带进宫去，刺王杀驾？你供招史娘娘是你的姑母，你是史娘娘的\n内侄。我想史娘娘，自进宫以来，并无三亲六眷，哪有什么内侄。你供招史娘\n娘，万岁大怒，将史娘娘推出斩首，况且史娘娘，身怀龙胎六甲。自古道：一\n点龙血落地，天下要干旱三载。你岂不怕天下人，咒骂于你？你若招出真情，\n请列位大人，作一本头，老夫作一本尾，保奏你在朝，大大作上一官，你是何\n等不喜，何等不乐？你若是不招出真情，一刀将你杀死，想你乃是天下英雄，\n岂能作这刀头之鬼？有道是："
        },
        {
          "character": "闵觉",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "要学天下奇男子，方显男儿大丈夫！"
        },
        {
          "character": "闵觉",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "我看你是一个英雄好汉，\n为什么当刺客下贱不堪？\n众公卿保奏你在廉外为官。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，你们慢慢地解劝于他。"
        },
        {
          "character": "招实供史娘娘感你的恩德非浅、衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "刺客，你若是招出真实口供，列位大人，作一本头，闵大人作一本尾，保你在\n朝，做上一官。你是何等不喜，何等不乐？你要再思吓，再想。"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好一个闵大人，下得位来，百般相劝，叫我招出真情，保我在朝，做上一官。\n我不免招了罢。\n哦，我有招。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "招上来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刺客看贺道庵，贺道庵摆手。）"
        },
        {
          "character": "刺客",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "招不得呀，招不得！想当年，我茌黄河渡口，打伤人命，不是恩公搭救，焉有\n今日？招不得。\n闵觉呀，闵觉！你作你的忠臣，我作我的义士。若要真实口供，就有你在内！"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，将牙齿敲掉一个！"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将他的舌头割了！"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "闵觉",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听说是割舌根心惊肉震，\n吓得我战兢兢遍体汗淋。\n尊一声众大人细听分明。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位大人，"
        },
        {
          "character": "下位来我这里把话来论、四朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大人。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今将刺客，调上堂来，刑法用尽，并无半点口供。下官有意，将他带回衙去，\n背审背审。不知列位大人，意下如何？"
        },
        {
          "character": "四朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "全凭大人。"
        },
        {
          "character": "闵觉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告辞了。"
        },
        {
          "character": "闵觉",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "小刺客咬牙关不吐真言，\n用尽了各刑法也是枉然。\n这件事你二人定有牵连。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（闵觉、衙役、刺客同下。）"
        },
        {
          "character": "四朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我等告辞了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四朝臣同下，〖吹打〗。）"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贾公公，你看闵觉，将刺客带回衙去。倘若审出其情，你我均有不便。"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "等到今天晚上，与他送饭之时，将饭中下上毒药，将他药死。给他个死无对证。"
        },
        {
          "character": "贺道庵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，全凭公公。请。"
        }
      ],
