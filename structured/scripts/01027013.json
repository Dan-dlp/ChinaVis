    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "富贵"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（富贵上。）"
        },
        {
          "character": "富贵",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "常侍金枝玉叶人，时随凤体伴龙行。"
        },
        {
          "character": "富贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咱家，穿宫内监，富贵是也。只因我主寿满百岁，满朝文武，有五世同堂，有"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "念": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
        0.0,
        0.0,
        0.5,
        0.5,
        0.0,
        1,
        0.0,
        0.0
      ]
    },
    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "万年青",
        "众人",
        "内侍",
        "刘子",
        "刘晨",
        "永长春",
        "皇上",
        "福康太",
        "鹤松寿"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鹤松寿、永长春、福康太、万年青同上。）"
        },
        {
          "character": "鹤松寿",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "紫云深处务光明，"
        },
        {
          "character": "永长春",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "带露奇花映月芬。"
        },
        {
          "character": "福康太",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "岁岁花开人不老，"
        },
        {
          "character": "万年青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "满屋蟠桃庆至尊。"
        },
        {
          "character": "鹤松寿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "鹤松寿。"
        },
        {
          "character": "永长春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "永长春。"
        },
        {
          "character": "福康太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "福康太。"
        },
        {
          "character": "万年青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万年青。"
        },
        {
          "character": "鹤松寿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今当我主寿满百岁，候驾临朝，同庆百龄。你我分班伺候。"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小监、大太监引皇上同上。）"
        },
        {
          "character": "皇上",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "九天金阙千朵光，紫气祥云照万方。"
        },
        {
          "character": "鹤松寿、永长春、福康太、万年青",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等见驾吾皇万岁，圣寿无疆。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "鹤松寿、永长春、福康太、万年青",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁。"
        },
        {
          "character": "皇上",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忆自登基四海宁，满天星斗照乾坤。太平一统民安乐，数满百龄万寿春。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寡人，大晋天子，国号永寿在位。寿命齐天，万民乐业，乃朕之洪福也。孤今"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "日寿满百岁，众卿衣冠齐整，莫非为寡人祝寿？"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。万岁请上，臣等拜寿。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘子上。）"
        },
        {
          "character": "刘子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁，今有七十年前，刘晨回朝。已在午门候旨。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，刘晨去有七十余年，杳无踪迹。今日回来，真乃罕见。来，宣他上殿。"
        },
        {
          "character": "刘子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "刘子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁有旨，宣刘晨上殿。"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘晨上。）"
        },
        {
          "character": "刘晨",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "且将仙界事，奏与我主知。"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣刘晨见驾，吾皇万岁。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家何不抬头？"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢抬头。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恕你无罪。"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刘晨你去七十余年，还是这等白面书生。"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣在深山过了七日，世上不觉七十余年。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寡人不信。"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁不信，臣有长生丹、展仙帕为证。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "长生丹有何妙处？"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将仙丹放在御酒内，饮入腹中，发白转黑，齿落重生。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "展仙帕呢？"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "展仙帕展开，霞光万道，瑞气千条。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍看宴。寡人与众卿同饮。"
        },
        {
          "character": "内侍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "鹤松寿、永长春、福康太、万年青",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刘卿将展仙帕，展开一观。"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘晨展帕。三仙女同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "三仙女 （同吹腔） 彩云边，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "蓦地里嘉祥现。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "满朝尽欢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "齐把那仙丹展帕，前来进献。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "这是太平年，同庆寿绵绵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同笑。）"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "真果是仙人传授秘密妙方也。内臣看香案伺候，同谢天地。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内侍允。）"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：臣献丹已毕，还要入山修炼。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿既回朝，还要入山修炼何来？"
        },
        {
          "character": "刘晨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本当不去，犹恐有误仙子之言。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既然如此，命光禄司大摆筵宴，众卿与刘卿饯行。"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。朝事已毕，请驾回宫。"
        },
        {
          "character": "皇上",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "退班。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监引皇上同下。）"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
