    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "刘禅",
        "刘谌",
        "女巫",
        "黄皓"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、刘禅同上。）"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "暗渡阴平困都城，"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "吓得孤王胆战惊。"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "为何不见到宫廷。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄皓上。）"
        },
        {
          "character": "黄皓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见万岁！神师请到，宫门候旨。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": "黄皓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请神师！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（女巫附神上，刘禅起，让女巫坐。）"
        },
        {
          "character": "女巫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃西川土神是也！"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见上神！"
        },
        {
          "character": "女巫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请来吾神，为了何事？"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只因邓艾暗渡阴平，袭了绵竹，围困都城，满朝文武降战不一。是孤毫无主见，"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请上神下界，赐一明示。"
        },
        {
          "character": "女巫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "依吾神之见，若肯投降，管保你天下太平。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谨遵上神之命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（女巫做醒。）"
        },
        {
          "character": "女巫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，原来圣驾在此！参见万岁爷！"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来！"
        },
        {
          "character": "黄皓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赏她白银千两，送她出宫去吧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（女巫、黄皓同出门，刘谌上，相遇，刘谌怒目视女巫、黄皓，女巫、黄皓同慌张下。）"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "父听女巫胡言论，"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "只怕江山难保存。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "父皇驾前把本呈。"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣见驾，父皇万岁！"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "迈步且把金殿进"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇儿进宫，有何本奏？"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "邓艾贼子兵困成都，父皇因何坐视不理？"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只因满朝文武议论纷纷，并无决策。孤想若动干戈，恐难取胜。不如投降，可"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "免生灵涂炭。"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自古以来，江山只有争斗，哪有禅让之理！"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤也曾问过神师，还是投降的好！"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "父皇莫信妖巫之言。想那邓艾，孤军入险，利在速战，如今只可固守成都，待"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣率领众将，背城一战，何愁敌人不灭！"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！动不动就要去战，胜了还好，若是败了，岂不送了你老子的性命嘛！"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "父王啊！"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "刘谌殿上把话论，"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "父皇在位仔细听。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "儿愿上阵退敌人！"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "巫婆之言何足信"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "皇儿休得胡言论，"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "神师指引敢不遵！"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "千言万语父不信，"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "倒做进退两难人。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "抱住父皇放悲声。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "未曾开言泪难忍，"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "父皇听我把话明："
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "尽是谗臣哄圣君。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "累死英雄费尽心。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "杀他个片甲不回走无门。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "祖宗的基业莫看轻！"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "走向前来忙跪定"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "邓艾孤军把城困"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "可叹姜维为国来效命"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "如今咱父子君臣背城一战战必胜"
        },
        {
          "character": "刘谌",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "非是儿臣抗君命"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "为父心意业已定，"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "午时三刻便开城。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "堂堂天子坐龙庭，"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "为何甘当亡国君？"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "辱骂父皇是无道人！"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "此事留与后世论"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "奴才出言敢不逊，"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "竟然金殿来欺君。"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "不杀你念在父子情！"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "恨不得一足要儿的命"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "父皇啊！"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不必多言，出宫去吧！"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "父皇不听儿奏本，"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "一足踢我出宫门。"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "国破家亡心何忍？"
        },
        {
          "character": "刘谌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先祖哇！罢！"
        },
        {
          "character": "刘谌",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "回府去杀妻儿然后杀身！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘谌下。）"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "神师与孤安排定，"
        },
        {
          "character": "刘禅",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "投魏之后享太平。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘禅、四太监同下。）"
        }
      ],
      "interactions": [
