    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "董敏"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（董敏带二王子同上。）"
        },
        {
          "character": "董敏",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "自幼净身入宫院，"
        },
        {
          "character": "董敏",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "侍奉先王有数年。"
        },
        {
          "character": "董敏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咱家，董敏。领着二位殿下御花园游玩，天气不早，回宫去者！"
        },
        {
          "character": "董敏",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "手领世子忙回转，"
        },
        {
          "character": "董敏",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但愿国家早平安。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（董敏、二王子同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 4,
          "唱": 1
        },
        "singing_ratio": 1.0,
