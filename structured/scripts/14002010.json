          "character": "赵女",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "观此本免了儿一门祸殃。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监引秦王同上。）"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾。"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "适才间观花灯与民同乐，"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "观相府好一似龙楼凤阁。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见万岁。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了，相国可在府中？"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在表本，待蝼蚁通报。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用通报，退下。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官下。）"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍摆驾。"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "内侍掩灯相府进，"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "灯光之下遇美人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵女下。）"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵高见驾，吾皇万岁。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身，赐座。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家在此则甚？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在此表本。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上来。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来匡府之事，寡人一概不究。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才灯光之下，见一妇人，她是何人？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是老臣小女。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤王意欲宣进宫去，同掌山河，意下如何？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日早朝，送进宫去。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，卿家听封，封你掌朝太师之职。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾回宫廷。"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "内侍摆驾回宫廷，"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "明日早朝看美人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦王、四太监同下。赵女上。）"
        },
        {
          "character": "赵女",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "有事在心头，终日眉头皱。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，爹爹，圣驾到此，为了何事？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁到此，将匡府之事，一概不究。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我主才是有道明君。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本来是有道明君。恭喜我儿，贺喜我儿。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喜从何来？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才万岁见我儿生得美貌，有意带进宫去，同掌山河。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹怎样回奏？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日早朝送你进宫。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹啊，你身为当朝首相，位列三台，连这三纲五常，都不晓得了么？"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "老爹爹你为人真个可厌，"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "儿岂做失节妇遗臭万年。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊，难道不遵父命么？"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹，有道是先嫁由父母，后嫁由自身。我看此事，就用不着你了。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "难道说不遵圣命么？"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹，慢说是圣命，就是一把钢刀，将儿首级割下，也是不能遵命的了。"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "见此情一时间不能言断，"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "必须要生巧计才得安然。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫头做手势教赵女装疯。）"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "见哑奴她叫我把乌云扯乱，"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "抓花容脱绣鞋扯破了衣裳。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿敢是疯了么？"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听说疯我乐得随机应变，"
        },
        {
          "character": "赵女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "倒卧在尘埃地信口胡言。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀，你当真的疯了么？"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么讲？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "疯了么？"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈。爹爹，孩儿要上天。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天高上不去。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀呀呀。爹爹，孩儿要入地。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "地后无门下不去。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀呀呀。爹爹，我那亲……"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "亲什么？"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "亲生的儿啊。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我这里假意儿懒睁杏眼，"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "摇摇摆摆摆摇扭捏向前。"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "奴的夫呀！"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹来呀。"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "随儿到红罗帐倒凤颠鸾。"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我只得把官人一声唤，一声来唤"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫头做手势。）"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸。"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "猛然间又只见天昏地暗，"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "许多的冤鬼魂站立面前。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打鬼！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀，那不是鬼，乃是太湖石。"
        },
        {
          "character": "赵女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太湖石呀。"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "那一旁又来了牛头马面，"
        },
        {
          "character": "赵女",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "玉皇爷驾祥云接我上天。"
        },
        {
          "character": "赵女",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈，呀哈哈哈。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫头、赵女同下。）"
        },
        {
          "character": "赵高",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "闭门家内坐，祸从天上来。"
        }
      ],
