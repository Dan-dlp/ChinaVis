        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "大限来时各一天。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "夫妻好比同林鸟"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "昔日里有个孟姜女，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "千里寻夫到城边。"
