        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "图谋汉室锦江山。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "称孤道寡坐西川。"
        },
        {
          "character": "吴国太",
          "line_type": "摇板",
          "musical_style": null,
          "style_family": null,
          "text": "等候尚香来问安。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四宫女引孙尚香同上。）"
