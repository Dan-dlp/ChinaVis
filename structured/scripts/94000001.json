        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "留得美名万古传。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "就不该当初配夫男！"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "往日贤来，如今反不贤。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "哭倒了长城人称赞"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "夫死不容儿祭奠"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "母后空把弥陀念"
        },
        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我儿说话失检点，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "讲什么古来论的什么贤！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "看哪个大胆到江边！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "为娘我坐在皇宫院"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "儿今一心要祭奠！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "为娘我一定要阻拦！"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "母后不容儿祭奠，"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢！"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "不如碰死在娘前！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "我儿不必寻短见，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "为娘同儿到江边。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿定要江边祭奠，也不阻拦于你；待为娘同儿前去就是。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这个……女儿怎敢劳动母后。有宫娥陪伴就是了……"
        },
        {
          "character": "孙尚香",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "哇！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有宫娥陪伴，我放心不下。也罢，为娘赐你半副銮驾护送前往，儿要早去早回。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此，母后请上，女儿我拜别。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？江边祭奠，去去就回，何言“拜别”二字？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后哇！"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "虽然暂别皇宫院，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "为人须要礼当先；"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "儿原母后福寿全。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四宫女同下。）"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "我母后不解巧机关。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香下。）"
        },
        {
          "character": "吴国太",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "我儿定要去祭奠，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "满怀心事话难言。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二大太监同下。）"
        },
        {
          "character": "吴国太",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "暮景残年谁问安！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吴国太下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "《祭江》"
        },
        {
          "character": "孙尚香",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四大铠、四小太监、四宫女、二大太监、孙尚香、车夫同上。）"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "想当年截江事无限悔恨，"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "背夫主撇娇儿两地离分；"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "到江边去祭奠好不伤情。⑴"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "闻皇叔白帝城丧了性命"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀郡主：来到江边。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祭礼摆下！"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祭礼摆下！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖哭皇天〗。二大太监同设香案，孙尚香焚香祭奠。）"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两厢退下！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四大铠、四小太监、四宫女、二大太监、车夫自两边分下。）"
        },
        {
          "character": "孙尚香",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "设祭长江岸，举目望西山。梦魂何日见，空教泪不干！"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "在江边摆祭礼悲声告禀，"
        },
        {
          "character": "孙尚香",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "皇叔，夫主，喂呀……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（反回龙） 尊一声汉皇叔在天之灵。"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "好夫妻恶因缘衷情难尽，"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "半空中当鉴我一点诚心。"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "可叹你结桃园义功死生；"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "可叹你烧赤壁同破曹兵。⑵"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "偏遇到讨荆州二弟丧生；"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "失机谋被他人火烧连营。⑶"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "辜负了平生志万里鹏程。"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "倒不如殉一死以报亡魂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖反哭皇天〗。孙尚香祭。）"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！想皇叔一死，我有何面目回转西川；留在东吴，兄长又岂能容我。也罢！"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不免拜别母后养育之恩，寻个自尽了吧……"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄散板",
          "musical_style": "反二黄散板",
          "style_family": "二黄",
          "text": "江水滔滔波浪滚，"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄散板",
          "musical_style": "反二黄散板",
          "style_family": "二黄",
          "text": "尚香拜别养育恩。"
        },
        {
          "character": "孙尚香",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "叫声皇叔你且等……"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香投江，下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "——————————"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "⑴此段另有四句唱词可供参考："
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "曾记得当年来此郡，"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "浪打鸳鸯两离分；"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "清风一去未亡人。"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "⑵此段有的增唱两句："
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "可叹你占荆州周郎不急，周郎不忿，皇叔哇！"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "可叹你入虎穴东吴招亲。"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "⑶此段有的增唱两句："
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "辜负了五虎将九泉遗恨，"
        }
      ],
