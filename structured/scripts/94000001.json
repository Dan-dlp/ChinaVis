        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "送儿到荆州有三年；"
        },
        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "母女们分别才得团圆。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "一滴何曾到九泉？"
        },
        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "儿嫁那刘备娘心愿"
