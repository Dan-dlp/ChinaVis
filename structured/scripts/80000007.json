          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子下。）"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "恨石虎把我的战马绞倒，"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "为大将无良骑怎把战交？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四老军同下。）"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "寻一个避风所再作计较。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业下。）"
        }
      ],
      "interactions": [
        {
          "edge": "杨继业→四老军",
          "turns": 4
        },
        {
