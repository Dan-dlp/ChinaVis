          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "探听七弟走一程。"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "辞别爹爹足踏蹬"
        },
        {
          "character": "杨延昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "杨继业"
        },
        {
          "character": "杨延昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "（六郎）（爹爹），（延昭）（我父）！"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹呀！罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延昭下。）"
        },
        {
          "character": "杨继业",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "啊！我的儿啊！"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "见姣儿上了马能行，"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "指着潘洪发恨声。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "潘洪啊，贼！"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "定把老命与尔拚！"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业下。）"
