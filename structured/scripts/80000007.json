        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "金沙滩双龙会一阵败了"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "我的大郎儿替宋王把忠尽了"
