          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "到如今只落得兵败荒郊。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "擅抢夺我主爷的锦绣龙朝。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我父子倒作了马前的英豪。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "只杀得血成河鬼哭神嚎。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "二郎儿短剑下命赴阴曹；"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "四八郎失番邦无有下梢；"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "七郎儿被潘洪箭射花标。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "可怜他尽得忠，又尽孝，血染沙场、马不停蹄，为国辛劳。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "可怜我八个子把四子丧了，把四子丧了，我的儿啊！"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "可怜我一家人无有下梢。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "请我主到五台快乐逍遥。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "四下里众番儿犹如海潮。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "一杆枪保圣驾闯出笼牢。"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "害得我东西杀砍、左冲右突、虎撞羊群，被困在两狼山，里无有粮，外无有草，"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "盼兵不到，眼见得我这老残生就难以还朝！"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "我的儿啊！"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "恨北国萧营中打来战表"
        },
        {
          "character": "杨继业",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "贼潘洪在金殿帅印挂了"
