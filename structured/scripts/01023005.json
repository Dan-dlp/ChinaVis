    {
      "scene_index": 10,
      "label": "第十场",
      "characters_present": [
        "余六"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、八头领、余六、余七同上。）"
        },
        {
          "character": "余六",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此人杀法厉害，用飞抓伤他！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（管宁迎上，打起，众人同败下，管宁追下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 2,
          "白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 11,
      "label": "第十一场",
      "characters_present": [
        "秦盛"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺天保上，众人同上，同围贺天保，大绕场，余六以飞抓打贺天保，贺天保下。管宁上，开打，众人同下。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "卢志义魂引秦盛上。）"
        },
        {
          "character": "秦盛",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺正在公馆打睡，梦见卢志义前来言道：他一人私自探山，被余六将他杀死，\n叫我与他报仇。是俺昏昏沉沉来在此地。好一高大山头，想必就是浮山了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内喊声。）"
        },
        {
          "character": "秦盛",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听山内有喊杀之声，待俺赶上前去！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦盛入山，下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "白": 2
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 12,
      "label": "第十二场",
      "characters_present": [],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺天保上，翻跟头，跌霸，倒。众人同上，同围管宁。秦盛上，同起打，众人败下。秦盛拉管宁出山，同"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 13,
      "label": "第十三场",
      "characters_present": [
        "贺天保"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺天保上。）"
        },
        {
          "character": "贺天保",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "在生时谁不知江南四霸，\n到如今作忠魂答报皇家。"
        },
        {
          "character": "贺天保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，贺天保鬼魂是也。只因俺私自探山，不料被余六飞抓，将俺打死。吾不免\n前去公馆，与黄贤弟托兆，叫他替俺报仇雪恨便了。"
        },
        {
          "character": "贺天保",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我这里驾阴风往前进，\n见了天霸说原因。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺天保下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 4,
          "唱": 1
        },
        "singing_ratio": 1.0,
        "dominant_style_family": "二黄",
        "musical_styles": [
          "二黄摇板"
        ]
      }
    },
    {
      "scene_index": 14,
      "label": "第十四场",
      "characters_present": [
        "关泰",
        "李堃",
        "秦盛",
        "管宁",
        "纪全",
        "贺天保",
        "金大力",
        "黄天霸"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（金大力、关泰、李堃、纪全、黄天霸同上。）"
        },
        {
          "character": "黄天霸",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听谯楼打罢了二更鼓转，\n待等明日探浮山。"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位仁兄。俺贺大哥往哪里去了？"
        },
        {
          "character": "金大力",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想必是去拉屎去啦！"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天已不早，你我安眠了罢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同允，同睡。〖起三更鼓〗。贺天保上。）"
        },
        {
          "character": "贺天保",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "来在了公馆内用目观望，\n又只见众英雄睡在两旁。"
        },
        {
          "character": "贺天保",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天霸，贤弟，愚兄一人，私自探山，不幸竟丧贼人之手。"
        },
        {
          "character": "贺天保",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为开言不由人珠泪双流，\n尊一声黄贤弟细听从头：\n被余六用飞抓打中咽喉。\n擒获了二贼子报吾冤仇。"
        },
        {
          "character": "贺天保",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "杀却了余六贼我气方休！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺天保下。）"
        },
        {
          "character": "黄天霸",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "适才间见兄长魂灵来临，"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "黄天霸",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "醒来时只觉得遍体淋淋。"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位英雄，昨晚三更，偶得一兆，见贺天保兄长浑身是血，言道他一人私自探\n山，倍余六飞抓打死了。吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄天霸哭。）"
        },
        {
          "character": "李堃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "黄爷，休得悲泪，待等着人，打探明白，再作道理。"
        },
        {
          "character": "管宁",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "走呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（管宁、秦盛同上。）"
        },
        {
          "character": "管宁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "黄叔父，大事不好了！"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事惊慌？"
        },
        {
          "character": "管宁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贺叔父他师徒二人，均被浮山余六杀死了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄天霸气绝。）"
        },
        {
          "character": "关泰、管宁、秦盛、金大力、李堃、纪全",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "黄爷醒来！"
        },
        {
          "character": "黄天霸",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "听一言不由人三魂离窍，"
        },
        {
          "character": "关泰、管宁、秦盛、金大力、李堃、纪全",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "黄爷醒来！"
        },
        {
          "character": "黄天霸",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我心中似中了万把钢刀！"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位英雄，想我兄长天保已死。我等需要前去，与他报仇才是！"
        },
        {
          "character": "李堃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待等禀明大人，再作道理！"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大家一同去见大人便了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。众人同下。）"
        }
