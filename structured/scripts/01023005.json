      }
    },
    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "余七",
        "余六",
        "卢志义",
        "沈球"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四头领、余六、余七同上。）"
        },
        {
          "character": "余六",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "弟兄们镇守浮山上，"
        },
        {
          "character": "余七",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "杀人放火逞豪强。"
        },
        {
          "character": "余六",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "将身坐在二堂上，"
        },
        {
          "character": "余七",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "且听喽啰报端详。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（沈球上。）"
        },
        {
          "character": "沈球",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀寨主：拿住奸细一人。"
        },
        {
          "character": "余六",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "押上来。"
        },
        {
          "character": "沈球",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "押上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人推卢志义同上。）"
        },
        {
          "character": "余六",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "胆大奸细，擅敢前来探山，该当何罪？你且通上名来！"
        },
        {
          "character": "卢志义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "瞎了尔等狗眼，俺乃贺天保的门徒，卢志义是也！"
        },
        {
          "character": "余六",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "晚辈小生，何足道哉？"
        },
        {
          "character": "卢志义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺既被擒，要杀就杀，何必多言！"
        },
        {
          "character": "余六",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "推出斩了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人推卢志义同下，斩，众人呈首级同上。）"
        },
        {
          "character": "余六",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将他的首级，号令在山口！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同允，同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "余六→余七",
          "turns": 2
        },
        {
