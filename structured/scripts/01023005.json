    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内擂鼓。沈球带八头领、四下手同上，卢志义起打，众人同围卢志义，同擒，押卢志义同下。）"
        }
      ],
      "interactions": [],
      "stats": {
