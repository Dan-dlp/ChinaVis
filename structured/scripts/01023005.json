    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "卢志义"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卢志义上。）"
        },
        {
          "character": "卢志义",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "适才大人传下令，\n不准私自探贼人。\n要到浮山看分明。"
        },
        {
          "character": "卢志义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，卢志义。方才听俺师父贺天保与黄叔父商议，明日要同来到浮山，是俺私\n自出衙，要探访贼人虚实，立功报效便了。"
        },
        {
          "character": "卢志义",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "甩开大步朝前进，\n来到山口看分明。"
        },
        {
          "character": "卢志义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看此山高大，山口宽广。待俺进山便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卢志义下。）"
        }
      ],
      "interactions": [],
