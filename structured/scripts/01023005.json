    {
      "scene_index": 9,
      "label": "第九场",
      "characters_present": [
        "余七",
        "余六",
        "沈球"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖急急风〗。四龙套、头领、余六、余七同上。沈球引八头领同上。）"
        },
        {
          "character": "沈球",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有一人前来探山，十分厉害。"
        },
        {
          "character": "余六、余七",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "杀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同允，贺天保迎上，起打，打六股荡，众人同败下。贺天保耍双刀花，下。）"
        }
      ],
      "interactions": [
