        {
          "character": "杨波",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁请！"
        },
        {
          "character": "徐延昭",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "大人请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨公子、杨波、徐彦昭同上。）"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "探罢皇陵到昭阳，"
        },
        {
          "character": "杨波",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "宫门上锁贼李良。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "铜锤付与大人掌，"
        },
        {
          "character": "杨波",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "锤击宫门禀皇娘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨公子接锤。）"
        },
        {
          "character": "杨公子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": "杨公子",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "我父把令往下降，"
        },
        {
          "character": "杨公子",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "哪怕铁壁与铜墙。"
        },
        {
          "character": "杨公子",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "铜锤一举只环响"
        },
        {
          "character": "徐小姐",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "你是何人击宫墙？"
        },
        {
          "character": "徐彦昭、杨波",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿休要动手，此乃（四公子）（徐小姐），上前见礼。"
        },
        {
          "character": "杨公子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这厢有礼！"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "还礼。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨公子下。）"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿启奏国太，徐、杨二家宫门求见。"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启奏国太：徐、杨二家宫门求见。"
        },
        {
          "character": "李艳妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宣他们进宫。"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国太有旨：徐、杨二家进宫。"
        },
        {
          "character": "徐彦昭、杨波",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人！"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁。"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此番进宫，将保国之事，细说一番，"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "全仗千岁。"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁请！"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "千岁爷进寒宫休要慌忙，"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "站宫门听学生细说比方："
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "鸿门设宴要害汉王。"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "九里山前摆下战场。"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "到后来封韩信三齐王。"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "后宫院有一位吕后娘娘。"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "三宣韩信斩首未央。"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "为国的忠良不能久长。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "徐彦昭 （夹白） 却是为何？"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "怕的是辜负了十载寒窗、九载遨游、八月里科场、七篇的文章，落得个兵部侍"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "郎，无有下场。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "说甚么学韩信命丧未央，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "站宫门听老夫改换比方："
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙国太怎比得吕后娘娘。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "大人怎比得三齐王。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "有老夫比樊哙、怀抱铜锤、保驾身旁、料也无妨。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "先皇爷怎比得汉高皇上"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "李良贼怎比得萧何丞相"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "这寒宫怎比得鸿门宴上"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我好比鱼儿闯过了千层罗网，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "受了惊恐着了些慌忙。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "只要你忠心把国掌，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老夫保你满门无伤。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "千岁爷保学生满门无伤，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "拚着一死闯进昭阳。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "前面走的是开国将，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "后面跟的兵部侍郎。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "站立在宫门朝内望，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "李艳妃 （夹哭） 喂呀！"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "又只见龙国太，怀抱太子两泪汪汪、口口声声哭的是先王。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙国太哭的是江山难掌，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "摆一摆手儿切莫要声张。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "进宫去休把那君臣礼上，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "学一个文站东，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "武列西，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "徐彦昭 （同二黄原板） 各自分班站立在两厢。"
        },
        {
          "character": "李艳妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先皇呀！"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "李艳妃坐昭阳自思自想，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "想起了先皇爷好不惨伤。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "想必是徐、杨二家进了昭阳。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "我只得怀抱太子、两泪汪汪、口口声声、哭的是先皇。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "耳边厢又听得朝靴响亮"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "有几句话儿不好言讲"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "怀抱着幼主爷江山执掌，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "为什么，恨天怨地、颊带愁肠、所为哪桩？"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "并非是哀家颊带愁肠，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "都只为我朝中不得安康。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我朝中有甚么祸从天降？"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你就该请太师父女商量。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "太师爷心肠如同王莽，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "他要夺我皇儿锦绣家邦。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "太师爷娘娘的父，他本是皇亲国丈，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "未必他一旦无情起下了篡位心肠，太师爷是一个忠良。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你道他无有篡位的心肠，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "封锁昭阳为的是哪桩？"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣七月十三，三本奏上，国太偏偏要让，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你言道大明朝有事无事，不用徐、杨二奸党，赶出朝廊自立为王。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "先前的话儿休要讲，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "不看哀家看先皇。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我封你一字并肩王。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "徐皇兄保太子登龙位上"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老臣我年迈难把国掌，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "要保国还要那兵部侍郎。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "徐皇兄年纪迈难把国掌，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "转面来叫一声兵部侍郎。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你的名儿万古扬。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你保太子登龙位上"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "吓得臣低头不敢望，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "战战兢兢启奏皇娘。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "今日里进宫来辞别皇娘。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣要学钟子期砍樵山岗。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣要学吕蒙正苦读文章。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "夏至荷花满池塘；"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "冬至腊梅带雪霜。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣要落个无忧无虑、无是无非、做什么兵部侍郎、赦臣还乡。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣昨晚修下了辞王本章"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣要学姜子牙钓鱼台上"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣要学尉迟恭耕种田上"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "春来百花齐开放"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "秋来菊花金钱样"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "望国太开龙恩将臣放"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "他二人把话一样讲，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "倒叫哀家无有主张。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "没奈何怀抱太子跪至在昭阳"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "吓坏了定国王，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "兵部侍郎。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "自从盘古立帝邦，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "君跪臣来臣怎敢当？"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "非是哀家来跪你，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "为的是我皇儿锦绣家邦。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "锦家邦来锦家邦，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣有一本启奏皇娘。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "昔日里有一个李文、李广，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "换刀杀妻保朝堂。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "李文北门带箭伤，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "伴驾山前又收李纲。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "收了一将损伤一将，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "一将倒比一将强。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "到后来保太子登龙位上，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "反把亚父斩首在庆阳。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "这都是前朝的忠臣良将，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "哪一个忠良又有下场？"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "有下场来无下场，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "细听哀家说比方："
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "长坂坡前救过小王。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "他的名儿万古扬。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "昔日里有一个子龙将"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "到后来保幼主登龙位上"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "困龙思想长江浪，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "虎落平阳想奔山岗。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "事到头来想一想，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "谁是忠良哪个是奸党？"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "忠良本是徐、杨将，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "奸党乃是我父李良。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "哀家跪死在昭阳。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "二卿不把国来掌"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "铜锤一举皇请上，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老杨波搀扶起定国王。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "回头来奏一道太平表章，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老杨波搬来了众家儿郎。"
        },
        {
          "character": "李艳妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好呀！"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听说是杨波搬兵到，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "不由哀家喜眉梢。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "太子付与小姐抱"
        },
        {
          "character": "徐小姐",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "双手奉与老年高。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "用手接过大明后，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（夹白） 大人！"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你保幼主坐龙楼。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "用手接过龙一条，"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "二目圆睁把臣瞧。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "浑身上下似水浇，难以保朝。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "乘此机会生计巧"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "大人不必生计巧，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你的心事某猜着。"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "莫不是保幼主你嫌官小？"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杨波 （同笑） 哈哈哈哈哈！"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "快与杨波加封号。"
        },
        {
          "character": "李艳妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨波听封！"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我封你七岁孩童戴纱帽，"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "九岁女儿进皇朝。"
        },
        {
          "character": "李艳妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "子子孙孙爵禄高。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李艳妃、徐小姐、宫娥同下。）"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叩罢头来谢龙恩！"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "徐延昭代驾且平身。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一文，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一武，"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "出宫门，"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "仗着幼主叫皇兄。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "大明的江山全仗你"
        },
        {
          "character": "徐彦昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "保国家还仗你杨家父子兵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐彦昭、杨波同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "李艳妃→杨波",
          "turns": 6
        },
        {
          "edge": "杨波→徐延昭",
