          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我分班伺候。"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴力士、高力士分站。）"
        },
        {
          "character": "杨玉环",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、四宫女同上，杨玉环上。）"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "海岛冰轮初转腾，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "见玉兔又转东升。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "皓月当空，恰便是嫦娥离月宫。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "冰轮离海岛，乾坤分外明"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "裴力士"
        },
        {
          "character": "高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "娘娘千岁！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二卿平身。"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "千千岁！"
        },
        {
          "character": "杨玉环",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "独坐皇宫有数年，圣驾宠爱我占先。宫中冷落多寂寞，辜负嫦娥独自眠。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾乃杨玉环，蒙主宠爱，钦点贵妃，这且不言。昨日圣上命我往百花亭大摆筵"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宴。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，高、裴二卿摆驾！"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "好似嫦娥下九重，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "凄凄冷落广寒宫。吓，广寒宫。"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：来此已是玉石桥！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "玉石桥斜依把栏杆靠，"
        },
        {
          "character": "高曲",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "金丝鲤鱼朝见娘娘！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "欢见鱼戏水，金丝鲤鱼在水面上漂，水上漂。"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "当空雁儿飞来了！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "当空雁儿飞腾，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "闻奴声影落画屏。"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：来此百花亭！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "正行时宫人来禀，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "轻移来在百花厅。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高、裴二卿，"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "娘娘。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待圣驾前来，速便通报。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公爷，这事瞒不过去，咱俩就禀了罢。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：驾转西宫去了！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你待怎讲？"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "驾转西宫去了！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "起过了！"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢娘娘！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，昨日圣上命我百花厅设宴。哎，怎么今日驾转西宫？哦，谅必是这贱人之"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "意！咳，由他去罢！吓，高、裴二卿看宴，待你娘娘自饮！"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！"
        },
        {
          "character": "宫女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：宫娥们敬酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "敬的什么酒？"
        },
        {
          "character": "宫女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "龙凤酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何为龙凤酒？"
        },
        {
          "character": "宫女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是圣上与娘娘所饮之酒，名曰龙凤酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，呈上来。"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：奴婢敬酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "敬的什么酒？"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太平酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何为太平酒？"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "满朝文武所做，名曰太平酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，呈上来。"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：奴婢敬酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你敬的什么酒？"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "通宵酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！呀呀啐！哪个与你同什么宵！"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：不要动怒，此酒也是满朝文武不分昼夜所造，故尔叫做通宵酒。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，呈上来。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "同宵捧金盅，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "高裴二卿接手捧。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "奴且开怀饮数盅。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "人生在世如春梦"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "裴力士"
        },
        {
          "character": "高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "看娘娘酒性不足，只恐还饮酒，你我小心伺候。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高、裴二卿，你娘娘酒性未足，看大觥伺候。"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同窝下。〖柳腰金〗。裴力士、高力士同上。）"
        },
        {
          "character": "裴力士、高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "你我打扫打扫，摆试起来。有请娘娘！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同上，杨玉环穿宫妆上，做身段。杨玉环下腰饮醉三斗醉。）"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣驾到，圣驾到！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "听报道万岁驾到百花亭，"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "娘娘酒性差不多了，你我来接驾。娘娘速去接驾。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "急急忙忙跪在地埃尘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同跪。）"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾妃杨玉环接驾来迟，望万岁恕罪。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启娘娘：奴婢诓驾。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么讲？"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴婢诓驾。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀呀啐！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "自古道酒不醉人人自醉，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "色不迷人人自迷。哎，人自迷。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "裴力士在哪里？"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "娘娘有话对你说："
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "我便来，来，来，来朝一本奏当今，卿家吓，管叫你官上加官职！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "你若是称了我的心，合了我的意"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴婢不敢。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你待怎讲？"
        },
        {
          "character": "裴力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴婢没有胆子。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "你若不称奴的心，不合奴的意，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "我便来，来，来朝一本奏当今，唗，狗才吓，管叫你一命见阎君，哎，见阎君！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "高力士在哪里？"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "娘娘有话对你说："
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "我便来，来，来一本奏当今，卿家吓，管叫你官上加官职！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨玉环取高力士帽戏弄。）"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴婢没有这个……"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你待怎讲？"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴婢想倒是想，可惜干不了！"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨玉环打高力士，高力士下。）"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啐啐啐！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "狗才吓！你若是不称我的心，不合我的意，"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "管叫你革职为庶民，哎，为庶民！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "安禄山在哪里？"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "想你当初进宫之时你娘娘怎生待你，何等爱你？"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "玉美人倒在鞧韆驾上。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "我便来，来，来朝一本奏当今"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "唗，狗才吓"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "至今日你忘恩负义"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "裴力士"
        },
        {
          "character": "高力士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "天色已晚，请娘娘回宫。"
        },
        {
          "character": "杨玉环",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾！"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "扶好了。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "去也去也，回宫去也！"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "唐明皇将奴骗，辜负好良宵。"
        },
        {
          "character": "杨玉环",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "万岁，只落冷清清独自回宫去也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
