          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "后殿王？"
        },
        {
          "character": "呼延赞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一十八驾总兵王？"
