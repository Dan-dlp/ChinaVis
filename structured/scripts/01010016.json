          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "原来还有后代根。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "不通名姓走了罢"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "钢鞭不打无名人！"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "乾德王现在黄罗帐，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我是他驾前一小军。"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "看你不像军家样，"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "定是御营乾德王！"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "少有关西闯帝邦，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "岂肯过伏小儿郎？"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "孤就是御营乾德王！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤、呼延赞同开打，赵匡胤下，呼延赞追下。赵匡胤上。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "催马来在战场下，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "小将到来顺说他。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（呼延赞上。）"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我父身犯何条律，"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "为何一命问斩刑？"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "小将军暂息雷霆怒，"
