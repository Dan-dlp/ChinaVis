        {
          "character": "呼延赞",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "家住在河南汴梁城，"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "我的父名叫呼寿廷。"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "跨下了一骑乌骓马"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "问一声小将名和姓"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "就是少爷的名！"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "若问小将名和姓"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "呼延赞"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "孤道呼家无有后，"
