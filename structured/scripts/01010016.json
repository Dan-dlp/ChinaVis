          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "会一会罗家山那家英豪。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "呼延赞 （内二黄导板） 乌骓马不住得吮声吼，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（呼延赞上。）"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "打将鞭一举鬼神愁！"
        },
        {
          "character": "呼延赞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀呔！"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "叫一声乾德王快出营头！"
        },
        {
          "character": "呼延赞",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "催马儿来至在御营口"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "只见他乌油盔乌油甲，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "皂罗袍上绣团花。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "打将钢鞭手内拿。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "通上名来好动杀法！"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "跨下了一骑乌骓马"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "问一声小将名和姓"
