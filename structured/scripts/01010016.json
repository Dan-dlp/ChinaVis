        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "他要夺孤王的锦绣龙廷。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "你的父倒作了马前先行。"
