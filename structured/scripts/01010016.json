          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "恨河东刘冲贼战表打定"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "欧阳藩在金殿挂了帅印"
