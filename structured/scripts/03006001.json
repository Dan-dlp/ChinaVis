      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员换白髯口上。）"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杀败了，杀败了！"
        },
        {
          "character": "伍员",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "子胥离家有数年，不报冤仇誓不还。解开甲胄观幼主，"
        },
        {
          "character": "伍员",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈……"
        },
        {
          "character": "伍员",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "一夜髯白过昭关。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！卞庄休赶，伍老爷去也！"
        }
      ],
