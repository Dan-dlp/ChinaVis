        {
          "character": "崔玉、史纪",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吾，"
        },
        {
          "character": "崔玉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "东吴大将崔玉，"
        },
        {
          "character": "史纪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "史纪。"
        },
        {
          "character": "崔玉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。今有黄忠前来讨战，你我杀上前去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠上。）"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来将通名受死！"
        },
        {
          "character": "崔玉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "崔玉。"
        },
        {
          "character": "史纪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "史纪。"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无名小卒，饶尔不死，去罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠下。）"
        },
        {
          "character": "崔玉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你看黄忠老儿，未曾交锋，他竟自败下阵去，待我赶上！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（崔玉、史纪同下。）"
