      "characters_present": [
        "朱元璋",
        "沐英"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吴桢、朱元璋同上，沐英背蒋忠同上。蒋忠哭。）"
        },
        {
          "character": "朱元璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是何人前来帮助？"
        },
        {
          "character": "沐英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣沐英，救驾来迟，万岁恕罪！"
        },
        {
          "character": "朱元璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你敢么就是钱塘大汉沐英么？"
        },
        {
          "character": "沐英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "朱元璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "久已闻名，今日相逢，孤之幸也。保孤回朝，定有封赠。"
        },
        {
          "character": "沐英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套引刘福通同上，朱元璋下。开打，吴桢、沐英同败下，众人同追下。）"
        }
      ],
