    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "吴桢",
        "我君臣今入了天罗地网",
        "朱元璋",
        "蒋忠"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱元璋上，烧。）"
        },
        {
          "character": "朱元璋",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "恼恨那刘福通贼奸党，\n为何故放火焚烧百凉？\n怕的是君臣们难回朝堂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱元璋倒。吴桢上，看两边，扶朱元璋起。）"
        },
        {
          "character": "朱元璋",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "一霎时烧得孤三魂飘荡，"
        },
        {
          "character": "朱元璋",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "又只见老将军站立一旁。"
        },
        {
          "character": "我君臣今入了天罗地网、吴桢",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "那贼兵好一似铁壁铜墙。"
        },
        {
          "character": "朱元璋",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "老将军你一人怎能抵挡？"
        },
        {
          "character": "吴桢",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "但愿得大兵到转回朝堂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（蒋忠上。）"
        },
        {
          "character": "蒋忠",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "牵战马来至在乱石岗上，\n只见那老吴桢扶保吾王。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱元璋上马，急下。）"
        },
        {
          "character": "蒋忠",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "老将军与某家同赴战场。"
        },
        {
          "character": "吴桢",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我这里提枪把马上，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吴桢夺旗内枪，上马。）"
        },
        {
          "character": "吴桢",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "要与番贼动刀枪。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吴桢、蒋忠同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "朱元璋→吴桢",
          "turns": 2
        },
        {
