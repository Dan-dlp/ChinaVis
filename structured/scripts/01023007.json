      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四上手、沐英同上。）"
        },
        {
          "character": "沐英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，沐英。哪里有喊杀之声，登高一望。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（沐英上山。吴桢上，刘福通追上，开打，吴桢败下。蒋忠上，开打，众人同败下，蒋忠追下。）"
        },
        {
          "character": "沐英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是番兵与吾主交战，待我向前帮助便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四上手、沐英同下。）"
        }
      ],
      "interactions": [],
