      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（使臣上。）"
        },
        {
          "character": "使臣",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "奉旨打战表，急急到天朝。"
        },
        {
          "character": "使臣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺西凉国使臣是也，奉旨进表中原，马上加鞭。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（使臣下。李子忠上。）"
        },
        {
          "character": "李子忠",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "执掌黄门侍奉君，金阶玉路色色新。为人若是全忠孝，臣奉君来子奉亲。"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官黄门官李子忠是也。今乃进表之日，只得在此伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（使臣上。）"
        },
        {
          "character": "使臣",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "山高路又远，特来进表文。"
        },
        {
          "character": "使臣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是午门，哪位老爷在此？"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪国来的？"
        },
        {
          "character": "使臣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "代战国进来战表。"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我传奏，午门候旨。"
        },
        {
          "character": "使臣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（使臣下。）"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "香烟霭霭，圣驾临朝。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众太监同上。）"
        },
        {
          "character": "众太监",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "咦咦。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唐王上。）"
        },
        {
          "character": "唐王",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "河清海晏，一统江山。"
        },
        {
          "character": "唐王",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "金鸡架上九龙头，太阳一出照九州。三天门外朝北斗，金钟一响拜冕旒。"
        },
        {
          "character": "唐王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寡人，大唐天子在位，今当早朝。"
        },
        {
          "character": "唐王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍！"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "唐王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闪放龙门。"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闪放龙门。"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣黄门官李子忠启奏：今有代战国进来表章，请主龙目观看。"
        },
        {
          "character": "唐王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传上金殿。"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "金殿上打开了代战表，"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "字字行行看分明。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "启奏大朝唐主君："
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "年年进贡反称臣。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "两国争斗定输赢。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "年年进贡愿称臣。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "要把中原一扫平。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不由孤王吃一惊。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "上写着小臣三顿首"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只因两国分上下"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "今日打来一战表"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "倘若你国得了胜"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "若是我国得了胜"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看罢表章心害怕"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "开言便把李卿叫"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "寡人言来听分明："
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "要夺寡人长安城。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "打发使臣转回程。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤家不日便出征。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "整顿人马到边廷。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只要精壮便为军。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "全家个个自有封。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为王进宫候音信。"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "代战王他今起反意"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你今领下王旨意"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回去报与他国主"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "再到兵部传王旨"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四门挂起招军榜"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "平贼有功回朝转"
        },
        {
          "character": "唐王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "爱卿快传王旨意"
        },
        {
          "character": "李子忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请驾回宫。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
