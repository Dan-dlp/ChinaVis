          "text": "领旨。"
        },
        {
          "character": "内侍",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闪放龙门！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卜荷上。）"
