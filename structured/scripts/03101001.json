    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "关羽",
        "周仓",
        "四水手",
        "大战船千百只江岸倚傍",
        "微风起淡云收天晴日朗",
        "耳边厢又听得人声喧嚷"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四水手同上，船靠岸。周仓上，摆式、亮架、舞刀。）"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请君侯！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。四耀武旗、关羽同上，同登船。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上得船来，好一派江景也！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "解缆开船。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喳！"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众水手！"
        },
        {
          "character": "四水手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "解缆开船。"
        },
        {
          "character": "四水手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。）"
        },
        {
          "character": "关羽",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "上船来只觉得神清气爽！"
        },
        {
          "character": "关羽",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "推楼窗展凤眼细看端详。"
        },
        {
          "character": "关羽",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "小战船密匝匝好似蜂房。"
        },
        {
          "character": "关羽",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "碧澄澄波浪稳水接天光。"
        },
        {
          "character": "关羽",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "又只见东吴兵排列两厢。"
        },
        {
          "character": "关羽",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "叫周仓将大船——"
        },
        {
          "character": "关羽",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "依靠岸上，"
        },
        {
          "character": "关羽",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "来到了东吴地天各一方。"
        },
        {
          "character": "关羽",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "大战船千百只江岸倚傍"
        },
        {
          "character": "关羽",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "微风起淡云收天晴日朗"
        },
        {
          "character": "关羽",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "耳边厢又听得人声喧嚷"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "水手的！"
        },
        {
          "character": "四水手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将船靠岸。"
        },
        {
          "character": "四水手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
