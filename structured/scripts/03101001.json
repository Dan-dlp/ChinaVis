        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周仓向关羽。）"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启君侯：东吴下书人求见。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周仓向下书人。）"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传你进去，你要小心了。"
        },
        {
          "character": "东吴卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "东吴卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见关将军！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你奉何人所差？"
        },
        {
          "character": "东吴卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奉鲁大夫所差。有书信呈上。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹牌子〗。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你对鲁大夫言讲，修书不及，照书行事。"
        },
        {
          "character": "东吴卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（东吴卒下。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来鲁肃请某过江饮宴。"
        },
        {
          "character": "关平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "鲁肃约请父帅饮宴，断无好意，父帅不可前去。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某若不去，岂不被东吴耻笑？"
        },
        {
          "character": "关平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "虽然如此，父帅岂可以万金之躯，轻入虎狼之地？倘有差池，怎能对得皇伯！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想为父出兵多年，纵横天下，岂惧东吴小辈！"
        },
        {
          "character": "关平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "父帅一定要去，必须多带人马。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只用大船一只，挑选关西大汉数名，在船中服役，周仓一人跟随，船上插红旗"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一面；再备白旗一面，暗藏船中。吾儿准备战船二十只，领精兵一千名，在江"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "心伺候。倘若东吴有诈，那时将白旗摆动，吾儿带兵急速接应，料无妨碍。"
        },
        {
          "character": "关平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关平，你随为父出兵多年，尚不深悉用兵之道。站立一旁，听为父训教。"
        },
        {
          "character": "关平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿恭听。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为将帅者，必须要上晓天文，深明地理，熟读兵书，通达战策。统兵出战，更"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "须足智多谋；治兵当以纪律为先，临阵务从精细入手。统率将士，体恤人心，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宽以济猛，猛以济宽。有功则赏，有过者罚。交锋之际，量自己之强弱，察敌"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "阵之虚实。又道是知己知彼，百战百胜，乘其未至，攻其不备。运筹帷幄之中，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "决胜千里之外。诈败不可紧追；得胜不可妄进。安营扎寨，靠山近水。深林"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "防埋伏；苇塘防火攻。此乃战无不胜，攻无不取，所谓行军之要诀也！"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "用兵之道须谨慎，"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "临阵交锋要小心。"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "得胜成功莫逞能。"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "靠山近水好屯军。"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "旗开得胜把功成。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
