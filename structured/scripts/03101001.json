      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、鲁肃同上。）"
        },
        {
          "character": "鲁肃",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "安排酒宴请关羽，为讨荆州费心机！"
        },
        {
          "character": "探子",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "报！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子上。）"
        },
        {
          "character": "探子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽到。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探。"
        },
        {
          "character": "探子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子下。）"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，摆队相迎。"
        },
        {
          "character": "四龙套",
          "line_type": "同白",
          "musical_style": null,
