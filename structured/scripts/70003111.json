    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "刘辟",
        "孙乾",
        "报子",
        "袁刚",
        "龚都"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四下手、四大刀手、四将、刘辟、龚都同上。）"
        },
        {
          "character": "刘辟、龚都",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "镇守汝南，雄心胆，恨曹瞒，自称英男，统兵灭奸佞。"
        },
        {
          "character": "刘辟、龚都",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "堂堂丈夫立帝基，雄心盖世武艺奇。空中五色旌旗摆，烈烈轰轰世无敌。"
        },
        {
          "character": "刘辟、龚都",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "某，（刘辟）（龚都），威镇汝南一带，可恨曹贼专权，是俺会同河北袁绍，"
        },
        {
          "character": "刘辟、龚都",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "共灭曹瞒。也曾命探马前去打探，未见回报。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀将军：今有曹操挂关羽为帅，统领五万人马，战将千员，攻打汝南，特来"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "报知！"
        },
        {
          "character": "刘辟、龚都",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "再探！"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。）"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽统兵前来，将军有何退兵之计？"
        },
        {
          "character": "龚都",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想桃园当年失散，各自东西，今晚吾军前去偷营劫寨，假意被擒，将刘备在河"
        },
        {
          "character": "龚都",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "北之事，对他说明，那关羽闻知兄信，定离曹寻刘。吾二人明日在阵前，用言"
        },
        {
          "character": "龚都",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "语激发于他，吾军退出汝南，俟关羽到了河北，与吾军共灭曹操，岂不美哉！"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好！"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传孙乾、袁刚进帐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "袁刚 （内同白） 来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙乾、袁刚同上。）"
        },
        {
          "character": "孙乾、袁刚",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "要为天下奇男子，须立人间稀世功。"
        },
        {
          "character": "孙乾、袁刚",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见将军，有何军情？"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你二人，统领本部人马，今晚去至关羽营盘，偷营劫寨，附耳上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘辟耳语授计。）"
        },
        {
          "character": "孙乾、袁刚",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙乾、袁刚、四下手同下。）"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孙乾此去，定然成功。正是："
        },
        {
          "character": "刘辟",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "将在谋略哪在勇，"
        },
        {
          "character": "龚都",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "兵在精来何用多！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘辟、龚都同下。众人随下。）"
        }
      ],
      "interactions": [
        {
          "edge": "报子→龚都",
          "turns": 1
        },
        {
          "edge": "龚都→报子",
          "turns": 1
