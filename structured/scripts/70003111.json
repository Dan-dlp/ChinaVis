    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "众将",
        "关羽",
        "孙乾"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐晃、于禁、张辽、许褚、乐进、李典、夏侯渊、夏侯惇、关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前道为何不行？"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来至汝南地界。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马列开，就地安营下寨。今晚提防那贼前来偷营劫寨！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。四下手、孙乾、袁刚同上。四上手、四将同上。开打，孙乾、袁刚被擒。）"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有请二将军！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马童持灯引关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "风吹旌旗转，气出斗牛寒。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "拿住奸细。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "绑进帐来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（上手绑孙乾、袁刚同上，同跪。关羽一惊，继又正色。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！无能之将，竟敢前来偷营劫寨。来！将此贼——"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽指袁刚。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "斩首，号令营门。众将歇息去吧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将同下，袁刚押下。）"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二将军！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "噤声！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两厢退下，老军伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四上手同下。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孙将军受惊了，请坐。"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自溃散之后，一向踪迹不闻，今何为至此？"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某自逃难，飘泊汝南，幸得刘辟收留。将军因何落在曹营？甘、糜二位夫人，"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可无恙否？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自那年失散之后，被困土山。为保定二位皇嫂，某万般无奈，与曹操约下三事，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "暂栖曹营。幸得二位夫人身体安泰。吾与曹公有言在先，若知大哥下落，立"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "功便离曹营。请问将军，可知某大哥今落何处？"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "近闻玄德公，在河北袁绍营中，末将意往投之，未得其便。今刘辟、龚都二人"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "归顺袁绍，相助攻曹。今将军到此，刘、龚二人特令小军领路，教某以为细作，"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来报将军。明日二人虚败一阵，公可速引二夫人，去投河北袁绍处，也好与"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "玄德公相见。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既兄在袁绍营中，吾必星夜而往，但恨吾斩袁绍二将，恐其事有变矣。"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军休得忧疑，吾当先往，探彼虚实，再来报知将军如何？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好。但见兄长一面，虽万死不辞。今回许昌，必辞曹操也。拜烦将军先行！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（打四更。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夜已更深，将军暗暗出营去吧！"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告辞了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙乾下。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住。孙乾言道，俺大哥今在河北袁绍营中，又言刘辟、龚都退让汝南，此事"
        }
      ],
