    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "众将",
        "关羽",
        "刘辟",
        "孙乾",
        "龚都"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘辟、龚都同上。）"
        },
        {
          "character": "刘辟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孙乾一去未回报，"
        },
        {
          "character": "刘辟",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "且等回营把令交。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙乾上。）"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见将军。"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。可曾与关羽相遇？"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那关羽言道，今回许昌，定辞曹操。阵前须要用言语激发于他。"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那是自然。后帐歇息去吧。"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢将军。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙乾下。）"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官！起兵迎敌者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘辟、龚都同下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹四将站门同上，刘辟、龚都、四龙套、四下手、四大刀手、四将同上，会阵。开打。曹四将同败下。刘"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "辟、众人同追下。关羽、四月华旗手同站门。曹四将同败上，刘辟、众将同上，会阵。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！汝等因何背反朝廷？"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住了，汝乃背主之人，反来责我！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！何言关某背主？"
        },
        {
          "character": "龚都",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽！刘玄德今在河北袁绍军中，汝却从曹，是何意也？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（过合。两边将士分下。打小三见面。架住。）"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关公，故主之恩，不可相忘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘辟、龚都同下。关羽、众人同追下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘辟、龚都、众人同上。）"
        },
        {
          "character": "刘辟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官！退让汝南！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。关羽、众将同上。）"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "那贼大败，退离汝南。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官！兵进汝南！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽三笑，下，众将随下。）"
        }
      ],
