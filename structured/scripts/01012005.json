      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马妃、二宫女同上。）"
        },
        {
          "character": "马妃",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "金龙盘玉柱，彩凤绕画梁。"
        },
        {
          "character": "马妃",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "头戴珠翠彩凤冠，身穿锦绣滚龙衫。陪王伴驾皇王宠，执掌西宫伴君眠。"
        },
        {
          "character": "马妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哀家马氏，兄长马龙。只因陈州干旱三载，圣上命我兄长前去放粮，不想他克\n扣军饷。圣上二次有命，命包拯前去放粮。我想此人铁面无私，恐他查明此事，\n与我兄长不便，是我今早在正宫国母台前，讨下半副銮驾，去到御街，与黑\n贼作对。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（宫女同允。）"
        },
        {
          "character": "马妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐銮仪走上！"
        },
        {
          "character": "宫女",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "銮仪走上！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（銮驾自两旁分上。）"
        },
        {
          "character": "马妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾御街！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同允。）"
        },
        {
          "character": "马妃",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "兄长做事太不成，"
        },
        {
          "character": "马妃",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "不该克扣众黎民。\n铁面无私不容情。\n单等南衙小包拯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯、四青袍、王朝、马汉同上。）"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "适才离了文华殿，\n辞别两班文武官。"
        },
        {
          "character": "王朝、马汉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "銮驾挡道！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转道！"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "只见銮驾御街挡，\n娘娘为何出宫廷？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯、四青袍、王朝、马汉同下。）"
        },
        {
          "character": "马妃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "满江撒下千丝网，\n哪怕鱼儿不上钩。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯、四青袍、王朝、马汉同上。）"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "包拯生来不怕人，\n他是君来我是臣。"
        },
        {
          "character": "王朝、马汉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "銮驾挡道！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转道！"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "三番两次把道挡，\n倒叫包拯解不明。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯、四青袍、王朝、马汉同下。）"
        },
        {
          "character": "马妃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "宫娥摆驾后街进，\n我看包拯哪里行。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯、四青袍、王朝、马汉同上。）"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "在金殿奉王命谁敢违抗，\n黑暗暗出朝堂亚赛阎王！"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "銮驾挡道！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转道！"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转道不及！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住轿！"
        },
        {
          "character": "包拯",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "御街落下一只凤，"
        },
        {
          "character": "包拯",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "好一似雀鸟离却山林。\n下有彩旗数十根。\n宫娥彩女两边分。\n押定满朝文武臣。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "见君不参有罪人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（宫女同笑。）"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "宫娥彩女笑连声。\n笑俺包拯黑脸人。\n遮住包拯黑面人。\n头不敢抬来眼不敢睁。"
        },
        {
          "character": "是是是来明白了、人来看过爷的无价宝、走向前，忙跪定、马妃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "明明知道将他问，\n你是何臣说分明。"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "娘娘把臣忘记了，\n臣是南衙小包拯。"
        },
        {
          "character": "马妃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不在朝中把君奉，\n来在御街为何情？"
        },
        {
          "character": "包拯",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "陈州干旱三年正，"
        },
        {
          "character": "包拯",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "树无枝叶草无根。\n命国舅散粮安黎民。\n克扣皇粮数万倾。\n万岁爷二次宣包拯。\n十家保官保定了为臣。"
        },
        {
          "character": "万岁爷闻之心不忍、谁想国舅心太狠、众百姓告下冤枉状、在金殿连推数道本、马妃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "十家保官哪一个？\n快对哀家说分明。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "头一家保官王丞相，\n第二家保官八贤君；\n第四家保官老陈琳；\n第六家保官佘太君；\n第八家保官老赵斌；\n第十家保官陈翰林。\n望娘娘开了天地恩。"
        },
        {
          "character": "第三家保官陈世美、第五家保官是寇准、第七家保官吕蒙正、第九家保官郭阁老、在御街闯了娘娘道、马妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！"
        },
        {
          "character": "第三家保官陈世美、第五家保官是寇准、第七家保官吕蒙正、第九家保官郭阁老、在御街闯了娘娘道、马妃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听一言来怒气声，\n闯了御街罪非轻。\n管叫黑头挂午门。"
        },
        {
          "character": "哀家上殿奏一本、包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
        },
        {
          "character": "哀家上殿奏一本、包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听一言来心内惊，\n苦苦作对为何情？"
        },
        {
          "character": "包拯正在为难处、王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "王朝禀事。"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "又听王朝报一声。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "王朝，此地什么所在？焉敢大呼喊叫！"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀相爷：她不是正宫主母，乃是西宫马娘娘。在正宫主母台前，讨来半副銮\n驾，来在御街前，与我爷作对。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "尔可看得真？"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看得真。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "见得明？"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "见得明。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷的考程？"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人的性命！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闪开了！"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "老龙正在沙滩困，\n忽听春雷响一声。\n老爷言来你是听：\n下打彩旗数十根。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王朝、龙套同打銮驾，马妃、宫女同下，王朝追下。）"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "有什么大过爷担承！"
        }
      ],
