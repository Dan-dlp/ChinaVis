        ]
      }
    },
    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "包拯",
        "大大的棺木买一口",
        "王朝"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯上。）"
        },
        {
          "character": "包拯",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "骂声贱妃哪里行，\n老爷赶你午朝门！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王朝上。）"
