    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "马妃"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女引马妃同上。）"
        },
        {
          "character": "马妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住，实指望来在御街，与黑贼作对，谁知又被黑贼看破，将銮驾打碎，这便\n怎么处？呵呵有了，我不免上殿奏他一本。包拯啊保证，管叫你命丧黄泉！"
        },
        {
          "character": "马妃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "宫娥女摆驾上金殿，\n见了万岁奏根源！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马妃、宫女同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
