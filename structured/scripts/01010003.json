    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "武吉"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（武吉上。）"
        },
        {
          "character": "武吉",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "胆大天下能去，刚强寸步难行。"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小子武吉。前日上山砍樵，误撞千岁御道，将他门军打死。姬千岁拿我问罪。"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是我奏道，家有八旬老母，无人侍奉。千岁赐我斗米串钱，回家安顿老母，限"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我七日前去领罪。是我行到渭水河边，偶遇一白发渔翁，他见我面带杀气，言"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "道必遭凶事。我将打死门军之事，对他言讲一遍。他教我小小法儿：回得家去，"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老母床前，挖一土阱，深要七尺，宽要丈二，口衔灯芯糯米，睡在里面。躲"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "过七七四十九日，方保无事。今乃四十八日，老母肚中饥饿，将我唤醒，上山"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "砍樵。正是："
        },
        {
          "character": "武吉",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "上山擒虎易，开口告人难。"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 4,
          "念": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
        0.0,
        0.0,
        0.7778,
        0.2222,
        0.0,
        1,
        0.0,
        0.0
      ]
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "二太子",
        "北宫高",
        "南宫适",
        "姬昌",
        "武吉",
        "辛免",
        "辛甲"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（南宫适、北宫高、辛甲、辛免同上，同起霸。〖点绛唇〗。）"
        },
        {
          "character": "南宫适",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "南宫适。"
        },
        {
          "character": "北宫高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "北宫高。"
        },
        {
          "character": "辛甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "辛甲。"
        },
        {
          "character": "辛免",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "辛免。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。主公发兵，两厢伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、二太子、姬昌同上。）"
        },
        {
          "character": "姬昌",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "点动兵和将，郊外访贤良。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见主公。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马可齐？"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俱已齐备。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐兵发郊外！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（南宫适、北宫高、辛甲、辛免同允。）"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "兵发郊外。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。武吉上。）"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马为何不行？"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "武吉当道。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马列开。"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见千岁。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哽，胆大武吉，前番将孤门军打死，孤王将你问罪。你言道家有八旬老母，无"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人侍奉。孤赐你斗米串钱，叫你回家安顿老母，限你七日前来领罪。为何一去"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "数十余日，该当何罪？"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前番小人，将千岁门军打死，问罪于我，是我言道，家有八旬老母，无人侍奉。"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁赐我斗米串钱，安顿老母。行至渭水河边，遇一白发渔翁，见我面带杀"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "气，说我必遭凶事。是我将打死门军之事一说，他教我小小法儿：在母亲床前"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "挖掘一坑，口衔灯芯糯米，躲过七七四十九日，方保无事。今乃四十八日，老"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母肚中饥饿，将我唤醒上山砍樵，又撞了千岁御道。情愿领罪。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "渔翁现在何处？"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在渭水河边。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "放下柴担，领孤前去。"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "二太子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀父王：郊外访贤，必须改换便衣。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看衣更换。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。姬昌更衣。）"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "郊外伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（南宫适、北宫高、辛甲、辛免、四龙套同下。）"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "武吉带路。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "樵夫道那渔翁颇有奥妙，"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "因此上为王的亲走这遭。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "青的山绿的水难画难描。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
