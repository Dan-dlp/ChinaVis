        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "看不见武吉身落何方。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我道此人还在，却原来亡故了，可叹吓，可叹。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两厢退下。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监同下。）"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "孤王建业在西方，"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "为争江山昼夜忙。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "南路燕山有伤亡。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "好似悠悠梦一场。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（飞熊上。）"
        },
        {
          "character": "姬昌",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "孤王正在睡朦胧，"
        },
        {
          "character": "姬昌",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "见一飞熊入帐中。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一阵狂风影无踪。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监同上。）"
        },
        {
          "character": "姬昌",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "四内臣摆驾进银安，"
        },
        {
          "character": "姬昌",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "不知吉来不知凶。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍，宣散宜生进见。"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王有旨，宣散宜生进帐。"
        },
        {
          "character": "散宜生",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（散宜生上。）"
        },
        {
          "character": "散宜生",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "袖算乾坤大，怀揣日月长。"
        },
        {
          "character": "散宜生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见主公。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身赐坐。"
        },
        {
          "character": "散宜生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。宣臣进帐，有何事议论？"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤王昨晚三更，偶得一兆，见一飞熊入帐，将孤左膀扑了一爪。不知吉凶。"
        },
        {
          "character": "散宜生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王郊外访贤，必得贤臣良将。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "替孤传旨。"
        },
        {
          "character": "散宜生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "姬昌",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "昨夜飞熊入帐中，"
        },
        {
          "character": "散宜生",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "郊外射猎访贤臣。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "姬昌→太监甲",
