      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（南宫适、北宫高、辛甲、辛免同上，武吉上。）"
        },
        {
          "character": "武吉",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "不是姜太公，焉能做先锋。"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，武吉。奉主公之命，准备车辇。远远望见主公来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同上，姬昌、二太子、姜尚同上。）"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启主公：车辇齐备，请先生登辇。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请先生登辇。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道有僭了。"
        },
        {
          "character": "姜尚",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "听号炮三声响忙登车辇，"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "众儿郎一个个齐下雕鞍。"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "姜子牙坐车辇细把君观："
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "有禹汤和尧舜四大名贤。"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "散宜生奏一本郊外访贤。"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "姜子牙八十二才会名贤。"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "到后来保江山八百八年。"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "对主公施一礼忙登车辇"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "前三皇后五帝年深日远"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "周文王夜得兆飞熊扑面"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "打樵汉名武吉引君来见"
        },
        {
          "character": "姜尚",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "行八百单八步忙退车辇"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众百姓头顶香盘，迎接主公先生进城。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆队进城。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
