    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "二太子",
        "姜尚",
        "姬昌",
        "武吉"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜尚上。）"
        },
        {
          "character": "姜尚",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "纣王无道贪色酒，"
        },
        {
          "character": "姜尚",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "午门外造下了摘星楼。"
        },
        {
          "character": "姜尚",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "贾氏夫人坠雕楼。"
        },
        {
          "character": "姜尚",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "那一旁又来了西伯王侯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姬昌、二太子、武吉同上。）"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "太平鸟止不住空中叫，"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "叫得孤王心内焦。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "手提着钓鱼竿独自在逍遥。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "二皇儿上前去细问根苗。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "土台上坐的是白发老道"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "孤看他倒有那仙家奥妙"
        },
        {
          "character": "二太子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "二太子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "渔翁请了。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "钓钓钓，大鱼不到小鱼到。用你不着，去罢。"
        },
        {
          "character": "二太子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "小王与你深施一礼，为何扬而不睬？"
        },
        {
          "character": "姜尚",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "几载未见尘劳倦，见了明君方开言。"
        },
        {
          "character": "二太子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "好大的口气。"
        },
        {
          "character": "二太子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀父王：那渔翁讲了两句淡话。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪两句淡话？"
        },
        {
          "character": "二太子",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "几载未见尘劳倦，见了明君方开言。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你二人敢是慢怠于他？"
        },
        {
          "character": "二太子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "儿不敢。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "退下。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二太子同下。）"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "渔翁请来见礼。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道稽首。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "口称稽首，在哪座名山修炼？"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "昆仑山修炼。稽首为尊。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在此作甚？"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在此垂钓。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "钓的何物？"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "西海鳌。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小小钓竿，也能钓得鳌起？"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "钓竿虽小，能坠千斤。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "借钓一观。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请看。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为何用直钩垂钓？"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道心直性直，愿者上钩。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但不知谁愿谁不愿？"
        },
        {
          "character": "姜尚",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "耐烦等到春雷到，自有鱼儿来上钩。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请问道者上姓？"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道姓姜名尚字子牙，道号飞熊。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀且住，想这“飞熊”二字，正应孤的梦兆。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请问军爷上姓？"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "西伯侯姬昌。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是姬千岁，失敬了。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不在西岐，来在荒郊作甚？"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请先生扶保周室江山。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "才疏学浅，不敢当此重任。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不必推辞。"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "武吉，封你开路先锋，准备车辇伺候。"
        },
        {
          "character": "武吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（武吉下。）"
        },
        {
          "character": "姬昌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请。"
        },
        {
          "character": "姜尚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "久闻先生今相见，"
        },
        {
          "character": "姜尚",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "姜子牙八十二岁会名贤。"
        },
        {
          "character": "姬昌",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "周室江山全仗你，"
        },
        {
          "character": "姜尚",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "愿保江山万万年。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姬昌、姜尚同下。）"
        }
      ],
