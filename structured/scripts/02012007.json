      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、四宫女、老王爷、老王妃同上。）"
        },
        {
          "character": "老王爷",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "腰悬玉带体龙衣，深感洪福恩重。"
        },
        {
          "character": "老王爷",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "春寿华堂春寿老，寿与天齐百寿高。"
        },
        {
          "character": "老王妃",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "福如东海福山茂，福寿绵长福寿滔。"
        },
        {
          "character": "老王爷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今当孤千秋华诞，方才阖家叩拜家庙，因此准备家筵，大家欢饮。"
        },
        {
          "character": "老王妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正当如此。"
        },
        {
          "character": "老王爷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看酒。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（甘州歌） 寿与天齐，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "献美酒，痛饮设列筵席。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "吹唱欢歌，高堂悬挂彩衣。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "恰比那氤氲升仙。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（武成上。）"
        },
        {
          "character": "武成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启爷：外面有四家王爷，前来庆寿。"
        },
        {
          "character": "老王爷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们退了，待我出迎。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小太监引四王爷同上。）"
        },
        {
          "character": "四王爷",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "皇王遵旨来拜王颜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "老王妃→老王爷",
          "turns": 2
        },
        {
          "edge": "老王爷→老王妃",
