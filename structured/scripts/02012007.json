          "style_family": null,
          "text": "（杨香武上。）"
        },
        {
          "character": "杨香武",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "乱乱烘烘罕，"
        },
        {
          "character": "杨香武",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "祝寿人儿非凡。"
        },
        {
          "character": "杨香武",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好比蓬莱群仙宴。"
        },
        {
          "character": "杨香武",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不能盗杯急燥倃。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨香武下。）"
        }
      ],
      "interactions": [],
