      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二大太监引吴国太同上。）"
        },
        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "转眼不觉有几年。\n东吴大事属孙权。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "等候皇儿把驾参。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香上。）"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "可叹皇叔把驾晏，\n离鸾别鹄有谁怜？\n母后驾前儿问安。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣见驾，母后千岁。"
        },
        {
          "character": "侍儿引路养老院、吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇儿平身，赐坐。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢母后。"
        },
        {
          "character": "孙尚香",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "喂呀……"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！我儿身穿素服，两眼落泪，为了何事？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀母后，适才我兄长进宫言道，刘皇叔在白帝城晏驾了。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！刘皇叔晏驾了？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！皇叔哇！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听说皇叔把驾晏，\n怎不叫人心痛酸。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后不必悲泪，想皇叔已死，儿臣有意去往江边，望空一祭，特来辞别母后。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想你兄长与刘皇叔，有敌国之仇，况且人死不能复生，你还祭他则甚？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿与皇叔，夫妻一场，未曾亲视晏驾，心中甚是不安。儿臣去心已定，望求母\n后恩准。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿不必如此，为娘有一言儿且听了。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后请讲。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "母女们对坐皇宫院，\n为娘言来听根源：\n我儿何必礼周全？"
        },
        {
          "character": "皇叔已然把驾晏、孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后！"
        },
        {
          "character": "皇叔已然把驾晏、孙尚香",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "母后说话言语颠，\n细听儿臣把话言：\n定下美人之计得配娇鸾。"
        },
        {
          "character": "皇叔已然把驾晏、孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "荆州转，\n假报母病接儿还。\n未曾见面心痛酸。\n纵死在黄泉我就也安然。"
        },
        {
          "character": "只因周郎心地险、夫妻奉命、如今皇叔把驾晏、儿到江边去祭奠、吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我的儿说话理不端，\n人死哪能又复还？\n一滴何曾到九泉？"
        },
        {
          "character": "江边祭奠空祭奠、孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "母后说话理太偏，\n往日贤来今不贤。\n一滴何曾到九泉。\n从前的事儿你想一番。"
        },
        {
          "character": "说什么祭奠空祭奠、老母空把那弥陀念、吴国大",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我儿休要将娘怨，\n开口反道娘不贤。\n为娘不准也枉然。"
        },
        {
          "character": "任你讲得天花现、孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "儿嫁刘备娘情愿，\n夫妻恩爱重如山。\n当初何必就结良缘？"
        },
        {
          "character": "今日不容儿祭奠，喂呀，儿的娘、吴国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "一见奴才把脸变，\n哪一个大胆到江边？"
        },
        {
          "character": "气得老身怒冲冠、为娘驾坐皇宫院、孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "气得老身怒冲冠、为娘驾坐皇宫院、孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "母后不容我祭奠，"
        },
        {
          "character": "气得老身怒冲冠、为娘驾坐皇宫院、孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢！"
        },
        {
          "character": "气得老身怒冲冠、为娘驾坐皇宫院、孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不如碰死在娘面前。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "我儿不必行短见，\n为娘陪儿到江边。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿不必如此，为娘陪儿前去就是。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢，母后年迈，江风甚大，还是儿臣自已前去罢。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此为娘赐儿半副鸾驾，须要早去早回。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢母后。啊，母后请上，受儿臣大礼参拜。"
        },
        {
          "character": "吴国大",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？去去就回，何必行此大礼？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这个……唉，娘啊！"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "虽然暂别皇宫院，\n为人须要礼当先。\n儿愿母后福寿全。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "生离死别好不惨然。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香下。）"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我儿出宫把脸变，\n倒叫老身心不安。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍！"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴婢在。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二千岁进宫。"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国太有旨，二千岁进宫啊！"
        },
        {
          "character": "孙权",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙权上。）"
        },
        {
          "character": "孙权",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忽听母后宣，进宫把驾参。"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣见驾，母后千岁！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千千岁！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐座。"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙权坐。）"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后为何这样唉声叹气？"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刘皇叔殡天，你还不知吗？"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿早已知道，有意带兵，护送我胞妹入川奔丧，乘他丧乱之时，儿要暗取他\n的成都，西川岂不唾手可得？母后何必长叹。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么，儿要借你胞妹，奔丧之时，暗取西川么？"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我把你这无谋无用的小奴才！想皇叔虽死，那诸葛亮现在成都，焉能不加防备。\n你若带兵夺取西川，那汉贼曹丕，必然趁机来伐东吴，像你这样三番两次，\n利用胞妹，以为交锋之兵刃，枉为九郡八十一州之主！怪不得你妹，进宫请命，\n去往江边祭奠。出宫之时，变脸变色，想是她看破儿的奸计。命你速速将她\n赶回，倘有差错，是定不与你干休，你、你、你快去！"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后不必动怒，儿臣即刻前去就是。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "快去！"
        },
        {
          "character": "孙权",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！正是："
        },
        {
          "character": "孙权",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "老母宫中怒气生，江边追妹转回程。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙权下。）"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "女儿出宫把脸变，\n怕她要学古圣贤。"
        },
        {
          "character": "吴国太",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "娇儿啊！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "残年暮景实可怜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吴国太下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "《祭江》"
        },
        {
          "character": "孙尚香",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小太监、四宫女、二大太监、孙尚香、车夫同上。）"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "曾记当年来此境，\n棒打鸳鸯痛伤情。\n英灵垂鉴未亡人。"
        },
        {
          "character": "从今不照菱花镜、大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀郡主：来到江边呐。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐祭礼摆下。"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祭礼摆下。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖哭皇天〗。四小太监、四宫女、二大太监同设香案，孙尚香焚香祭奠。）"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两厢退下了。"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两厢退下呀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小太监、四宫女、二大太监自两边分下。）"
        },
        {
          "character": "孙尚香",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "设祭长江岸，举目望西川。梦魂何日见，空叫泪不干。"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "在江边只哭得泪流不尽，"
        },
        {
          "character": "孙尚香",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "皇叔，我夫，唉，喂呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（回龙） 尊一声汉皇叔在天上灵："
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "好夫妻恶姻缘前生造定，\n又谁知半途中两下离分。\n可叹你结桃园誓死同生；\n可叹你入虎穴东吴招亲；\n偏遇着讨荆州火烧连营。\n辜负了诸葛亮赤胆忠心。\n倒不如投江死万世留名。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖反哭皇天〗。孙尚香再祭。）"
        },
        {
          "character": "孙尚香",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "且住！祭奠已毕，我不免投江一死了罢！"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄散板",
          "musical_style": "反二黄散板",
          "style_family": "二黄",
          "text": "江水滔滔白浪滚，\n尚香难舍养育恩。\n哭一声汉皇叔慢慢相等……"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香投江，下。孙权上。）"
        }
      ],
