        },
        {
          "character": "天宝帝",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "听说来到马嵬坡，"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "点点珠泪似滂沱。"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "满腹酸辛可奈何。"
        },
        {
          "character": "天宝帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍，吩咐外面预备清香白酒，到贵妃娘娘坟前一祭，聊表寸心。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
