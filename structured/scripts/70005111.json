      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监同上，高力士上，设祭堂。）"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请万岁！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（天宝帝上。）"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "定情钿盒今犹在，"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "长生密誓记心怀。"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "这才是伯劳飞燕两分开。"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我前度刘郎今又来。"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "冤怨缘三字孤不解"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "看天台犹是人不在"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启万岁：杨娘娘坟茔，已经打扫洁净了。"
        },
        {
          "character": "天宝帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待孤拈香。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖哭皇天〗，〖吹打〗，〖牌子〗。）"
        },
        {
          "character": "天宝帝",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "梓童！爱卿啊！"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄顶板",
          "musical_style": "二黄顶板",
          "style_family": "二黄",
          "text": "尊一声贵妃杨玉环孤的爱卿，"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄顶板",
          "musical_style": "二黄顶板",
          "style_family": "二黄",
          "text": "在夜台下，九泉间，一件件，一桩桩，细听根芽："
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "想当初孤坐的风流天下，"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "重国色慕倾城运走桃花。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "压六宫冠粉黛绝世才华。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "连理枝比翼鸟并蒂莲花。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "破潼关扫河北直抵京华。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "幸西蜀为的是有情冤家。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "最可恨这六军按兵不发。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "孤忙问尔六军因何驻马？"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "扬言道杀兄妹六军始发。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "卿家吓！"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "可怜你今日里玉殒桃花。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "倒叫孤空辜负恩宠独加。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "身不能庇一女辜负名花。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "夜台下谁怜你少妇无家。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "国乱时权在臣不在孤家。"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "爱卿啊！"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "为娇容孤也曾求遍风雅"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "七月七日长生殿花前月下"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "遭不幸安禄山渔阳杀驾"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "无奈何暂且迁起了銮驾"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "离都门路不远马嵬坡下"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "叹贵妃死在这白绫之下"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "红颜女变作了白骨黄沙"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "谢秋波止不转百媚无价"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "唐天宝空坐了一朝天下"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "卿一死且莫要将孤咒骂"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "朕负卿并非是卿负陛下"
        },
        {
          "character": "天宝帝",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
          "text": "李三郎只哭得泪如雨下，泪如雨下"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁不可过伤，务宜保重圣体要紧。"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "高力士捧金爵酒祭香插。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。祭奠已毕，请万岁上马回銮。"
        },
        {
          "character": "天宝帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高力士，带马。"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "陈元礼奏一本催孤起驾，"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "浩荡荡领人马直奔京华。"
        },
        {
          "character": "天宝帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "要相逢除非是梦里天涯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
