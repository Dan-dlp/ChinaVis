          "character": "徐母",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "打不动老身我铁石心肠。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟，程老爷到此，禀我知道。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "抱不平打死了他人命丧"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也是我养姣儿教训不当"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我的儿离膝下十年以上"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恨只恨曹孟德痴心妄想"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那时节恼得我气冲上撞"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "狗奸贼传一令将我上绑"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内有个小程昱把情来讲"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将老身安置在静室奉养"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小程昱来问安谦谦让让"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "任你等设下了天罗地网"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母下。丫鬟随下。）"
        }
      ],
      "interactions": [
        {
          "edge": "丫鬟→徐母",
          "turns": 1
        },
        {
          "edge": "徐母→丫鬟",
          "turns": 1
        }
