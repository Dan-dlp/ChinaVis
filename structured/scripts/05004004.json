      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、旗牌、徐庶同上。）"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "闻听得老萱堂囚禁许昌，"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "在新野辞别了创业豪强。"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "在长亭饯行时桃园弟兄举杯捧觞。"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "俱都是珠泪成行，好叫我痛断肝肠。"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "走马回荐诸葛表我的心肠。"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "都只为母子情五伦纲常。"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "恨不能插双翅飞到了许昌。"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "皆因为子不孝累及高堂。"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "好一个刘使君宽宏大量"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "赵子龙坠镫扯丝缰"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "得书信致使我神魂飘荡"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "非是我无终始半途异想"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "过几处招商店日夜盼望"
        },
        {
          "character": "徐庶",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "适才间进都门愁眉展放"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "快去通禀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子暗上。）"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "里面哪位在？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐老爷回来了。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大相公在上，小人叩头。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。快去禀报太夫人知道。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请太夫人。"
        },
        {
          "character": "徐母",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "吉凶二子难猜想，"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "眼跳心惊为哪桩？"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恭喜太夫人，恭喜太夫人。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喜从何来？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大相公回来了。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "莫非徐庶到此？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他不在新野，到此则甚？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人不知。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他在何处？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在门外。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唤他进来。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大相公，太夫人唤你进去。"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "知道了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌、四青袍同下。）"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母亲在哪里？"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母亲在上，孩儿徐庶参拜。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "畜生哪！"
        },
        {
          "character": "徐母",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "蠢材你把良心坏！"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐庶！"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母亲！"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿！"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老娘！"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我把你这不孝的奴才吆！"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大骂徐庶小奴才。"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "私到许昌为何来？"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不在新野为将帅"
        },
        {
          "character": "徐庶",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "娘啊！"
        },
        {
          "character": "徐庶",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "不在新野为将帅"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "想当年儿把人打坏，"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "黑夜逃走颍川来。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "常把儿的老娘挂在儿的心怀。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "协助皇叔把兵排。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "孩儿一见痛心怀。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "岂忍白发赴泉台？"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "儿离膝下十余载"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "因避难儿把名姓改"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "母亲差人把书带"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "宁可娘在儿不在"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哽！"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿离膝下十余载"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "因避难儿把名姓改"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母亲差人把书带"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宁可娘在儿不在"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "听罢言来牙咬坏，"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "定是曹操巧安排。"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "一封书信诓儿来。"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "你平日聪明今何在？"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "儿离膝下十余载"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "因避难儿把名姓改"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "母亲差人把书带"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "宁可娘在儿不在"
        },
        {
          "character": "徐母",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "我的儿啦！"
        },
        {
          "character": "徐母",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "儿离膝下十余载"
        },
        {
          "character": "徐母",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "因避难儿把名姓改"
        },
        {
          "character": "徐母",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "母亲差人把书带"
        },
        {
          "character": "徐母",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "宁可娘在儿不在"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "为娘的笔迹儿就解不开！"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "儿自幼访友四海外"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "孩儿见信不自揣，"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "辞别皇叔探娘来。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "儿自幼访友四海外"
        },
        {
          "character": "徐庶",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "儿的娘啊！"
        },
        {
          "character": "徐庶",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "儿自幼访友四海外"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "母亲恕儿无学才。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "忽促之间儿难解"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "此信何人与你带？"
        },
        {
          "character": "徐庶",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "带信人儿一齐来。"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "问家院来人可在外？"
        },
        {
          "character": "家院",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "大相公进门他走开。"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大相公进门之时，他就走去了。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，原来如此。徐庶徐庶，我把你这无智无才不孝之子！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母坐。）"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想当年你因激于义愤，将人打死。黑夜之间，涂面逃走。那时为娘带汝弟徐康，"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "苦守家门，并无一言责备与你。我儿虽然闯下杀身大祸，乃是义气肝胆。自"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿涂面出外之后，为娘昼夜放心不下，刻刻在外，托人打听儿的着落。闻得我"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿江湖访友，四海寻师。指望你达练人情，洞明世事。志量自然开展，学业必"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "然精通。谁料你遇事粗心，当局鲁莽。忘却三思之戒，不顾时局之箴。儿既读"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣贤之书，必达周公之礼。忠孝二字，不能同尽；家国两地，岂能兼全？况曹"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "操乃欺君罔上之徒，怎及刘皇叔仁义之士；又是中山靖王之后裔，为汉室嫡派"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宗亲。儿既倾心辅佐，可谓得其主也。今凭一纸书，竟不查虚实，不辨笔迹，"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么，你竟别皇叔弃明投暗，自取臭名，玷辱宗祖。使为娘担不义之名，儿贻"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "笑五湖三江。我纵死九泉，有何颜面去见徐氏门中之祖先也。"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "恨畜生你把那纲常来败，"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "好一似狼牙箭刺我胸怀。"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "黑夜间涂面目远避祸灾。"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "也不枉为娘我教训奴才。"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "岂不知尽其忠孝名例外？"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "接着了假书信星夜前来！"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "辜负了白发人铁石心怀。"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "在家中因不平将人打坏"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "在新野佐皇叔终身有赖"
        },
        {
          "character": "徐母",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "到如今降逆贼臭名万代"
        },
        {
          "character": "徐庶",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "老娘亲休得要身体气坏，"
        },
        {
          "character": "徐庶",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "恕孩儿不细揣莽撞前来。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "误中了狗奸贼巧计安排。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "想孩儿扶助他转世投胎。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "这也是儿不该荣膺三代"
        },
        {
          "character": "徐庶",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "任凭他再作出千奇百怪"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "你虽然不能把奸贼依赖，"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "走新野弃皇叔大大不该。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "孩儿不愿为官宰，"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "愿在膝下奉萱台。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "儿的娘啊……"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "无奈何我只得连连叩拜"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "气得老娘眼发呆。"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "徐庶焉能走得开？"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我儿也好死心怀。"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "点点珠泪洒下来。"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "无奈何我只得连连叩拜"
        },
        {
          "character": "徐母",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "我的儿啦！"
        },
        {
          "character": "徐母",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "无奈何我只得连连叩拜"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢！"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无奈何我只得连连叩拜"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "要想相逢梦中来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上吊，死。）"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "母亲请出屏风外，"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "孩儿跪得腿难挨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟上。）"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大相公，大事不好！"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事惊慌？"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太夫人自缢身死！"
        },
        {
          "character": "徐庶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闪开了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐庶看。）"
        },
        {
          "character": "徐庶",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "母亲！老娘！唉，娘啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐庶晕倒。）"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大相公醒来！"
        },
        {
          "character": "徐庶",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "见老娘自缢死魂飞天外！"
        },
        {
          "character": "徐庶",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "母亲！老娘！唉娘啊……"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不由我一阵阵刀割胸怀。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "少奉甘旨老萱台。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "哪里是曹操假书带？"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "分明是老母勾魂来。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "万剐千刀也应该。"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "忠孝二字今何在？"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "儿的娘啊！"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "此事叫儿怎安排？"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "儿离膝下十余载"
        },
        {
          "character": "徐庶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不孝的孩儿将娘害"
        },
