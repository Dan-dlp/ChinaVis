    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "孙膑",
        "毛蕡"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（毛蕡上。）"
        },
        {
          "character": "毛蕡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住，痂夫杀法厉害，他若追来，混元铜锤伤他！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙膑上。）"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里走！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙膑打毛蕡，毛蕡下。）"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "道友休走，你孙老师不来赶你！"
        }
      ],
      "interactions": [
        {
          "edge": "毛蕡→孙膑",
          "turns": 1
        }
      ],
      "stats": {
