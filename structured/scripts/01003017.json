    {
      "scene_index": 7,
      "label": "第七场",
      "characters_present": [
        "安殿宝"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（安殿宝、周青同上，安殿宝打周青，周青下。）"
        },
        {
          "character": "安殿宝",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛礼上，扎枪，开打。安殿宝、薛礼同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 2
        },
        "singing_ratio": 0.0,
