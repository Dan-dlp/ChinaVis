    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "众伙头军",
        "周青",
        "薛礼"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周青、众伙头军同上。）"
        },
        {
          "character": "周青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位兄弟，大哥大战安殿宝，你我在高坡一望。"
        },
        {
          "character": "众伙头军",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周青、众伙头军同上山。薛礼、安殿宝同上。薛礼挑安殿宝死。）"
        },
        {
          "character": "众伙头军",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥醒来！"
        },
        {
          "character": "薛礼",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "一霎时不觉得魂飞天外，"
        },
        {
          "character": "薛礼",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "众贤弟近前来细听根芽。"
        },
        {
          "character": "薛礼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位贤弟，那安殿宝呢？"
        },
        {
          "character": "众伙头军",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "被大哥枪挑马下。"
        },
        {
          "character": "薛礼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此乃神灵保佑，你我望空一拜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "薛礼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请总爷进关。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同上，张士贵上，同进关，众人同下。）"
        }
      ],
