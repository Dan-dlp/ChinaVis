      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛礼、张士贵、众伙头军同上。）"
        },
        {
          "character": "薛礼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀总爷：小人枪挑安殿宝，得来独木关，总爷查点。"
        },
        {
          "character": "张士贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "些须小事，何足为奇。后面埋锅造饭去吧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛礼叹。）"
        },
        {
          "character": "薛礼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗳！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛礼、众伙头军同下。）"
        },
        {
          "character": "张士贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寻找二位少爷。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张志龙、何宗宪同上。）"
        },
        {
          "character": "张志龙、何宗宪",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我二人吃了苦了。"
        },
        {
          "character": "张士贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不必如此，将薛礼之功，上在你二人名下就是。后帐摆宴，与你二人庆功。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
