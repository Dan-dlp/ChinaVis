    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "二老军",
        "薛礼"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛礼上，二老军手抬枪同上。）"
        },
        {
          "character": "薛礼",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一霎时眼昏花双目不明。"
        },
        {
          "character": "薛礼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛礼吓薛礼，想你这样英雄，得下这冤孽之病——"
        },
        {
          "character": "薛礼",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "似猛虎丧了命威风还在，\n大将军八面威何足道哉。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛礼上马。）"
        },
        {
          "character": "薛礼",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我不杀安殿宝誓不回还。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛礼下。）"
        },
        {
          "character": "二老军",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "薛爷去不得。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二老军同追下。）"
        }
      ],
      "interactions": [
        {
          "edge": "薛礼→二老军",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
