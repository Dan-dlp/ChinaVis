    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "二刀斧手",
        "哭一声南斗生",
        "大胆且把法场进",
        "旗牌",
        "知道者他说是冤枉难辩",
        "禁婆",
        "窦娥",
        "蔡母",
        "见法场好一似森罗宝殿",
        "走前街顾不得出头露面",
        "钱惠命"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、二侩子手引钱惠命同上。）"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官监衙司。"
        },
        {
          "character": "钱惠命",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "法令权在手，一任我使行。"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官山阳县知县钱惠命是也。今早接着上司来文，监斩窦娥一案。"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刀斧手，将窦娥绑至法场。时辰一到，报我知道。掩门。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（钱惠命下，二刽子手同下。二刀斧手搀窦娥同上。）"
        },
        {
          "character": "窦娥",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "上天天无路，入地地无门。慢说奴心怕，金刚——"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗳！"
        },
        {
          "character": "窦娥",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "也掉魂。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "没来由遭阴险受此大难，"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "老天爷明朗朗不能明冤。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为恶的享荣华反加寿延。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "老天爷他也是顺水推船。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "虽有那骨肉亲恐怕牵连。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我儿夫身在外不能回转，不能回转，奴的夫吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（下锣。）"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "老婆婆年纪迈不敢向前。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "过小巷难免那众人讲谈。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "不知者说窦娥为恶不贤。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "一霎时窦娥女命染黄泉。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "走前街顾不得出头露面"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "知道者他说是冤枉难辩"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "见法场好一似森罗宝殿"
        },
        {
          "character": "二刀斧手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "为何不走？"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位爷有所不知：少时我典刑之后，将我尸首隐藏一边。"
        },
        {
          "character": "二刀斧手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "却是为何？"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想我婆婆乃年迈之人，见了尸首，尤恐性命难保。二位爷请上，受我一拜。"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄摇板",
          "musical_style": "反二黄摇板",
          "style_family": "二黄",
          "text": "二位爷请上受我拜，"
        },
        {
          "character": "窦娥",
          "line_type": "反二黄摇板",
          "musical_style": "反二黄摇板",
          "style_family": "二黄",
          "text": "我死后将尸首藏在一边。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（蔡母上。）"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "大炮连天响一声，"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叹望窦娥小娇生。"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "大胆且把法场进"
        },
        {
          "character": "二刀斧手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "呔，什么人？"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我是她的婆婆，前来探望于她。"
        },
        {
          "character": "二刀斧手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "容你一祭。"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳了！"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "自见我儿上绑绳。"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎吓，儿吓，事到如今，还有什么言语，嘱咐为婆几句。"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎吓，婆婆吓！事到如今，叫媳妇还有什么话讲吓？"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "倘若你爹爹回来，问起我儿，叫为婆用何言答对？"
        },
        {
          "character": "窦娥",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，婆婆吓！"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "倘若我爹爹回来，看望孩儿，婆婆休提法场之事；就说孩儿得病而亡了吓！"
        },
        {
          "character": "窦娥",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "倘若是我爹爹来把儿看，"
        },
        {
          "character": "窦娥",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "老婆婆且莫要说出真言。"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓！"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "到如今你才把老身来念，"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "白发人反送她命丧黄泉。"
        },
        {
          "character": "哭一声南斗生、窦娥",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "北斗死，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "窦娥 （同二黄摇板） 早已注定，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（蔡母下。四青袍引钱惠命同上。）"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，时辰可到？"
        },
        {
          "character": "二刀斧手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "时辰已到。"
        },
        {
          "character": "禁婆",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，将窦娥绑上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二刀斧手同允。）"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "窦娥吓窦娥，想你小小年纪，做出这样事来。今日斩了你，下次不可。"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "绑了下去。"
        },
        {
          "character": "窦娥",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "苍天吓，苍天！"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想我窦、窦、窦娥，今日典刑，就无有报应了吓！"
        },
        {
          "character": "窦娥",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "眼睁睁望青天心中悲惨，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二神童同暗上，下雪。）"
        },
        {
          "character": "窦娥",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "为什么六月间大雪满天？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二神童同下。）"
        },
        {
          "character": "窦娥",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "观见我窦娥女遭此深冤。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌上。）"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "县官请了。"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。到此何事？"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有窦太师打此经过，下此大雪，窦娥必有冤枉。暂且发回原郡审问。"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听令发落。"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌下。）"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，将窦娥松绑，叫她婆婆领她回去，听窦太师发落。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二刀斧手同允，同松绑。）"
        },
        {
          "character": "钱惠命",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打道回衙。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、二刀斧手、钱惠命同下。蔡母上。）"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "六月炎天飞雪片，"
        },
        {
          "character": "蔡母",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我儿得了活命还。"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿醒来！"
        },
        {
          "character": "窦娥",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "在法场绑得我三魂不在，"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "醒来！"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "窦娥",
          "line_type": "二黄摇扳",
          "musical_style": "二黄摇扳",
          "style_family": "二黄",
          "text": "哪有个人死后又还阳来？"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，婆婆，孩儿还未曾死么？"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿有所不知：六月天降大雪，窦大师打此经过，言道此案必有冤情，发回原"
        },
        {
          "character": "蔡母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "籍审问。我儿才得活命。"
        },
        {
          "character": "窦娥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，婆婆，此乃神圣保佑。"
        },
        {
          "character": "蔡母、窦娥",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "你我婆媳，必须要望空一拜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。蔡母拉窦娥同下。）"
        }
      ],
