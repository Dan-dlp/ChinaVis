      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、张良、韩信、陈平、樊哙、萧何、刘邦同上。）"
        },
        {
          "character": "刘邦",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "耳听得三声长乐钟，\n摆驾出了未央宫。\n全仗文臣武将功。\n还有那萧何、张良、与陈平。\n天命攸归定太平。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（随何上。）"
        },
        {
          "character": "随何",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "纪母已在朝门等，\n引见汉王诉不平。"
        },
        {
          "character": "随何",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣随何见驾，愿吾皇万岁！"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "随何",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上殿有何本奏？"
        },
        {
          "character": "随何",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启奏万岁：今有纪信之母有本口奏，朝门候旨。"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "金殿乃尊严之地，岂是妇女出入之所，见她作甚？"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启奏万岁：亡臣纪信与臣等同共患难，匪伊朝夕。其母既有本口奏，陛下当念\n荥阳替主赴难之功，容她上殿，以显圣德汪洋，厚待功臣之意。"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众卿所奏，正合孤意。\n内侍宣纪太君上殿！"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宣纪太君上殿！"
        },
        {
          "character": "纪母",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（纪母上。）"
        },
        {
          "character": "纪母",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "忽听金殿宣一声，\n来与亡儿诉不平。\n怒气不平立殿廷。"
        },
        {
          "character": "既到此间舍了命、刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇伯母怒气不息，上得殿来有何本奏？"
        },
        {
          "character": "纪母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你还是明知，还是故问？"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤焉能知伯母心中之事？\n内侍，看坐！\n皇伯母有本慢慢奏来。"
        },
        {
          "character": "纪母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗐！万岁啊！"
        },
        {
          "character": "纪母",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "未曾开言心酸痛，\n尊声万岁听分明：\n可记得当年荥阳城。"
        },
        {
          "character": "今日江山归一统、刘邦",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "寡人闻言龙心痛，\n想起当年救驾功。\n折孤的良将怎不疼！"
        },
        {
          "character": "替孤赴难丧了命、纪母",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "既是万岁念前功，\n亡儿在黄泉也感情。\n为什么纪信不追封？"
        },
        {
          "character": "但是满朝加恩重、刘邦",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "恨孤王酒醉乱了性，\n萧何奏本未分明。\n因此不能再追封。"
        },
        {
          "character": "君无戏言保信用、纪母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁！"
        },
        {
          "character": "君无戏言保信用、纪母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "未曾开言叹一声，\n点点珠泪洒前胸。\n无有能将敌重瞳。\n他不该头戴王帽、身穿黄袍，假扮天子，大逆不道有罪名。\n曾对苍天把誓盟。\n我纪家代代儿孙享恩荣。\n功罪二字要分明。\n争什么替主赴难到楚营全无半点功。\n愿代亡儿领罪名。"
        },
        {
          "character": "我主被困荥阳境、纪信登车虽丧命、万岁当日恩情重、母受皇恩子食俸、今日已然天下定、纪信虽死罪未定、朝廷之上君言重、张良",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "闻言拭泪心酸痛，"
        },
        {
          "character": "韩信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可见人在有人情。"
        },
        {
          "character": "萧何",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "昨日酒醉今当醒，"
        },
        {
          "character": "陈平",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我看君王怎样行！"
        },
        {
          "character": "樊哙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "鸿门宴救驾我真侥幸，"
        },
        {
          "character": "随何",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他舍命救主是第一功臣！"
        },
        {
          "character": "刘邦",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "皇伯母说话欠聪明，\n酒后之言不可听。\n昧却良心天不容。\n细听孤王来加封：\n一品太君享恩荣；\n节义夫人受诰封；\n孝义郎冠戴把身荣。\n再赐你黄金万两、彩缎百端送家中，表一表恩情。\n春秋致祭寡人要亲行。\n请！请！请！伯母安然自在下龙廷。"
        },
        {
          "character": "当日荥阳誓言重、皇伯母且把气平定、皇伯母年高德又重、久闻皇嫂有贤性、贤侄年小难大用、一家满门食君俸、修盖庙堂把忠臣供、龙书案上一声请、纪母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "匍匐叩谢皇恩重，\n一家大小受荣封。\n功罪二字要分明。\n宽仁大度自不同。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（纪母下。）"
        },
        {
          "character": "刘邦",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "寡人金殿加恩宠，\n怕的是将相寒心怨朝廷。\n萧丞相进前孤有命：\n从今后酒后不谈公。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张良、萧何、韩信、陈平、樊哙、随何同下。）"
        },
        {
          "character": "刘邦",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "管教那群雄入壳中。"
        }
      ],
