      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张良、萧何、韩信、陈平、樊哙、随何同上。）"
        },
        {
          "character": "张良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官张良。"
        },
        {
          "character": "萧何",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官萧何。"
        },
        {
          "character": "韩信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官韩信。"
        },
        {
          "character": "陈平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官陈平。"
        },
        {
          "character": "樊哙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官樊哙。"
        },
        {
          "character": "随何",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官随何。"
        },
        {
          "character": "张良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位公侯请了！"
        },
        {
          "character": "萧何、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "张良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天下已定，我主大封功臣，分茅列土，加官进爵。今在未央宫赐宴，我等躬逢\n其盛。远远望见圣驾来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、大太监引刘邦同上。）"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等接驾。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张良、萧何、韩信、陈平、樊哙、随何同迎进。）"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等见驾，愿我皇万岁！"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众卿平身。"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍摆宴。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监同摆宴。）"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众卿请！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众卿！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁！"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤自斩蛇起义以来，灭秦破楚，抚有天下。虽赖众卿之功，实赖三杰之力也！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请问万岁何谓三杰？"
        },
        {
          "character": "刘邦",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "运筹决胜，孤之智谋，不如张良；用兵布阵，孤之韬略，不如韩信；理财行政，\n孤之才能，不如萧何。此三人乃当世之人杰也。孤何幸而得之！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "虽三杰有功于国，然非万岁不能知；亦非万岁不能用也。"
        },
        {
          "character": "张良、韩信、萧何",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "刘邦",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "子房智略世少有；\n韩元帅乌江用计谋；\n众卿戮力大功收。\n君臣同饮太平瓯。"
        },
        {
          "character": "萧丞相治国是好手、内侍与孤斟美酒、萧何",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "萧何席间正饮酒，\n尊声万岁听根由：\n可怜他替主一命休；\n请万岁追封到荒坵。"
        },
        {
          "character": "忽然一事上心头、急忙离席来启奏、纪信荥阳功为首、今日诸臣受恩厚、刘邦",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刘邦闻言双眉皱，\n卿家奏本没来由。\n纪信登车赚楚囚。\n假扮天子罪为头。\n往事休提一笔勾。\n人死何必再封侯。"
        },
        {
          "character": "当日荥阳孤逃走、虽然救驾功劳有、将功折罪孤不究、丞相开怀且饮酒、萧何",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "萧何不敢再开口，"
        },
        {
          "character": "张良",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "张良一旁暗点头。"
        },
        {
          "character": "韩信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "韩信座上把眉皱，"
        },
        {
          "character": "陈平",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "陈平低头自揣忧。"
        },
        {
          "character": "樊哙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "樊哙怒气冲牛斗，"
        },
        {
          "character": "随何",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "随何不语泪双流。"
        },
        {
          "character": "刘邦",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "众卿放量多饮酒，\n畅饮葡萄饱珍馐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘邦下。）"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "臣等送驾转龙楼。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张良、陈平、萧何、韩信、樊哙同下。）"
        },
        {
          "character": "随何",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "随何此刻心难受，"
        }
      ],
