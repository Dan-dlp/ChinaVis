    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "四校尉",
        "屠岸贾"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、四大铠、四校尉、屠岸贾同上。）"
        },
        {
          "character": "屠岸贾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住。方才进宫搜孤，为何不见踪影？想是藏在民间，老夫自有道理。"
        },
        {
          "character": "屠岸贾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来呀！"
        },
        {
          "character": "四校尉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
