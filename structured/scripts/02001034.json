        {
          "character": "程婴",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "洗手焚香把神酬。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程婴下。）"
        },
        {
          "character": "韩厥",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我将大事安排就，"
        },
        {
          "character": "韩厥",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "要救孤儿出龙楼。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有人么。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（童子上。）"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么人？"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，将军来了。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "快快通禀。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请老爷。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太医上。）"
        },
        {
          "character": "太医",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "神农尝百草，轩辕执衣巾。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "韩将军到。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军在哪里？"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军请进。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军到此何事？"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主偶得疾病，请先生进宫诊脉。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，带了药箱，随我进宫。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "太医",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "仙丹产在深山内，"
        },
        {
          "character": "韩厥",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "妙药生于幽谷中。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（韩厥、太医、童子同走小圆场。）"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是。稍候。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "退下。"
        },
        {
          "character": "童子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（童子下。）"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请国太。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太后、庄姬同上。）"
        },
        {
          "character": "太后",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "吾儿平安稳，"
        },
        {
          "character": "庄姬",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "且喜病离身。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太医院到。"
        },
        {
          "character": "太后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主病已痊愈。看过赏封，打发来人去罢。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生，公主病已痊愈。国太有赏。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢。正是："
        },
        {
          "character": "太医",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "趁我十年运，有病早来医。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "药箱呢？"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "随后送去。"
        },
        {
          "character": "太医",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太医下。）"
        },
        {
          "character": "庄姬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后在上，想那屠贼搜寻孤儿不着，只恐又生别计。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国太，公主。为臣去请太医，中途路上遇见程婴，他倒有扶养公子之意。"
        },
        {
          "character": "太后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，程婴为人如何？"
        },
        {
          "character": "庄姬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃忠义之人。只是孤儿不能出宫。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太医院现有药箱在此。将公子装在里面，抱出宫去，付与程婴抚养。岂不安然"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无事？"
        },
        {
          "character": "太后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此计甚好，你母子速速分别了吧！"
        },
        {
          "character": "庄姬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，想你一家三百余口，被屠贼斩尽杀绝。但愿你出得宫去，长大成人，拿"
        },
        {
          "character": "庄姬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "着屠贼，冤冤相报。母子们就此一别，不知何日才得相见了。"
        },
        {
          "character": "庄姬",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "怀抱姣儿珠泪滚，"
        },
        {
          "character": "庄姬",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "才出娘胎就离分。"
        },
        {
          "character": "庄姬",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "痛断肝肠对谁明。"
        },
        {
          "character": "庄姬",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤儿交与忠义士"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主。"
        },
        {
          "character": "韩厥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤儿交与忠义士"
        },
        {
          "character": "韩厥",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "公主但把心放定，"
        },
        {
          "character": "韩厥",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "救孤之事我担承。"
        },
        {
          "character": "韩厥",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "谅奸贼难解其中情。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（韩厥下。）"
        },
        {
          "character": "太后",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤儿出宫情难忍，"
        },
        {
          "character": "庄姬",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好似钢刀刺娘心。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太后、庄姬同下。）"
        }
      ],
