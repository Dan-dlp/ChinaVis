      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、朱温同上。）"
        },
        {
          "character": "朱温",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "辕门战鼓响，儿郎报端详。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子上。）"
        },
        {
          "character": "探子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少爷被潼台小将杀死，亲事抢了去了！"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子下。）"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，杀奔潼台！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱温、四龙套同下。）"
        }
      ],
