          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。刘智远上，岳彦真拉刘智远对拜谢。）"
