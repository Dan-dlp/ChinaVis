          "character": "岳彦真",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "刘高生来真英雄，"
        },
        {
          "character": "岳彦真",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "好似当年苏保通。"
