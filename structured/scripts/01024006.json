          "musical_style": null,
          "style_family": null,
          "text": "（四刽子手、四龙套、四大铠、中军、二门子同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "莫文豪 （内西皮导板） 奉王旨意出帝京，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（莫文豪上。）"
        },
        {
          "character": "莫文豪",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "为国为民哪得安宁。\n贪官污吏怎胡行！\n杀父之仇要报清。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四上手引戚继光同上，同出城，同迎上。戚继光跪。）"
        },
        {
          "character": "戚继光",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "蓟州总镇迎接大人。"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启大人：蓟州总镇戚继光，迎接大人。"
        },
        {
          "character": "莫文豪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "察院伺候。"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "蓟州镇察院伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同入城，同下。）"
        }
      ],
      "interactions": [
