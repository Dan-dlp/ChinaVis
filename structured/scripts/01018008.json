      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭得福上。）"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "报何事？"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有一女子闯山。"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "加马追回。"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将女子获住。"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带上高山。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭得福下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭得福上。）"
        },
        {
          "character": "郭得福",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "今日下山无得财，获住乡民女裙衩。吩咐喽兵松了绑，将民女与我带上来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜美容上。）"
        },
        {
          "character": "姜美容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "与大王叩头。"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这一女子，家住哪里，姓甚名谁？对本大王一讲。"
        },
        {
          "character": "姜美容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王容禀！"
        },
        {
          "character": "姜美容",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "战兢兢跪在了山坡以上，\n叫一声大王爷细听分明："
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家住哪里？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "家住在山西太原府，\n随波门来到永平城。\n我是他儿妻姜氏美容。"
        },
        {
          "character": "郭老爷在京把尚书做、郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "说起别人我不晓，\n提起郭家我知情。\n郭老爷他有几个子？\n几个亲生几螟蛉？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "郭老爷他有四个子，\n两个亲生二螟蛉。"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "二亲生来二螟蛉，\n你与哪个配婚成？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我夫名叫郭得福，"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "他为官来他为民？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "儿父名叫一总镇，"
        },
        {
          "character": "郭得福",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "看起来他是官门中。\n来路之事问过清。\n一字说错活不成。"
        },
        {
          "character": "吩咐令人打上座、说了实话还罢了、姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "八月中秋赴寿诞，\n张意挂画在庭前。\n恼怒我父二品官。\n张意贼怀恨在心前。\n四门四张五门悬。\n奏与唐皇主圣贤。\n带领人马抄家眷。"
        },
        {
          "character": "张意挂画挂不正、我父打他四十棍、灯下写了无头卷、又叫仇官揩了去、唐王爷听信奸臣话、三百余口俱杀死、郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "他不杀你为哪般？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "小奴本是宦门女，\n岂能配他下贱残？"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "既然不愿成亲事，\n何人把你容颜扳？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "话到舌边我难讲，"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "半言半语为哪般？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "奴家身怀有了孕，"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我问你分娩不分娩？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "奴家生下郭门后，"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "怎么不见你儿男？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "张意贼记心间，\n要害郭门后根源。"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "张意要害你儿命，\n何人救他一命还？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "多亏他家老张保，\n施了亲生救螟蛉。"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "施亲生来救螟蛉，\n他岂肯与你罢不成？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "万般出在无计奈，\n火炎草堂归阴城。"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "出永平来离永平，\n黑夜女郎哪里行？"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "今日一到太原府，\n太原府里去搬兵。\n好与郭门报冤恨。"
        },
        {
          "character": "太原府搬的人马到、郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我当你是哪个到，\n原是我妻姜美容。"
        },
        {
          "character": "太原府搬的人马到、郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳呀，罢了！夫人哪！"
        },
        {
          "character": "太原府搬的人马到、郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "走上前来把妻认，\n再把夫人叫一声。"
        },
        {
          "character": "意思不把她来认、姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听一言来好心惊，\n骂声恶贼细耳听：\n想要成亲万不能！"
        },
        {
          "character": "拿刀来把我头割下、郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我妻不必胆战惊，\n丈夫把话对你明：\n把我当作哪一个？"
        },
        {
          "character": "姜美容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是哪个？"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我是你丈夫郭得福。"
        },
        {
          "character": "姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "儿夫三绺胡须下，\n你像三国二关公。"
        },
        {
          "character": "郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "好叫夫人得知晓，\n听我把话对你明：\n因此落得像关公。\n净面水里洗面容。"
        },
        {
          "character": "也是我高山闭了脸、喽啰看过净面水、姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "果然你是我丈夫到，\n拿着何物作证明？\n快快拿来对相逢。"
        },
        {
          "character": "若有金钗和玉带、郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "郭得福正在海滩睡，\n一语叫起梦中人。\n金钗玉带拿手中。\n拿去玉带对分明。"
        },
        {
          "character": "将身回到连环帐、高叫夫人抬头看、姜美容",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我一见玉带心酸痛，\n金钗玉带拿手中。\n不得相逢又相逢。\n能工巧匠又锯成。"
        },
        {
          "character": "不得相见又相见、金盆打得粉粉碎、郭得福",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "夫人稳坐梁山上，\n来路之事要问清。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜美容哭。）"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夫妇相见，天降大喜，恸哭为何？"
        },
        {
          "character": "姜美容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夫妻见面，天降大喜。但不知二弟、五弟，流落何所？"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二弟、五弟，现在金顶太行山，那边有信来，这边有信去，单等八月中秋，兵\n合一处，将合一家，好与郭门报仇。夫人请入后帐歇息罢。"
        },
        {
          "character": "郭得福",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "梧桐叶落还未干，"
        },
        {
          "character": "姜美容",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "张意把咱下眼看。"
        },
        {
          "character": "郭得福",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "有朝一日获张意，"
        },
        {
          "character": "姜美容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷！"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夫人！"
        },
        {
          "character": "姜美容",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "千刀万割遂心间。"
        },
        {
          "character": "郭得福",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，好个千刀刮遂心意！夫人请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭得福、姜美容同下。）"
        }
      ],
