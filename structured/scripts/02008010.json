    {
      "scene_index": 7,
      "label": "第七场",
      "characters_present": [
        "丫鬟甲",
        "刘员外",
        "刘安人"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘员外、刘安人同上。）"
        },
        {
          "character": "刘员外",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "膝下无子苦，"
        },
        {
          "character": "刘安人",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "老来不公平。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟甲上。）"
        },
        {
          "character": "丫鬟甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启员外、安人：小姐花园游玩，偶遇狂风一阵，猛然痴呆，不知主何吉凶。"
        },
        {
          "character": "刘员外、刘安人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有这等事。丫鬟，带路上房。"
        },
        {
          "character": "丫鬟甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "刘员外",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听一言把我的三魂吓掉，"
        },
        {
          "character": "刘安人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "七孔毛炸似火烧。"
        },
        {
          "character": "刘员外",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟带路上房到，"
        },
        {
          "character": "刘安人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看看吾女为哪条？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘员外、刘安人、丫鬟甲同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "刘员外→刘安人",
