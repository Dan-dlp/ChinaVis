      "characters_present": [
        "丫鬟甲",
        "公子",
        "刘员外",
        "刘安人",
        "刘来",
        "刘玉英"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘玉英上。）"
        },
        {
          "character": "刘玉英",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我适才花园遭不幸，\n猛然狂风扑淋身。\n浑身麻木为何情？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘员外、刘安人同上。）"
        },
        {
          "character": "刘员外",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "夫妻二人把上房进，"
        },
        {
          "character": "刘安人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见了吾女问一声。"
        },
        {
          "character": "刘员外、刘安人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，醒来！"
        },
        {
          "character": "刘玉英",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "耳听得有人叫一声，"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀爹娘！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘玉英笑。）"
        },
        {
          "character": "刘玉英",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见爹娘不由我喜盈盈。"
        },
        {
          "character": "刘员外、刘安人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，花园游玩可见什么？"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无有见着什么。一时身体不爽，爹娘不必劳心了。"
        },
        {
          "character": "刘员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既然如此，安人，你我暂且上房去罢。"
        },
        {
          "character": "刘安人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "员外请。"
        },
        {
          "character": "刘员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": "刘员外",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但愿吾女无灾难，"
        },
        {
          "character": "刘安人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "满炉内焚香答谢苍天。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘员外、刘安人同下。公子上。）"
        },
        {
          "character": "公子",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我这里翻身打一变，\n变个书生降下凡。"
        },
        {
          "character": "公子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃千年狐仙。今见刘小姐生得天姿国色，不免调戏一番便了。"
        },
        {
          "character": "公子",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将身且把绣房进，\n床上睡的女佳人。"
        },
        {
          "character": "公子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐醒来！"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，你是甚人，来在绣房为了何事？"
        },
        {
          "character": "公子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃宦门公子，前来与你成双。"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（洞房。丫鬟甲、刘员外、刘安人同上。）"
        },
        {
          "character": "刘员外",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "只为吾女病，"
        },
        {
          "character": "刘安人",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "长挂一片心。"
        },
        {
          "character": "丫鬟甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "员外，安人。来此已是绣房。"
        },
        {
          "character": "刘员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前去叫门。"
        },
        {
          "character": "丫鬟甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐，员外、安人来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（公子走。刘玉英开门。）"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹娘来了。"
        },
        {
          "character": "刘员外、刘安人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，你可好些？"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿倒也好些。"
        },
        {
          "character": "刘员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟，请小姐上房用饭。"
        },
        {
          "character": "丫鬟甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐。员外安人请小姐上房用饭。"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我茶饭不想，请员外、安人上房去罢。"
        },
        {
          "character": "丫鬟甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐言道，茶饭不想，请员外、安人上房去罢。"
        },
        {
          "character": "刘员外、刘安人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，你有什么病症，对我二老说明。"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，爹娘吓。女儿有一言不敢禀明双亲。"
        },
        {
          "character": "刘员外、刘安人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，有甚么话，对我二老说明才是。"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹娘有所不知，自从那日花园游玩，猛然见一黑风扑来，女儿一时昏迷。之后\n每日有一书生来到绣房，儿就甚事不知了。"
        },
        {
          "character": "刘员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，这就奇怪了。吓，是了。想是吾儿被仙人扑身。我自有道理。\n刘来过来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘来上。）"
        },
        {
          "character": "刘来",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "员外。"
        },
        {
          "character": "刘员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我今写下招帖，四方张贴，有人揭了招帖，带他进来。"
        },
        {
          "character": "刘来",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "刘员外",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "“庄是刘家庄，妖怪内面藏。有人降妖怪，小姐配鸾凰。”"
        },
        {
          "character": "刘员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刘来快去。"
        },
        {
          "character": "刘来",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "刘员外",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "我今吩咐你，"
        },
        {
          "character": "刘来",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "怎敢稍迟延。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘来下。）"
        },
        {
          "character": "刘安人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓，随为娘上房去罢。"
        },
        {
          "character": "刘玉英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿遵命。"
        },
        {
          "character": "刘员外",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "膝下无子靠，"
        },
        {
          "character": "刘安人",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "皆因命安排。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘员外、刘安人、刘玉英同下。）"
        }
      ],
