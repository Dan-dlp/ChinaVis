    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "众人",
        "蔡天化"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（蔡天化上。）"
        },
        {
          "character": "蔡天化",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，天明了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（菩萨蛮） 玉漏初残露光寒，"
        },
        {
          "character": "蔡天化",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徒弟们走上！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众徒弟同上。）"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "师父何事惊慌？"
        },
        {
          "character": "蔡天化",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "印信不见，被何人盗去？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同看。）"
        },
        {
          "character": "蔡天化",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来从天窗内而。印信既被他人盗去，必有人前来见我。大家一同用了斋饭，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "蔡天化→众人",
          "turns": 1
        },
        {
          "edge": "众人→蔡天化",
          "turns": 1
        }
      ],
      "stats": {
