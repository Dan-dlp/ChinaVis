          "style_family": null,
          "text": "且住。看前面有一人，急走如飞，定不是好人，待我赶上前去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（斗鹌鹑） 我这里急走慌忙，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "哪怕他飞至天上。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺仁杰下。）"
        }
      ],
      "interactions": [
        {
          "edge": "李兴儿→贺仁杰",
          "turns": 1
        }
      ],
      "stats": {
