        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又只见刘家新坟台。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "公公婆婆哭起来。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我今天不到别处去"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "正走之间泪满腮"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他上京城去赶考"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一双爹娘冻饿死"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坟台垒起三尺土"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "身背琵琶描容像"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "找到京城不相认"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "贤惠五娘遭马践"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "正走之间抬头看"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坟前放下千张纸"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "嗳，奴家哭到伤心处"
        },
        {
          "character": "刘禄景",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "打道！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四衙役引刘禄景同上。）"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又来了为官受禄人。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哭一声儿夫刘景禄！"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回老爷，刘氏新坟有一妇人啼哭。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "起过了。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀且住。想我刘家坟茔，哪有什么女子啼哭？其中必有缘故。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来！"
        },
        {
          "character": "衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住轿！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（衙役同允。）"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前去问问那妇人，说我家老爷问你，为何在此啼哭？"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这妇人，我家老爷问你，为何在此啼哭？"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "萧素贞这里的头抬，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尊一声老爷你打哪里来？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坟后头又无有接官厅；"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坟西里又无有饮马泉。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我的老爷呀！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你为何来到我刘家的坟茔？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坟前无有关王庙"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坟东里无有放马场"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又不通南北各大道"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（衙役同允。）"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你去对那妇人说，就说老爷是清官到了。"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喳。"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那一女子，我家老爷是清官到了。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呕！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听罢一声清官到，"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那一女子有什么冤枉，一状一状的诉来！"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容禀！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我有心告状无人写，"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "口诉上来！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "口诉的状儿句句真。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "头一状？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "头一状不把别人告，"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告哪个？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "告的是公婆二双亲。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为了何事？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "终日打来每日骂，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "打骂得奴家实实的难忍。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公婆打骂，分所当然，我这里不准。第二状告来！"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容禀！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "第二状不把别人告，"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告哪个？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "告的是我娘舅李大公。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为了何事？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他一日三遭我家走，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "挑唆我的公婆二双亲；"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我的老爷呀！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "打骂得奴家险些儿改嫁了人。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又是打来又是骂"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "世间之上哪有这样的事！我这里不准。再把第三状诉来！"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎！你若不准，我就不告了。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来！"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你去对那妇人说，我这里准了她的状子，叫她往下告来。"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这妇人，我家老爷准了你的状子，叫你往下告来。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么着，你们老爷准了我的状子啦？"
        },
        {
          "character": "衙役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此说来我还要告。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "第三状不把别人告，"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告哪个？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "告的我儿夫……"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叫什么名字？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刘禄景！"
        },
        {
          "character": "衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "唔！"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "准了。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们没有事，去到松林之下玩耍玩耍去吧。"
        },
        {
          "character": "衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四衙役同下。）"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那一女子有什么冤枉，再往上诉来！"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容禀！"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你起来讲。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他娶奴家三月整，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一去赶考不回程。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可有书信寄回来？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一封信走了三年整，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "上写着我儿夫死丧在那东京城。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为官这里怒冲冲，"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "骂一声娘舅李大公："
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "还有那家书信一封。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "决不该说我死在东京。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "先斩后奏不容情。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我是你儿夫转回程。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我交你纹银三百两"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你昧我银子是小事"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "圣上赐我尚方剑"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叫声贤妻认认我"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我道你是清官到，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "却原来是一个糊涂虫。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "少鞍无辔认你不成。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "槽头拴上逍遥马"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "贤妻打我我不恼，"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "贤妻你骂我我不嗔。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "决不该忘了你我夫妻情。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "打我骂我是小事"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你若是我儿夫到，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奴说几桩大事情。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好做怪你就是公子王孙我认你不成！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你若对不上我三宗宝"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我道她是裙钗女，"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "件件桩桩记得明。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将我的宝贝拿手中。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叫一声贤妻认个清。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二十四箱打开看"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宝贝放在流平地"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿起乌绫看一看，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四四方方的手帕巾。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "八月十五放光明。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "千针万线奴做成。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿起菱花照一照"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿起绣鞋对一对"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一点也不错呀！"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宝贝宝贝真宝贝，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "禄景还是假禄景。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宝贝宝贝真宝贝，"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "禄景也是真禄景。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想当初我儿夫上京时他本是十七八岁读书生，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到如今你回来满脸上长胡须好不丑人！"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想当初上京时我的妻她本是十七八岁裙钗女，"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到如今我回来满脸长皱纹好不丑人！"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有皱纹无皱纹累你心疼？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有胡须无胡须累你什么心疼？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你若是我儿夫到，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奴还有几件大事情。"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "家住哪州并哪县？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哪个村庄有家门？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "爹姓甚来娘何姓？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄们同胞几个人？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "娶的妻子谁家女？"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "她的名儿叫做什么名？"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "家住山东济南府，"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刘家庄上有家门。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "母亲张氏老夫人。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "就是我禄景一个人。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "她的名字叫做萧素贞。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹本是刘员外"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "上无兄来下无弟"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "娶的妻子萧家女"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听说是我儿夫到，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奴家随你到接官厅。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为官这里朝前走，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "后面跟的萧素贞。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "迈步进了关王庙，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奴家随你进庙门。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "忙把乌纱整一整，"
        },
        {
          "character": "萧素贞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "在头上去了素帕绫。"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只道夫妻难相会，"
        },
        {
          "character": "刘禄景",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "谁知相会在接官厅。"
        },
        {
          "character": "萧素贞",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "喂呀呀！"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，妻呀！不要哭了。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "站着！"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "做什么？"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我来问你，上京这几年就不想家了吗？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我为了做官，哪里还能想家。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你为了做官就不想家了？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就不想家了。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我再问你，上京有多少年了？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "十八年了。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你的胡子怎么就长得这么长了？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天长日久就长长了。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天长日久就长长了？怎么我就不长呢？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎！那叫什么话？"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我再问你上京的时候多大年纪？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我问你今年有多大年纪？"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一十七岁。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我上京十八年，你今年才十七岁。我上京时候，你还在你妈肚子里哪。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "站着！你这头上戴的是什么？身上穿的是什么？你到底是个什么东西？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我做了官了。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你做了官了，做的什么官？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "八府巡按。圣上恩赐尚方宝剑，准我先斩后奏。你要不听我的话，我也照样儿"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杀你！"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你杀谁？"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我杀你。"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你杀我？附耳上来。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "说什么？"
        },
        {
          "character": "萧素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（萧素贞下。）"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你不用跑，跑到什么地方，我也饶不了你。"
        },
        {
          "character": "刘禄景",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闲人闪开，刘大老爷来也！嗯哼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘禄景下。）"
        }
