        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大仙，仙子请！"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "圣母请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。麻姑上。）"
        },
        {
          "character": "麻姑",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "手捧佳酿瑶池献，整来彩衣拜金阶。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣母在上，小仙麻姑拜寿。"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "麻姑仙子平身。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣寿无疆！"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "手捧何物？"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小仙特制的圣寿长生不老酒。"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何谓圣寿长生不老酒？"
        },
        {
          "character": "麻姑",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "此酒本是鲜花炼，灵芝仙草精益鲜。凡人若得饮此酒，可得长生永绵绵。"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此身受你一杯。"
        },
        {
          "character": "李铁拐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊圣母，麻姑仙子之长生不老酒，可能给我等饮一杯否？"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那是理当奉敬，今日众仙驾临，乃是仙池之大幸也，现今园内蟠桃也熟，各敬"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一枚，以为结缘之品。"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "侍女们，将蟠桃各敬一枚。"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "麻姑仙子，命你在众仙面前执壶敬酒一杯。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵法旨。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "瑶池奉了圣母命，"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "回身取过酒一樽。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "金壶玉液仔细斟。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "饮一杯来延寿龄。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "愿祝仙子比那南极天星。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "愿年年如此日不老长生。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "进前忙把仙姑敬"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "饮一杯来增福命"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "愿祝仙师万年庆"
        },
        {
          "character": "麻姑",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "霎时琼浆都倾尽"
        },
        {
          "character": "吕洞宾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大仙，这里有编戏上寿词一首，请麻姑仙子跳舞一番如何？"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、张果老",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "好，我等幸会。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小仙当得奉命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（山花子） 寿筵开处风光好，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "争看寿星荣耀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "寿同王母年高。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "玉杯寿酒增寿考。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "愿福如东海得寿比南山。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大和佛） 青鹿御芝呈瑞草，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "齐祝愿寿弥高。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "寿基巩固寿坚牢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "展寿席人人欢笑。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "齐庆寿诞中祝寿间妙。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（红绣鞋） 寿炉宝篆香消香消，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "寿桃结子堪描堪描。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "歌寿曲寿多娇。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "齐祝寿比南山高。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（尾声） 长生寿域宏开了，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "寿烛辉煌彻夜烧。"
        },
        {
          "character": "圣母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众仙如此殷勤，乃我神之幸也，你等随我往凌宵宝殿谢恩去者。"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "遵法旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "张果老 （同合头） 愿岁岁年年增寿考。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
