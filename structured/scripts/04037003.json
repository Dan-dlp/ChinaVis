      "characters_present": [],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四军士引杜平同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杜平 （泣颜回） 顿首拜彤庭，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "金章紫绶，白面乌纱相称。"
        },
        {
          "character": "杜平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官杜平。叨蒙圣恩特授四路都总管，执掌天下帑藏金银。今日告假还乡，果"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "然好气象也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（泣颜回） 春风自生，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杜员外富贵齐鸣。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
