      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（扈三娘上。）"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！王英来的厉害。"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众女兵走上！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四女兵、四下手同上。）"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "绊马索伺候！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王英上，被擒。）"
        },
        {
          "character": "四女兵、四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "王英被擒。"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贼子！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刮地风） 这才是狭路相逢难回避。"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，将王英吊在高竿之上！"
        },
        {
          "character": "王英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咦，这才是狭路相逢难回避。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手押王英同下，报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前面便是宋江营盘！"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子应，下。）"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众女兵，踹宋江营盘者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（水仙子） 恨、恨、恨小毛贼，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "怎、怎、怎、怎逃俺虎穴龙潭地！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "似、似、似、似大鹏展翅飞不起。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杀、杀、杀、杀得他无路奔，血染马蹄。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "管、管、管、管叫他片甲不存死如泥。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（扈三娘引四女兵同下。）"
        }
      ],
