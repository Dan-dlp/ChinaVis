        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "旌旗飘扬战马吼，"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老爷出兵鬼神愁。"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "稍若迟延一命休。"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "劝你马前卸甲胄"
        },
        {
          "character": "扈三娘",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "女将威名贯九州，"
        },
        {
          "character": "扈三娘",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "画戟能取项上头。"
        },
        {
          "character": "扈三娘",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "管你尸骨不存留。"
        },
        {
          "character": "扈三娘",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "狭路相逢难罢手"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "今日交锋龙虎斗，"
        },
        {
          "character": "扈三娘",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不灭贼子誓不休。"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三军起鼓催坐吼，"
        },
        {
          "character": "扈三娘",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "谅你插翅难出头。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（林冲、扈三娘同起打。扈三娘被擒。众人同下。）"
