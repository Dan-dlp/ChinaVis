    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "王英"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四上手、王英同上，王英起霸。）"
        },
        {
          "character": "王英",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "自幼身量矮小，胸中韬略颇高。上阵不用战马，纵跳强似飞雕。"
        },
        {
          "character": "王英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，矮脚虎王英。奉了大哥将令，攻打扈家庄。闻得一丈青生得天姿国色，真"
        },
        {
          "character": "王英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是闭月羞花之貌。俺若擒住此女，也好做一个老婆，啊哈哈哈……好不快乐人"
        },
        {
          "character": "王英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也！"
        },
        {
          "character": "王英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，今日出兵必须要人人奋勇、个个当先。就此前往！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王英、四上手同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "念": 1
        },
        "singing_ratio": 0.0,
