        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "提刀误入白虎堂。"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "披星戴月投宋江。"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "带领人马下山岗。"
        },
        {
          "character": "林冲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
