    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "伽蓝",
        "哪吒",
        "唐三藏去西天路经此境",
        "善才",
        "四云童",
        "孙悟空",
        "木吒",
        "灵官",
        "玄坛",
        "白虎",
        "观音菩萨",
        "金吒",
        "青龙",
        "龙女"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四云童、善才、龙女、韦陀引观音菩萨同上。）"
        },
        {
          "character": "观音菩萨",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "佛法无边，法轮常转，金身现，世界大千，普度迷津岸。"
        },
        {
          "character": "观音菩萨",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "身坐南海普陀山，紫竹林中静参禅。净瓶杨柳施法雨，众生普渡广因缘。"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃观音大士是也。适才从西天而回，在云端之内，观见流沙河岸，杀气连天，\n必是唐僧到此，悟净不肯轻易放他过去。悟空必来此处求救。待我差遣天兵\n天将，收伏于他，远远望见悟空来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖水底鱼〗。孙悟空上。）"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弟子悟空参见菩萨！"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "悟空，你到此何事？"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "菩萨容禀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "悟空，你且回去等候，待我遣动天兵天将，管叫他皈依佛门，保你师父西天取\n经就是。"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢菩萨，弟子去也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙悟空下。）"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看悟空已去，待我遣动天兵天将便了！"
        },
        {
          "character": "观音菩萨",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坐至在莲台上急传法令，\n遣天兵与天将降下凡尘。\n三玄坛四灵官速降天庭。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "灵官 （内同白） 来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（青龙、白虎、玄坛、灵官同上。）"
        },
        {
          "character": "青龙、白虎、玄坛、灵官",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见菩萨！"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "站立两厢！"
        },
        {
          "character": "观音菩萨",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "传法旨再唤那伽蓝、哪吒，\n有金吒与木吒速速降临。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "木吒 （内同白） 来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伽蓝、哪吒、金吒、木吒上。）"
        },
        {
          "character": "伽蓝、哪吒、金吒、木吒",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见菩萨！"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听吾吩咐："
        },
        {
          "character": "观音菩萨",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "今有那卷帘将违背法令，\n流沙河兴波浪迫害行人。\n理应当收伏他西天同行。"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "木吒！"
        },
        {
          "character": "唐三藏去西天路经此境、木吒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "观音菩萨",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "执法宝收伏他取名悟净，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（观音菩萨递葫芦，木吒接过。）"
        },
        {
          "character": "观音菩萨",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "粉骷髅做法船渡过唐僧。"
        },
        {
          "character": "青龙、白虎、玄坛、灵官、伽蓝、哪吒、金吒、木吒",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨！"
        },
        {
          "character": "青龙、白虎、玄坛、灵官、伽蓝、哪吒、金吒、木吒",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "莲台下遵领了菩萨法令，\n流沙河去收伏卷帘将军。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（青龙、白虎、玄坛、灵官、伽蓝、哪吒、金吒、木吒同下。）"
        },
        {
          "character": "观音菩萨",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看众天将已去，必然成功。众护法，收了威严者！"
        },
        {
          "character": "四云童、善才、龙女",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。四云童、善才、龙女、观音菩萨同下。）"
        }
      ],
