        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "叫声三姐快开窑门。"
        },
        {
          "character": "王宝钏",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏上。）"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "忽听门外一声唤，\n想必薛郎回窑前。"
        },
        {
          "character": "开开窑门用目看、薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三姐，为丈夫回来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵进窑。）"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "来了堂堂将一员。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，薛郎，你回来了！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回来了。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这身荣耀，莫非作了官了?"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为丈夫降了红鬃烈马，圣上见喜，封为后军督府。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀呀，果然作了官了。待我谢天谢地。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三姐慢谢天地，其中有变哪。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛郎，此话活从何而起？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊呀三姐呀！可恨你父与魏虎奸贼，上得金殿，参奏一本，言道西凉下国，打\n来战表，要夺我主江山，苏龙、魏虎以为正副帅，为丈夫后军督府改为了马前\n的先锋，即日就要登程。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么讲？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我就要走了。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏晕倒。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三姐，三姐醒来！"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "听一言来珠泪洒！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三姐醒来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "薛平贵 （同叫头） （薛郎）（宝钏）！（我夫）（我妻）！（喂呀）（嗳呀）！"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "好一似万把刀把我心扎！\n又好比汉萧何私造律法。"
        },
        {
          "character": "父好比秦赵高指鹿为马、薛平贵",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "贼好比秦赵高指鹿为马，\n贼好比汉萧何私造律法。\n害得我夫妻俩各奔天涯。"
        },
        {
          "character": "为丈夫与你父冤仇结下、王宝钏",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "手指相府，"
        },
        {
          "character": "为丈夫与你父冤仇结下、王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "高声骂，\n爹爹作事理太差。"
        },
        {
          "character": "为丈夫与你父冤仇结下、王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "夫妻们只哭得泪如雨下，\n好鸳鸯遭棒打各奔天涯！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三姐！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "三姐不必泪双流，\n丈夫言来听从头：\n你在寒窑度春秋；\n三姐呀！守不住来将我丢。"
        },
        {
          "character": "干柴十担米八斗、守得住来将我守、王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "薛郎说话没来由，\n为妻言来听从头：\n我在寒窑度春秋；\n纵死在寒窑也不回头。"
        },
        {
          "character": "干柴十担米八斗、守不住来也要守、薛平贵",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "三姐说话世少有，\n上得青史把美名留。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（中军上。）"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先行听令。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵出窑。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "元帅初点大卯，不要误了卯期。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": "中军",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "将军不下马，"
        },
        {
          "character": "薛平贵",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "各自奔前程。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（中军下。薛平贵进窑。）"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方才何人到此？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方才中军至此，言道元帅初点大卯，不要误了卯期。三姐你看，天色不早，我\n要告辞了。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛郎，你这就要走了吗？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！我这就要走了。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你有什么言语，嘱咐为妻几句。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我的心如刀割，也想不起什么言语来了。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你……嘱咐为妻几句啊！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢！为丈夫此番从军，不知几时回来，寒窑之中，干柴十担，老米八斗，你苦\n度春秋；倘若是柴米不够，你……回转相府去吧！"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛郎啊！我与我爹爹三击掌，纵然是饿死寒窑，我也是不……回去的啊！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好哇！好个三姐，虽是女流，却比男子刚强。为丈夫此番征战西凉，不知三年\n五载，才得回来；你在这窑前、窑后、窑左、窑右，与人家缝缝连连度日，为\n丈夫回来，一家一家登门叩谢。话已讲完，我告辞了！"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛郎，你当真要走了？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我即刻就要走了。唉！"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待为妻送你一程。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "外面的风大得很哪！"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我一定要送。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不送也罢。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一定要送啊！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此有劳了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵欲走，回身为王宝钏拭泪。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊三姐，为丈夫征战西凉，就要回来了，你……不要哭啊！"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛郎，你自己珍重，也不……要哭啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏为薛平贵拭泪。薛平贵出窑，头碰窑门，王宝钏为薛平贵抚痛。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不妨事。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵、王宝钏同出窑。）"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "夫妻双双出窑门，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "叫人难舍又难分。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "但愿得此一去旗开得胜，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "自有那探马儿来报捷音。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "一路上必须要小心谨慎！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "你在那寒窑内切莫要挂心。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "送薛郎送至在三岔路口，\n喂呀，薛郎啊！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三姐啊！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "刀绞肝肠泪淋淋。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "从空降下无情剑，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "斩断夫妻两离分。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "王宝钏难舍薛平贵。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "薛平贵难割结发情。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "流泪眼观流泪眼。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "断肠人送……"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "断肠人。"
        },
        {
          "character": "王宝钏",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "夫妻们只哭得珠泪滚滚……\n喂呀，我的夫啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（号炮三声。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "又听大炮响三声。"
        },
        {
          "character": "辞别三姐踏金蹬、王宝钏",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "拉住薛郎不放开。\n你要走来将我带！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
