        "musical_styles": []
      }
    },
    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "四小道",
        "张女",
        "武松",
        "王飞天",
        "老道"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王飞天上。）"
        },
        {
          "character": "王飞天",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "徒弟下山去抢亲，为何不见转回程。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小道背张女同上。）"
        },
        {
          "character": "四小道",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "抢来了！"
        },
        {
          "character": "王飞天",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，好，好！你等下面吃酒，明日俱有重赏。"
        },
        {
          "character": "四小道",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢师父。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小道同下。王飞天坐，张女掩面哭。）"
        },
        {
          "character": "王飞天",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "美人不要啼哭了。"
        },
        {
          "character": "张女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！胆大狂徒，清平世界，朗朗乾坤，擅抢良家妇女，难道你不怕王法么！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（武松急跑上。）"
        },
        {
          "character": "王飞天",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某家生来，向不知什么王法。你若从了某家的亲事，造化不小。"
        },
        {
          "character": "武松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！开门来！"
        },
        {
          "character": "王飞天",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老道！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（老道上。）"
        },
        {
          "character": "老道",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么事吓？"
        },
        {
          "character": "王飞天",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看看外面，什么人叫门。"
        },
        {
          "character": "老道",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张女暗下。）"
        },
        {
          "character": "老道",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "头发根札插，不妙，不妙。咳！"
        },
        {
          "character": "老道",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "昨夜一梦甚可愁，梦见小鬼偷我的油。我今开门瞅一瞅，必定杀了我的头。"
        },
        {
          "character": "老道",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "没法子，不出去也不行，待我开开门，看看是谁。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（老道开门。武松杀老道，老道下。武松扑王飞天，起打。王飞天败下，武松追下。）"
        }
      ],
      "interactions": [
