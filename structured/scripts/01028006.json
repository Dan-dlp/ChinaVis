        "musical_styles": []
      }
    },
    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "张志善"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子、张志善、张女同上。）"
        },
        {
          "character": "张志善",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "桃红柳绿万家春，\n眺望郊原欲断魂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张志善、张女同下车，同跪。）"
        },
        {
          "character": "张志善",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "见坟茔不由人泪盈盈，\n无限悲伤哭先灵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小道同上，同抢张女，同背张女，同打走张志善、院子，双下，众人同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "武松",
        "院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子上，撞武松，院子倒地。）"
        },
        {
          "character": "武松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！昏夜之间，不看路径，慌慌张张，莫非你是奸细么？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老汉不、不、不是奸细，老汉是避、避、避难的。"
        },
        {
          "character": "武松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既然你是避难之人，有话起来慢慢讲。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎吓爷爷吓！今当清明佳节，小老儿随同我家主人、小姐，上坟祭扫。此地有\n一蜈蚣岭，岭上有一三清观，观中有一道士，名叫王飞天，横行霸道，无恶不\n为。是他看见我家小姐，生得美貌，前来提亲。那时我家主人不允。不料他今\n日竟命许多强徒，竟将我家小姐抢了去了。"
        },
        {
          "character": "武松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想这清平世界，朗朗乾坤，竟敢擅抢良家妇女。老头儿，洒家情愿替你，搭救\n你家小姐，不知你意下如何？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎吓爷爷呀！你若能搭救我家小姐的性命，不但小老儿感激，就是我那主人也\n是感激不尽了。"
        },
        {
          "character": "武松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此番待洒家前去，你在岭下等候。若见火光一起，你便前来，迎接你家的小姐。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爷爷吓，若是火光不起呢？"
        },
        {
          "character": "武松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若是火光不起么，你就各自逃命去吧。"
        }
      ],
      "interactions": [
        {
          "edge": "武松→院子",
          "turns": 4
        },
        {
          "edge": "院子→武松",
          "turns": 4
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 4,
          "白": 9
        },
        "singing_ratio": 0.0,
