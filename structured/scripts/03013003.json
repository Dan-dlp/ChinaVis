  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "且不论前朝事用不观定",
        "再不然将我的卦棚拆损",
        "口属水水已干犹如枯井",
        "急忙忙向前去先生来问",
        "放下犁拴上牛卦棚来进",
        "有纣王宠妲己天心不顺",
        "来至在十字路用目观定",
        "眼属火火无光不能生金",
        "管辂",
        "耳属金金不能生水半寸",
        "赵颜",
        "鼻属土土入陷死气已真"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（管辂上。）"
        },
        {
          "character": "管辂",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "慧眼能识仙鬼，判断祸福无差。"
        },
        {
          "character": "管辂",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "天上星辰日月，人间山水物华。争长论短空嗟呀，还是父母为大。"
        },
        {
          "character": "管辂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道，姓管名辂字公明，乃平原县人氏。自幼生就一双慧眼，能知过去未来之\n事。在这十字街前，摆了一座卦棚，无非指引世人。看今日天气晴和，不免卦\n棚走走。"
        },
        {
          "character": "管辂",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "叹光阴似箭穿过目烟云，\n见世间有草木尽已发青。\n又看见这山下花开缤纷。\n花瓣落比人老迟暮光阴。\n有等人为妻妾家业凋零。\n有等人为小事大祸临身。\n切不可以势力欺压贫人。\n等候了繁华世痴迷之人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵颜上。）"
        },
        {
          "character": "赵颜",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "在家中遵奉了双亲严命，\n手牵着青牛儿去把田耕。"
        },
        {
          "character": "赵颜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小生，赵颜。奉了双亲之命，下田耕种。就此走走。"
        },
        {
          "character": "赵颜",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "世间人必须要耕种为本，"
        },
        {
          "character": "赵颜",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "官出民民出土土内生金。\n卦棚内坐定了算命的先生。\n看一看他手托哪部古文。"
        },
        {
          "character": "来至在十字路用目观定、放下犁拴上牛卦棚来进、管辂",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "坐至在卦棚内心中烦闷，\n观前朝和后汉累代圣君。\n黄飞虎反五关去投国君。\n猛抬头见小哥大吃一惊。"
        },
        {
          "character": "来至在十字路用目观定、放下犁拴上牛卦棚来进、管辂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可叹呐，可叹！"
        },
        {
          "character": "有纣王宠妲己天心不顺、且不论前朝事用不观定、赵颜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，先生叹者何来？"
        },
        {
          "character": "管辂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请问小哥，家住哪里，姓字名谁？身背犁杖，要向何往？"
        },
        {
          "character": "赵颜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小子赵颜，奉了双亲之命，下田耕种。"
        },
        {
          "character": "管辂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我劝你休要耕种；急速回家，好酒好肉饱餐三天。"
        },
        {
          "character": "赵颜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生何出此言？"
        },
        {
          "character": "管辂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我看你气色不正，三日后你定夭寿而亡。"
        },
        {
          "character": "赵颜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，先生，我行路有影，痰嗽有声，怎见得我三日后必死？"
        },
        {
          "character": "管辂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小哥呀！"
        },
        {
          "character": "管辂",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "休道你行有影痰嗽有声，\n岂不知天有那不测风云？"
        },
        {
          "character": "赵颜",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "管先生说此话我却不信，\n哪有个平白的死了好人？"
        },
        {
          "character": "管辂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小哥！"
        },
        {
          "character": "管辂",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "劝小哥听此话休要不信，\n待贫道下位去观看无行。\n眉属木木生火枝叶凋零。\n三日后你必定命丧残生。"
        },
        {
          "character": "耳属金金不能生水半寸、口属水水已干犹如枯井、眼属火火无光不能生金、鼻属土土入陷死气已真、赵颜",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听他言不由我心神不定，\n背转身我这里自己思忖。\n三日后我不死有何为凭？"
        },
        {
          "character": "急忙忙向前去先生来问、管辂",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三日后你不死只管议论，\n如不然我和你去到公厅。\n任你羞任你辱任你施行。"
        },
        {
          "character": "再不然将我的卦棚拆损、赵颜",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听他言吓得我心意不定，\n想必是三日后要见阎君。\n见双亲把此话细说分明。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵颜下。）"
        },
        {
          "character": "管辂",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可叹他年少人大数已尽，"
        }
      ],
      "interactions": [
        {
          "edge": "赵颜→管辂",
          "turns": 8
        },
        {
