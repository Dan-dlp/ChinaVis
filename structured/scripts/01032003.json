    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "喽啰甲"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二喽啰同上。）"
        },
        {
          "character": "喽啰甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伙计，将才寨主吩咐啦，今天黄天霸前来探山，他山下必有余党，叫咱们千万"
        },
        {
          "character": "喽啰甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要留神呐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二喽啰同下。）"
        }
      ],
      "interactions": [],
