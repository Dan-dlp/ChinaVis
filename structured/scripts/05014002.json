          "style_family": null,
          "text": "（〖风入松〗。众人同下。刘备、孙权同上。）"
        },
        {
          "character": "刘备",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二马相骤驻马坡，"
        },
        {
          "character": "孙权",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一来一往争山河。"
        },
        {
          "character": "刘备",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一朝鼎足非小可，"
        },
        {
          "character": "孙权",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只恐目下动干戈。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备、孙权同杀。四下手、赵云同上，刘备跌，赵云斗孙权，孙权败下。）"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵云救驾！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，你是赵云！你保的好驾？"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方才孙权拔剑要害主公，若非为臣在此，主公一命休矣！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎吓！方才孙权面带杀气，拔剑斩孤，若不是赵云在此，险遭毒手。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵云，你我深入虎穴，难保无事。"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "以后有事无事，不可出宫。权居东阁，自有太后护庇。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将人马扯回馆驿！"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": "众将、四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马扯回馆驿！"
        },
        {
          "character": "四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖江儿水〗。众人同下。）"
        }
