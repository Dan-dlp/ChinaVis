          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（韦护上，冲场。用锣鼓下。内吹打。四金刚同舞上，同摆排齐门户。内打吹。十天王、四侍者、释迦牟尼、"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。释迦牟尼、文殊、普贤同入座。）"
        },
        {
          "character": "释迦牟尼",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "海裳春，卿云开处祥光袅。施慧眼，普天皆晓。"
        },
        {
          "character": "文殊",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "物阜与民安，海宇咸恩浩。"
        },
        {
          "character": "普贤",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "昨有散花仙女报道蓬岛奇葩开了，"
        },
        {
          "character": "普贤",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "试取众花来。齐贺升平兆。"
        },
        {
          "character": "释迦牟尼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃释迦摩尼佛是也。"
        },
        {
          "character": "文殊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃文殊是也。"
        },
        {
          "character": "普贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃普贤是也。"
        },
        {
          "character": "释迦牟尼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方今圣朝德政，国泰民安。恩膏遍及，仙岛均沾其惠。好太平景象也。"
        },
        {
          "character": "四侍者",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "阿弥陀佛。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（散花天女上。）"
        },
        {
          "character": "散花天女",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "天心永洽呈祥瑞，地发奇葩庆岁华。"
        },
        {
          "character": "散花天女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "散花女参见佛祖。昨奉敕旨，命众仙女在十州三岛，各取奇花献瑞。今在极乐"
        },
        {
          "character": "释迦牟尼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，就命尔率众仙女到极乐坛来者。"
        },
        {
          "character": "散花天女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领佛旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众仙女同上。）"
        },
        {
          "character": "众仙女",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "众仙女参见佛爷。"
        },
        {
          "character": "释迦牟尼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看——"
        },
        {
          "character": "释迦牟尼",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "花芳争艳现祯祥，预报皇家福运长。极乐坛前呈瑞色，万年千载暗生香。"
        },
        {
          "character": "释迦牟尼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "尔等到坛前庆贺圣寿无疆，然后试呈详瑞。"
