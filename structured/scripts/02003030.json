  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "众将",
        "如今落得刘备手",
        "字表元直徐门后",
        "既与玄德为好友",
        "曹操",
        "程昱"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将引曹操同上。）"
        },
        {
          "character": "曹操",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "执掌威权，收天下，文武英贤。"
        },
        {
          "character": "曹操",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "汉室江山气运终，群雄四方各争锋。老夫坐镇许昌地，搜罗天下众英雄。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫曹操，汉室为臣。只因曹仁、李典，失守樊城，闻得刘备军中有一单福划\n策，不免请程昱进帐，问明来历。\n来，请程谋士进帐。"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请程谋士进帐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程昱上。）"
        },
        {
          "character": "程昱",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "胸藏三坟五典，才能调将遣兵。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生少礼。请坐。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。唤卑人进帐，有何军情？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闻得刘备军中，有一单福划策。先生可知单福何人也？"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相容禀："
        },
        {
          "character": "程昱",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "单福家住在颍州，\n其中必有细根由：\n单名徐庶有名头。\n丞相兴兵实堪忧。"
        },
        {
          "character": "字表元直徐门后、如今落得刘备手、曹操",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "此人智高才量有，\n丞相我怜才早设计谋。\n要想收他我也无计求。"
        },
        {
          "character": "字表元直徐门后、如今落得刘备手、曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此人既与刘备相投，恐无外人能下手，真乃可惜了。"
        },
        {
          "character": "既与玄德为好友、程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相有心要用此人，却也不难。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卑人素闻徐庶极孝。只消丞相差人，将徐母赚至许昌，令其修书元直，谅无不\n来之理。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此计甚好。后堂摆宴，与先生同饮。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "众将→程昱",
          "turns": 1
        },
        {
          "edge": "程昱→曹操",
          "turns": 5
        },
        {
          "edge": "曹操→程昱",
          "turns": 4
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 8,
          "同白": 1,
          "念": 1,
          "白": 8,
          "唱": 1
        },
        "singing_ratio": 0.091,
        "dominant_style_family": "二黄",
        "musical_styles": [
          "二黄原板"
        ]
      }
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "徐母"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "闷坐草堂，自凄凉，怎不惨伤。"
        },
        {
          "character": "徐母",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "大儿四海访良朋，次子一命赴幽冥。可叹老身无伺奉，凄凉孤苦在家中。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老身，徐庶之母。所生二个孩儿：长子徐庶，在外访友；次子徐康，不幸身亡。\n撇下老身独守家中，好不伤感人也！"
        },
        {
          "character": "徐母",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "老身生来命不强，"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 5
        },
        "singing_ratio": 0.0,
        "dominant_style_family": "二黄",
        "musical_styles": [
          "二黄"
        ]
      }
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "家将",
        "徐母",
        "路人"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家将上。）"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "丞相差我颍州往，\n迎接徐母进许昌。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，曹府家将是也。奉丞相之命，迎接徐庶之母进京。就此马上加鞭。"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "催马加鞭朝前闯，\n抬头只见一村庄。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "借问一声，此地可有个徐老太太？"
        },
        {
          "character": "路人",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "哪个徐老太太？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐庶、徐康之母——徐老太太。"
        },
        {
          "character": "路人",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "前面合脊门楼便是。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢多谢。\n来此已是。\n徐老太太开门来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "门外有人把话讲，\n莫非徐庶转回乡。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母开门。）"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是哪里来的？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "京都来的。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到此则甚？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奉了我家主人之命，迎接徐老太太进京。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你可认识？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不相认。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老身正是。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是徐老太太。小人叩头。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不消。你奉何人所差？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人奉程大老爷与徐大老爷所差。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "程大老爷——他是何人？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我家老爷姓程名昱，与徐大老爷同殿为官，结拜弟兄。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他二人官居何职？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俱是议郎。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "因何接我进京？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位老爷，闻听徐二老爷亡故，恐老太太无人伺奉，特差小人接老太太进京，\n同享荣华。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可有书信？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无有。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为何无有书信？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "官差荣耀，修书不及。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此，备车辆伺候。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家将下。）"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好啊！"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我儿官居为议郎，"
        }
      ],
      "interactions": [
