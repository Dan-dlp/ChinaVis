    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "家将",
        "徐母"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家将上。）"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "门前备下车一辆，\n有请老太太上京城。"
        },
        {
          "character": "徐母",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "家将引路将车上，\n想起徐康两泪汪。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，儿啊。你哥哥接为娘进京享荣华，你是怎的不来？徐康，苦命儿啊啊……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母、家将同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "家将→徐母",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 4,
          "唱": 2,
          "内白": 1
        },
        "singing_ratio": 0.667,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮摇板"
        ]
      }
    },
    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "众将",
        "家将",
        "徐母",
        "曹操",
        "程昱"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将引曹操同上。）"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "各路烟尘起四方。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家将上。）"
        },
        {
          "character": "家将",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "相府门前住车辆，"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相在上，小人叩头。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐母可曾接到？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在府外。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命众将前去迎接。"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将同下。）"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "适才家将对我讲，"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "他说徐母到许昌。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将引徐母同上。）"
        },
        {
          "character": "徐母",
          "line_type": "唱",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "有劳将军列两旁。"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相有大事相商。"
        },
        {
          "character": "徐母",
          "line_type": "唱",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "旧理根由全不像，"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "太夫人到。"
        },
        {
          "character": "徐母",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "见了那曹丞相我细问端详。"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "徐母到。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "徐母",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "未见姣儿面，总然心不安。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相在上，老身万福。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太夫人少礼，请坐。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太夫人一路之上，多受风霜，身体可好？"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老身承问。请问丞相，我儿徐庶，他往哪里去了？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐元直现在新野。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但不知他在新野依佐何人？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在新野帮着谗臣刘备，如美玉陷在淤泥，明珠埋于尘垢。太夫人修书一封，招"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "徐元直本是一英豪，"
        },
        {
          "character": "徐母",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "此事其中有蹊跷。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我闻家将言道，我儿在朝，官居议郎之职。如今又命我修书招他，其中是何道"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恐太夫人不允前来，故言在京为官，以安太夫人之心。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来你等用的诡计！丞相，你知道刘备是何种人物？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他乃涿郡小辈，妄称皇叔，所谓外君子而内小人也。"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "老夫一番美言讲，"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听他言来心好恼，"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹丞相，我有几句言语，你且听了。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太夫人讲来。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老身久闻玄德乃中山靖王之后，孝景皇帝玄孙。屈身下士，恭己待人。义气传"
        },
        {
          "character": "徐母",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "刘备本是英雄将，"
        },
        {
          "character": "徐母",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "勒死了贵妃实可伤。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "老夫当朝一首相，"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住了！"
        },
        {
          "character": "徐母",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "听他言来气上闯，"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "击死奸贼赴无常。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母举砚向曹操掷去，未击中。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "反了啊！"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "人来与我上了绑，"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大胆恶妇，敢击打老夫。武士推出斩了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将押徐母同下，程昱上。）"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刀下留人。"
        },
        {
          "character": "程昱",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "将身且把二堂上，"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相因何将徐母斩首？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恶妇百般叫骂，故而将她斩首。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "斩了徐母，恐大事不利。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相若将她斩首，她子徐庶在彼，闻听此事，必然尽心相助刘备。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "依你之见？"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将她放回，派人侍奉，每天伺候。套她笔迹修书，差人送至新野。徐庶乃是大"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈，此计甚好。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "唱",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "欲借曹操帐下刀，"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹操，要杀就该开刀，为何又将老身放回，真真岂有此理！"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "非是老夫不杀于你，程先生言道，他与你子有八拜之交，斩了你，如斩他母亲"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "程先生为何多事？"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伯母啊！"
        },
        {
          "character": "程昱",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我与元直曾交好，"
        },
        {
          "character": "徐母",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "先生只顾将我保，"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生，将徐母小心伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操下。）"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "徐母",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "久闻曹操多奸诈，今日一见果不差。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伯母，随小侄来啊。"
        },
        {
          "character": "程昱",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母、程昱同下。）"
        }
      ],
