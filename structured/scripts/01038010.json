        },
        {
          "character": "一支虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "对战。"
        },
        {
          "character": "李自成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就命洪基儿对战，你看如何？"
        },
        {
          "character": "一支虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可以胜得过那周遇吉。"
        },
        {
          "character": "李自成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "旗牌过来，去到教坊，命李洪基带领数十万精兵，前去岱州，不得违误。"
        },
        {
          "character": "旗牌甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌甲下。）"
        },
        {
          "character": "李自成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我点动人马便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "李自成→一支虎",
          "turns": 3
        },
        {
          "edge": "一支虎→李自成",
