    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "周遇吉",
        "四上手"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四小军、四上手引周遇吉同上。）"
        },
        {
          "character": "周遇吉",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "手握兵符，镇守岱州，献威武，虎视耽耽，谁敢关前遇。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周遇吉坐高台。）"
        },
        {
          "character": "周遇吉",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "渺渺戈纹贯落星，长幡早已动高旌。丈夫鹊印摇边月，大将龙韬旧有声。"
        },
        {
          "character": "周遇吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本帅周遇吉。奉命镇守代州等处。可恨闯贼统领大兵，直压城下，他有一义子，"
        },
        {
          "character": "周遇吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "名叫李洪基，我又与他连战数阵。看他有败怯之心，眼见得生擒在我，怎奈"
        },
        {
          "character": "周遇吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他马骤如飞，不能擒获。探马报到，他又兴兵前来。今日与他交战。必定成功。"
        },
        {
          "character": "周遇吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔，众将官！"
        },
        {
          "character": "四上手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "周遇吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "与俺迎敌者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（金钱花） 旌旗云绕，迷漫迷漫，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "摆开阵势，城南城南。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "擒虎儿寸心丹，擒虎儿寸心丹。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "周遇吉→四上手",
          "turns": 1
        },
        {
          "edge": "四上手→周遇吉",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 5,
          "念": 1,
          "同白": 1,
          "白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
        0.0,
        0.125,
