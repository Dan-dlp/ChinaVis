    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "三兄弟家住有涿郡范阳",
        "关羽",
        "刘备",
        "孙庞斗智均都是英雄汉",
        "小弟我家住在蒲州解良",
        "张飞",
        "旗牌",
        "楚汉相争两国为难",
        "马童"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备上。）"
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄重相见，枯木又逢春。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌上。）"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二爷到。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽上。马童随上。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二弟！"
        },
        {
          "character": "关羽、刘备",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "（大哥）（二弟）呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（同哭相思） 弟兄徐州曾失散，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "今日古城又团圆。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请坐。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马童，见过大爷。"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "与大爷叩头。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一路劳乏，歇息去吧。"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "马童",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "行程多劳苦，今日才得安。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马童下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看宴来，待我与二弟把盏。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "折煞小弟了！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看酒！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（傍妆台牌。刘备、关羽同入座。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二弟在曹营一十二载，怎样逃出龙潭虎穴？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弟在曹营呵！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（侥侥令。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二弟请过来，受兄一拜。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "施礼为何？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在曹营受尽千辛万苦，保护二嫂，兄这里谢过。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "份内之事，理当效劳。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天时不早，安歇了吧！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥请便。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞上。）"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥！这个人情讲得怎么样了？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀呀！只顾与你二哥讲话，忘怀了。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！你怎么给忘了？好大哥，与小弟讲个人情去吧！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看你的造化如何。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我的造化是不错的。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二弟请上，受兄一全礼！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "施全礼为何？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三弟在城外得罪二弟，少时跪在你的面前，替兄教导于他。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小弟不敢。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打也打得。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小弟越发不敢。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弟遵命！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告便。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请便。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这个情讲得怎么样了？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你二哥性情不好，讲不下来，你自己去哀告去吧！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥随小弟一同进去。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太罗嗦了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备下。）"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我又罗嗦了！自家兄弟，我怕的什么，待我自己进去。哎呀呀，我的腿它倒打"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "起战来了！老腿呀，老腿！你不要害怕，有你张三爷作主，待咱老张溜了进去。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉，心中烦闷，待某看书解闷。"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "看古书看的是南北交战，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "似这样绝义厮杀，关某何须看它。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！想我在曹营一日，与二嫂三次问安，难道说，来到古城废却此礼不成？待"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我去到后面，问候二位皇嫂金安。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "楚汉相争两国为难"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孙庞斗智均都是英雄汉"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二哥！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何人在此？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "燕人翼德张飞。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我道何人，原来是张三爷！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢，张飞，张飞！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三将军！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小三，小三！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "跪在尘埃，为了何事？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得罪二哥，前来磕头赔礼。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自己弟兄，何出此言。三弟快快请起。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好个有仁有义的二哥哥！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯！好个张三爷，好个三将军！想当年，我弟兄有徐州失散，愚兄困于土山，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那曹操差去大将张辽，顺说愚兄降曹。兄宁死不降。皆因不知兄弟存亡，二嫂"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "失在下邳城中，无所依赖。兄万般无奈，与张辽约下三事，曹操件件应允。兄"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自进曹营，那曹操三日一小宴，五日一大宴，上马献金，下马献银，赠袍赐马，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待兄十分恩厚。兄在曹营，无一日不思兄，无一日不想弟。只因兄奉曹操将"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "令，统领人马，攻打汝南，在阵前得遇孙乾先生，言道大哥已在河北袁绍军中。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此事未辨真假，恐其有诈，兄回至许昌，闷闷不乐。忽然大哥使陈震先生前"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来下书，兄连辞曹操，回避高挂，不容相见。兄万般无奈，挂印封金，写柬辞"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹，保定二位皇嫂，过关斩将，远路而来。实指望来在古城，弟兄相见。三弟"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "见了愚兄，一言不发，提枪就刺。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二哥，你看我这一枪刺得好不好？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哼，你这一枪刺得不关紧要，险些弟南兄北，各自东西。古城楼上，你赐我三"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "通战鼓，十名小卒，蒙天护佑，我斩了蔡阳。若是斩不了蔡阳，我的性命，断"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "送你手。哎呀，似你这样不讲情义之人，还有什么桃园义气？话已讲明，我要"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回转蒲州去了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备暗上。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀二弟呀！三弟跪在你的面前，慢说结拜弟兄，就是一母同胞，也不过如此。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你来看，兄也跪下了！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥！"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "大哥哥家住在大树楼桑，"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "仁兄弟均都是汉室栋梁。"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "小弟我家住在蒲州解良"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "三兄弟家住有涿郡范阳"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "刘备"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "关羽"
        },
        {
          "character": "张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "望空一拜！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "桃园结拜义气同，乌牛白马祭苍空。"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "徐州失散古城会，"
        },
        {
          "character": "张飞",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "二哥可算大英雄！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥是英雄。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二弟、三弟均是英雄。"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，哈哈哈！请啊，哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞、关羽、刘备同下。）"
        }
      ],
