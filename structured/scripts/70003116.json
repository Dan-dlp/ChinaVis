    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "不愿意归降者赏银两",
        "关羽",
        "张飞",
        "旗牌乙",
        "旗牌甲",
        "马童",
        "龙套"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马童引关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "这一阵只杀得某力尽气衰，"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "险些的二弟兄厮杀起来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（雁鸣声。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔呼呀！原来大雁空中喧哗。当年我弟兄，在徐州失散，大雁空中喧哗，今日"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "古城相见，又来喧哗，真乃奇事也！"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "南来雁不住地当头叫，"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "只叫得关云长英雄心内好焦！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二旗牌同上。）"
        },
        {
          "character": "旗牌甲、旗牌乙",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哪位听事？"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "甚么人？"
        },
        {
          "character": "旗牌甲、旗牌乙",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "烦劳通禀，大爷差役求见。"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启二爷：大爷差人求见。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唤他们进来。"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。我家二爷唤你们，小心了！"
        },
        {
          "character": "旗牌甲、旗牌乙",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "是。与二爷叩头。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到此何事？"
        },
        {
          "character": "旗牌甲、旗牌乙",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "奉大爷之命，送来官袍带履，请二爷进城。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看衣更换。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽换衣。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你二人先行回去，我随后即至。"
        },
        {
          "character": "旗牌甲、旗牌乙",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二旗牌同下。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带路！"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "卸连环露出了绿袍甲胄，"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "大英雄今日里才得出头。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内呐喊声。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "是何处军卒们吵闹所为何由？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何处人马喧哗？"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何处人马在此喧哗？"
        },
        {
          "character": "龙套",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "蔡阳人马，无处投奔，故而在此喧哗。"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启二爷：蔡阳人马在此喧哗。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "愿降者开名上册，不愿降者，各自散去。"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "教他们愿降者开名上册，"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "叫他们各自逃生。"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "不愿意归降者赏银两"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "蔡阳人马听者！愿归降者，开名上册，不愿归降者，各自逃生去吧。"
        },
        {
          "character": "龙套",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "我们散去了！"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐过了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、张飞同上。）"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "作什么的？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "古城县令，带令人役，迎接二爷进城！"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "候着！"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "古城县令，带领人役，迎接二爷进城。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用，下去！"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用，下去！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上跪，上跪！"
        },
        {
          "character": "马童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他们跪上来了！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打了下去！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马童打张飞。）"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "狗仗人势！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞下，四青袍同随下。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带路！"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "军卒们将队伍且慢来摆，"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "关二爷一步一步儿走进了城来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马童、关羽同下。）"
        }
      ],
