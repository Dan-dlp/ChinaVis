          "text": "这一？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卸了甲胄，文职官员打扮。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这二件？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "头顶香盘，迎接你二哥进城。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这三件？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "跪在你二哥面前听他训教。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小弟件件依从。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好！快去改扮。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "旗牌！准备官袍带履，与二爷送去，就说备请他进城。"
        },
        {
          "character": "二旗牌",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二旗牌同下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "悲喜交加心方稳，且候二弟叙衷情。"
        }
      ],
