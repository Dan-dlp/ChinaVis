      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（浣纱女上。）"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "光阴似箭日月梭，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "人生在世奈如何。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "母女浣纱度日活。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "伍员 （内西皮导板） 豪杰打马奔吴国，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员上。）"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "龙离沧海虎离窝。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "令出山摇不敢挪。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "各国不敢动干戈。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "秦诓诸侯求讲和。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "不该倚强做媒约。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "见一位娘行浣纱罗。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "篮中有饭又有馍。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "娘行斋生念弥陀。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "樊城一呼人百诺"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "力举千斤伍明甫"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "天下英雄俱服我"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "只是我当初不知过"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "可叹我一家无有结果"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "行来觉得肚饥饿"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "下得马来把揖做"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "樊城一呼人百诺"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "力举千斤伍明甫"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天下英雄俱服我"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只是我当初不知过"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可叹我一家无有结果"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "行来觉得肚饥饿"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下得马来把揖做"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "眼观水底人影过，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "耳旁听得言语多。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "男女交谈是非多。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "樊城一呼人百诺"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "力举千斤伍明甫"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "天下英雄俱服我"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "只是我当初不知过"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "可叹我一家无有结果"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "行来觉得肚饥饿"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "下得马来把揖做"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军，听汝之言，敢是迷失路途。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "浣纱溪边谁问我"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "非也。行路之人，肚中饥饿，望求娘行周济一碗半碗充饥。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想我浣纱女三十未嫁，与寡母同居，哪有余食与将军充饥。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，娘行！在下乃是落难之人，娘行行个方便吧。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听你之言，亦非平常之人。请道其详。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此娘行听了。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "未曾开言我的心难过，"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "两眼不住泪如棱。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "我的父人称伍相国。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "父子三人保山河。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "可怜我一家大小三百余口见阎罗。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "穷途落魄受折磨。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "家住在楚国御皇阁"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "伍子胥，就是我"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "我的父谏奏反遭祸"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "只剩下子胥人一个"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家住在楚国御皇阁"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伍子胥，就是我"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我的父谏奏反遭祸"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只剩下子胥人一个"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "听罢言来珠泪落，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "忠臣孝子受折磨。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "免了奔波受饥饿。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "篮中有馍你用过"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "多谢娘行周济我，"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一饭千金不为多。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "将军打马忙走却，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "男女交谈理不合。"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "娘行一言提醒我，"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "句句言语记心窝。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员下。）"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "盖世英雄受折磨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员上。）"
        },
