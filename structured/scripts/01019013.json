      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵云上。）"
        },
        {
          "character": "赵云",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "老天无故困英雄，\n浅水怎能养蛟龙？\n大鹏展翅上苍穹。"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，赵云，袁绍帐下为将。可恨那厮目不识人，藐视英雄，不叫我出兵。是俺\n仍在这磐河牧马……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内喊声。）"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里人声呐喊？登高一望。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵云上高坡。公孙瓒上，袁绍、四龙套同追上。公孙瓒败下，袁绍、四龙套同追下。）"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住。前面败的公孙瓒，后面袁绍带兵追赶。看看落马，此时不救，等待何时？"
        }
      ],
