    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "公孙瓒",
        "报子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（公孙瓒上。）"
        },
        {
          "character": "公孙瓒",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "心惊肉跳，坐卧不宁。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启元帅：大事不好了！"
        },
        {
          "character": "公孙瓒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事惊慌？"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二老爷行至中途，被袁绍差人，假充马腾兵马，将二老爷乱箭射死了！"
        },
        {
          "character": "公孙瓒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你待怎讲？"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将二老爷射死了！"
        },
        {
          "character": "公孙瓒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不好了！"
        },
        {
          "character": "公孙瓒",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听一言来怒气生，\n大骂袁绍狗奸人。\n要与二弟报冤恨。"
        },
        {
          "character": "公孙瓒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐大小三军，全身披挂，校场伺候。掩门。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（公孙瓒下。报子下。）"
        }
      ],
      "interactions": [
        {
          "edge": "公孙瓒→报子",
          "turns": 3
        },
        {
          "edge": "报子→公孙瓒",
          "turns": 3
        }
      ],
