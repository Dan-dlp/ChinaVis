      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四接彩人甲同上。）"
        },
        {
          "character": "接彩人甲",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "春游芳草地，"
        },
        {
          "character": "接彩人乙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "夏赏绿荷池。"
        },
        {
          "character": "接彩人丙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "秋饮菊花酒，"
        },
        {
          "character": "接彩人丁",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "冬吟白雪诗。"
        },
        {
          "character": "接彩人甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "接彩人甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今当二月二日，王相府彩楼招婿，你我一同前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同走圆场，薛平贵随上，门官迎上。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们可是接彩的？"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "正是接彩的。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请进。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（接彩人甲、接彩人乙、接彩人丙同进门下。门官将接彩人丁、薛平贵拦住。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "干什么的？"
        },
        {
          "character": "接彩人丁、薛平贵",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "接彩的。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官向薛平贵。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "花郎也配接彩？不能进去。"
        },
        {
          "character": "接彩人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "对了。你不能进去，我进去。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你年纪太大了，接不得彩了。"
        },
        {
          "character": "接彩人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这个人可真是少见多怪。昔日姜太公八十而娶，我比他还小得多哪。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那也不准你进去。"
        },
        {
          "character": "接彩人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "真不让我进去？我这个人可有个怪脾气，要是不让我进去，我非进去不可！"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要是让你进去呢？"
        },
        {
          "character": "接彩人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那我倒不进去啦。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我来试验试验。我不让你进去！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵乘机进门下。）"
        },
        {
          "character": "接彩人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我偏要进去！"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我让你进去了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（接彩人丁进门。）"
        },
        {
          "character": "接彩人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢谢您啦！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（接彩人丁下。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叫他蒙进去了。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "远远望见三姑娘来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "王宝钏 （内西皮导板） 梳妆打扮出绣房，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟执彩球引王宝钏同上。）"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "在堂前辞别了二老爹娘。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "彩球打中平贵郎。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟、王宝钏同上楼。四接彩人、薛平贵同上。）"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "手扶着栏杆"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "看端详。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "也有那士农工商站立在两旁。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "倒叫我含羞带愧心内慌。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "低下头来用目望……"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "也有王孙公子样"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "老少人儿纷纷嚷"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "不要回去！"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "回府怎见二爹娘？"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "蓦地里见他在楼旁。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看彩球！"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "假意东抛反西向，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏举起彩球向远处虚抛，悄悄抛与薛平贵。）"
        },
        {
          "character": "四接彩人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "在这儿哪！在这儿哪！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵举球。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在这里呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵下。）"
        },
        {
          "character": "四接彩人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "咳！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（同西皮摇板） 彩球打中彩花郎。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四接彩人同下。）"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "耳边厢听得人喧嚷："
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "彩球打中讨饭郎。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "不由宝钏意彷徨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏下楼。丫鬟下。）"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "回府去禀告二老爹娘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏下。）"
        }
      ],
      "interactions": [
        {
          "edge": "接彩人甲→接彩人乙",
          "turns": 1
        },
        {
          "edge": "接彩人乙→接彩人丙",
          "turns": 1
        },
        {
          "edge": "接彩人丙→接彩人丁",
