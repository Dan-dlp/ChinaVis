      ]
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "四衙役",
        "捕头",
        "捕头副",
        "曹操",
        "门子",
        "陈宫"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四衙役、门子引陈宫同上。）"
        },
        {
          "character": "陈宫",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "身受皇恩，与黎民，判断冤情。"
        },
        {
          "character": "陈宫",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "头戴乌纱忠孝先，慈祥愷悌万民欢。嘉言犹如壶中地，德霈汪洋水底天。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本县姓陈名宫，字公台。幼年科甲出身。蒙主恩特授中牟县正印。前日接到董"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太师钧旨，上面写道：曹操相府行刺不成，惧罪脱逃。因此命各州县，画影图"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "形，捉拿刺客曹操。我也曾差王升等四门巡查，未见交签。今日升堂理事。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，伺候了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（捕头上。）"
        },
        {
          "character": "捕头",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "捉拿曹操事，报与太爷知。"
        },
        {
          "character": "捕头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太爷在上，小人叩头。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。"
        },
        {
          "character": "捕头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恭喜太爷，贺喜太爷！"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喜从何来？"
        },
        {
          "character": "捕头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹操被小人们拿获了。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有何为证？"
        },
        {
          "character": "捕头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有宝剑为证。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上来。"
        },
        {
          "character": "捕头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（陈宫接宝剑，细看。）"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自要尔等拿得不差，解进京去，俱有千金重赏。"
        },
        {
          "character": "捕头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人们不愿领赏，愿太爷禄位高升。"
        },
        {
          "character": "陈宫",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈！"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "官升隶赏，分所当然。吩咐将刺客曹操，押上堂来。"
        },
        {
          "character": "捕头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伙计们，将曹操押上堂来。"
        },
        {
          "character": "捕头副",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（捕头副押曹操同上。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "跳龙潭出虎穴逃灾避祸，"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "又谁知中牟县又入网罗。"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "看陈宫他把我怎样发落。"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "怒冲冲站立在滴水檐过"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "曹孟德进衙来齐声威喝，"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "书吏们站两旁虎占山坡。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "见本县不下跪却是为何？"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "怒冲冲站立在滴水檐过"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下站可是曹操？"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "观刺客面貌上带定凶恶"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既知我名，何必动问？"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "见了本县，为何不跪？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我这双金膝，上跪天子，下跪父母，岂肯跪你这小小县令？"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂不知王子犯法，与民同罪。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我身犯何法？"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你行刺董太师，还说无罪？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我行刺董太师，可是你亲眼得见？"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "虽非亲眼得见，现有董太师钧旨，捉拿于你，还敢强辩不成？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "听他言吓得我心似刀割，"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "心问口口问心自己揣摩。"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "管叫他弃县令随我逃脱。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公台，你可知朝中谁忠谁奸？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "说几句巧言语将他哄过"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我在廉外为官，怎知朝中之事？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "却又来！"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "你本是外省官怎知朝歌，"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "哪知道董卓贼奸雄作恶？"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "满朝中文共武木雕泥塑。"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "一心要谋取那汉室山河。"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "细思量董卓贼奸恶如何？"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "刺死了丁建阳文武胆破"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "到如今收吕布作事太错"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "我看你做的事广有才学"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺死了丁建阳文武胆破"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到如今收吕布作事太错"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我看你做的事广有才学"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "曹孟德休得要谤毁董卓，"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "董太师他倒有治国的韬略。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "十常侍乱宫门扫荡群魔。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "传将令好一似山倒海落。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "又好比抢食鱼你自投网罗。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "既擒虎焉能够放虎归窝？"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "擒虎易放虎难你自去揣摩。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "破黄巾虽无功却也无过"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "收下了吕奉先威镇海角"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "你好比扑灯蛾自来投火"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "你本是出山虎把路来投错"
        },
        {
          "character": "陈宫",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "擒住了你反放你必来伤我"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "你将我解进京献与董卓，"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "那时节见太师自有话说："
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "管叫你遍体排牙难以分说！"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "刺董卓是陈宫修书与我"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺董卓是陈宫修书与我"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "听他言吓得我双眉皱锁，"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "这件事倒叫我无可奈何。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "若不放又恐怕惹出风波。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "刺董卓是陈宫修书与我"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，有了！"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刺董卓是陈宫修书与我"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "学苏秦放张仪计上心窝。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "就放你也说个言投意合。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "若放他只恐怕罪归于我"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "思一思想一想无计安妥"
        },
        {
          "character": "陈宫",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "既被拿放不放全凭于我"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "陈公台说此话真个软弱，"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "小县令怎能够名标烟阁？"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "约诸侯带人马杀进朝歌。"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "管叫你换朝衣封官受爵。"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "细思量想一想心下如何？"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "依我劝弃县令随定与我"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "到那时灭谗臣除奸剿恶"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "陈公台人道你才似王佐"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "曹孟德出此言如梦初觉，"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "七品县岂不负经纶才学。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "奔天下约诸侯重整朝歌。"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "倒不如弃县令从你入伙"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "下位来与明公亲解扭锁"
        },
        {
          "character": "四衙役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "衙役们且退避也有发落。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四衙役、捕头、捕头副同下。）"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "手挽手与明公二堂内坐，"
        },
        {
          "character": "陈宫",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "驾光临少奉迎望乞恕却。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明公到此，衙役们得罪，望乞宽恕。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢。多蒙释放，日后必当重报！"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "久闻明公献剑为名，刺杀董卓。天意不随，今欲何往？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我有意奔走天涯，颁来五路诸侯，灭却董卓。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官有意随同明公，奔走天涯，不知意下如何？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若得公台同去便好。只是连累宝眷不便。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不妨。老母、妻子，俱在东郡。仆人、使女，不在衙署。料无妨碍。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既然如此，事不宜迟，你我连夜出城，以遮百姓耳目。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请至书房待茶。下官料理公案，即便同行。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "暂且告别。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操下。）"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少刻奉陪。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来！"
        },
        {
          "character": "门子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将印信付与右堂代管。说老爷领了上司公文，下乡查旱，多则十日，少则一日"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就回。你附耳上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门子附耳听，点头。）"
        },
        {
          "character": "陈宫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "备马伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门子、陈宫同下。）"
        }
      ],
