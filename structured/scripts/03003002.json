    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "众人",
        "匡罢",
        "朝官丙",
        "朝官乙",
        "朝官甲",
        "李广",
        "辽太"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（辽太、匡罢、四朝官率四北兵摆对子同上。李广、李虎率四龙套同上。相见行礼。众人同下，同上。）"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国主请上，李广参拜！"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢！"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "焉有不拜之理？"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这就不敢！大人请坐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（辽太、李广同坐。）"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不知大人驾到，未曾远迎，望乞恕罪！"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢！少来问候国主金安，望乞海涵。"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我主龙驾可安？"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我主安泰。"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "满朝文武可好？"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俱有书信手本问候国主金安。"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳他们。"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "宴齐！"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看宴来！"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两厢摆宴，款待天使。"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人请！"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国主请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。众人同坐。）"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请问国主，从前原许年年进贡，岁岁来朝，至今三载无宝奉上，是何理也？"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人哪！"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "未曾开言珠泪涌，"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尊一声大人听详情："
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "黎民百姓受苦穷。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宽限几载朝见主公。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大旱三载灾荒重"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "望大人回朝把本动"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "国主说话理不通，"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "李广言来听分明："
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "要夺我主锦疆洪。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只杀得你国计皆穷。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "每岁来朝见主公。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "情理二字实难容。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "从前不该刀兵动"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我国兵多将又勇"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "原许下年年把宝奉"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到如今三载未进贡"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大人说话言语重，"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "羞得孤王脸通红。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尊声大人听心中："
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一路之上受霜风。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "能解百毒妙无穷。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "全仗大人多宽容。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "望大人笑纳饮几盅。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "下位来我把好言奉"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有劳你千里迢迢来催贡"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "避毒仙帕来相送"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "此宝并非将王送"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "自古道礼轻人意重"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "谢过国主把宝赠，"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "李广言来听分明："
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "圣命在身难依从。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "非是我李广不肯应"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤王传旨山岳动，"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "两班文武听心中："
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "每人奉敬酒一盅。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "天朝大人来催贡"
        },
        {
          "character": "匡罢",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "匡罢进前好言奉，"
        },
        {
          "character": "朝官甲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尊声大人听详情："
        },
        {
          "character": "朝官乙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我国无有别的奉，"
        },
        {
          "character": "朝官丙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "每人奉敬酒一盅。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他君臣全是好言奉，"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "个个脸上带笑容。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宽限几载也可容。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "国主宽怀免愁容。"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国主！宽你三年，以后年年进贡，岁岁来朝。"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只要他不把刀兵动"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下位来我把好言奉"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人开了天地之恩，俺君臣感恩不浅。"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺、告辞了！"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！就在我国宽住几日，这有何妨？"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣命在身，难以久停。"
        },
        {
          "character": "辽太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人留步！孤有一言，转奉天朝。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "深感天朝恩泽广，"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三呼万岁口称王。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但愿主亚赛尧舜王。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "愿效犬马报君王。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但愿各国宝进上"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "倘若哪国敢犯上"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "国主但把宽心放，"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你本是北海有道王。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宽限几载见君王。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我主降罪俺李广承当。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李广率李虎、四龙套同下。）"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "天朝来了李广将，"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "仪貌堂堂杀气昂。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "忠心耿耿世无双。"
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤王言来听端详："
        },
        {
          "character": "辽太",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "各守疆界乐安康。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
