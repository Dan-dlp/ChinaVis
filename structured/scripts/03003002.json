    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "李广"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、李广、李虎同上。）"
        },
        {
          "character": "李广",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "李广打马出皇朝，"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "对对旌旗空中飘。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "要夺我主九龙朝。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只杀得他国无处逃。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "每岁进在我国朝。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "龙颜大怒将我召。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "命本爵催贡到他朝。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "黎民百姓远脱逃。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "树无枝叶草无苗。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大小三军听根苗："
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "恩威并用去服辽。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宽限几载转回朝；"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "就在他国动枪刀。"
        },
        {
          "character": "李广",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我看辽太怎开消！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
