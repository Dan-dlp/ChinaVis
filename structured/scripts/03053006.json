        {
          "character": "八小妖",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有！"
        },
        {
          "character": "大妖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看包拯陈州放粮回来，打此经过。趁此机会，你等变作王朝、马汉等模样，待"
        },
        {
          "character": "大妖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我看来！"
        },
        {
          "character": "八小妖",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "好，闪开了！"
        },
        {
          "character": "八小妖",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "运动法力摇身变，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（火彩，八小妖同下，假四青袍、假王朝、假马汉、假张龙、假赵虎同上。）"
        },
        {
          "character": "假四青袍、假王朝、假马汉、假张龙、假赵虎妖",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "就请大仙仔细观。"
        },
        {
          "character": "假四青袍、假王朝、假马汉、假张龙、假赵虎妖",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大仙，看我等变得可像？"
        },
        {
          "character": "大妖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "变得倒也不错。"
        },
        {
          "character": "假四青袍、假王朝、假马汉、假张龙、假赵虎妖",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大仙变来，我等观看。"
        },
        {
          "character": "大妖",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你等闪开了！"
        },
        {
          "character": "大妖",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "摇身一变金光绕！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（火彩，大妖下，假包拯上。）"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "假变包拯乐逍遥。"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "个个小心莫辞劳。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同走圆场，假包拯坐。）"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "带上了二施信细问恨苗。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（施信、假施信同上。）"
        },
        {
          "character": "施信、假施信",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见大人！"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你叫什么名字？"
        },
        {
          "character": "施信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人名叫施信。"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你叫什么名字？"
        },
        {
          "character": "假施信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人名叫施信。"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你二人谁是真的，谁是假的？从实招来！"
        },
        {
          "character": "施信、假施信",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我是真的，他是假的。"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住了！"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听罢言来心头恼，"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "敢在开封欺老包。"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "真施信！"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "赐你皮鞭将他拷！"
        },
        {
          "character": "假施信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（假施信打施信。）"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看他承招不承招？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内鸣锣。四青袍、王朝、马汉、张龙、赵虎引包拯同上。）"
        },
        {
          "character": "包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "来在开封下了轿，"
        },
        {
          "character": "包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一见妖魔怒冲霄。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！何方妖怪，敢坐老夫的法堂？"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！何方妖怪，敢来老夫的法堂？"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谁不知龙图阁大学士断事如神？劝你本早现了原形便罢；如若不然，可知老夫"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "照妖镜的厉害！"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谁不知龙图阁大学士断事如神？劝你早早现了原形便罢；如若不然，可知老夫"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "照妖镜的厉害！"
        },
        {
          "character": "包拯、假包拯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "王朝、马汉，看照妖镜伺候！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王朝、马汉同取照妖镜，假包拯喷照妖镜。）"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！老夫照妖镜百照百准，今日为何照不出他的原形来了？"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！老夫照妖镜百照百准，今日为何照不出他的原形来了？"
        },
        {
          "character": "包拯、假包拯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "王朝、马汉，照妖镜收起！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王朝、马汉同收照妖镜。）"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "反了哇！"
        },
        {
          "character": "假包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "反了哇！"
        },
        {
          "character": "包拯、假包拯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "反了！"
        },
        {
          "character": "包拯、假包拯",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "不由老夫心头恼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖四击头〗。）"
        },
        {
          "character": "包拯、假包拯",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯！"
        },
        {
          "character": "包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大宋朝又出了二老包。"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大宋朝又出了二老包。"
        },
        {
          "character": "包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老夫的威名谁人不晓？"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老夫的威名谁人不晓？"
        },
        {
          "character": "包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尔竟敢在开封府假变臣僚！"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尔竟敢在开封府假变臣僚！"
        },
        {
          "character": "包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我劝你早把那原形现了，"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我劝你早把那原形现了，"
        },
        {
          "character": "包拯、假包拯",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "少有迟延尔的命难逃！"
        },
        {
          "character": "包公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "妖魔胆量真不小，"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "敢与老夫絮叨叨？"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尔竟敢搅扰开封变臣僚！"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "真假老包不差半分毫。"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "今日照不出他原形为哪条？"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这件事，怎样了？"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只气得包拯怒发冲冠气难消。"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "王朝与爷你就忙焚表！"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "俺包拯赤胆忠心君王保"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这真老包，假老包"
        },
        {
          "character": "包公",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "照妖镜，是法宝"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喳！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯下。王朝焚表。）"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一见焚表心内焦。"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我的性命难保牢。"
        },
        {
          "character": "假包拯",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回洞去搬来了众弟妹，齐心努力与他闹糟糕。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（假包拯、假四青袍、假王朝、假马汉、假张龙、假赵虎同下。〖急急风〗。众天兵引天神同上。）"
        },
        {
          "character": "天神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "差官请了！"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "天神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我等奉了天师之命，前来相助。"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妖魔搅闹开封，请尊神降妖。"
        },
        {
          "character": "天神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "差官禀知包大人，我等降妖者！"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳尊神！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王朝下。）"
        },
        {
          "character": "天神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众天兵，追赶妖魔去者！"
        },
        {
          "character": "众天兵",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
