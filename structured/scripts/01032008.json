        0.4545,
        0.0
      ]
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "又谁知马悲鸣爱姬留恋",
        "妾心愿纵然到海枯石烂",
        "我有心放了你且回乡转",
        "樊素",
        "满目愁云霎时散",
        "白居易",
        "院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（白居易上。）"
        },
        {
          "character": "白居易",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "叹人生在世间如霜如电，"
        },
        {
          "character": "白居易",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "有富贵和贫穷皆如是观。"
        },
        {
          "character": "白居易",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "到如今鬓发白兴趣萧然。"
        },
        {
          "character": "白居易",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "衰朽年病身躯能活几年！"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫白居易，表字乐天，太原人氏，唐室驾前为臣。初为翰苑词臣，历官太子"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太傅，沉浮宦海，四十余年。老夫今年已六十八岁，春蚕已老，蜡炬将灰。是"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾致仕归里，虽然悠游自得，诗酒娱情倒也快乐。只奈近年，又患风痺之症，"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "更觉老态龙钟。想吾的爱姬樊素，正在芳年，虽则两情眷爱，朝暮难离，倘若"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫一朝不测，岂不耽误了她的青春？仔细思量，倒不如开笼放鸟，使她另择"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "佳偶，倒是一桩好事。还有裴令公，赠吾那一骑骆马，代步多年，留它何用。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "倒不如将它卖去，以省刍秣之资，岂不是好？正是："
        },
        {
          "character": "白居易",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "落花有意随流水，流水无情恋落花。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子捧茶上。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请老爷用茶。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "院子。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "去至后堂，将素姬唤来见我。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转来。再到厩中，将骆马牵来。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子转身望上场门。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看素娘已分花拂柳而来。待我唤她一声。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，素娘，老爷叫你到书房讲话。"
        },
        {
          "character": "樊素",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "来了。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待吾到槽头牵马去者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子下。樊素上。）"
        },
        {
          "character": "樊素",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听说是老太傅将奴呼唤，"
        },
        {
          "character": "樊素",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "急忙间移莲步去问根源。"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷万福。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告坐。请问老爷，今日身体可好？"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳！吾乃老病之身，还讲些什么好与不好？也不过是待死而已。吓素姬，你自"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "入府以来，随侍老夫，有几年了？"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将次十年了。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看老夫日来心烦意乱，你乃是聪明伶俐之人，可晓得老夫的心事？"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴见老爷这几日常常愁闷，正在狐疑。不知老爷，到底有何心事。妾身愚蠢，"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "实难猜透。望老爷说个明白。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳，素姬呀！"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叹人生在世上如同梦幻，"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "哪有这百年间不散的华筵。"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "寻一个美满姻缘过上几年，嗳嗳嗳，过上几年。"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我有心放了你且回乡转"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷此话，从何说起？"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想老夫衰病残年，不能久于尘世。念你正在芳年，随同老夫，岂不耽误了你的"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "终身。吾意欲放你归去，另配良缘，也不枉你跟随老夫一场。"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷说哪里话来。想妾身自奉巾栉，并无过犯。仰蒙老爷，十分宠爱，正在无"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恩可报。况堂堂尚书之府，难道说就容不得妾身一人？嗳呀老爷呀，我樊素生"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是白府人，死是白府鬼。就是粉身碎骨，理所当然。若叫妾身另行改嫁，是断"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "断不能从命的呀，吓吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（樊素跪哭。）"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "素姬！"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷！"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗳，樊素吓！"
        },
        {
          "character": "白居易",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "劝爱姬休得要泪流满面，"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "樊素！"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷！"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爱姬！"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "主君！"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我那多情的素姬呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（回龙） 叫一声多情姬细听我言："
        },
        {
          "character": "白居易",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "非是我把恩情一旦割断，"
        },
        {
          "character": "白居易",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "怕的是耽误你美貌芳年。"
        },
        {
          "character": "白居易",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "出府去寻良匹另配良缘。"
        },
        {
          "character": "白居易",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "好一似沾泥絮莫再纠缠。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子牵马上。）"
        },
        {
          "character": "院子",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "纵出黄金价，难求千里驹。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我将马拴在栏杆之外。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启老爷：骆马牵到。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "素姬，随老夫同去看来。"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾身遵命。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你看此马，赭流朱汗，竹耳霜蹄，锡鸾腾躣于康庄，房驷昭回于云汉。但是你"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "口齿未老，吾的筋力已衰。世间自有阴阳，哪怕不得识主。今日老夫，致仕归"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "田，无力养豢于你，要将你卖于他人，你好好另事新主去罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马悲鸣连三。）"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，老爷，你看着骆马蒙你乘骑多年，今日你要将它变卖，它竟不住悲鸣，深"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "深恋主，不忍舍去之意。马尚如此，人岂无情？想我樊素，服侍老爷一场，蒙"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你十分眷爱，难道我反倒不如那牲畜么？事已至此，我实对老爷说了罢！老爷"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在一日，妾身便服侍你一日；老爷倘有不测，妾身一死，相从地下。耿耿此心，"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天日可鉴。咳，老爷呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（胡琴多罗起顶板。）"
        },
        {
          "character": "樊素",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "说什么人在世如同梦幻，"
        },
        {
          "character": "樊素",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "说什么耽误了美貌芳年。"
        },
        {
          "character": "樊素",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "侍巾栉同衾枕永不变迁。"
        },
        {
          "character": "樊素",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "妾心愿纵然到海枯石烂"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，老爷，看这骆马同素娘，都是相依数载，同受恩养。今日恋恋，皆有不忍"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "舍去之心。又听素娘一片言语，情词恳切，叫老奴也肝肠痛断，心似箭攒。望"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "求老爷开恩，仍将素娘同骆马留下了罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子哭。马鸣。樊素哭。）"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呵！"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "白乐天我本是慈心一片，"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "怕的是辜负了良马、红颜。"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "此时间反叫我意惹情牵。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢，既然如此，也就罢了。"
        },
        {
          "character": "白居易",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "骆马且莫嘶，素姬也免悲。汝等不我弃，彼此仍相依。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家院，将马仍旧牵至后槽，要多加草料。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "又谁知马悲鸣爱姬留恋"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子牵马下。）"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想老夫只为此事，踌躇多日。不料今日，竟将满腹的愁烦，竟自到冰消雪化了。"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷既然免却了愁烦，待妾身捧巵进酒，与老爷解闷。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好。老夫生受你几杯。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家院，看酒！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子捧酒，樊素接，斟三杯。笛吹柳叶锦牌。白居易连饮三杯。）"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "素姬，你把那杨柳枝词，与老夫歌上一曲。"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾身遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吹笛。）"
        },
        {
          "character": "樊素",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一树春风万万枝，"
        },
        {
          "character": "樊素",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "嫩于金色软于丝。"
        },
        {
          "character": "樊素",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尽日无人属阿谁。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（白居易笑。）"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "清歌流丽如莺啭，"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "不愧玉润与珠圆。"
        },
        {
          "character": "白居易",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "打起精神且寻欢。"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自今以后，老夫倒愿……"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "满目愁云霎时散"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷你愿什么？"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我与你——"
        },
        {
          "character": "白居易",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "在天愿作比翼鸟，在地愿为连理枝。天长地久有时尽，相爱相偎永不离。"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好一个相爱相偎永不离。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（白居易、樊素同笑。）"
        },
        {
          "character": "樊素",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷，今日园中芍药盛开，何不前去赏玩？"
        },
        {
          "character": "白居易",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫正要前去赏玩。素姬，随老夫来呀。哈哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（白居易、樊素同挽手下。）"
        }
      ],
