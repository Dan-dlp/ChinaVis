      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监同上，高力士上。设祭堂。）"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请万岁！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唐明皇上。）"
        },
        {
          "character": "唐明皇",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "定情钿盒今犹在，\n长生密誓记心怀。\n这才是伯劳飞燕两分开。\n我前度刘郎今又来。"
        },
        {
          "character": "冤怨缘三字孤不解、看天台犹是人不在、高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启万岁：杨娘娘坟茔，已经打扫洁净了。"
        },
        {
          "character": "唐明皇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待孤拈香。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖哭皇天〗。）"
        },
        {
          "character": "唐明皇",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "贵妃！梓童！咳，卿家吓！"
        },
        {
          "character": "唐明皇",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "见坟台不由人泪如雨下，"
        },
        {
          "character": "唐明皇",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "贵妃！梓童！爱卿吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（顶板回龙） 尊一声杨贵妃，杨玉环，孤的爱卿，在夜台下，九泉间，一件件，一桩桩，细"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "听根芽："
        },
        {
          "character": "唐明皇",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "想当初孤坐的风流天下，\n重国色慕倾城运走桃花。\n压六宫冠粉黛绝世才华。\n连理枝比翼鸟并带莲花。\n破潼关扫河北直抵京华。\n幸西蜀为的是有情冤家。\n最可恨这六军按兵不发。\n孤忙问尔六军因何驻马？\n扬言道杀兄妹六军才发。\n卿家吓！\n红颜女变作了白骨黄沙。\n酒醉后闭月羞花；\n可怜你今日里玉损桃花。\n倒叫孤空辜负恩宠独加。\n身不能庇一女辜负名花。\n夜台下谁怜你少妇无家。\n国乱时权在臣不在官家。\n卿家吓！"
        },
        {
          "character": "为娇容孤也曾求遍风雅、七月七长生殿花前月下、早不幸安禄山渔阳杀驾、无奈何且迁都起了銮驾、离都门路不远马嵬坡下、叹贵妃死在这尺组之下、可怜你霓裳舞独擅风雅、可怜你洗儿钱空空挣下、谢秋波止不转百媚无价、唐天宝空坐了一朝天下、卿一死且莫要将孤咒骂、朕负卿并非是卿负陛下、李三郎只哭得泪如雨下，泪如雨下、高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁不可过伤，务宜保重圣体要紧。"
        },
        {
          "character": "唐明皇",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "高力士捧金爵酒祭香插。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。祭奠已毕，请万岁上马回銮。"
        },
        {
          "character": "唐明皇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高力士，带马。"
        },
        {
          "character": "唐明皇",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "陈元礼奏一本催孤起驾，\n浩荡荡领人马直奔金华。\n要相逢除非是梦里天涯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
