          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唐明皇下山。）"
        },
        {
          "character": "唐明皇",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "雨霁风消寒夜冷，\n人马浩荡转帝京。"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前面人马为何不进？"
        },
        {
          "character": "四龙套、四大铠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是马嵬坡了。"
        },
        {
          "character": "唐明皇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高力士，来此什么所在？"
        },
        {
          "character": "高力士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是马嵬坡。"
        },
        {
          "character": "唐明皇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "唐明皇",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "听说来到马嵬坡，"
        },
        {
          "character": "唐明皇",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "点点珠泪似滂沱。\n满腹酸辛可奈何。"
        },
        {
          "character": "唐明皇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍，吩咐外面预备清香白酒，到贵妃娘娘坟前一祭，卿表寸心。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
