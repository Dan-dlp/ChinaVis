      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺仁杰、王殿臣同上。）"
        },
        {
          "character": "贺仁杰、王殿臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俺——"
        },
        {
          "character": "贺仁杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贺仁杰。"
        },
        {
          "character": "王殿臣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "王殿臣。"
        },
        {
          "character": "贺仁杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。你我二人，私访恶霸，就此走遭也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺仁杰、王殿臣同下。）"
        }
      ],
      "interactions": [
