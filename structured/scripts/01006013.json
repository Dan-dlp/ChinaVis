    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "二宫女",
        "吴国太",
        "孙尚香"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女引吴国太同上。）"
        },
        {
          "character": "吴国太",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "恨的是陆伯言智足谋广，"
        },
        {
          "character": "吴国太",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "火攻计烧连营鸡犬难藏。"
        },
        {
          "character": "吴国太",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "尚香在吴国内未离兰房。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女同下。）"
        },
        {
          "character": "吴国太",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "闷恹恹只想我幼女尚香。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香上。）"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "在生前常出进宫人随往，"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "今见母孤单单躲躲藏藏。"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "跪御榻音声细忍住凄惶。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后醒来！"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "欲开言老年人心散神恍"
        },
        {
          "character": "吴国太",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "空负我数十年儿女娇养，"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎吓！"
        },
        {
          "character": "吴国太",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听姣音真是我幼女尚香。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "孙尚香 （回龙） 人命大关系重岂能谎谈。"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "尽节死阴灵魂水府路上，"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "未报答哺乳恩难舍亲娘。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓！"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "听儿言似空中霹雳下降，"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "娘好似燕衔泥枉费心肠。"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "甘露寺娘见面相儿招夫郎。"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "今尽节不尽孝娘谁供养？"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为荆州献儿计恨你兄长"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "老娘亲缺甘旨还有兄王。"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "儿不是枭鸟心天大仓娘。"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "尽节烈以图了后人钦仰"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "古今来女生时面生外向，"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "但不知儿尸首漂流何方？"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "寻着你尸和首好去奔丧。"
        },
        {
          "character": "吴国太",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "阴灵魂既见娘直言话讲"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "儿的尸向西方逆水漂上，"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "蒙上帝敕封我孝姬娘娘。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，儿封为孝姬娘娘？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿的尸首呢？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后。"
        },
        {
          "character": "孙尚香",
          "line_type": "反二黄原板",
          "musical_style": "反二黄原板",
          "style_family": "二黄",
