          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "郡主投江已死！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你才怎讲？"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "郡主投江而亡！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎吓！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "儿为夫尽节死鱼肠埋葬，"
        },
        {
          "character": "吴国太",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "尚香！我儿！哎儿吓！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "比前朝汉昭君不舍刘王。"
        },
        {
          "character": "吴国太",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "恐难效孟姜女受职表扬。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内臣，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大太监允。）"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "郡主投江，可有人搭救？"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "难以救起。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "报与主公知道。"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大太监下。）"
        },
        {
          "character": "吴国太",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "尚香！我儿！儿吓！"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为娘若知你有此尽节之心，我也不要你江边祭奠去了吓！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "要尽节也应该对娘直讲，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "讨祭奠投江死魂灵渺茫。"
        },
        {
          "character": "吴国太",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓！"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "宫娥们扶本后即归龙床。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女搀吴国太同下。）"
        }
      ],
      "interactions": [
