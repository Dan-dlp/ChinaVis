      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二门神同上。）"
        },
        {
          "character": "门神甲",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "上苍有旨意，"
        },
        {
          "character": "门神乙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "看守宫门庭。"
        },
        {
          "character": "门神乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "门神甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "门神乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奉了玉帝敕旨，看守宫门。远远望见，孙氏尚香来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套引孙尚香同上。）"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "水晶宫与阳间一般模样，"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "也有这银銮殿画角雕梁。"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "比不得水府内任儿猖狂。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "尊神请了。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众神将且肃静休要声嚷"
        },
        {
          "character": "二门神",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "到此何事？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "尊神吓！"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "奴虽受玉帝封魂魄飘荡，"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "哪一处是我的神位庙堂？"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "托一兆不久停即出宫墙。"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "乘夜来见我母待求方向"
        },
        {
          "character": "二门神",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "只许你一人进去，休要惊吓于她。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "知道了。"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你等在宫门外隐身休闯，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同下。）"
        },
        {
          "character": "孙尚香",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "二尊神请让路暂息张扬。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香下。二门神同下。）"
        }
      ],
