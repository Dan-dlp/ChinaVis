      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（花荣、林冲、燕青、李逵同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "众人 （同吹腔） 忙忙逃出神州去，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "遥望梁山，转回还。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四下手、四家将、王宏同追上。）"
        },
        {
          "character": "王宏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔，贼寇休走，俺来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（起打。花荣、林冲、燕青、李逵同败下，王宏、众人同追下。）"
        }
