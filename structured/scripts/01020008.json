          "musical_style": null,
          "style_family": null,
          "text": "（四上手、秦明、王英、顾大嫂、孙二娘、扈三娘同上。）"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，"
        },
        {
          "character": "秦明",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "霹雳火秦明，"
        },
        {
          "character": "王英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "矮脚虎王英，"
        },
        {
          "character": "顾大嫂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母大虫顾大嫂，"
        },
        {
          "character": "孙二娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母夜叉孙二娘，"
        },
        {
          "character": "扈三娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一丈青扈三娘。"
        },
        {
          "character": "秦明",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "秦明",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我奉了军师将令，暗地保护燕青众兄弟。前面杀声震耳，想是官军追来，你"
        },
        {
          "character": "秦明",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我一同前去帮助。"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（群场会阵。众人同上，起打，众人同败下，王宏追下。）"
        }
