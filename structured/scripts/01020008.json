    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "探子",
        "王宏"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四下手、四家将、王宏同上。）"
        },
        {
          "character": "王宏",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "剑戟霜寒，冲冠气岸，长虹贯，立志除奸，霎时风云变。"
        },
        {
          "character": "王宏",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "剑气冲开斗牛光，刀枪耀日落星霜。踏平水泊擒晁盖，踢破梁山捉宋江。"
        },
        {
          "character": "王宏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本镇，王宏。也曾命任原摆下擂台。今已打了九十九擂，只有一擂未满。待等"
        },
        {
          "character": "王宏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "完满，就授他为先锋之职，起兵攻打梁山。"
        },
        {
          "character": "王宏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "左右，伺候了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子上。）"
        },
        {
          "character": "探子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀元帅：任将军被梁山贼寇打死了。"
        },
        {
          "character": "王宏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子下。）"
        },
        {
          "character": "王宏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，一齐追赶！"
        },
        {
          "character": "王宏",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "任他轴走上焰魔天，"
        },
        {
          "character": "王宏",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "我铁骑如云赶上前。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "探子→王宏",
          "turns": 1
        }
      ],
