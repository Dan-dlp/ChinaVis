      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐彦昭、杨溥、马子千、杨太同上。）"
        },
        {
          "character": "徐彦昭",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "为国尽忠义，"
        },
        {
          "character": "杨溥",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "昼夜常挂心。"
        },
        {
          "character": "马子千",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "吃王君上俸，"
        },
        {
          "character": "杨太",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "最要早报恩。"
        },
        {
          "character": "徐彦昭、杨溥、马子千、杨太",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俺——"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "定国公徐彦昭。"
        },
        {
          "character": "杨溥",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "蒲州杨溥。"
        },
        {
          "character": "马子千",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马子千。"
        },
        {
          "character": "杨太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨太。"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大人请了。"
        },
        {
          "character": "杨溥、马子千、杨太",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今逢大朝之日，上殿参王。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙安上。）"
        },
        {
          "character": "孙安",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大人慢走！"
        },
        {
          "character": "徐彦昭、杨溥、马子千、杨太",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "孙大人到了。"
        },
        {
          "character": "孙安",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大人，到此为何？"
        },
        {
          "character": "徐彦昭、杨溥、马子千、杨太",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "今逢大朝之日，上殿参王。"
        },
        {
          "character": "孙安",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大人，是我当日上本，万岁恼怒，免我一月不来，朝见圣驾。今日一月有"
        },
        {
          "character": "孙安",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "余，上殿参王，众位大人，作一本头，下官作一本尾，本参奸贼张居正！"
        },
        {
          "character": "徐彦昭、杨溥、马子千、杨太",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "咳呀！"
        },
        {
          "character": "孙安",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若要不然，下官作一本头，众位大人，作一本尾，本参张居正！"
        },
        {
          "character": "徐彦昭、杨溥、马子千、杨太",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "咳呀！"
        },
        {
          "character": "孙安",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "竟是与贼同党，待我上殿参王。"
        },
        {
          "character": "徐彦昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孙大人上殿，你我前去保本，请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
