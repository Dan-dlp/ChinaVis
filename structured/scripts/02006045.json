          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。我们看你不像本国的人吓。"
        },
        {
          "character": "薛强",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃大唐中原人氏。"
        },
        {
          "character": "众公子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，山水远隔，因甚至此？"
