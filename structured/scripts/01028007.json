          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子迎上。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟请。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长请坐。家院，准备酒饭伺候。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子摆酒。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "酒饭到。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长请酒。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子下。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟，时才在关前，被崔浩那厮，差人捉拿于我。若非嫂嫂张氏，叫我一声丈"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夫，愚兄险遭不测。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此乃是仁兄洪福，有道是吉人自有天相也。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（顶板原板） 说什么吉人有天佑，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "细听我赵玄郎诉说根由："
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "他与我一定要做下对头。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "要害我赵玄郎他方罢休。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "因此上逃性命才得回头。"
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "兄长不必泪双流，"
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "小弟言来听从头："
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "待等明日做良谋。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬睡。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听一言来心内忧，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "倒叫某家皱眉头。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（起更鼓。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟！睡熟了。咳！想我赵玄郎半生落魄，屡遭凶险，不知何日才是我出头之"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "日！思想起来，好不烦闷人也！"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "赵玄郎坐书房心中纳闷，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "二相公心无事瞌睡沉沉。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "真乃是中秋月，星星朗朗，朗朗星星，月到中秋，万里无云分外的光明。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "走金桥曾遇着先生苗训，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "那先生排八卦会算子平。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "他算我到后来有九五之尊。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "俺玄郎也要仗四海宾朋。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "跳龙潭出虎穴脱了残生。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "用金钩钩出了红日东升。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张氏上。）"
        },
        {
          "character": "张氏",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "谯楼上打罢二更尽，"
        },
        {
          "character": "张氏",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "走到堂前看分明。"
        },
        {
          "character": "张氏",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "暗地里听他说原因。"
        },
        {
          "character": "张氏",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "悄悄儿来在窗门外"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴家张氏。时才关前遇一红脸大汉，颇似我家丈夫。是我向前叫了他一声，被"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "官军将奴赶去。既然是我丈夫归来，为何不见到来？方才邻舍陈家伯伯言到，"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有一红脸大汉，在二相公书房安歇。是奴家暗自出房，来在此地，听他说些什"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "么。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！想我赵匡胤，今日在关前，被官军盘问。若非被张氏嫂嫂叫了我一声丈"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夫，我命休矣。看将起来，真真的难得呀难得！哎咦，什么难得？此人乃是旁"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人的妻子，倘若是我的妻子，既然叫人一声丈夫，我便一刀将她杀死！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张氏倒跌，急跑下。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "张氏生来太奇情，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "错把旁人叫夫君。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "又听得谯楼上打三更。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（华佗上。）"
        },
        {
          "character": "华佗",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "在洞中奉了玉帝令，"
        },
        {
          "character": "华佗",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "割除肉瘤救真龙。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃华佗是也。只因大宋天子赵匡胤身生肉瘤。崔浩命人，各处严拿与他。吾"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今奉了上帝敕旨，前去为他割除肉瘤，以救危难。就此走走。"
        },
        {
          "character": "华佗",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "天下纷纷刀兵乱，"
        },
        {
          "character": "华佗",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "无人执掌锦江山。"
        },
        {
          "character": "华佗",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "去到曹府走一番。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是。看他熟睡，待我与他医治起来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。华佗用刀割瘤，敷药。赵匡胤看。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是何人？莫非前来行刺么？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "非也。贫道乃是汉室华佗。今日特来，为主公割除肉瘤，以救危难。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是华先生到了，多蒙医治，感恩非浅！"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣前来讨封。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "封你为药圣真人。去往华山归位去吧。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "华佗",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "三呼万岁谢皇恩，"
        },
        {
          "character": "华佗",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "去到华山且修真。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（华佗下。张氏魂上。）"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "飘飘荡荡风一阵，"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "来了张氏一鬼魂。"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "万岁台前诉详情。"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "将身且把书房进"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下跪何人？"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "张氏鬼魂。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前来做甚？"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多蒙你救驾之恩，理应封赠。你且听了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "玄郎开言加封赠，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "张氏嫂嫂听详情："
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "理当加封受隆恩。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "安受香烟称正神。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "关前蒙你救我命"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "华山老母加封你"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主隆恩。"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关前蒙你救我命"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "华山老母加封你"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "谢过皇恩忙站定，"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "去到华山为正神。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张氏下。）"
        },
        {
          "character": "曹彬",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "时才间朦胧方睡醒，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬看。）"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "又只见红日自东升。"
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "去到后堂看分明。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬下。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "昨夜晚三更得一梦，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "华佗技艺果然精。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤看。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "肉瘤不见喜吟吟。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "昨夜三更时分偶得一梦，梦见华佗前来，将我的肉瘤割掉。肉瘤已去，我今日"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "定可出关也！"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "人言华佗艺道精，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "话不虚传果然真。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "今日去到关前论。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "看崔浩把我怎样行？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬上。）"
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "时才家院报一信，"
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "张氏嫂嫂命归阴。"
        },
        {
          "character": "曹彬",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "尊声兄长听分明。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀兄长：我那张氏嫂嫂昨夜三更十分悬梁自尽了。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将身且把书房进"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不好了！"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将身且把书房进"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听罢言来吃一惊，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "张氏为我丧残生。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我纵死黄泉也感你的大恩。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "将身且把书房进"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟，愚兄想得一计，可以逃出虎口。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但愿得灵魂儿早归仙境"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长有何妙计？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "烦劳贤弟将愚兄捆绑起来，上了枷锁，去到衙前投首。但不知贤弟意下如何？"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长说哪里话来！想那崔浩与兄长夙有冤仇，今日他命人四下查访捉拿兄长。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今日兄长不去逃生，反去送死。此事断断使不得！"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟有所不知。想那崔浩，虽然与我有仇，但是他并未见过我面，只知愚兄身"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有肉瘤。今日愚兄肉瘤已去，纵然见我，他又岂奈我何？"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "话虽如此，还要兄长三思，免得后悔。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟不必多虑，愚兄自有言语回答于他。我有一言，贤弟听了！"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "手挽手儿把话论，"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "尊一声贤弟听分明："
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "幼习武艺共刀兵。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "浪荡江湖四海飘零。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "好似一母同胞生。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "苦苦要害我命残生。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "多亏张氏救我的恩。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "去到关前通姓名。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "改名换姓诈他们。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "他定放我去逃生。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "统领兵马杀仇人。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "千刀万剐不留情。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "你且大胆放宽心。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤带枷锁。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "去到衙前把话论。"
        },
        {
          "character": "曹彬",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "玄郎果是英雄汉，"
        },
        {
          "character": "曹彬",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "足智多谋胆包天。"
        },
        {
          "character": "曹彬",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "哪怕虎穴与龙潭。"
        },
        {
          "character": "曹彬",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "二人一同去冒险"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "叫贤弟与我把路带，"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大胆前去走一番！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤、曹彬同下。）"
        }
      ],
