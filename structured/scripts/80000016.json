        "赵普"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬、赵普、潘洪、苗宗善同上。）"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯哼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（同点绛唇） 静鞭声敲，禁门待诏，立金阙，新主临朝，山河齐戴孝。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "下官，"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "潘洪。"
        },
        {
          "character": "赵普",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵普。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹彬。"
        },
        {
          "character": "苗宗善",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "苗宗善。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位大人请了。"
        },
        {
          "character": "曹彬、赵普、苗宗善",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今当新主登基，一同上殿朝贺。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看：香烟缭绕，圣驾临朝，分班伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬、赵普、潘洪、苗宗善同下。〖二黄小开门〗。潘疆、潘豹引赵光义同上。）"
        },
        {
          "character": "赵光义",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "兄亡侄幼，众文武，扶孤登基。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵光义归坐，曹彬、赵普、潘洪、苗宗善同上。）"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众卿平身。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "赵光义",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "兄王晏驾龙归西，全凭争先一着棋。满朝文武来辅助，孤王才得立帝基。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤，赵光义。今日登基受贺。众卿，"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤王登基，不知当降什么国号？"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：弟继兄位，当用大宋国号。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "依卿所奏。待孤传旨，晓谕天下。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵旨！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "潘卿听封！"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "封你左班丞相。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵普听封！"
        },
        {
          "character": "赵普",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "封你右班丞相。"
        },
        {
          "character": "赵普",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹彬听封！"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "封你孝义侯之位，代管禁军。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "苗宗善听封！"
        },
        {
          "character": "苗宗善",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "封你护国军师，子袭父职。"
        },
        {
          "character": "苗宗善",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "潘疆、潘豹听封。"
        },
        {
          "character": "潘疆、潘豹",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "封你二人以为镇殿将军。"
        },
        {
          "character": "潘疆、潘豹",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "满朝文武加升三级。大赦天下。有本早奏，无本退班。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：今当我主登基，杨继业不来参驾，定有藐视我主之意。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待孤传旨，宣杨继业上殿。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁有旨：杨继业上殿。"
        },
        {
          "character": "杨继业",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业上。）"
        },
        {
          "character": "杨继业",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忽听万岁宣……"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "龙帘卷起。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呜呼呀！我道幼主登基，原来二主篡位。唉！"
        },
        {
          "character": "杨继业",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "上殿把驾参。"
        },
        {
          "character": "杨继业",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "臣，杨继业见驾，吾皇万岁！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大胆杨继业，孤王登基，为何不来朝贺？"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣参驾来迟，死罪啊，死罪！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里是参驾来迟，分明是藐视寡人。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "殿前武士！"
        },
        {
          "character": "四武士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有！"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "推出斩了。"
        },
        {
          "character": "四武士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四武士绑杨继业同下。）"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刀下留人！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "四武士 （内同白） 啊！"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：斩了杨继业，倘若他那几个虎子，反进京来，难以抵挡。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？怎么参本是你，保本也是你呀？"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣乃是为主江山。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就依卿所奏，将杨继业赦回。"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将杨继业赦回。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业上。）"
        },
        {
          "character": "杨继业",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "午门得活命，死而又复生。"
        },
        {
          "character": "潘洪",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "不是我保本，焉有你命存？"
        },
        {
          "character": "杨继业",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "我今愿一死，何劳你讲情？"
        },
        {
          "character": "潘洪",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "好心来救你，反倒不知情。"
        },
        {
          "character": "杨继业",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忠臣不怕死，怕死岂为忠？"
        },
        {
          "character": "潘洪",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "你既不怕死，随我去面君。"
        },
        {
          "character": "杨继业",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "面君便面君，怕你不成？"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "走！"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "走！"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请呐。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨继业多谢万岁不斩之恩。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "非是孤王不斩于你，念你在朝有十大汗马功劳，今将你削职为民，赐你百亩田"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "园，下殿去吧。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁。"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "先王爷待臣恩义广，"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "汗马功劳付汪洋。"
        },
        {
          "character": "杨继业",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "万里江山不久长。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵德昭上。）"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "父王不幸归泉壤，"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "我朝出了篡位王。"
        },
        {
          "character": "赵德昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请母后！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺后上。）"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "快与孩儿作主张。"
        },
        {
          "character": "贺后",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "老王不幸把命丧，"
        },
        {
          "character": "贺后",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "二主篡位谋家邦。"
        },
        {
          "character": "贺后",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "要回社稷自立为王。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贺后下。）"
        },
        {
          "character": "赵德昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "迈步且把金殿上，"
        },
        {
          "character": "赵德昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叔父啊！"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "快快还我锦家邦。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "大皇儿上殿高声嚷，"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "口口声声要家邦"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "本当下位把国让"
        },
        {
          "character": "潘洪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！臣启万岁：太子年幼，社稷为重。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "难学尧舜和商汤。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "孤不封你自立为王。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "回头便对皇侄讲"
        },
        {
          "character": "赵德昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住口！"
        },
        {
          "character": "赵德昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回头便对皇侄讲"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "你今不把江山让，"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "篡位的名儿天下扬。"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大胆！"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "奴才说话忒猖狂，"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "开口便把孤王伤。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "快将奴才绑法场。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "吩咐潘豹与潘疆"
        },
        {
          "character": "赵德昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "赵德昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐潘豹与潘疆"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "听一言来怒满腔，"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "奸王做事狠心肠。"
        },
        {
          "character": "赵德昭",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "不如碰死见先王。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵德昭碰死。贺后、赵德芳同上。）"
        },
        {
          "character": "贺后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喂呀！"
        },
        {
          "character": "贺后",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "一见皇儿把命丧，"
        },
        {
          "character": "贺后",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "怎不叫娘我痛断肠。"
        },
        {
          "character": "贺后",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "随娘到金殿去骂昏王。"
        },
        {
          "character": "贺后",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "昏王！篡位王！无道的昏王啊！"
        },
        {
          "character": "贺后",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "有贺后在金殿一声高骂，"
        },
        {
          "character": "贺后",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "昏王！篡位王！喂呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（回龙） 骂一声无道君细听根芽："
        },
        {
          "character": "贺后",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "老王爷为江山足踢拳打，"
        },
        {
          "character": "贺后",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "老王爷为山河奔走天涯。"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "遭不幸老王爷晏了御驾，"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "贼昏王篡了位谋乱邦家。"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "反道说为嫂我拦阻有差。"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "贼好比曹阿瞒奸雄不差；"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "贼好比司马师搅乱中华。"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "只骂得贼昏王扭转身躯、闭目合睛、羞羞惭惭一语不发；"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "两旁的文武臣珠泪如麻。"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "你叔王不让位我再去骂他。"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "把一个皇太子逼死殿下"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "贼好比王莽贼称孤道寡"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "贼好比秦赵高指鹿为马"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "只骂得贼昏王装聋作哑"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "只骂得贼昏王无言对答"
        },
        {
          "character": "贺后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "搬一把金交椅娘且坐下"
        },
        {
          "character": "赵光义",
          "line_type": "二黄三眼",
          "musical_style": "二黄三眼",
          "style_family": "二黄",
          "text": "自盘古立帝邦天子为重，"
        },
        {
          "character": "赵光义",
          "line_type": "二黄三眼",
          "musical_style": "二黄三眼",
          "style_family": "二黄",
          "text": "老皇嫂骂孤王情理难容。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄三眼",
          "musical_style": "二黄三眼",
          "style_family": "二黄",
          "text": "论国法就该把残生断送"
        },
        {
          "character": "贺后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谁敢？"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "退班！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵光义下位，曹彬、赵普、潘洪、苗宗善同下。）"
        },
        {
          "character": "赵光义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇嫂！"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "孤念你与兄王执掌东宫。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "满朝中文武臣议论孤穹。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "因此上保孤王驾坐九重。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "哪一个大胆的敢坐金龙。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "昭阳院改作了养老宫。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "崇上徽号容是不容？"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "兄王爷晏了驾钟鼓齐动"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "都说道大皇儿年幼无用"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "孤登基用国号还是大宋"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "走上前施一礼皇嫂尊重"
        },
        {
          "character": "赵光义",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "把皇嫂当做了太后侍奉"
        },
        {
          "character": "贺后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "享荣华受富贵要它何用？"
        },
        {
          "character": "贺后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "倒不如带皇儿务农耕种，受的什么荣封？"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老皇嫂说什么务农耕种，"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "普天下俱都是兄王亲封。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "亦非是、叔为君、侄为臣各自西东。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "掌三宫、和六院、大小嫔妃若有违背、任你施行，王是件件依从。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "享荣华受富贵母子们同共"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "孤赐你尚方剑泰山执重"
        },
        {
          "character": "赵德芳",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "喂呀！"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "赵德芳我的儿休要悲痛，"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "近前来听叔王将你来封："
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "加封你一亲王，二良王，三忠王，四正王，五德王，六敬王，上殿不参王，下"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "殿不辞王，再赐你凹面金锏，上打昏君，下打谗臣，压定了满朝的文武大小官"
        },
        {
          "character": "赵光义",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "员哪一个不尊，你是个八贤王，代管朕穹。"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "老皇嫂休要再悲痛，"
        },
        {
          "character": "赵光义",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
