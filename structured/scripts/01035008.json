        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哪有不拜之理！正是："
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "画堂今日寿筵开，"
        },
        {
          "character": "金母",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "相邀众仙到此来。"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "殷勤祝寿瑶池界，"
