    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "麻姑"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖长锤〗。麻姑携花篮、花镰上。）"
        },
        {
          "character": "麻姑",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "隐身儿行过了流水溪涧。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "转眼间观河边灵芝一片。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃麻姑仙子是也。只因金母寿诞之期，柏酿寿酒，现今百花俱全，缺少灵芝"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "仙草，因此来至绛珠河畔，采取灵芝。呵呀妙吓，看此处异样灵芝，甚是鲜妍，"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不免采取便了。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "观一派天连水水又连天，"
        },
        {
          "character": "麻姑",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "尘世上怎比得天上华严。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "急忙忙我这里去拿花镰。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（麻姑拿花镰舞。）"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这一枝——"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（跺头。）"
        },
        {
          "character": "麻姑",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "这一枝灵芝草灵光威显，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（麻姑舞。）"
        },
        {
          "character": "麻姑",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "那一枝似青云朵朵连绵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（麻姑舞。）"
        },
        {
          "character": "麻姑",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "但只见溪边上玉石灿烂，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（麻姑舞。）"
        },
        {
          "character": "麻姑",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "又见那碧桃花齐列坡前。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "酿琼浆到瑶池把金母寿添。"
        }
      ],
      "interactions": [],
