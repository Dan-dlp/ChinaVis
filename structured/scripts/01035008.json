      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小锣打。百花仙子、牡丹仙子、芍药仙子、海棠仙子同上。）"
        },
        {
          "character": "百花仙子",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "云中化日东升浩，"
        },
        {
          "character": "牡丹仙子",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "紫霞飞雪瑞气飘。"
        },
        {
          "character": "芍药仙子",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "上苑齐献灵山宝，"
        },
        {
          "character": "海棠仙子",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "瑶池会上赴蟠桃。"
        },
        {
          "character": "百花仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃百花仙子是也。"
        },
        {
          "character": "牡丹仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃牡丹仙子是也。"
        },
        {
          "character": "芍药仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃芍药仙子是也。"
        },
        {
          "character": "海棠仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃海棠仙子是也。"
        },
        {
          "character": "百花仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位仙子请了！"
        },
        {
          "character": "牡丹仙子、芍药仙子、海棠仙子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "百花仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今日三月三日，金母寿诞之期，你我不免去寻麻姑仙子，一同前去上寿。"
        },
        {
          "character": "牡丹仙子、芍药仙子、海棠仙子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "如此甚好，请哪！"
        },
        {
          "character": "百花仙子",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "各驾祥云往前进，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "海棠仙子 （同西皮摇板） 相请麻姑走一程。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（百花仙子、牡丹仙子、芍药仙子、海棠仙子同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "百花仙子→牡丹仙子",
          "turns": 2
        },
        {
          "edge": "牡丹仙子→芍药仙子",
          "turns": 2
        },
        {
          "edge": "芍药仙子→海棠仙子",
