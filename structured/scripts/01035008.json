      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖长锤〗。八龙套、四宫女引金母同上。）"
        },
        {
          "character": "金母",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "喜孜孜移莲步用目观望，"
        },
        {
          "character": "金母",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "看瑶池好华艳胜似天堂。"
        },
        {
          "character": "金母",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "因此上设寿宴齐集非常。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（金母上高台。）"
        },
        {
          "character": "金母",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "海屋添寿祝圣诞，福星永乐画堂前。岁岁年年逢此日，蟠桃会上集群仙。"
        },
        {
          "character": "金母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃瑶池金母是也。上帝见我广軿九寿，常度众生，时命诸仙，齐赴蟠桃。为"
        },
        {
          "character": "金母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此准备筵席，候众仙降临。"
        },
        {
          "character": "金母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "侍女们伺候了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（百花仙子、牡丹仙子、芍药仙子、海棠仙子同上。）"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "画堂筵庆雀屏开，福禄荣华自天来。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "金母在上，小仙们拜寿！"
        },
        {
          "character": "金母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众仙子平身。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "圣寿无疆！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖长锤〗。吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅同上。）"
        },
        {
          "character": "吕洞宾",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "银烛辉煌瑞彩草，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "曹国舅 （同西皮摇板） 年年此日捧蟠桃。"
