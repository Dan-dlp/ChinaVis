        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "金母在上，我等拜寿！"
        },
        {
          "character": "金母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大仙，不用拜了。"
