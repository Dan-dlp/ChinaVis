    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "海棠仙子",
        "牡丹仙子",
        "百花仙子",
        "芍药仙子",
        "麻姑"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小跺头。麻姑上。）"
        },
        {
          "character": "麻姑",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "好景色艳阳天花林开放，"
        },
        {
          "character": "麻姑",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "蓬莱岛众仙子齐集山岗。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "寿诞日叩金母长寿无疆。"
        },
        {
          "character": "麻姑",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "头上宝髻玉钗横，一只翠蝶梅花分。断红双脸长眉秀，绛唇一点樊素樱。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃麻姑仙子是也。只因三月三日，金母寿诞之期，故而离座出得洞府，连日"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "采取百样花草，酿成美酒，也是与金母上寿。远远望见，众仙子来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（百花仙子、牡丹仙子、芍药仙子、海棠仙子同上。）"
        },
        {
          "character": "百花仙子",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "离却洞府到深山，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "海棠仙子 （同西皮摇板） 但见麻姑在面前。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，麻姑仙子，稽首了！"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位仙子稽首。到此何事？"
        },
        {
          "character": "百花仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只因金母寿诞之期，我等相邀仙子，前去上寿。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我亦正为此事，连日在此采取奇花异草，酿成美酒，也好与金母添寿。"
        },
        {
          "character": "百花仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此，我等先行一步，告辞。"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "恕不远送。"
        },
        {
          "character": "百花仙子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "百花仙子",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "只为金母寿诞日，"
        },
        {
          "character": "麻姑",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "准备贡献赴瑶池。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（百花仙子、牡丹仙子、芍药仙子、海棠仙子同下。）"
        },
        {
          "character": "麻姑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位仙子已去，我不免准备花篮镰刀，再往后山，采取灵芝仙草便了。"
        },
        {
          "character": "麻姑",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "到后山摘灵芝制成琼浆，"
        }
      ],
      "interactions": [
        {
          "edge": "麻姑→百花仙子",
          "turns": 4
        },
        {
          "edge": "百花仙子→海棠仙子",
