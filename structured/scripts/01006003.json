  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "刘秀",
        "太监甲",
        "岑彭",
        "杜茂",
        "郭荣",
        "马武"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭荣、岑彭、杜茂、马武同上。〖牌子〗。）"
        },
        {
          "character": "郭荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫郭荣。"
        },
        {
          "character": "岑彭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本爵岑彭。"
        },
        {
          "character": "杜茂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本爵杜茂。"
        },
        {
          "character": "马武",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本爵马武。"
        },
        {
          "character": "郭荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位大人请了！"
        },
        {
          "character": "岑彭、杜茂、马武",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "郭荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今当万岁千秋之日，少时登殿，一同拜寿。香烟渺渺，圣驾临朝，分班伺候！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监引刘秀同上。）"
        },
        {
          "character": "刘秀",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "香烟缠渺，"
        },
        {
          "character": "刘秀",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "宝篆冲开紫气临，白水起义坐龙廷。黄道吉日登九五，五谷丰登乐太平。"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寡人，汉光武。昔走南阳，多亏众位皇兄帮助，邓先生妙算，削除莽贼，重兴"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "汉室。自登基以来，四海安静，真乃福泽无疆。众卿衣冠齐整，所为寡人圣寿。"
        },
        {
          "character": "郭荣、岑彭、杜茂、马武",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁，臣等拜寿！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍传孤旨意：命光禄寺大摆御宴，君臣同乐。"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可叹吓，可叹！"
        },
        {
          "character": "郭荣、岑彭、杜茂、马武",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "圣上龙心不悦，臣等未解其情？"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位皇兄，俱已在朝与寡人庆寿，惟有姚皇兄镇守草桥关，受尽风霜，孤心不"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "安。"
        },
        {
          "character": "马武",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁既然思念姚皇兄，何不将姚家父子，调进京来，陪王伴驾？"
        },
        {
          "character": "郭荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！万岁将姚皇兄调进京来，倘若柳蛮反上，何人抵挡？有道是：一载干戈"
        },
        {
          "character": "郭荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "动，十载不太平！"
        },
        {
          "character": "马武",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁何不命马、杜、岑三人镇守草桥，料然无事！"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就依三位皇兄所奏，尊朕旨意：至草桥关，调换姚期，即日回都。退班。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭荣、岑彭、杜茂、马武分班，四太监引刘秀同下。八手下自两边分上。）"
        },
        {
          "character": "马武、杜茂、岑彭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，带马草桥去者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
