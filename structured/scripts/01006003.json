    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "中军",
        "姚期"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二旗牌引姚期同上。）"
        },
        {
          "character": "姚期",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "终朝边塞征胡奴，扫灭蛮夷定河山。"
        },
        {
          "character": "姚期",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "塞北干戈起战争，南征北剿拜元戎。将令一出山摇动，镇守边关扫烟尘。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫，伴驾王姚，汉室为臣。奉命镇守草桥。可恨王郎贼子，约齐各洞苗夷，"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "屡次攻打草桥，被俺父子血战争先，才得两家罢兵停仗。咳！不知何日才能卸"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "甲。正是："
        },
        {
          "character": "姚期",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "旌旗电闪遮日月，辕门鼓响震天阙。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（中军上。）"
        },
        {
          "character": "中军",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "龙虎台前出入，貔貅帐内传唤。"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启王爷：圣旨下。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何人押旨前来？"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马、杜、岑三位王爷。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐摆队相迎！"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆队相迎！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同上，同摆队，众人同下。）"
        }
      ],
      "interactions": [
