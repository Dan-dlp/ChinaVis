    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "姚期",
        "杜茂",
        "马武"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马武、杜茂、岑彭、八手下同上，过场。姚期、四龙套同上，同出城。杜茂上前。）"
        },
        {
          "character": "杜茂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，姚皇兄！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，杜皇兄！"
        },
        {
          "character": "杜茂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我下马。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不必下马，请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马武上前。）"
        },
        {
          "character": "马武",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！姚皇兄，待我下马。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马皇兄不必下马，请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（岑彭上前。众人同进城，同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "杜茂→姚期",
