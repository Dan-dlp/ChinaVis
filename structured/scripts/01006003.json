    {
      "scene_index": 7,
      "label": "第七场",
      "characters_present": [
        "刘秀",
        "太监",
        "太监甲",
        "姚期",
        "郭妃"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监引刘秀、郭妃同上。）"
        },
        {
          "character": "刘秀",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "每日宫庭多欢笑，饮御宴酒乐逍遥。"
        },
        {
          "character": "郭妃",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "陪伴君王多有道，文臣武将贺圣朝。"
        },
        {
          "character": "郭妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾妃见驾，吾皇万岁！"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身！"
        },
        {
          "character": "郭妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐坐。"
        },
        {
          "character": "郭妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐！"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "梓童，寡人闻报姚皇兄已到京都，今日入朝谢恩。寡人意欲移在太和殿等待，"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "梓童意下如何？"
        },
        {
          "character": "郭妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾妃陪驾。"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍，摆驾太和殿！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监甲允。）"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "想从前老王爷治国清政，"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "有王莽起歹心谋位乾坤。"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "十八载才除恶孤立中兴。"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "用药酒毒平帝怜伤命尽"
        },
        {
          "character": "郭妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "万岁爷休题那前朝奸佞，"
        },
        {
          "character": "郭妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "自古道一朝君，一朝臣，顺天而行。"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "内侍臣与孤王把旨传定："
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "速宣诏姚子匡开国元勋。"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监甲下。）"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "将御宴摆至在太和殿进，"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "候姚期孤与他同饮刘伶。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姚期、太监甲同上。）"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "随咱家来。"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "皇恩浩调老臣宫庭独往，"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙恩重愧无报心意彷徨。"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "按戎装卸甲胄朝见君王。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣，姚期见驾，吾皇万岁！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转过了万花亭品级台上"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇兄平身！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！娘娘千岁！"
        },
        {
          "character": "郭妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢娘娘！"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "姚皇兄把草桥之事，奏与朕知。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容奏！"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "数万儿郎边关镇，"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "蛮夷不敢扰边庭。"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "万里山河归圣君。"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "干戈安静民安定"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老皇兄镇边关昼夜劳顿，"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "朕亲自赐香醪以待忠臣。"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "谢过了吾主爷皇封御饮，"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "愿我主国安泰福寿康宁！"
        },
        {
          "character": "郭妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁，姚皇兄乃开国元勋，妾妃要敬一樽。"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "姚皇兄，娘娘要敬酒一樽，上前谢过娘娘。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁，只有臣敬君酒，那有君敬臣酒之礼？"
        },
        {
          "character": "刘秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你乃开国元勋，这又何妨？"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "郭妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看酒来。"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "郭妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "满满斟上葡萄酿，"
        },
        {
          "character": "郭妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "代驾把敬有功臣。"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老臣年迈如霜降，"
        },
        {
          "character": "姚期",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "娘娘待臣恩如山。"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "梓童暂且回宫往，"
        },
        {
          "character": "刘秀",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "孤与皇兄叙衷肠。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭妃下。刘秀、姚期同下。）"
        }
