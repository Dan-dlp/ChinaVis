    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "姚期",
        "岑彭",
        "杜茂",
        "马武"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姚期、马武、岑彭、杜茂、四龙套同上。）"
        },
        {
          "character": "岑彭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "见，圣旨下，跪！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁！"
        },
        {
          "character": "岑彭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宣读诏曰：孤王思念功臣，调姚皇兄进京陪王伴驾。草桥之事，付与马、杜、"
        },
        {
          "character": "岑彭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岑三位皇兄执掌。钦哉谢恩！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳三位皇兄奉旨前来，一路之上，多受风霜之苦！"
        },
        {
          "character": "马武、杜茂、岑彭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢！姚皇兄镇守草桥，柳蛮不敢犯界，吾等佩服！"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夸奖了！"
        },
        {
          "character": "马武、杜茂、岑彭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我等到此，就该开度。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "中军看印！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马武、杜茂、岑彭同拜印。）"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三位皇兄镇守草桥，可喜可贺！"
        },
        {
          "character": "马武、杜茂、岑彭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢！姚皇兄几时起程？我等长亭饯行。"
        },
        {
          "character": "姚期",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "准备明日起程。告辞了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同待马，姚期下。）"
        },
        {
          "character": "马武、杜茂、岑彭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "明日准备酒宴，长亭饯行！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
