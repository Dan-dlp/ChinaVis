    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "四大将",
        "数百年至平帝王莽乱政",
        "斩英布诛彭越三杰丧命",
        "班超"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（班超上。四大将同上。）"
        },
        {
          "character": "班超",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "想高皇坐江山全亏韩信，\n吕太后与萧何害却忠臣。\n已有那张子房告老归林。\n天不灭汉家后光武中兴。"
        },
        {
          "character": "班超",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位将军，桌案现有酒宴，大家畅饮一回。"
        },
        {
          "character": "斩英布诛彭越三杰丧命、数百年至平帝王莽乱政、四大将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "侯爷请。"
        },
        {
          "character": "班超",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位将军。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "班超",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀呀呀。你我安息了吧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（班超睡。阴锣。虎形上，站班超后。四大将同醒，同看。）"
        },
        {
          "character": "四大将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "侯爷醒来。"
        },
        {
          "character": "班超",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "班超",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "耳边厢忽听得有人喧嚷。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（班超醒，看。）"
        },
        {
          "character": "班超",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又只见众将军站立两旁。"
        },
        {
          "character": "班超",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位将军，何事惊慌？"
        },
        {
          "character": "四大将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启侯爷：猛虎出现。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（班超看。）"
        },
        {
          "character": "班超",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊呀，猛虎出现，乃大吉之兆。有道是“不入虎穴，焉得虎子”。呀！"
        },
        {
          "character": "班超",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "交锋之际加兵将，\n大小儿郎要提防。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四大将同下。）"
        },
        {
          "character": "班超",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "惟愿此阵收复西凉。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（班超上马，下。）"
        }
      ],
      "interactions": [
        {
          "edge": "班超→四大将",
          "turns": 3
        },
        {
          "edge": "四大将→班超",
          "turns": 3
        }
      ],
