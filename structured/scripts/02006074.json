    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "卞金遂",
        "史敬思",
        "李克用"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史敬思上。）"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "“太平桥”……“太平桥”……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史敬思打马上桥，退。）"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗳，看此桥高大，如何得过？待俺下马过桥……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史敬思上桥。卞金遂上，刺，下。史敬思僵尸倒下。李克用上。）"
        },
        {
          "character": "李克用",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾儿醒来！"
        },
        {
          "character": "史敬思",
          "line_type": "唱",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "耳边厢又听得有人呼唤，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史敬思起，看。）"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "父王吓……"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "中了奸贼巧机关。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史敬思包胸。）"
        },
        {
          "character": "史敬思",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "又见人马到桥前。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四上手引卞金遂同上，架枪。）"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来将通名！"
        },
        {
          "character": "卞金遂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老爷卞金遂！"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太平桥行刺，可是你么？"
        },
        {
          "character": "卞金遂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是你老爷！"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看枪！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卞金遂倒。）"
        },
        {
          "character": "史敬思",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "适才道尔的武艺好，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四下手、朱温同上，同转场，同下。）"
        },
        {
          "character": "李克用",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "父子快快把命逃！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手、朱温同赶上。李克用下。史敬思开打，败下。四下手、朱温同下。史敬思上。）"
        },
        {
          "character": "史敬思",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "英雄入了牢笼套！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史敬思前俯后仰，起，抱胸。）"
        },
        {
          "character": "史敬思",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "三魂渺渺赴阴曹。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史敬思摔僵尸。李克用上，哭。四下手、朱温同追上。李克用下。四下手、朱温同下。）"
        }
