          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，追！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱温、四龙套同下。）"
