    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "史敬思",
        "探子",
        "朱温",
        "李克用",
        "王銮英"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套引朱温同上。）"
        },
        {
          "character": "朱温",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "一边撒下青丝网，哪怕鱼儿不上钩。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子上。）"
        },
        {
          "character": "探子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "李晋王到！"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（探子下。）"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆队相迎！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。朱温、四龙套同下。朱温、四龙套同上，四龙套引史敬思、李克用同上。）"
        },
        {
          "character": "李克用",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "梁王，御弟。"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "晋王，千岁，"
        },
        {
          "character": "朱温",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "啊哈哈哈哈哈。"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱温、李克用、史敬思、八龙套同下。朱温、李克用、史敬思、八龙套同上。）"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "晋王驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "李克用",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤来得卤莽，望祈海涵。"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将宴摆下！"
        },
        {
          "character": "李克用",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此就要叨扰。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。朱温敬酒，朱温、李克用同入座。史敬思搜。）"
        },
        {
          "character": "朱温",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": "李克用",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。军士上，执锤撞锣。）"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "忽听铜锣一声响，"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "刀枪剑戟列两旁。"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "此处定然有埋藏！"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "回头再把话来讲"
        },
        {
          "character": "李克用",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "看梁王不似杀人样，"
        },
        {
          "character": "李克用",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "且看他怎样动刀枪。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（军士执锤撞锣。）"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "又听铜锣二下响，"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "倒叫豪杰着了忙。"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "请出皇姑问端详。"
        },
        {
          "character": "史敬思",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "再与父王把话讲"
        },
        {
          "character": "李克用",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "孤家到此饮琼浆，"
        },
        {
          "character": "李克用",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不见皇姑为哪桩？"
        },
        {
          "character": "朱温",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "人来后堂把话讲，"
        },
        {
          "character": "朱温",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "请出皇娘到前堂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王銮英上。）"
        },
        {
          "character": "王銮英",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "忽听帐外闹嚷嚷，"
        },
        {
          "character": "王銮英",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "迈步向前看端详。"
        },
        {
          "character": "王銮英",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "细听妾身说端详："
        },
        {
          "character": "王銮英",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "要害你君臣一命亡！"
