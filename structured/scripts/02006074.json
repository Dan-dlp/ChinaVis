      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李克用上，史敬思随上。）"
        },
        {
          "character": "李克用",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看四面俱是兵将，城门紧闭，你我父子怎生逃脱？"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "父王随儿臣去到水门，将木栅砍断，托起水闸，打从水门逃出便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李克用、史敬思同下。史敬思上，砍栅，托闸。李克用上。）"
        },
        {
          "character": "史敬思",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "父王速速带马从水门逃出！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李克用穿闸，下。史敬思随下。）"
        }
      ],
      "interactions": [
        {
