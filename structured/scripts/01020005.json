    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "书吏",
        "何路通",
        "关泰",
        "家院",
        "张夫人",
        "张桂兰",
        "施世纶",
        "李堃",
        "王栋",
        "计全",
        "谢永泰",
        "黄天霸"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、八英雄、朱光祖、李堃、黄天霸、施世纶同上。）"
        },
        {
          "character": "施世纶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "本院下马鸡鸣驿，"
        },
        {
          "character": "施世纶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "失却金牌甚跷蹊。"
        },
        {
          "character": "施世纶",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "且等众人报端的。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王栋、王梁同上。）"
        },
        {
          "character": "王栋、王梁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见大人！"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "王栋、王梁回来了。金牌之事如何？"
        },
        {
          "character": "王栋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀大人：小人去到包头镇，见有一个人家，是八字小门墙。进去一问，果然"
        },
        {
          "character": "王栋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是张姓。只是凤凰张七现已去世，见了那老夫人。她曾言道："
        },
        {
          "character": "王栋",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "若问金牌事，李五爷便知情。"
        },
        {
          "character": "李堃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳，不好了！"
        },
        {
          "character": "李堃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听说是老英雄丧了命，"
        },
        {
          "character": "李堃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "倒叫李堃恸在心。"
        },
        {
          "character": "李堃",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "只为他女一段婚姻。"
        },
        {
          "character": "李堃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀大人：那张七之女，名唤桂兰，久已许配黄爷，并未下聘。今日失去金牌，"
        },
        {
          "character": "李堃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "定是为黄爷而起。"
        },
        {
          "character": "李堃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人若问金牌事"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既然如此，本院就同诸位同到她家，本院还要看看她的武艺。吩咐外厢开道！"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "开道！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同允。〖吹牌子〗。众人同转场。）"
        },
        {
          "character": "书吏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "里面有人么？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家院上。）"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么人？"
        },
        {
          "character": "书吏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "施大人要见你家老夫人。"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请老夫人！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张夫人上。）"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "施大人到。"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫人！"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见大人！"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫人请坐！"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "金牌奉上！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（施世纶接。）"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天霸，见过你的岳母！"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见岳母！"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不消拜了。"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，请你家小姐！"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请小姐！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张桂兰上。）"
        },
        {
          "character": "张桂兰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见母亲！"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "向前见过大人。"
        },
        {
          "character": "张桂兰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见大人！"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。本院要看你夫妻的武艺，当面演来。"
        },
        {
          "character": "黄天霸、张桂兰",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": "黄天霸、张桂兰",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "（黄天霸、张桂兰同比武，同起打。张桂兰打黄天霸嘴巴，黄天霸摸镖欲打，朱光祖、李堃同拦，张桂兰下。"
        },
        {
          "character": "黄天霸、张桂兰",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "关泰、谢永泰、何路通、计全同上。）"
        },
        {
          "character": "关泰、谢永泰、何路通、计全",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见大人！"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你探听薛金龙，怎么样了？"
        },
        {
          "character": "关泰、谢永泰",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我二人被他们擒去，不是何路通前去搭救，险遭不测。"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天霸听令！命你前去捉拿薛金龙，不得有误！"
        },
        {
          "character": "黄天霸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄天霸、关泰、谢永泰、何路通、计全同下。）"
        },
        {
          "character": "张夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "后堂摆宴，李五爷奉陪大人同饮。"
        },
        {
          "character": "施世纶",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叨扰了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
