  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "二庄客",
        "八英雄",
        "关泰",
        "四弟兄",
        "李玉",
        "杨香武",
        "薛金龙",
        "谢永泰",
        "院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛金龙上。）"
        },
        {
          "character": "薛金龙",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "武艺超群，压绿林，白发如银。"
        },
        {
          "character": "薛金龙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "自幼生来胆气豪，白发苍苍似银条。绿林之中谁不晓，薛家窝内逞英豪。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手、丑院子同暗上。）"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾，薛金龙。爱习拳棍，带领四个孩儿独霸薛家窝。今乃老夫寿诞之期。"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众家丁，伺候了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四弟兄同上。）"
        },
        {
          "character": "四弟兄",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "好汉生来秉性刚，爱习拳棒和刀枪。"
        },
        {
          "character": "四弟兄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹在上，孩儿等拜寿！"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不消拜了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "八英雄 （内同白） 众位英雄到！"
        },
        {
          "character": "四弟兄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（八英雄同上。）"
        },
        {
          "character": "八英雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！老英雄！"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位请！"
        },
        {
          "character": "八英雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "老英雄请上，待吾等拜寿！"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这就不敢当！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。院子上。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨、李二位老英雄前来拜寿。"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "敢么是那杨香武、李玉么？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨香武、李玉同上。）"
        },
        {
          "character": "杨香武、李玉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "薛老英雄！"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位老英雄请！"
        },
        {
          "character": "杨香武、李玉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "老英雄请上，待我二人与老英雄拜寿！"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢当了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。）"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "未知二位老英雄驾到，小弟未曾远迎，当面恕罪！"
        },
        {
          "character": "杨香武、李玉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢！"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "酒宴摆下！"
        },
        {
          "character": "杨香武、李玉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来此就要叨扰！"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二庄客同上。）"
        },
        {
          "character": "二庄客",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启寨主：我等在庄外酒楼擒住两个奸细。"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "竟有这等事？与我绑上来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手押关泰、谢永泰同上。）"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大胆奸细，擅敢前来窥探，通上名来！"
        },
        {
          "character": "关泰",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "你老爷总漕大人标下，漕标参将关泰。"
        },
        {
          "character": "谢永泰",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "你老爷漕标守备谢永泰。"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是无名之辈。"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将他二人吊在马棚之内，押下去！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手押关泰、谢永泰同下。）"
        },
        {
          "character": "杨香武、李玉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "老英雄，想关泰、谢永泰二人俱是漕标手下的官员，今将他等擒来，只恐与老"
        },
        {
          "character": "杨香武、李玉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "英雄有些不便。"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想那天霸在施世纶手下，每每与吾绿林作对。今日他二人前来，未必非天霸的"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "主使，这也是他自投罗网。"
        },
        {
          "character": "杨香武",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "倘若那天霸带领官兵前来，你是怎生得了？"
        },
        {
          "character": "薛金龙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "纵有官兵到来，俺薛某何惧！想俺薛家五虎乎！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吹牌子。）"
        },
        {
          "character": "杨香武",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好言相劝，执意不听，少时悔之晚矣！俺杨香武告辞了！"
        },
        {
          "character": "杨香武",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我把好言来劝你，"
        },
        {
          "character": "杨香武",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "怎奈你心中太痴迷。"
        },
        {
          "character": "杨香武",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "船到江心补漏迟。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨香武、李玉同下。）"
        },
        {
          "character": "薛金龙",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "他二人一怒出庄院，"
        },
        {
          "character": "薛金龙",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大家到后堂痛饮一番。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
