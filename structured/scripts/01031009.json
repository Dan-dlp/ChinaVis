  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "诸葛亮",
        "马谡"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四大铠、王平、马岱、廖化、张嶷引诸葛亮同上。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "叹先皇白帝城龙归天上，\n托孤与诸葛亮扶保朝纲。\n保幼主登大宝国泰民康。\n奉圣命统大兵渡过泸江。\n深入那不毛地累动刀枪。\n火烧尽藤甲兵转回朝堂。\n灭却了小曹贼答报先皇。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "待等那探马报便知端详。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马谡上。）"
        },
        {
          "character": "马谡",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "探听中原事，报与丞相知。"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军少礼。"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢丞相。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你打听中原之事如何？"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀丞相：曹丕已死，曹睿继位，加封文武官员。封司马懿为骠骑大将军，统\n领兵马，督阵雍凉等处，特来报与丞相知道。"
        },
        {
          "character": "诸葛亮",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "啊，哈哈呀！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹丕已死，孺子曹睿继位，皆不足虑。惟有司马懿，此人深有谋略，颇能用兵。\n今日提督雍凉兵马，倘若训练已成，必为我汉中之大患。必须起兵征剿，以\n灭此人。"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启丞相：今当平定南蛮而回，军马疲惫，只可存恤，不可远征。末将倒有一计\n献上。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军有何妙计？"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "司马懿虽是魏国大臣，怎奈曹睿年少，素怀疑忌。丞相何不遣人，散布流言，\n道此人欲反；遍贴告示，晓喻百姓。那曹睿闻之，必杀此人也。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此计甚妙。就命将军去至洛阳、邺郡等处，散布流言，遍贴榜文，告示天下，\n不得有误。"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马谡下。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看马谡此去，行此反间之计，管叫司马性命难保！"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "恼恨曹睿狗奸党，\n他命司马镇雍凉。\n管叫那司马懿无有下场。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "诸葛亮→马谡",
          "turns": 5
        },
        {
          "edge": "马谡→诸葛亮",
          "turns": 5
        }
      ],
      "stats": {
        "line_counts": {
