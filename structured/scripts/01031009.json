    {
      "scene_index": 7,
      "label": "第七场",
      "characters_present": [
        "司马师",
        "司马懿"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马懿上。）"
        },
        {
          "character": "司马懿",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "辕门旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马师上。）"
        },
        {
          "character": "司马师",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忙将朝中事，启禀父帅知。"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见父帅。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾儿少礼。进帐何事？"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才探马报到：万岁驾幸安邑，不久即到。特来禀告父帅。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此，吾儿传令下去，命全部人马，大小将官，全身披挂，刀枪要齐整，盔甲"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马师下。）"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "司马懿",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "整顿全部人和马，欲令天子识威严。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马懿下。）"
        }
      ],
      "interactions": [
        {
          "edge": "司马懿→司马师",
          "turns": 3
        },
        {
          "edge": "司马师→司马懿",
          "turns": 3
        }
      ],
      "stats": {
