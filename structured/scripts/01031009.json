    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "司马师",
        "司马懿",
        "司马昭"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马懿上。）"
        },
        {
          "character": "司马懿",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "虎跃龙骧，统貔貅，督镇雍凉。"
        },
        {
          "character": "司马懿",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "长须如雪鬓如霜，战策兵机腹内藏。愿学孙武与吕望，扶保魏国锦家邦。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫，司马懿。魏王驾前为臣，官拜骠骑大将军，提督全国兵马，坐镇雍凉。\n每日带领两个孩儿，操练军士。待等兵马练熟，定要扫灭西蜀，生擒诸葛亮，\n以报国恩。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马师、司马昭同上。）"
        },
        {
          "character": "司马师",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "黄公三略安天下，"
        },
        {
          "character": "司马昭",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "吕望六韬定太平。"
        },
        {
          "character": "司马师、司马昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见父帅。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾儿少礼。"
        },
        {
          "character": "司马师、司马昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢父帅。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你等整顿兵马，可曾点齐？"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马将士，均在校场伺候，请父帅前去阅操。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，一同前往。正是："
        },
        {
          "character": "司马懿",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "校场训练兵和将，要与诸葛定雌雄。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马懿、司马师、司马昭同下。）"
        }
      ],
      "interactions": [
