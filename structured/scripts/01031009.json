    },
    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "曹睿"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四大铠、二内侍、四将、贾诩引曹睿同上。）"
        },
        {
          "character": "曹睿",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "刀枪剑戟排列如林。\n文武百官随驾行。\n他本是我朝中两代老臣。\n因何故一旦间起下反心。\n竟敢在各州郡遍贴榜文。\n司马懿他必然带兵来迎。\n就车前一定要把他来擒。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四大铠、二内侍、四将、贾诩同下。）"
        },
        {
          "character": "曹睿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "但愿得此一去灭却反臣。"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "唱": 2
        },
        "singing_ratio": 1.0,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮慢板",
          "西皮摇板"
        ]
      }
    },
    {
      "scene_index": 9,
      "label": "第九场",
      "characters_present": [
        "司马懿",
        "曹睿"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四上手、四将、司马师、司马昭、司马懿自下场门同上，同出城迎接。四龙套、四大铠、四将、"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "二内侍引曹睿同上。司马懿跑接。〖吹打〗。）"
        },
        {
          "character": "曹睿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "胆大司马懿！你身受先皇帝厚意，不知报效，擅敢造反。本当将你斩首问罪，\n姑念你是先朝老臣，加恩撤去兵权，削职为民。去罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（八龙套、四上手、四大铠、八将、二内侍、曹睿同同下。司马懿看司马师、司马昭。）"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马懿、司马师、司马昭同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "曹睿→司马懿",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
