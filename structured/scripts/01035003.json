          "text": "朝朝暮暮乐无穷。"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "十二金钗半凋零。"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "蟾宫折桂成了名。"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "叩别我父把仙界登。"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "大观园里锦绣地"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "十八年来抛岁月"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "父母生我恩义重"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "一朝悟道脱凡景"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "茫茫大士"
        },
        {
          "character": "渺渺真人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "神瑛使者，随我来呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（茫茫大士、渺渺真人同笑。茫茫大士、渺渺真人、贾宝玉同下。）"
        }
      ],
      "interactions": [
