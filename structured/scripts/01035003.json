    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "下书人",
        "二稍水",
        "茫茫大士",
        "贾宝玉",
        "贾政",
        "院子",
        "院子甲"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政上。）"
        },
        {
          "character": "贾政",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "扶柩归南，大事毕，转回顺天。"
        },
        {
          "character": "贾政",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "日月如梭去如风，人生一世枉劳形。富贵皆是前生定，到头只怕一场空。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫贾政。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四家丁、二院子同暗上，分两边站。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "金陵人氏，世居京师官居吏部郎中之职。前年钦命江南学政，科场已毕回朝交"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "旨。只因老母年迈，奏明终养。不幸老母寿终，将灵柩送回金陵下葬。大事已"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "毕。前日接到家信，且喜家产赏还，官复原职真，乃皇恩浩荡也！"
        },
        {
          "character": "下书人",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯哏！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（下书人上。）"
        },
        {
          "character": "下书人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人与大人叩头。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。到此何事？"
        },
        {
          "character": "下书人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有家书呈上。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上。下边伺候。"
        },
        {
          "character": "下书人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（下书人下。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家信到来，待我看来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政看。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呵！宝玉得中七名举人，贾兰二百三十名举人。可喜呀可喜！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政笑。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这是祖宗有德，上天垂佑，家门之幸也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政笑。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我往下看来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政看。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！宝玉出场，怎么走失了？此事真乃奇怪。好一个有道明君，命地方官各处"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寻找。这就不愁找着了。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家院！"
        },
        {
          "character": "院子甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人役可齐？"
        },
        {
          "character": "院子甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俱已齐备。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "挑轿打道江岸。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政起，上轿。吹六马令。众人同转场。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "禀大人：来至江岸。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传稍水走上。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传稍水。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二稍水同上。）"
        },
        {
          "character": "二稍水",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来了来了！"
        },
        {
          "character": "二稍水",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "稍水与大人扣头。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。将船向北进发。"
        },
        {
          "character": "二稍水",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "二稍水",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "开船了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二稍水同拔锚。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上得船来——"
        },
        {
          "character": "贾政",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "归心忙似箭，千里奔家乡。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "坐舟中思姣儿心中烦恼，"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "不由我老贾政珠泪嚎啕。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "父子情半路途各奔一条。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "又只见日西沉影挂树梢。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家院，前面什么所在？"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "实指望养姣儿终身有靠"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叫稍公你与我摇橹泊棹"
        },
        {
          "character": "院子甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "常州地界。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你看天色将晚，将船泊住，明晨早行。"
        },
        {
          "character": "院子甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人吩咐：将船泊住，明晨早行。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二稍水同应，同下锚。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家院，看酒来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政饮。〖吹牌子〗。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将杯撤去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政睡。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "贾宝玉 （内二黄导板） 出科场见仙师邀赴仙境，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（火彩。茫茫大士、渺渺真人、贾宝玉同上。）"
        },
        {
          "character": "茫茫大士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你父亲在官船以内。前去叩别，以报养育之恩。我二人在山前相候着。"
        },
        {
          "character": "贾宝玉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳仙师指引了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（茫茫大士、渺渺真人同下。扭丝。）"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叩别我老爹爹养育之恩。"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "又只见老爹尊盹睡昏沉。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（阴锣。贾政惊醒。）"
        },
        {
          "character": "贾政",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "猛抬头又只见宝玉娇生。"
        },
        {
          "character": "贾政",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你、你、你为何出场来走失无踪？"
        },
        {
          "character": "贾政",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我本当下位来将儿抱定——"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "贾宝玉 （回龙） 尊一声老爹爹细听儿言："
        },
        {
          "character": "贾政",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "吾的父养姣儿一十八年。"
        },
        {
          "character": "贾政",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "日餐高粱穿文绣高楼大厦自安然。"
        },
        {
          "character": "贾政",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "阿娘抚养更周全。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "最不该终日游荡不把书念，"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "最不该姐妹丛中学缠绵。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "最不该傍花随柳贪笑玩。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "侥幸折桂中经元。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "太虚幻境为了仙。"
        },
        {
          "character": "贾政",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "这就是一子成佛，七祖升天。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾宝玉叩头。贾政醒。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿不要行礼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾宝玉走。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宝儿慢走！"
        },
        {
          "character": "贾宝玉",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "父子们要相逢梦中团圆。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾宝玉下。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿慢走，为父赶你来了！"
        }
      ],
      "interactions": [
        {
          "edge": "贾政→下书人",
          "turns": 3
        },
        {
          "edge": "下书人→贾政",
