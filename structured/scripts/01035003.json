    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "下书人",
        "二院子",
        "茫茫大士",
        "贾政"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（茫茫大士、渺渺真人拉贾宝玉同急上，贾政追上。茫茫大士分。火彩。贾政坐。贾宝玉、茫茫大士、渺渺"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "真人同上下场门高场。）"
        },
        {
          "character": "茫茫大士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贾大人莫要追赶。听小仙一言道来！"
        },
        {
          "character": "茫茫大士",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "各自归各界，仙凡从此分。我携顽石去，交与天上人。"
        },
        {
          "character": "茫茫大士",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "世人愁肠听我讲，"
        },
        {
          "character": "茫茫大士",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "儿女姻缘本无常。"
        },
        {
          "character": "茫茫大士",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "剩下顽石不曾伤。"
        },
        {
          "character": "茫茫大士",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "投生人间做儿郎。"
        },
        {
          "character": "茫茫大士",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "大劫成灰不再扬。"
        },
        {
          "character": "茫茫大士",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "仍作顽石归大荒。"
        },
        {
          "character": "茫茫大士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宝玉随我去者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（火彩。贾宝玉、茫茫大士、渺渺真人同下。四青袍、二院子、下书人同上。）"
        },
        {
          "character": "二院子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大人不知哪里去了？"
        },
        {
          "character": "二院子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "在这里！"
        },
        {
          "character": "二院子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大人醒来！"
        },
        {
          "character": "贾政",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "我父子正相会二仙冲散，"
        },
        {
          "character": "贾政",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一霎时不见了所为哪般？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（下书人扶贾政。）"
        },
        {
          "character": "下书人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人追赶何人？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（贾政两看。）"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我么？追的宝玉。"
        },
        {
          "character": "下书人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我等追去。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！不必追了。听我一言道来！"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "他本是含玉降了生，"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "上有字迹写通灵。"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "过目成诵真聪明。"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "左右不离小姣生。"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "弃我出家把仙界登。"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "貌如冠玉原不俗"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "都只为太君心爱重"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "今得经魁名成就"
        },
        {
          "character": "贾政",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "二院子"
        },
        {
          "character": "下书人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大人不必烦恼。去到荣国府，见了太太，再作道理。"
        },
        {
          "character": "贾政",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好！开船回府。"
        },
        {
          "character": "贾政",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "宝玉！我儿！孩儿吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖尾声〗。众人同下。）"
        }
      ],
