          "character": "李妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "独坐在寒宫院闷闷忧忧，\n看一看又到了八月中秋。\n我朝中又出了篡位奸谋。\n怕的是太师爷来把宫搜。"
        },
        {
          "character": "先王爷晏了驾太子年幼、徐小姐你把那宫门把守、徐延昭",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐延昭、杨波、杨四郎同上。）"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叹罢皇灵到昭阳，"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "宫门上锁是贼李良。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "铜锤付与大人掌，"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "四郎我儿击宫墙。"
        },
        {
          "character": "杨四郎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命！"
        },
        {
          "character": "杨四郎",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "千岁、我父把令传，\n哪怕宫门千层墙。"
        },
        {
          "character": "铜锤一举双环响、徐小姐",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你是何人击宫墙？"
        },
        {
          "character": "徐延昭、杨波",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿休要动手！此乃（四公子）（徐小姐），上前见礼！"
        },
        {
          "character": "杨四郎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小将有礼。"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "还礼。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨四郎下。）"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见爹爹！"
        },
        {
          "character": "徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了！我儿启奏国太，徐、杨二臣，宫门求见。"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀国太：徐杨二臣，宫门求见。"
        },
        {
          "character": "李妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宣徐、杨二臣进宫。"
        },
        {
          "character": "徐小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国太有旨：宣徐、杨二臣进宫！"
        },
        {
          "character": "徐延昭、杨波领",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "旨！"
        },
        {
          "character": "徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人！"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁！"
        },
        {
          "character": "徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此番进宫，将保国之事细表一番。"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "全仗千岁。"
        },
        {
          "character": "徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人请。"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁请。"
        },
        {
          "character": "杨波",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "千岁爷进寒宫休要慌忙，\n站宫门听学生细说比方：\n鸿门设宴要害汉王。\n九里山前摆下战场。\n到后来封韩信三齐王。\n后宫院又有个吕后娘娘。\n三宣韩信斩首未央。\n盖世的忠良不得久长。"
        },
        {
          "character": "昔日里楚、汉两争强、汉萧何背宝剑把韩信来访、逼得个楚项羽乌江命丧、他朝中有一个萧何丞相、君臣们定下了天罗地网、九月十三雪霜降、千岁爷进寒宫，学生不往、徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "却是为何？"
        },
        {
          "character": "杨波",
          "line_type": "二黄垛板",
          "musical_style": "二黄垛板",
          "style_family": "二黄",
          "text": "怕只怕辜负了，十载寒窗，九载遨游，八月登场，七篇文章，才落得个兵部侍\n郎无有下场。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "说什么学韩信命丧未央，\n站宫门听老夫细说比方：\n龙国太怎比得吕后皇娘。\n杨大人也不是三齐叛王。\n有老夫好一比大将樊哙，手执铜锤，保驾身旁，料也无妨！"
        },
        {
          "character": "先皇爷怎比得汉高皇上、李良贼怎比得萧何臣相、这宫门今当作鸿门宴上、杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我好比鱼儿闯过了千层罗网，\n受了些惊怕，着了些慌忙。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "只要你忠心把国掌，\n老夫保你满门无伤！"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "千岁爷保学生满门无伤，\n待学生舍死忘生闯进了昭阳。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "前面走的定国王，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "后面跟随兵部侍郎。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "站立在宫门朝里望，"
        },
        {
          "character": "李妃",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "先王呀……"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "又只见龙国太怀抱太子两泪汪汪，\n口口声声哭的先王。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙国太哭的是江山难掌，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "摆一摆手儿切莫要承当。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "见国太休行那君臣大礼，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "学一个文站东，"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "武立西，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杨波 （同二黄原板） 各自分班站立两厢。"
        },
        {
          "character": "李妃",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "先王呀！"
        },
        {
          "character": "李妃",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "李艳妃坐昭阳前思后想，\n思一思想一想无有主张。\n想必是徐杨卿进了昭阳。\n只落得怀抱太子两泪汪汪，哭一声先王。"
        },
        {
          "character": "耳边厢又听得朝靴底响、有句话儿不好讲、徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙国太抱幼主把国执掌，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "为什么恨天怨地夹带愁肠，所为哪桩？"
        },
        {
          "character": "李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "也非是哀家夹带愁肠，\n都只为我朝中不得安康。"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我朝中有什么祸从天降？"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "何不请太师爷进宫来，父女们商量，这又何妨？"
        },
        {
          "character": "李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "太师爷心肠毒亚赛王莽，\n他要夺我皇儿锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "太师爷娘娘的父，他本是皇亲国丈，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣看他一旦无情，并未有篡位的心肠，太师爷忠良！"
        },
        {
          "character": "李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你道他无有那谋位心肠，\n为什么封锁昭阳，断了水火，所为哪桩？"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙凤阁让江山也曾把三本奏上，龙国太你偏偏要让，"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你言道大明朝有事无事，不用徐杨二大奸党，赶出朝房为王。"
        },
        {
          "character": "李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "先前的话休要讲，\n不看哀家看先王。\n你的名儿万古扬。"
        },
        {
          "character": "徐王兄保幼主登龙位上、徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙国太错把旨来降，\n臣有一本启奏皇娘：\n眼昏花难观那阵头刀枪。\n要保国还有那兵部侍郎。"
        },
        {
          "character": "臣耳聋听不见朝皇鼓响、老臣两鬓白如霜降、李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "徐王兄年纪迈难把国掌，\n回头来叫一声兵部侍郎。\n哀家封你并肩王。"
        },
        {
          "character": "你保幼主登龙位上、杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "吓得臣低头不敢望，\n战战兢兢启奏皇娘：\n今日里进宫门辞别皇娘。\n要告辞还落一个自在安康。"
        },
        {
          "character": "臣昨晚修下了辞王表章、望娘娘开龙恩将臣放、李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "他二人不把国来掌，\n倒叫哀家无主张。"
        },
        {
          "character": "没奈何怀抱太子跪昭阳、徐延昭",
          "line_type": "二黄顶板",
          "musical_style": "二黄顶板",
          "style_family": "二黄",
          "text": "吓坏了定国王，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "兵部侍郎。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "自从盘古立帝邦，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "君跪臣来臣不敢当。"
        },
        {
          "character": "李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "非是哀家来跪你，\n为的是我儿锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "锦绣邦来锦绣邦，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣有一本启奏皇娘："
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "昔日里有个李文、李广，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "弟兄双双护朝纲。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "李文北门带箭丧，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "万家山前又收李广。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "收了一将又一将，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "一将倒比一将强。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "到后来保太子登龙位上，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "反把李广斩首法场。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "这都是前朝的忠臣良将，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "哪个忠良又有下场。"
        },
        {
          "character": "李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "有下场来无下场，\n细听哀家说比方：\n长板坡前救小王。\n他的名儿万古扬。"
        },
        {
          "character": "昔日里有个子龙将、到后来保太子登龙位上、徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "困龙思想长江浪，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "虎落平阳想奔山冈。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "国太思，国太想一想，"
        },
        {
          "character": "杨波",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "哪一个是忠良，哪一个是奸党。"
        },
        {
          "character": "李妃",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "忠良本是徐杨，\n奸党的是我父李良。"
        },
        {
          "character": "李妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "哀家跪死在昭阳！"
        },
        {
          "character": "二卿不把国执掌、徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "铜锤一举王请上，"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "老杨波搀扶起定国王。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "回头来奏一道太平表章，\n老杨波搬下了众家儿郎。"
        },
        {
          "character": "李妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听说是杨波颁兵到，\n不由哀家喜眉梢。"
        },
        {
          "character": "太子付与小姐抱、徐小姐",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "双手付与老年高。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "用手接过大明后，"
        },
        {
          "character": "徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人！"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁！"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你保幼主坐龙楼。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "用手接过龙一条，\n两眼睁睁把臣瞧。"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不好了！"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "浑身上下似火烧，难以保朝。"
        },
        {
          "character": "站立宫门生巧计、徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "大人不必生计巧，\n你的心事某猜着。\n莫不是保幼主你嫌官小？"
        },
        {
          "character": "站立宫门生巧计、徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是与不是？"
        },
        {
          "character": "站立宫门生巧计、徐延昭",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈……啊……哈……"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这个……"
        },
        {
          "character": "杨波",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "呵……哈……哈……哈……"
        },
        {
          "character": "徐延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国太！"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "快将杨波加封号。"
        },
        {
          "character": "李妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨波听封！"
        },
        {
          "character": "李妃",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "哀家封你七岁孩童戴纱帽，\n九岁女儿入皇朝。\n子子孙孙永在朝。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李妃、徐小姐、二宫女同下。）"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叩罢头来谢罢恩，"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "徐延昭代驾且平身。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一文，"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一武，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杨波 （同二黄摇板） 出宫门。"
        },
        {
          "character": "杨波",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "仗着幼主叫皇兄，\n大明江山全仗你。"
        },
        {
          "character": "徐延昭",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "要保国还是杨家父子兵！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐延昭、杨波同下。）"
        }
      ],
