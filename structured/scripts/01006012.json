    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "刘杭燕",
        "华云",
        "嫂子",
        "将身坐在绣阁内",
        "花妈妈",
        "走上前来双膝跪倒"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘杭燕、华云同上。）"
        },
        {
          "character": "华云",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "怎不叫人喜在心！"
        },
        {
          "character": "华云",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "再对小姐说分明。"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小生告辞。"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将身坐在绣阁内"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢。你要逃走了，叫奴怎样舍得你吓？"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姑娘不必如此，你可有什么心爱之物赠我，后来还有相逢之日吓。"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我说是华郎、华郎吓，你等着。"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "叫华郎你不必泪流满面，"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "听为妻把话对你言。"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "临行时赠与你凤头花鞋。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（嫂子上。丫鬟、花妈妈同上。）"
        },
        {
          "character": "嫂子",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "行走来在绣阁外，"
        },
        {
          "character": "嫂子",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "叫声丫鬟叩门庭。"
        },
        {
          "character": "嫂子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟前去叩门。"
        },
        {
          "character": "花妈妈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "慢着，她不会，待我去叩开门来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（花妈妈叩门。）"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来了。"
        },
        {
          "character": "花妈妈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姑娘你那病可好了？"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我那病么，早已好了。"
        },
        {
          "character": "花妈妈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我晓得你早已好了。那么一来，就好了。"
        },
        {
          "character": "华云",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "苦吓！"
        },
        {
          "character": "嫂子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你也不用哭了，拿这五十两银子，你走去罢！"
        },
        {
          "character": "花妈妈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想夫人待你这样仁义，还不谢了夫人！"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "拜夫人！"
        },
        {
          "character": "花妈妈",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哽！先拜后跪下。"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦哦是了。"
        },
        {
          "character": "华云",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "拜夫人你的恩情好，"
        },
        {
          "character": "华云",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "这件事倒叫我面目发烧。"
        },
        {
          "character": "华云",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "走上前来双膝跪倒"
        },
        {
          "character": "嫂子",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "叫丫鬟把门开，"
        },
        {
          "character": "嫂子",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "说是他再也不回来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（嫂子下。华云下。）"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "一见华郎他去了，"
        },
        {
          "character": "刘杭燕",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "华郎呀，哎吓！"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "怎不叫人痛伤心。"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "但不知华郎几时回来。"
        },
        {
          "character": "刘杭燕",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "华郎吓，华郎吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘杭燕下。）"
        }
      ],
