        {
          "character": "华云",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "小姑娘只生得亚赛天仙。"
        },
        {
          "character": "华云",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "我与她作一对并头双莲。"
        },
        {
          "character": "华云",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "但愿得苍天爷心随我愿"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "刘杭燕在洞房偷眼观看，"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "观看他只生得盖世无双。"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "女孩家羞答答难以开言。"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "但愿得苍天爷心随我愿"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嫂嫂请来见礼。"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明知道小华云男扮女来"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "还礼。小生华……"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "“华”什么？"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小生华云。只因那日梵王宫，相见一面，观见小姐见爱。今日前来，与小姐做"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伴来了吓！"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我有心将终身大事，托付于你。到后来，不要忘了奴的好意。"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若要忘了小姑娘的好意，死在乱箭之下。"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "言语太重了。你我拜什么为媒？"
        },
        {
          "character": "华云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现有桌台为媒。请吓！"
        },
        {
          "character": "刘杭燕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请吓！"
        },
        {
          "character": "华云",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "拜过了桌台为媒证，"
        },
        {
          "character": "华云",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我与你做夫妻永不离分。"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "来来来咱夫妻上床安眠，"
        },
        {
          "character": "刘杭燕",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "好夫妻上牙床永不离分。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘杭燕、华云同下。）"
        }
      ],
      "interactions": [
