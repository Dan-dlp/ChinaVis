          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唐。就是这个主意，就此走遭也。"
        },
        {
          "character": "王彦章",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "自幼生来不可挡，"
        },
        {
          "character": "王彦章",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "全凭铁篙把人伤。"
        },
        {
          "character": "王彦章",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "专等存孝小儿郎。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王彦章下。）"
        }
      ],
      "interactions": [],
