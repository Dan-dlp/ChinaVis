      ]
    },
    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "关羽",
        "华佗",
        "周仓",
        "小童引华佗同",
        "马良"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周仓上。）"
        },
        {
          "character": "周仓",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "悬挂招医榜，满营昼夜忙。"
        },
        {
          "character": "华佗",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "带路！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小童引华佗同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "华佗 （江儿水） 路行飘荡速速去慌忙，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "携带药箱奔荆襄；"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "特来医治到樊襄。"
        },
        {
          "character": "小童引华佗同",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "门上哪位听事？"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "作什么的？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "烦劳通禀，华佗求见。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请父王。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马良引关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "惟恐军心乱，忍痛下围棋。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "华佗求见。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马将军，华佗何许人也？"
        },
        {
          "character": "马良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "华佗乃世外高人，前在东吴曾医周泰箭伤，君侯快快传见。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "说我有请。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请华先生。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯在上，贫道有礼。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生少礼，请坐。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯在上，哪有贫道的坐位。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有话叙谈，焉有不坐之理。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生到此，有何见教？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闻得君侯在樊城中箭，特来医治。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就劳先生一看。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待贫道一观。唔呼呀！此乃弩箭所伤，箭头有毒透入骨髓，若不急速医治，此"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臂就残废了。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔！请问先生可有治法？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在厅前立一标杆，上钉铜环，君侯将膀臂穿在环内，用绳索捆住；再选数名精"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "壮大汉，扶定将军，方可医治。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生医治箭伤，用标杆铜环大汉何用？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯哪里知道，治此箭伤，必须割破皮儿，挖去烂肉，刮净骨儿疗去毒，恐君"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "侯难以忍痛耳。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哼哼哼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽冷笑。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某久历疆场，百万军中，向无惧色，今日何惧箭伤！我与马将军饮酒弈棋，就"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请先生动手。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "周将！"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "设下棋盘，与先生更衣。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "（万年欢牌。大边斜摆竖桌，关羽、马良对坐。周仓站小边，华佗更衣，小童跪端盆，华佗置关羽右手于小"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "童头上。关羽举杯。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽饮酒。）"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "设下棋盘两交战，"
        },
        {
          "character": "关羽",
          "line_type": "吹腔",
          "musical_style": null,
          "style_family": null,
          "text": "不用刀枪我和你厮杀一场。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（万年欢牌。华佗医伤，周仓哭泣，关羽笑，马良敬酒。周仓不时拦阻。华佗刮毒时，关羽举杯让酒。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "干！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽笑。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯——"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽示周仓不许拦阻。）"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请二君侯试臂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽站起，三伸右膀。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "关羽 （三笑） 哈哈，哈哈，哈哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽上坐，华佗下坐。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马良听令！"
        },
        {
          "character": "马良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "镇守荆州去吧！"
        },
        {
          "character": "马良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马良下。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生真乃神人也。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道一生未尝见过君侯如此虎威，真乃天神也。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "周将！"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看黄金千两，赠送先生。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！贫道浪迹江湖，要那黄金何用！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关某何以答报？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯乃当世英雄，贫道特来解救，未敢望报。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生几时启程？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日动身。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "周将！"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "准备船只，明日送先生过江。后帐摆宴，与先生送行。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
