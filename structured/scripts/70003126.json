    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "华佗",
        "小童"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（华佗上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "华佗 （新水令） 清水池边红日悬，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "松柏滴翠柳成行。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "堪笑世人利禄忙。"
        },
        {
          "character": "华佗",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "天上星辰日月，人间山水物华。山中风景多幽雅，还是天地为大。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道姓华名陀字元化，乃沛郡人也。自幼入山修炼，蒙异人传授歧黄，医治为"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本，并非贪利，不过济世救人。前者在东吴医治周泰箭伤；近闻关公在襄阳身"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "中箭伤，不免前去医治，顺便瞻仰关公虎威。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小童暗上。）"
        },
        {
          "character": "小童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "背了药箱前往蜀营去者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（新水令） 只为云长一箭伤，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "亲自前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（华佗、小童同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "小童→华佗",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 6,
          "白": 2
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
