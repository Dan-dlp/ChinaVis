          "text": "一路行来腹饥饿"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "娘行若肯周济我"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "听罢言来珠泪落，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "可叹将军受折磨。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "篮内取出饭与馍。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "请君饱餐免饥饿"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "多谢娘行周济我，"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "用手拿起饭与馍。"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "千金相谢不为多。"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "一饭未足充饥饿"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "将军不必言谢我，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "区区小事值几何！"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "请君快快离此河。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "阳关路上是非多"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "娘行一言提醒我，"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "男女交谈是非多。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员下。）"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "盖世英雄受折磨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员上。）"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "再与娘行把话说。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军为何去而复转？"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "非是我去而复转，倘有追兵到此，莫说我伍员打此经过！"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这——"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军少待。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "娘行请便。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住，我好心周济于他，反而疑心于我。也罢，不免投江一死，免他疑心便了。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军，那旁有人来了！"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在哪里？"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在那里！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（浣纱女投江，下。）"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "娘行身投河，"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "两眼泪如梭。"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "可叹女娇娥。"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "建碑立旌报恩德。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！娘行投江一死，是非之地，不可久停，速速拉马走去。"
        }
