      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（浣纱女上。）"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮慢三眼板",
          "musical_style": "西皮慢三眼板",
          "style_family": "西皮",
          "text": "光阴一去快如梭，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮慢三眼板",
          "musical_style": "西皮慢三眼板",
          "style_family": "西皮",
          "text": "人生在世能几何？"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮慢三眼板",
          "musical_style": "西皮慢三眼板",
          "style_family": "西皮",
          "text": "每日溪边浣纱罗。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "溧阳史氏女。与寡母同居。年已三十，尚未嫁人。每日浣纱织罗，奉母度日。"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看天气晴和，不免去到溪旁浣纱便了！"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮慢三眼板",
          "musical_style": "西皮慢三眼板",
          "style_family": "西皮",
          "text": "村边桃花——"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "红灼灼，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "垂柳绿叶映清波。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "辜负春光可奈何。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "临流倚石浣纱罗。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "伍员 （内西皮导板） 豪杰打马奔吴国，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员上。）"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "龙离沧海虎离窝。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "压定了各国不敢动干戈。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "各路诸侯来求和。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "又谁知一旦起风波。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员看。）"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "见一娘行浣纱罗。"
        },
        {
          "character": "伍员",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "见她篮中饭与馍。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员下马。）"
        },
        {
          "character": "伍员",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "含羞带愧无奈何！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员投石。）"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "忽见水底人影过，"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "落石击水却为何？"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "只得低头把话说。"
        },
        {
          "character": "浣纱女",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "想是壮士呼唤我"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "娘行请了！"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！客官敢是失迷路途？"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "并非失迷路途，我乃避难之人，行至此间，腹中饥饿，见娘行篮中有饭食馍馍，"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可否周济于我？"
        },
        {
          "character": "浣纱女",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听客官之言，不像此地人氏，家住哪里，尊姓大名？请道其详。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉，娘行听了！"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "未曾开言心难过，"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "两眼不住泪如梭。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "我的父就是伍相国。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "临潼斗宝压服了各国。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "父纳子妻理不合。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "可怜我的一家满门三百余口见阎罗。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "插翅不能逃出网罗。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "混出了昭关逃奔吴国。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "多蒙渔丈渡江河。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "但只见你的篮中有饭又有馍。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "没齿不忘大恩德。"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "家住监利在楚国"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "伍子胥就是我"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "恨平王无道贪酒色"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "我的父谏奏反得祸"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "只剩下伍员人一个"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "幸遇东皋公周全我"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "行至在江边不能过"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "一路行来腹饥饿"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
