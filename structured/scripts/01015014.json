    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "云飞",
        "众人",
        "王通",
        "韩秀"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍推车、四上手、王通同上。）"
        },
        {
          "character": "王通",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "自幼儿逞英雄保镖为首，"
        },
        {
          "character": "王通",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "全仗着折铁刀闯荡九州。"
        },
        {
          "character": "王通",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "只恐怕难挡我一字甩头。"
        },
        {
          "character": "王通",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "急忙忙上山坡莫停留。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（云飞、韩秀、四下手同上。）"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "留下车辆放尔等过去。"
        },
        {
          "character": "王通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何方毛贼，敢挡你爷的去路。"
        },
        {
          "character": "云飞、韩秀",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "听了！"
        },
        {
          "character": "云飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你老爷小白脸云飞。"
        },
        {
          "character": "韩秀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你老爷贪花浪子韩秀。"
        },
        {
          "character": "王通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无名小辈，吃我一刀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（云飞、韩秀同倒地。）"
        },
        {
          "character": "云飞、韩秀",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "英雄饶命！"
        },
        {
          "character": "王通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你老爷不斩你这无名之辈，饶尔不死，去吧！"
        },
        {
          "character": "云飞、韩秀",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "山下得活命，死而又复生。"
        },
        {
          "character": "云飞、韩秀",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "走呀，上山上去凑胆子去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（云飞、韩秀同下。）"
        },
        {
          "character": "王通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二贼此去，必有为首者前来。"
        },
        {
          "character": "王通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众好汉，车辆转至松林！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "王通→众人",
          "turns": 1
        },
        {
          "edge": "众人→王通",
          "turns": 1
