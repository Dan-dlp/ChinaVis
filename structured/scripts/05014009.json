        {
          "character": "诸葛亮",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "回言便把马岱唤，\n虚情假意战魏延。\n命你兵败凤凰山。⑴"
        },
        {
          "character": "见了姜维不交战、马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": "见了姜维不交战、马岱",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "丞相将令一声传，\n命我兵败凤凰山。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
