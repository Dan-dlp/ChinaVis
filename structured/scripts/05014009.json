          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老将军回来了？"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回来了。"
