    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "主临朝大小事和他们议论",
        "关兴",
        "内侍臣看过了皇封御饮",
        "刘禅",
        "太监甲",
        "张苞",
        "张苞 赵云 魏延",
        "诸葛亮",
