        {
          "character": "诸葛亮",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "中军帐内把令传，\n征北将军名魏延。\n跟随山人二十年。\n又比不得当初交锋在渭南。\n要出兵等待三更天。\n口口声声出反言。"
        },
        {
          "character": "自从长沙来降汉、今日战比不得往日战、黄昏之后用战饭、假扮姜维关前战、魏延",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": "自从长沙来降汉、今日战比不得往日战、黄昏之后用战饭、假扮姜维关前战、魏延",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "丞相将令不怠慢，\n假扮姜维去骂关。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（魏延下。）"
