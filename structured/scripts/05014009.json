          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "站立两厢，听山人令下！"
