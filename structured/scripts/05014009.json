        {
          "character": "赵云",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "韩德父子命丧了，\n不由老夫喜眉梢。\n那旁来了小儿曹！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜维上。）"
        },
        {
          "character": "姜维",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "上战场见一将年迈衰老，\n叫老儿通上名好把兵交。"
        },
        {
          "character": "赵云",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "你老爷常山的赵子龙谁人不晓；\n黄毛贼通上名好把兵交。"
        },
        {
          "character": "姜维",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "你老爷姓姜名维伯约起号，\n今日里生擒你要立功劳！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜维打，赵云下。关兴上，砍一刀。姜维盖。关兴下。）"
        },
        {
          "character": "姜维",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "正要擒拿赵子龙，"
        }
      ],
