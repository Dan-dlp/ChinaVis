  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "内侍臣替孤王忙传圣命",
        "刘禅",
        "命为臣保陛下社稷重整",
        "太监甲",
        "臣上本并非为别事议论",
        "诸葛亮"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘禅、四太监同上。）"
        },
        {
          "character": "刘禅",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "刘禅",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "先王晏驾白帝城，满朝文武不安宁。多亏相父来扶助，孤王才得登龙庭。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤，刘禅。国号建安在位。登基以来，风调雨顺，国泰民安。今当设立早朝。\n内侍！"
        },
        {
          "character": "太监甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴婢在。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闪放龙门。"
        },
        {
          "character": "诸葛亮",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯哼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（诸葛亮上。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "代理山河，掌丝纶，运筹帷幄。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣诸葛亮见驾。陛下千岁。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "相父平身！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千千岁！"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐坐。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "相父手捧何物？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣修得出师表章，请我主龙目御览。"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘禅看表。）"
        },
        {
          "character": "刘禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呜呼呀！如今才得干戈宁静，相父又要出兵，叫小王心下何忍？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "陛下！"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "先帝爷白帝城龙归海境，\n传口诏叫老臣时刻挂心。\n命老臣把孙、曹一旦扫平。\n望陛下准臣本臣要发兵。"
        },
        {
          "character": "命为臣保陛下社稷重整、臣上本并非为别事议论、刘禅",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老相父奏的是治国经纶，\n一桩桩一件件全记在心。\n文武臣随小王长亭饯行。"
        },
        {
          "character": "内侍臣替孤王忙传圣命、诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "食君禄报王恩理当尽命，\n臣怎敢劳我主长亭饯行。"
        },
        {
          "character": "刘禅",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "内侍臣摆御驾后宫来进，\n明日里待小王长亭饯行。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘禅、四太监、诸葛亮同下。）"
        }
      ],
      "interactions": [
