        "魏延"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、魏延、马岱、关兴、张苞同上。）"
        },
        {
          "character": "魏延",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "大将生来盖世雄，"
        },
        {
          "character": "马岱",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "万马军中逞威风。"
        },
        {
          "character": "关兴",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "耀武扬威英雄将，"
        },
        {
          "character": "张苞",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "斩将擒王立大功！"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俺——"
        },
        {
          "character": "魏延",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "魏延。"
        },
        {
          "character": "马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马岱。"
        },
        {
          "character": "关兴",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关兴。"
        },
        {
          "character": "张苞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "张苞。"
        },
        {
          "character": "魏延",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位将军请了！"
        },
        {
          "character": "马岱、关兴、张苞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "魏延",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "元戎发兵，你我在此侍候！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同下，赵云上。）"
        },
        {
          "character": "赵云",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "白发苍苍似银条，东战孙权北剿曹。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见老元戎！"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马可齐？"
        },
        {
          "character": "魏延、马岱、关兴、张苞 赵云 魏延、马岱、关兴、张苞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "喳！"
        },
        {
          "character": "太监甲",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "圣驾到！"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一同接驾！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、诸葛亮、刘禅同上。）"
        },
        {
          "character": "刘禅",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "手挽手与相父长亭来进，\n众将官一个个杀气腾腾。\n我与那老相父杯酒饯行。"
        },
        {
          "character": "内侍臣看过了皇封御饮、诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "接过了我主爷皇封御饮，\n背转身祭过了旗纛尊神。"
        },
        {
          "character": "刘禅",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "四皇叔年纪迈忠心耿耿，\n这斗酒表一表小王之心。"
        },
        {
          "character": "赵云",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "臣年迈扶我主洪福天命，\n食君禄必须要答报王恩。"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我朝中有二臣忠心秉正，\n蒋公言、费文伟二大贤臣。\n常言道军国事以理而行。"
        },
        {
          "character": "主临朝大小事和他们议论、刘禅",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "君臣们在长亭叙说不尽，"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "请吾主龙驾归臣要发兵。"
        },
        {
          "character": "刘禅",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "内侍臣摆御驾后宫来进，\n得胜回孤迎接十里长亭。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、刘禅同下。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "传将令众将军齐跨金镫，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵云、魏延、马岱、关兴、张苞同上马，诸葛亮坐车。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "文武官且免送响炮抬营。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，兵出祁山！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。赵云、魏延、马岱、关兴、张苞引诸葛亮同下。）"
        }
      ],
