        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "胜负如何？"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "头一阵刀劈韩德父子五人落马，二一阵遇见一红脸大汉；不是关兴搭救，险遭\n不测！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可曾问过敌人名姓？"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此人姓姜名维字伯约。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "姜维！"
