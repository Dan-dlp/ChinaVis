      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼上。）"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！山寇来得厉害。他若追来，撒手锏伤他！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼下。单雄信上。）"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里走？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼上，打单雄信坠马。）"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我这里暗发撒手锏，"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只见山寇落马前。"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这一锏叫你尸骨不全。"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不看你是英雄汉"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不看你是英雄汉"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我这里被他打一锏，"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好汉坠落马雕鞍。"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尊一声英雄听我言："
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "来生结草报衔环。"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "跌跪尘埃求好汉"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你若放我活命转"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听罢言来心暗转，"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看他也非无义男。"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "下得马来用手搀"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你把名姓对咱言。"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "家住山东历城县，"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "姓秦名琼当快班。"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是山东好汉秦叔宝、秦二哥？"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢！就是在下。"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "久仰了！"
        },
        {
          "character": "单雄信",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "啊哈哈哈……"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "久闻二哥今相见，"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为何事故到此山？"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我今奉了太爷签，"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "护送皇家钦命官。"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有劳二哥把大人见，"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "施礼赔罪到台前。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼、单雄信同下。）"
        }
      ],
