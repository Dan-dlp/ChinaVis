          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "相劝他必须要以礼当先。"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尊一声好汉细听我言："
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "朝内无人掌兵权。"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "落个美名在万古传。"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为首的赤发红须蓝靛面"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我看他也是条英雄好汉"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "出轿来走向前躬身立站"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "天下荒荒刀兵乱"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "若听本官来相劝"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "雄信闻言自思叹，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "你又何须相劝咱？"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "河南一带有某的庄田。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "原为出头在朝班。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "信用了奸佞掌兵权。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "英雄出头就实实难。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "混天大王扫狼烟。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "不日打破天成关。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "推倒炀帝坐江山！"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "某祖父在朝为官宦"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "自幼儿习学弓马箭"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "昏王无道皇宫乱"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "父忠无用反遭斩"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "因此上扯起了大纛旗一面"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "招聚喽兵做好汉"
        },
        {
          "character": "单雄信",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "满朝文武俱问斩"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "下官好言来相劝，"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "口口声声出反言。"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "船到江心补漏难！"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你若不听良言劝"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听一言来怒气冲冠，"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你敢恶言回复咱！"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "雄信聚众枣阳山。"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "谁敢与某来交战！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖急急风〗。秦琼上。）"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "秦叔宝催马到山前。"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！大胆贼寇，擅敢阻挡皇家命官，尔敢是造反？"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！你来在山前，口出大话，必有本领。也罢！你我比比雌雄，你若胜得过俺，"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺便马前归顺；你若不胜，便怎么样？"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺若不胜，愿将车辆奉送。"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丈夫一言？"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂能反悔！"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三班的，松林保护大人！"
        },
        {
          "character": "四青袍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "四青袍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
