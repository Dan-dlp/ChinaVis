        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待草民护送大人一程。"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！过了枣阳山，前面一带，平安无事。请大人前行！"
