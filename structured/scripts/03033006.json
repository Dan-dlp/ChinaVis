          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "山寨必须火焚散，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、院子、丫鬟、黄夫人、黄大人同下。）"
