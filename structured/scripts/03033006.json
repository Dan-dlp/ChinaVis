          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、院子、丫鬟、黄夫人、黄大人同上。）"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "壮士秦琼把贼战，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼、单雄信同上。）"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "带来雄信见恩官。"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见大人！死罪呀死罪！"
        },
        {
          "character": "黄大人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "山寇做事理不端，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼跪。黄大人搀。）"
        },
        {
          "character": "黄大人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看在壮士且放宽。"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢大人！"
        },
        {
          "character": "单雄信",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大人释放恩匪浅，"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
