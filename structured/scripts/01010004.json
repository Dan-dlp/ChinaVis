        },
        {
          "character": "徐夫人",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "张"
        },
        {
          "character": "徐夫人",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "薛家在朝中屡屡争斗"
        },
        {
          "character": "徐夫人",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "怕的是画虎不成反类其狗"
        },
        {
          "character": "徐策",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "贤夫人平日里待人恩厚，"
        },
        {
          "character": "徐策",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "到今日为薛家全然不周。"
        },
        {
          "character": "徐策",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "无奈何我只得二堂叩首"
        },
        {
          "character": "徐夫人",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "老相爷跪尘埃情理不周。"
        },
        {
          "character": "徐夫人",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "无奈何我只得二堂叩首"
        },
        {
          "character": "徐夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "相爷请起，妾身舍子就是。"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夫人舍了罢！"
        },
        {
          "character": "家院、家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听我吩咐：将你少爷，装在食盒里面，去到法场，看老夫的眼色行事。"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "徐策",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "可叹薛家世代贤，"
        },
        {
          "character": "徐夫人",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "只因薛刚受牵连。"
        },
        {
          "character": "徐策",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "苍天若助三分眼，"
        },
        {
          "character": "徐夫人",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "仇报仇来冤报冤！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐策、徐夫人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "徐夫人→徐策",
          "turns": 7
        },
        {
          "edge": "徐策→徐夫人",
