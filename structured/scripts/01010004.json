    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "二刽子手",
        "你我一死不打紧",
        "刽子手",
        "刽子手甲",
        "家院",
        "张泰",
        "徐夫人",
        "徐策",
        "恨不得一足将儿踹",
        "薛家与你何仇害",
        "薛猛",
        "马氏"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、二刽子手、张泰上。〖牌子〗。）"
        },
        {
          "character": "张泰",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "树大遮天盖地，根深那怕狂风。任他皇亲国戚，一本斩草除根。"
        },
        {
          "character": "张泰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫张泰，今奉圣命，监斩薛猛夫妇。刀斧手，将他夫妻绑上来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二刽子手同允，绑薛猛、马氏同上。）"
        },
        {
          "character": "马氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉吓，老爷，叫你反来你不反，叫你走来你不走！你我夫妻一死，不值要紧，"
        },
        {
          "character": "马氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可怜三岁孩儿，也受一刀之苦。吓、吓、吓！"
        },
        {
          "character": "马氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叫你反来你不反，"
        },
        {
          "character": "马氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叫你走来你不行。"
        },
        {
          "character": "马氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "三岁孩童也受刑。"
        },
        {
          "character": "马氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你我一死不打紧"
        },
        {
          "character": "薛猛",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "夫人休把我来怪，"
        },
        {
          "character": "薛猛",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "忠良哪怕刀下开？"
        },
        {
          "character": "薛猛",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "苦苦害我为何来？"
        },
        {
          "character": "薛猛",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "阴曹地府等儿来。"
        },
        {
          "character": "薛猛",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "薛家与你何仇害"
        },
        {
          "character": "薛猛",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "恨不得一足将儿踹"
        },
        {
          "character": "张泰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "绑上法标！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家院上。）"
        },
        {
          "character": "家院",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "奉了相爷命，法场走一行。"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "门上哪位在？"
        },
        {
          "character": "刽子手甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐相爷前来活祭。"
        },
        {
          "character": "刽子手甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "候着。"
        },
        {
          "character": "刽子手甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启相爷：今有徐相爷前来活祭。"
        },
        {
          "character": "张泰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这老儿又来多事！"
        },
        {
          "character": "刽子手甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夫人也来了。"
        },
        {
          "character": "张泰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容他一祭。时辰一到，速报我知！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张泰下。）"
        },
        {
          "character": "刽子手甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容他一祭。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二刽子手同下。）"
        },
        {
          "character": "家院",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请相爷、夫人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐策、徐夫人抬盒同上。）"
        },
        {
          "character": "徐策",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "我夫妻双双到法场，"
        },
        {
          "character": "徐夫人",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "不知忠良在哪旁？"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛猛儿吓！"
        },
        {
          "character": "徐策",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "儿夫妻好比一张弓，"
        },
        {
          "character": "徐夫人",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "万马营中逞威风。"
        },
        {
          "character": "徐策",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "儿正好开弓弦来断，"
        },
        {
          "character": "徐夫人",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一到法场一场空！"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛猛！"
        },
        {
          "character": "徐夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马氏！"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，夫人，法场之上，人烟甚众，回府去罢。"
        },
        {
          "character": "徐夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "徐夫人",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "薛猛，马氏，我的金……"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "噤声！"
        },
        {
          "character": "徐夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐夫人下。）"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳，"
        },
        {
          "character": "徐策",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "法鼓咚咚扎，西方月影斜，黄泉无客店，"
        },
        {
          "character": "徐策",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "薛猛，马氏！"
        },
        {
          "character": "徐策",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "今晚落谁家？"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "见夫人哭出了法场以外，"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "可叹她年半百十月怀胎。"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "转面来埋怨了薛猛奴才："
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "大不该命薛刚私回京来。"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "痛儿的父和母将他酒开。"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "酒壮胆胆包天惹下祸来。"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "幼主爷紫金冠坠落尘埃。"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "大不该又打那奸贼张泰。"
        },
        {
          "character": "徐策",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "将儿的父和母斩首御街。"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "只问得薛元帅无言答代，"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "转面来再埋怨马氏裙钗："
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "万马营中逞将才。"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "那马龙来摘印怎不把兵排？"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我的儿吓！"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "为什么把姣儿带回京来？"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "真可叹三岁子也把刀开！"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "因此上舍亲生调换下来。"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "到后来谁与我祭扫坟台？"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你把我老徐策换子心细说明白。"
        },
        {
          "character": "徐策",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "马夫人我不能搀你，你自己起来。"
        },
        {
          "character": "徐策",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "悲切切哭出了席棚以外，"
