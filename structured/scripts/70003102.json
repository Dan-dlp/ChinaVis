    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "关羽",
        "刘备",
        "吕常",
        "张世平",
        "张飞",
        "方雄",
        "苏双",
        "院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子上，摆香案、果品。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请三位老爷。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备、关羽、张飞同上，同焚香。院子暗下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祝告：皇天后土、过往神灵，弟子刘备、关羽、张飞虽为异姓，今结金兰之好\n祸福共之。不求同年同月同日生，愿求同年同月同日死。一在三在，一死三亡。\n上报国家，下安黎庶，誓扶汉室基业。若有二意者，天神共鉴。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。刘备、关羽、张飞同焚香，同叩首。）"
        },
        {
          "character": "关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥请上，受小弟一拜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽、张飞同拜刘备。）"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二哥请上，受小弟一拜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞拜关羽。院子上。）"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来了四位义士，拜访三位老爷。"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请到桃园一叙。"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请列位义士。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。苏双、张世平、吕常、方雄同上。）"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "诸位义士。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢，三位义士。"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "诸位义士驾到，有何见教？"
        },
        {
          "character": "苏双",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闻听人言，三位义士，武艺精通，何不与国家出力报效？"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "虽有此心，但缺良马兵器。"
        },
        {
          "character": "张世平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我愿赠良马五十匹，折铁两千斤。但不知三位使何兵器？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "双股宝剑。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "冷艳锯。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丈八蛇矛。"
        },
        {
          "character": "苏双",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待等择一吉日，打造兵器。"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢众位义士美意，桃园设宴，大家痛饮。请！正是："
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "群雄巧遇在范阳，"
        },
        {
          "character": "关羽、张飞",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "桃园结义刘、关、张。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "赠送折铁与良骥，"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "誓扶汉室锦家邦。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
