          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "苏双。"
        },
        {
          "character": "张世平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "张世平。"
        },
        {
          "character": "吕常",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吕常。"
        },
        {
          "character": "方雄",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方雄。"
        },
        {
          "character": "苏双",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位兄弟请了。如今群雄四起，道路难行。前面已是涿郡，大家赶到那里投店\n便了。"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥言之有理。"
        },
        {
          "character": "苏双",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄们，趱行者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "方雄→苏双",
          "turns": 2
        },
        {
          "edge": "苏双→张世平",
          "turns": 1
        },
        {
          "edge": "张世平→吕常",
          "turns": 1
        },
        {
          "edge": "吕常→方雄",
          "turns": 1
        },
        {
          "edge": "苏双→众人",
          "turns": 1
        },
        {
          "edge": "众人→苏双",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 2,
          "同白": 2,
          "白": 6
