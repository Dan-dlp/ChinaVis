    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "杨延嗣",
        "杨延昭",
        "杨继业"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖起初更鼓〗。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "杨继业 （內二黄导板） 金乌坠玉兔升黄昏时候，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业上。）"
        },
        {
          "character": "杨继业",
          "line_type": "二黄回龙",
          "musical_style": "二黄回龙",
          "style_family": "二黄",
          "text": "盼娇儿不由人珠泪双流。我的儿啊！"
        },
        {
          "character": "杨继业",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "七郎儿回雁门搬兵求救，"
        },
        {
          "character": "杨继业",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "为什么此一去不见回头？"
        },
        {
          "character": "杨继业",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "怕只怕我的儿一命罢休。"
        },
        {
          "character": "杨继业",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "腹内肌身寒冷遍体飕飕。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业睡。〖起二更鼓〗。杨延昭上。）"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听谯楼打罢了二更时分，"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨延昭倒做了巡更之人。"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又只见老爹爹瞌睡沉沉。"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "困沉沉坐一旁不敢高声。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延昭坐，睡。〖起三更鼓〗。四鬼卒引杨延嗣同上。）"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听谯楼打罢了三更时分，"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "半空中又来了七郎鬼魂。"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又只见老爹爹瞌睡沉沉。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延嗣拂杨继业。）"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "猛抬头又只见七郎娇生。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "儿为何哭啼啼身带雕翎？"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我这里下位去将儿抱定！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业睡。）"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老爹爹休贪睡儿有话云。"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老爹爹命孩儿搬取救兵。"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将孩儿绑芭蕉乱箭攒身。"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "小弟言来听分明："
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "休得要学小弟不孝之人。"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "怕的是天明亮难回天庭。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延嗣、四鬼卒同下。）"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "方才朦胧刚睡定，"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "梦见七郎回大营。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又只见六郎儿瞌睡沉沉。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿醒来！"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "睁开了昏花眼用目观定"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "适才间与七弟把话来论，"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "猛抬头又只见年迈爹尊。"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "睁开了昏花眼用目观定"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀爹爹呀！适才见七弟浑身是血，头带雕翎，不知是何缘故？"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔呼呀！为父也得此梦。我想梦梦相同，必有应验。哎呀儿呀！快快回去，探"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听你七弟下落！"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿不去。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为何不去？"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹年迈，孩儿放心不下。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为父虽然年迈，身体倒还健康。我儿不必忧虑，快快前去才是！"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿还是不去！"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀儿呀！为父倒有父子之情，难道我儿你就无有手足之义么？"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹不必如此，孩儿前去就是。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这便才是。快快上马去吧！"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿去也！"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "倘若胡儿来骂阵，"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "稳坐大营莫出兵。"
        },
        {
          "character": "杨延昭",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "探得消息即回程。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延昭下。）"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "六郎！延昭！唉，我的儿呀！"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见娇儿上了马能行，"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "手指潘洪发恨声。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我把老命与尔拼。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨继业下。）"
        }
      ],
