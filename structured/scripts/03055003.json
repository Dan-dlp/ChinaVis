        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我四哥和八弟失落番营；"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "弃红尘拜师尊学道法，每日里在禅堂，时时刻刻念经文，他就成了僧人。"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "最可叹我七郎乱箭攒身。"
        },
        {
          "character": "杨延嗣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见了那老爹爹细说分明，我大放悲声。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延嗣、四鬼卒同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "杨延嗣→四鬼卒",
          "turns": 2
        },
        {
          "edge": "四鬼卒→杨延嗣",
          "turns": 2
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "念": 1,
          "同白": 2,
          "白": 1,
          "唱": 1
        },
        "singing_ratio": 0.2,
        "dominant_style_family": null,
