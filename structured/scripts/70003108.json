          "西皮流水"
        ]
      }
    },
    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "关羽",
        "夏侯惇",
        "孟德有令将某遣",
        "弟兄三人徐州散",
        "张辽",
        "曹操",
        "朱灵",
        "许褚",
        "路昭",
        "身在曹营心在汉",
        "颜良"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马童、关羽、飞旗手同上。）"
        },
        {
          "character": "关羽",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "正气冲霄日光寒。\n为保皇嫂暂从曹瞒。\n不知兄长驾可安？\n正好立功报效还。\n催马来到黄河岸——"
        },
        {
          "character": "弟兄三人徐州散、身在曹营心在汉、孟德有令将某遣、张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "云长来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操下山，迎接。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "迎接将军上土山。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二将军请上土山。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相请。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖小吹打〗。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相传唤，有何事议？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只因颜良连斩宋宪、魏绩二将。徐晃亦被刀伤左膀，此人勇不可挡，特请将军\n前来退敌。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容某一观，便知分晓。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内喊声。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，二将军，你看颜良与许褚杀来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许褚、颜良同上，起打，许褚败下，夏侯惇上接战，败下。颜良追下。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "河北人马，如此骁勇，真不愧雄师也。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "以某看来，犹如土鸡瓦犬耳！"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "土鸡瓦犬兵十万，\n有名无实不足观。\n马到成功即刻还。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（夏侯惇、许褚同败上。）"
        },
        {
          "character": "夏侯惇、许褚",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀丞相：颜良勇猛非常，不能取胜。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "各归队伍。\n朱灵、路昭听令！快去敌住颜良，不要叫他冲上土山。"
        },
        {
          "character": "朱灵、路昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱灵、路昭同下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "颜良 （内西皮导板） 人似天神刀光闪——"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、颜良同上。）"
        },
        {
          "character": "颜良",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "杀退曹营众将官。\n鞭梢一指云雾散！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（颜良走阵势。）"
        },
        {
          "character": "颜良",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大骂曹操尔敢下山？"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔，曹操你敢下得山来，与你颜老爷战上几个回合，方算英雄好汉。踞山不出，\n真乃匹夫之辈。\n众将官，将土山围住了。\n呸！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（颜良、四龙套同下。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，将军，你看麾盖之下，绣袍金甲，手持大刀，那就是河北颜良。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我观颜良，犹如插标卖首！"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "分明鲁莽一蠢汉，\n插标卖首几文钱。\n青龙偃月金光闪——"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军！"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我营将士心胆寒！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（颜良上。朱灵、路昭同上，起打，颜良杀朱灵、路昭。）"
        },
        {
          "character": "颜良",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（颜良下。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可怜二将，又死于颜良之手！无人能敌，如何是好？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相休惊，某虽不才，愿去万军之中取颜良首级，来献麾下。"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，二将军，有道是军无戏言。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "文远，你好小量关某也。"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "非是关某敢斗胆，\n熟读春秋志不凡。\n气盖群雄社稷安。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽卸袍。）"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "辞别丞相跨雕鞍，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽下山。）"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "即刻立功寻兄还！"
        }
      ],
