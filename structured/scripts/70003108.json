    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "许褚",
        "颜良"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（颜良、马夫、四龙套同上。）"
        },
        {
          "character": "颜良",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "立斩二将血染袍，\n颜良今日如虎啸——"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许褚上。）"
        },
        {
          "character": "许褚",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "来了许褚将英豪。"
        },
        {
          "character": "许褚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔，来将可是颜良？"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "然。"
        },
        {
          "character": "许褚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你可知俺许褚的威风？"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无名小辈，倒也不晓。"
        },
        {
          "character": "许褚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸，你且听了！"
        },
        {
          "character": "许褚",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "力分双牛谁不晓，"
        },
        {
          "character": "颜良",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈！"
        },
        {
          "character": "颜良",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "村夫蠢子莫逞英豪。"
        },
        {
          "character": "许褚",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "你河北反寇送死到，"
        },
        {
          "character": "颜良",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "要拿曹操祭宝刀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（颜良、许褚比刀，许褚败下，颜良追下。）"
        }
      ],
      "interactions": [
        {
          "edge": "颜良→许褚",
          "turns": 3
        },
        {
          "edge": "许褚→颜良",
          "turns": 3
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 6,
          "唱": 4,
          "白": 4
        },
        "singing_ratio": 0.5,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮摇板"
        ]
      }
    },
    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "夏侯惇",
        "曹操"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操、四上手、四龙套、众将同上。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水",
          "musical_style": "西皮流水",
          "style_family": "西皮",
          "text": "金鼓声敲心胆寒，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操上山。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "但愿斩将奏凯还！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许褚上，颜良追上。复战，许褚败下，颜良追下。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "只见许褚刀法乱，\n怕的是阵前有伤残。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看许褚刀法已乱。\n夏侯惇听令：快快出马护救。"
        },
        {
          "character": "夏侯惇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": "夏侯惇",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "提刀出马去助战，\n好比蛟龙浪里翻！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（夏侯惇下。）"
        }
      ],
      "interactions": [
        {
          "edge": "曹操→夏侯惇",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 6,
          "唱": 3,
          "白": 1
