  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "刘备",
        "孙乾",
        "颜良"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备上。）"
        },
        {
          "character": "刘备",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "青梅煮酒，忆奸曹，炎汉家，社稷倾倒。"
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "东奔西走路重重，时不遇人叹困穷。独对青山思往事，老天何不佑英雄。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刘备。自徐州失散，家小不知存亡。幸我逃脱在袁绍帐下为将，暂且安身，欲\n借兵破曹。今日袁绍，拜大将颜良为先锋，进取白马坡，特来把盏送行。正是："
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "借人檐下易，举头世上难。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙乾上。）"
        },
        {
          "character": "孙乾",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "待等时运到，风云天地宽。"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启主公：颜良将军到。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐伺候把盏！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。颜良、马夫、四龙套同上。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，颜将军，刘备在此把盏送行。"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳使君。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看酒。"
        },
        {
          "character": "孙乾",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "酒在。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军请饮此酒，但愿此去马到成功，立斩曹操首级，以安天下。"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "非是颜良夸口，此去白马坡前，必斩曹操首级，以消心中恶气，方算英雄。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈，将军之言，真乃威壮也。"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "使君。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军。"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺恼恨沮受，在袁公台前，说俺勇而无谋，不可任为先锋。今日幸有使君识俺\n是个英雄，可谓有了知已。此去到了白马坡前，我战死沙场方休。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，将军有勇有谋，何出此不利之言。"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大丈夫临阵，不死即伤，有何惧哉！"
        },
        {
          "character": "颜良",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "使君说话真奥妙，\n何惧孟德小儿曹。\n白马坡前立功劳。"
        },
        {
          "character": "颜良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（颜良、马夫、四龙套同下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，颜良性情急躁，有勇无谋，袁绍此番起兵，恐成画饼也。"
        },
        {
          "character": "刘备",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "指望河北泰山靠，"
        }
      ],
      "interactions": [
        {
          "edge": "孙乾→刘备",
