        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（罗四虎上。）"
        },
        {
          "character": "罗四虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是天霸前来拿我。众英雄走上！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同上。）"
        },
        {
          "character": "罗四虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄天霸、朱光祖同上，同起打，同捉罗四虎，同下。）"
        },
