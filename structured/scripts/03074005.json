        0.0,
        0.0
      ]
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "他的父即我父向前拜倒",
        "俞伯牙",
        "樵夫",
        "渔夫",
        "琴童",
        "钟元圃"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（琴童、俞伯牙上。）"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "昨夜晚抚瑶琴内藏悲调，"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "寻不到钟贤弟我好心焦。"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但不知集贤村路在哪条？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是阳关岔道，不知哪一条是往集贤村的去路？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（钟元圃内嗽。）"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那旁有一老丈。等他到此，问个明白便了。"
        },
        {
          "character": "钟元圃",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（钟元圃上。）"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "曲弯弯走过了溪边小道，"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到坟前与我儿去把纸烧。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老丈请了！"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！先生敢是失迷路途么？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但不知问的是哪条道路？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "集贤村。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请看：上十五里也是集贤村，下十五里也是集贤村。不知问的哪个集贤村？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老丈请少待。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生请便。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀贤弟！此处既有两个集贤村，何不对愚兄说明，叫我哪里去寻？哪里去找？"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生。你背地沉吟，敢是指路之人说的不明？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无妨事。老汉在此世居多年，亲朋不少。但不知问的是哪一家？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "问的是钟家。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "钟家何人？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "钟子期。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你怎么讲？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "钟子期。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀！"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "相逢才说一句话，"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不由老汉泪如麻。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生，你来迟了！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "因何来迟？"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老汉钟元圃。吾儿钟子期。只因去岁中秋在马鞍山前，遇一晋国大夫，叫什么"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俞——"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可是那俞伯牙？"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是那俞伯牙。他二人共谈琴律，甚是相投，结为金兰之好。临行之时，约定"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今岁中秋，仍在马鞍山相会，并赠吾儿黄金二笏。是吾儿回到家中，白日砍柴，"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夜晚读书，因此劳碌而亡了！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你怎么讲？"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他竟自一病而亡了！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（俞伯牙昏倒。）"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此位是谁？"
        },
        {
          "character": "琴童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此位就是俞伯牙大夫。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此位就是俞伯牙大夫？"
        },
        {
          "character": "琴童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大人醒来！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听说是钟贤弟一命丧了！"
        },
        {
          "character": "俞伯牙",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "子期！贤弟！好兄弟呀！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不由我俞伯牙好不心焦。"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他的父即我父向前拜倒"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "问先生行此礼所谓哪条？"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我就是俞伯牙老丈不晓，"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "请把他临终话细说根苗。"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我的儿临终时亦曾言道："
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "埋在那马鞍山候驾来瞧。"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "既如此望老丈前边引道！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同走圆场。）"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这就是新坟墓上插纸标。"
        },
        {
          "character": "俞伯牙",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "子期！贤弟！好兄弟呀！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见坟台不由我双膝跪倒，"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叫不醒唤不应旧日故交。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老伯，那旁有一土台，老伯在那里坐候片时，待侄男一祭。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老汉奉陪。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "童儿，将瑶琴携了！"
        },
        {
          "character": "琴童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（渔夫、樵夫同上。）"
        },
        {
          "character": "樵夫",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "山中樵夫多自在，"
        },
        {
          "character": "渔夫",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "江上渔翁乐逍遥。"
        },
        {
          "character": "樵夫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嘿，他们那里做什么？"
        },
        {
          "character": "渔夫",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咱们去听听。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟呀！"
        },
        {
          "character": "渔夫、樵夫",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "敢是咸的！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "愚兄千里而来，未曾带得祭礼，只用瑶琴吊祭了！正是："
        },
        {
          "character": "俞伯牙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "可叹知音渺茫去，"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "俞伯牙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟留作土一丘。"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "自去岁中秋节相逢交好，"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "今日里见坟台不见故交。"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又只见秋风起黄叶飘飘。"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为贤弟我不要玉带紫袍；"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为贤弟千里程空走这遭。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（俞伯牙抚琴。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "樵夫 （同笑） 哈哈哈……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（渔夫、樵夫同下。）"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "那一旁因何故笑走渔樵？"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老伯！他二人为何发笑而去？"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他乃山野之人，不谙音律，故而发笑而去！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不好了！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听说是笑走了渔樵二老，"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "倒叫我俞伯牙心内发焦。"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我只得将瑶琴摔碎不要！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（俞伯牙摔琴。）"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "摔碎此琴为哪条？"
        },
        {
          "character": "俞伯牙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "摔碎瑶琴凤尾寒，子期不在向谁弹？春风满面皆朋友，"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老伯！"
        },
        {
          "character": "俞伯牙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "再会知音难上难！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "问老伯住何处告侄知道，"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "家住在集贤村倒也逍遥。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看黄金！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（琴童取金。）"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这黄金与老伯甘旨奉老，"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "春秋季买纸钱与侄代烧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（俞伯牙去而复转。）"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "再与伯父说根苗。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老伯，我此番回到任所，多则半月，少则十天，差人迎接你二老同享荣华，那"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "时千万不要推辞。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀先生！这两句话漫说我二老感你的大恩，就是我那去世孩儿也感恩非浅！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告辞了！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "相逢未久今别了，"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "异姓兄弟胜同胞。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伯牙在，"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "子期死！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可叹贤弟下世早！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟呀！"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我的儿啊！"
        },
        {
          "character": "俞伯牙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "再与老伯说根苗。"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老伯！从今以后不要思他！"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我不思他！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也不要想他！"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我不想他！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "子期即我。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我即子期。"
        },
        {
          "character": "钟元圃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "越发不敢！"
        },
        {
          "character": "俞伯牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告辞了！"
        },
        {
          "character": "俞伯牙",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "子期！贤弟！我那兄弟呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（俞伯牙、琴童同下。）"
        },
        {
          "character": "钟元圃",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "伯牙！先生！儿呀！"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "俞伯牙谢知音瑶琴碎了！"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他二人可算得生死故交。"
        },
        {
          "character": "钟元圃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回家去与老妻细说根苗。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（钟元圃下。）"
        }
