    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "众水手",
        "关羽",
        "叫仓将",
        "周仓",
        "四水手",
        "大舟船千百只均靠岸上",
        "将舟船依靠岸上",
        "微风起淡云收天晴日朗",
        "耳边厢又听得人声喧嚷"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四水手同上船，依岸，同转场，同下。周仓上，摆式，亮驾，舞刀。）"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请主公！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽上。〖吹打〗。关羽上船。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上得船来，好一派江景。"
        },
        {
          "character": "周仓、周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "解缆开船。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咋。"
        },
        {
          "character": "众水手、众水手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "开船。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。关羽唱。场面用笛子。）"
        },
        {
          "character": "关羽",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "上船来只觉得神清气爽，"
        },
        {
          "character": "关羽",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "推楼窗丹凤眼细看端详：\n小舟船密匝匝好似蜂房。\n绿澄澄波浪平水接天光。\n又只见东吴兵排列两厢。"
        },
        {
          "character": "关羽",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你随某下船去细看端详。"
        },
        {
          "character": "大舟船千百只均靠岸上、微风起淡云收天晴日朗、耳边厢又听得人声喧嚷、叫仓将，将舟船依靠岸上、周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "水手的！"
        },
        {
          "character": "四水手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将船靠岸。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
