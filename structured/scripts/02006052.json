        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "马赞 （同笑） 哈哈！"
        },
        {
          "character": "吴奇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "李大师乃活神仙也，果然不误时刻。你我就此下山，断住他的去路。"
        },
        {
          "character": "马赞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长传令。"
        },
        {
          "character": "吴奇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众喽啰杀下山去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。吴奇、马赞、四喽兵、四头目、四马甲同走圆场。）"
        },
        {
          "character": "四喽兵、四头目、四马甲",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来此三岔路口。"
        },
        {
          "character": "吴奇、马赞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "埋伏松林。"
        },
        {
          "character": "四喽兵、四头目、四马甲",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "吴奇→马赞",
          "turns": 5
        },
        {
