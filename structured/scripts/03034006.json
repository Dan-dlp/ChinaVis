      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、大太监、包拯、姜洪顺、王恩慕、宋仁宗同上。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "论功劳买动了帝王心。\n太君领兵挡贼人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（宋仁宗坐。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "太君到此禀寡人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（岳士奎上，见宋仁宗。穆桂英、车夫同上，穆桂英下车。）"
        },
        {
          "character": "穆桂英",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "来在长亭下车轮，\n万岁驾前臣见君。"
        },
        {
          "character": "宋仁宗",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "内侍看过酒一樽，\n孤与皇嫂来饯行。"
        },
        {
          "character": "穆桂英",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "谢罢万岁下车轮，\n回到家乡乐安宁。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（穆桂英、车夫同下。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "长亭去了穆桂英，\n江山去了八九分。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（阿红女、车夫同上，阿红女下车。）"
        },
        {
          "character": "阿红女",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "迈步且把长亭进，\n万岁驾前问安宁。"
        },
        {
          "character": "宋仁宗",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "内侍看过彩缎金，\n千两黄金表寸心。"
        },
        {
          "character": "阿红女",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "急急忙忙上车行，\n万岁赐我彩缎金。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（阿红女、车夫同下。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "长亭去了阿红女，\n不知何日转回程。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "佘太君 （内西皮导板） 佘氏女哭出了帅府门，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（车夫、杨排风、佘太君同上。）"
        },
        {
          "character": "佘太君",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "珠泪滚滚洒衣襟。\n父子们九人保乾坤。\n可怜他为国丧残生！\n并无一子随着娘亲。\n御街之上臣见君。"
        },
        {
          "character": "我夫继业投大宋、令公李陵碑下尽、八个孩儿俱丧命、来到长亭下车轮、宋仁宗",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "一见太君到长亭，\n倒叫孤王两泪淋。\n不知何日转回程？"
        },
        {
          "character": "今日告职归原郡、佘太君",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "一朝君王一朝心，\n一朝天子一朝臣。\n因此告职归故林。"
        },
        {
          "character": "无功受禄心不忍、宋仁宗",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "内侍看过酒一樽，\n孤与太君来饯行。\n还望太君发救兵。"
        },
        {
          "character": "倘若哪国刀兵起、佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "倘若哪国刀兵起、佘太君",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "用手接过酒一樽，\n背转身来敬神灵。\n君臣同享太平春。"
        },
        {
          "character": "但愿四海狼烟尽、包拯",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "人来看过酒一樽，\n我与太君来饯行。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢大人！"
        },
        {
          "character": "佘太君",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "杨家在朝有何能？\n怎敢有劳包大人！\n铁面无私万古存。"
        },
        {
          "character": "宋室江山你保定、岳士奎",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "人来看过酒一樽，\n我与太君来饯行。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢大人！"
        },
        {
          "character": "佘太君",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "有劳大人把酒敬，\n转面谢过岳大人。\n万古流传落美名。"
        },
        {
          "character": "岳家世代忠心尽、宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君哪！"
        },
        {
          "character": "岳家世代忠心尽、宋仁宗",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "愿太君此去多安稳，\n愿太君此去享太平。\n愿太君鬓发又转青。\n愿太君长生不老长寿星。"
        },
        {
          "character": "愿太君齿落又重整、愿太君寿比南山永、佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "愿太君齿落又重整、愿太君寿比南山永、佘太君",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "谢罢万岁龙言赠，\n转面来辞别了列位大人。\n再不能参君午朝门。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（车夫、杨排风、佘太君同下。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "内侍摆驾回宫廷，\n倒叫孤王两泪淋！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
