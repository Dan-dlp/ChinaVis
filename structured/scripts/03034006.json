      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（包拯、岳士奎、姜洪顺、王恩慕同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "王恩慕 （同点绛唇） 凤阁龙楼，群臣齐辏，英明佑，文物集筹，分班朝廊候。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫包拯。"
        },
        {
          "character": "岳士奎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官岳士奎。"
        },
        {
          "character": "姜洪顺",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官姜洪顺。"
        },
        {
          "character": "王恩慕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官王恩慕。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位大人请了！"
        },
        {
          "character": "岳士奎、姜洪顺、王恩慕",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有佘太君征剿黄花国，得胜还朝，已在午门候旨。少时万岁登殿，把本启奏。"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "看香烟缭绕，圣驾临朝，你我分班伺候！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监引宋仁宗同上。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "龙门展放，众文武，齐保孤王。"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "黄花国内起风波，黎民涂炭受折磨。多蒙太君来扶助，孤王才得坐山河。"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤，大宋天子至和在位。自登基以来，风调雨顺，国泰民安。只因黄花国作乱，\n孤命佘太君带兵征剿。前三日有火牌到来，太君今日还朝。\n众卿！"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有本早奏，无本退班。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：今有太君征剿黄花国得胜还朝，已在午门候旨。"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "替孤传旨：宣太君上殿！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！\n万岁有旨：太君上殿！"
        },
        {
          "character": "佘太君",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨排风捧表引佘太君同上。）"
        },
        {
          "character": "佘太君",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "写就辞王表，上殿奏当朝。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣佘氏女见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君平身。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐坐。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐！\n啊列位大人！"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "太君！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君将征剿黄花之事，一一奏来！"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣妾奉命征剿黄花，且喜大兵一到，那贼不战自降，写来降书降表，年年进贡，\n每岁来朝。"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君之功！"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁洪福！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍！"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐光禄寺大摆筵宴，与太君贺功！"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君为何拦阻？"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣妾有本启奏。"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有本当殿奏来！"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "排风！"
        },
        {
          "character": "杨排风",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将本呈上！"
        },
        {
          "character": "杨排风",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨排风呈表。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（宋仁宗看表。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔呼呀！才得干戈宁静，太君就要辞朝，叫孤心下何忍？"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁呀！"
        },
        {
          "character": "佘太君",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "佘氏女在金殿把本启奏，\n尊一声万岁爷细听从头：\n太祖爷下河东才把宋投。\n赐臣门一个个官封公侯。\n实可怜七郎儿乱箭命休！"
        },
        {
          "character": "我杨家祖居在磁州山后、圣天子待杨家恩比天厚、我儿夫命丧在两狼山口、宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君！"
        },
        {
          "character": "我杨家祖居在磁州山后、圣天子待杨家恩比天厚、我儿夫命丧在两狼山口、宋仁宗",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "劝太君休得要把本启奏，\n龙书案听孤王细说从头：\n叫孤王怎能够顺水流舟！"
        },
        {
          "character": "好容易征黄花扫荡贼寇、佘太君",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "万岁爷不准辞王表，\n臣妾二本奏当朝：\n并无一个将英豪。\n望我主准了本臣好离朝。"
        },
        {
          "character": "杨家将帅俱丧了、佘氏女在金殿急忙跪倒、宋仁宗",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "见太君在金殿双膝跪倒，\n倒叫孤王心内焦。\n再与包卿说根苗。"
        },
        {
          "character": "杨家将帅俱丧了、佘氏女在金殿急忙跪倒、宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "包卿！"
        },
        {
          "character": "两班中文武臣齐把泪掉、包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君辞朝，孤是准与不准？"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太君辞朝，焉有不准之理？问明太君居住何地，日后我主思念功臣，也好差人\n前去问安！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是呀，太君辞朝，孤哪有不准之理？请问太君居住何地，孤王思念功臣，也好\n差人前去问安。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣妾闻得沟西番黄河套内，俱是淤泥之地。臣妾意欲那里居住。"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想那沟西番乃是杨文广征服之地。就将那一省钱粮换与太君，以为养老之费。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "隆恩太重了！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不知太君何日启程？"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁准本，明日启程。"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日长亭备宴，与太君饯行。"
        },
        {
          "character": "佘太君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "佘太君",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好个明君真有道，\n开了龙恩出赦条。\n从今后再不上九龙朝。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（佘太君、杨排风同下。）"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岳卿，明日长亭预备酒宴！"
        },
        {
          "character": "岳士奎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！"
        },
        {
          "character": "宋仁宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "退班！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
