        "报子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四喽兵、四女兵引徐凤英同上。）"
        },
        {
          "character": "徐凤英",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "霸占青峰岭，耳听报好音。"
        },
        {
          "character": "报子",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "报！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "山下许多镖车打此经过。"
        },
        {
          "character": "徐凤英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探！"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。）"
        },
        {
          "character": "徐凤英",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众女兵，带马下山！"
        },
        {
          "character": "四女兵",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
