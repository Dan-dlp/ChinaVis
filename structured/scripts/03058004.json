      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（乱锤。刘飞虎、江老鼠同上。）"
        },
        {
          "character": "刘飞虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀贤弟呀！徐凤英杀法厉害，如何是好？"
        },
        {
          "character": "江老鼠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我倒有个主意：你蹲下我骑着你。"
        },
        {
          "character": "刘飞虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你别挨骂啦！"
        },
        {
          "character": "徐凤英",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里走！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐凤英、四女兵同上，同开打。刘飞虎、江老鼠同败下，徐凤英、四女兵同追下。）"
        }
      ],
      "interactions": [
