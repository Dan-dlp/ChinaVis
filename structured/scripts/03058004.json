    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "四上手",
        "李虎"
      ],
      "lines": [
        {
          "character": "李虎",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "车夫们，趱行者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四上手引李虎同上。）"
        },
        {
          "character": "李虎",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "虎背熊腰豹子胆，志气凌云八面威。"
        },
        {
          "character": "李虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺、旗牌官李虎。奉了蔡相钧旨，押解饷银，去往山西太原交纳。看前面这座"
        },
        {
          "character": "李虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高山峻岭，惯出歹人。"
        },
        {
          "character": "李虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嘚！车夫们，弓上弦，刀出鞘，过了此岭，方保无虞。速速趱行者！"
        },
        {
          "character": "四上手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "李虎→四上手",
          "turns": 1
        }
      ],
