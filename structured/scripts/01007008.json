      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吴国太、二宫女同上。）"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "光阴迅速不回还。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "每日兴兵不时闲。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "篡夺汉室锦江山。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "称孤道寡坐西川。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "叫人暗地泪涟涟。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "等候尚香把我参。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙尚香上，二宫女同上。）"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "宫娥女摆驾养老院，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "见了母后把驾参。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣见驾，母后千岁。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "王儿平身。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢母后。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐坐。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，儿吓，今日进宫，为何不戴凤冠，不穿霞帔，身着孝服来见为娘，所为何"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "事？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后有所不知，今有刘皇叔在白帝城晏驾，因此上儿臣身穿缟素。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，刘先主晏驾了？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可叹吓可惜！"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启奏母后：儿臣要到江边一祭，以表夫妻之情。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿虽然与刘先主有夫妻之份，况且分别数载，他与你兄王又有敌国之仇，你还"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "祭他则甚？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后吓，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "母后说话言语颠，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "细听孩儿把话言："
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "女大须嫁礼当然。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "未曾与儿配婚男。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "将奴定计礼不端。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "反道他人礼不然。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "年少青春独自眠。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "叫人泪涟不泪涟。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "男大当婚愁眉散"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "孩儿青春二十满"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "都只为荆州未讨转"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "不说东吴见识浅"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "孤衾独枕谁人伴"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "儿好比南来失群雁"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "我儿不必来埋怨，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "细听为娘说根源："
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "早年一命丧黄泉。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "江南九郡付孙权。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "才将我儿配凤鸾。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "以免将士不安然。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "送儿荆州有三年。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "母女分别又团圆。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "一滴何曾到九泉。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "不幸你父寿命短"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "抛下基业无人管"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "只为荆州讨不转"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "定计本是周郎想"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "儿嫁刘备娘心愿"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "接儿回转是周善"
        },
        {
          "character": "吴国太",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "江边祭奠空祭奠"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "母后说话理太偏，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "往日贤来今不贤。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "一滴何曾到九泉？"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "从前事儿想一番。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "说什么江边祭奠空祭奠"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "老母枉把弥陀念"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "蠢才不必强舌辩，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "细听为娘把话言："
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大限来时各一边。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一生须当孝为先。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "膝下不敢乱胡言。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "开口反道娘不贤。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为娘不准枉徒然。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "夫妻好比同林鸟"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我儿曾把书来念"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "孙权他把大事管"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我儿本是闺中女"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "要到江边去祭奠"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "母后不必把脸翻，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "有辈古人请听言："
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "战死沙场命不全；"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "千里寻夫万古贤。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "一点诚心到江边。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "昔日姬妃大交战"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "姜氏痛哭长城断"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "儿虽然学不得姜氏女"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "任儿说得莲花现，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "讲什么古来论什么贤。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "看哪个大胆到江边。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为娘坐在皇宫院"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "今日不容儿祭奠，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为娘坐在皇宫院"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢！"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为娘坐在皇宫院"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不如一死染黄泉。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我儿休要寻短见，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为娘送你到江边。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿一定要去，为娘也不再三阻拦于你，待为娘同你前去就是了。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不烦母后前往，儿有宫娥相伴。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这却使得。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宫娥们，此番同郡主去往江边祭奠，须要早去早回，休令主公知道。"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿知道。母后请上，受孩儿拜别。"
        },
        {
          "character": "吴国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓！分别一时，何言“拜别”二字？"
        },
        {
          "character": "孙尚香",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "礼当拜过母后吓。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "虽然暂时别宫院，"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "人生须当礼为先。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "双膝跪在地平川。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "儿愿老母福寿全。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "心中有事不敢言。"
        },
        {
          "character": "孙尚香",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "要想回头难上难。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女引孙尚香同下。）"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "娇儿出宫去祭奠，"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "袖内机关不好言。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一心要学古圣贤。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "暮景逢春谁问安。"
        },
        {
          "character": "吴国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
