    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "张济",
        "樊稠"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四军士、四大铠、张济、樊稠同上。）"
        },
        {
          "character": "张济",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "运筹帷幄意精详，"
        },
        {
          "character": "樊稠",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "樊笼困鸟怎翱翔。"
        },
        {
          "character": "张济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟，那马腾、韩遂，必因军粮不接，夜间弃营遁去。俺与将军兵分两路，打"
        },
        {
          "character": "张济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "从山谷绕出，以劫其军。两下相继而战，料马腾、韩遂，难出我计矣！"
        },
        {
          "character": "樊稠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兵贵神速。"
        },
        {
          "character": "樊稠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，就此抄路截杀者！"
        },
        {
          "character": "四军士、四大铠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "张济",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "分路剿杀休轻放，"
        },
        {
          "character": "樊稠",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "整顿威风战西羌。"
        },
        {
          "character": "张济",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "莫教遁去留余障！"
        },
        {
          "character": "樊稠",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "兵速如风声势扬。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
