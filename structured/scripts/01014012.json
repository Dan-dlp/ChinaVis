    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "众",
        "先蔑",
        "唐狡",
        "楚庄王",
        "连尹襄老"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、连尹襄老同上。）"
        },
        {
          "character": "连尹襄老",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "晋楚常争斗，何时得罢休。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫连尹襄老。今有晋国先蔑带兵前来，大王命我为前战先行。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "左右侍候了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唐狡上。）"
        },
        {
          "character": "唐狡",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "摘缨得活命，未能报国恩。"
        },
        {
          "character": "唐狡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见元帅。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唐狡，无令进帐何事？"
        },
        {
          "character": "唐狡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有晋国先蔑，兴兵前来。末将不才，情愿攻打头阵。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你小小年纪，怎是那先蔑的对手？"
        },
        {
          "character": "唐狡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "元帅说那里话来。自古道，有志不在年高，无志空活百岁。元帅你好小量人也。"
        },
        {
          "character": "唐狡",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "英雄惯出少年将，"
        },
        {
          "character": "唐狡",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一人能当百万郎。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本帅正要出兵，你在帐中絮絮叨叨。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，叉出帐去！"
        },
        {
          "character": "唐狡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唐狡下。）"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，人马可齐？"
        },
        {
          "character": "众",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俱已齐备。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杀上前去！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（先蔑、四龙套同上。对阵。）"
        },
        {
          "character": "先蔑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来将通名受死。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃楚国先锋官，连尹襄老是也。"
        },
        {
          "character": "先蔑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无名小辈，放马过来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（连尹襄老败下，先蔑追下。四龙套、四大铠、二将、楚庄王同上。）"
        },
        {
          "character": "楚庄王",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "旌旗不住空中飘，"
        },
        {
          "character": "楚庄王",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "个个儿郎杀气高。"
        },
        {
          "character": "楚庄王",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "旗开得胜转还朝。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（连尹襄老上。）"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见大王。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可曾与晋兵见过阵来？"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "会过一阵，大败而回。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，杀上前去！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同转场。四龙套、先蔑同上。）"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "胆大先蔑，我国何曾亏负你等。每每侵犯吾国疆土，是何理也？"
        },
        {
          "character": "先蔑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾奉晋主之命，带领倾国人马，要与尔平分疆土。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一派胡言！放马过来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（楚庄王败下。三将接战，同败下。先蔑追下。楚庄王上，先蔑追上，楚庄王下，先蔑下。）"
        }
      ],
