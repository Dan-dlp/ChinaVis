    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "先蔑"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖风入松〗。四龙套、先蔑同上。）"
        },
        {
          "character": "先蔑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾，晋国大司马先蔑。今奉晋侯之命，带领人马，攻伐楚邦。"
        },
        {
          "character": "先蔑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官，起兵前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖尾声〗。四龙套、先蔑同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 2,
          "白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
