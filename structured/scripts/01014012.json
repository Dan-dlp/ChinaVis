    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "楚庄王",
        "连尹襄老"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（楚庄王上，先蔑上，刺楚庄王落马。唐狡上，起打，先蔑下。四龙套同上，开打，同下。楚庄王看。）"
        },
        {
          "character": "楚庄王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "孤被先蔑挑下马，"
        },
        {
          "character": "楚庄王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "忽然闪出年少娃。"
        },
        {
          "character": "楚庄王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "孤王怎么就不认识他？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（先蔑上，唐狡追上，打，擒先蔑，下。连尹襄老上。）"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓。爱卿，孤的马呢？"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王的马，叫先蔑扎死啦。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你的马呢？"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我的马？昨夜就跑啦！"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家，摆驾回营。"
        },
        {
          "character": "连尹襄老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（楚庄王、连尹襄老同下。）"
        }
      ],
      "interactions": [
