          "musical_style": null,
          "style_family": null,
          "text": "丫鬟！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟允。）"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "捧定香炉，带路花园。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "昨夜晚一梦甚跷奇，"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "斗大红星坠落在房里。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "不知凶来主何吉。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "双膝跌跪在丹墀。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "夜梦红星是跷奇，"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "不知凶来主何吉？"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "到花园叩神祗。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "且坐花园散心机。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵上。）"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "肚中饥饿路难往，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "身上寒冷实难挡。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "抬头只见大门墙。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺薛平贵，乃长安人氏，时运不佳，落在乞讨之中。来此已是王相府花园门首，"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我打睡片时便了。正是："
        },
        {
          "character": "薛平贵",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "一心推开心头事，昏昏沉沉睡阳台。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵睡。）"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟，我闷坐花园，哪里玩耍才好？"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "花园门外玩耍。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此带路。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐大事不好了。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事惊慌？"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "外面有火。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我看来。"
        },
        {
          "character": "丫鬟你远看、丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是火。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你近看，"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是一花郎。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将那花郎唤醒，带进花园，奴有话问。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "花郎醒来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵醒。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来丫鬟姐，唤我何事？"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我家小姐有话问你。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳了，丫鬟姐带路。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "难人参见小姐。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住，看这花郎，两耳垂肩，双手过膝，后来必有大贵，为何落在乞讨之中？"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我自有道理。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这花郎，家住哪里？姓甚名谁？一一讲来，要周济于你。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐容禀！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "小姐在上容我禀，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "细听难人说分明："
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "父母早已命归西。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "薛平贵就是我的名。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "家住本国长安地"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "若问小生名和姓"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "听他言来自思忖，"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "看他不像受苦人："
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "龙眉凤目帝王尊。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "想必应在花郎身。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "家住本国长安地"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "若问小生名和姓"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家住本国长安地"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若问小生名和姓"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "又恐丫鬟一旁听。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "家住本国长安地"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "若问小生名和姓"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟请些银米过来，周济花郎，快去。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两耳垂肩贵相品"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夜梦红星是有准"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "彩楼之事对他论"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟下。）"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那一花郎，我听你言父母双亡，家中可有……"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有什么？"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可有妻室否？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐说哪里话来，落在乞讨之中，哪有银钱娶妻室呢？"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴有一言，不好启齿。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐有何金言，当面赐教。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我父亲为我终身大事，二月二日，在十字街前，高搭彩楼，抛球招婿。你若前"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "去，倘若姻缘有分，亦未可知。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "里面都是王孙公子，哪有花郎之分？"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "二月二日事有准，"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "切莫错过这光阴。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "便是蟠桃会上人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟上。）"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐，银米在此。"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "付于花郎去罢。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢小姐。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "辞别小姐出园门，"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转来。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "小姐有话快些言。"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "你若不来失了信，"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "休做忘恩负义人。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "小姐不必细叮咛，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "平贵岂是无义人？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵下。）"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "奴家婚姻天注定，"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "二月二日定终身。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏、丫鬟同下。）"
        }
      ],
      "interactions": [
