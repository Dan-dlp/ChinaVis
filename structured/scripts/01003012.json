      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四游人同上。）"
        },
        {
          "character": "游人甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在我这里——无有吓！"
        },
        {
          "character": "游人乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在我这里——无有吓！"
        },
        {
          "character": "游人丙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在我这里——无有吓！"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在我这里——无有吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵上。）"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在这里。"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "与你两百钱，卖于我吧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵下。）"
        },
        {
          "character": "游人甲",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "王孙公子，"
        },
        {
          "character": "游人乙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "不如花子；"
        },
        {
          "character": "游人丙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "花掉了银子，"
        },
        {
          "character": "游人丁",
          "line_type": "念",
