      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏、四丫鬟同上。）"
        },
        {
          "character": "王宝钏",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "在后堂辞别了二老爹娘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四游人同上。）"
        },
        {
          "character": "王宝钏",
          "line_type": "唱",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "手扶着栏杆——"
        },
        {
          "character": "王宝钏",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "看端详："
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四游人同喝。月老引薛平贵同上。）"
        },
        {
          "character": "王宝钏",
          "line_type": "唱",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "因何故不见薛平郎？"
        },
        {
          "character": "四游人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "不要回去。"
        },
        {
          "character": "王宝钏",
          "line_type": "唱",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "回府去怎对二爹娘？"
        },
        {
          "character": "王宝钏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看彩球！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏拿球。）"
        },
        {
          "character": "王宝钏",
          "line_type": "唱",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "手拿彩球朝下打，"
        },
        {
          "character": "月老",
          "line_type": "唱",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "彩球付于薛平郎。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四游人、薛平贵同下。）"
        },
        {
          "character": "王宝钏",
          "line_type": "唱",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "耳边厢听得人喧嚷，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王宝钏、丫鬟同下。）"
        }
      ],
