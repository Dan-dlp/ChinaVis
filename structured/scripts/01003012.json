      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四游人同上。）"
        },
        {
          "character": "游人甲",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "春游芳草地，"
        },
        {
          "character": "游人乙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "夏赏绿荷池。"
        },
        {
          "character": "游人丙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "秋饮黄花酒，"
        },
        {
          "character": "游人丁",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "冬吟白雪诗。"
        },
        {
          "character": "四游人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。今有王相府，高搭彩楼，抛球招婿。你我前去走走，请了请了。"
        },
        {
          "character": "游人甲",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "二月二日龙抬头，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官上。）"
        },
        {
          "character": "游人乙",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "三姐打扮上彩楼。"
        },
        {
          "character": "游人丙",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "但愿彩球到我手，"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位，"
        },
        {
          "character": "游人丁",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我与三姐轧姘头。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们各位可是接彩的？请进。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（三游人同下。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这老头儿做什么？"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我也是接彩的。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你年纪大了，不能进去的。"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我人老心不老。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不能进去。"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我与你商量商量：没有胡子，可能进去？"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "等你没胡子，再作商量。"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "剃头的等着。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（游人丁下。薛平贵上。）"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "急急忙忙往前行，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "高打彩球闹盈盈。"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "迈步且把花园进"
        },
        {
          "character": "门官",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "胆大花郎哪里行？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我是来接彩的。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "里面俱是王孙公子，哪有花郎之份？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他们接他们的，我也好接的。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不许你进去。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "偏要进去。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赶出去！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不好了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（哭板） 听说门官不放进，"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "唬得我胆战心又惊。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（月老上。）"
        },
        {
          "character": "月老",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "这旁来了一仙翁。"
        },
        {
          "character": "月老",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我今带你彩楼前。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵、月老同下。游人丁上。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这老头儿又来了，这只手怎么不放下来？"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "放下来有点难为情。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不要紧。"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我就放下来。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这胡子哪里去了？"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "剃头的没有，找了一个修脚的，一根一根的修去了。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "还是不能进去。"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么讲？"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到底年纪大了。"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我有个脾气，你让我不进去，我偏要进去；你叫我进去，我就不进去了。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，我来试验试验。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老头子，我不让你进去——"
        },
        {
          "character": "游人丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我偏要进去！"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我让你进去吧——"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（游人丁溜进，下。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我上了他的当了。"
        }
      ],
