    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "张辽",
        "曹操",
        "荀彧"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操、众人同上。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "统领雄师龙虎斗，\n将士英勇战徐州。\n文远顺说未回头。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张辽上。）"
        },
        {
          "character": "张辽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "千军容易得，一将最难求。"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "去说关羽一事如何？"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽约下三事：一者降汉不降曹。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈……吾为汉相，汉即我也，此可从之。二事？"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二夫人请给皇叔俸禄，一应上下人等，皆不许擅入内室。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾于皇叔俸内，更加倍与之。至于严禁内外，乃是家法，又何疑焉！三事？"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但知玄德信息，虽远必往。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "然则吾养云长何用？此事难从。"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相岂不知豫让之论乎？刘玄德待关羽不过恩厚，丞相更施厚恩，以结其心，\n何忧云长之不服也。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "文远之言甚当，吾愿从三事。"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请丞相传令，撤回本部人马。"
        },
        {
          "character": "荀彧",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢，不可退兵，恐其有诈。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "云长乃义士，必不失信。文远传我将令，将人马退后十里，各归本部。"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张辽下。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "掩门。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
