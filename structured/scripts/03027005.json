    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "旗牌",
        "曹真",
        "王朗",
        "郭淮"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。四龙套、王朗、郭淮、曹真同上。）"
        },
        {
          "character": "曹真",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "奉命西征，"
        },
        {
          "character": "王朗",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "仗智谋，"
        },
        {
          "character": "郭淮",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "大战蜀兵。"
        },
        {
          "character": "曹真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "军师、将军请坐！"
        },
        {
          "character": "王朗、郭淮",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有坐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌上。）"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见元帅！"
        },
        {
          "character": "曹真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你下书，那诸葛亮怎样回答？"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那诸葛亮言道：修书不及，照书行事。"
        },
        {
          "character": "曹真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下面歇息。"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢元帅！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌下。）"
        },
        {
          "character": "曹真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊军师，明日与蜀兵交战，必须定计而行方可取胜。"
        },
        {
          "character": "王朗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "元帅明日出兵，务要严整队伍，大展旌旗，只要老夫阵前一席言语，顺说孔明，"
        },
        {
          "character": "王朗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "管教他不战而降也。"
        },
        {
          "character": "曹真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此就命郭将军点动人马，旌旗务要鲜明，军士俱要强壮，刀枪明亮，鼓角整"
        },
        {
          "character": "曹真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "齐，五更造饭，天明起兵，不得有误！"
        },
        {
          "character": "郭淮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（郭淮下。）"
        },
        {
          "character": "曹真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "心中恼恨诸葛亮，"
        },
        {
          "character": "王朗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "纵有机谋也无妨。"
        },
        {
          "character": "曹真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "明日阵前来较量，"
        },
        {
          "character": "王朗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "管叫他马前来归降。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
