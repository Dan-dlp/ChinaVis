      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。四龙套、四上手、马岱、高翔同上。）"
        },
        {
          "character": "马岱、高翔",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俺——"
        },
        {
          "character": "马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马岱。"
        },
        {
          "character": "高翔",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "高翔。"
        },
        {
          "character": "马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "高翔",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "马岱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奉了丞相将令，在祁山左右扎下营寨，准备截杀曹兵，就此前往！"
        },
        {
          "character": "高翔",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
