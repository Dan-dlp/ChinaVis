  "scenes": [
    {
      "scene_index": 1,
      "label": "全剧",
      "characters_present": [
        "众将官",
        "单通",
        "太监",
        "尉迟恭",
        "徐绩",
        "李世民",
        "李元吉",
        "李建成",
        "秦琼",
        "程咬金",
        "花神",
        "谢映登",
        "门官乙",
        "门官甲"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将官引单通同上。）"
        },
        {
          "character": "单通",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "执掌兵权，貔貅百万。"
        },
        {
          "character": "单通",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "身披铠甲透玲珑，匹马大槊逞英雄。忆昔当年放响马、反隋主，曾作南朝驸马"
        },
        {
          "character": "单通",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "公。"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，单通，今有建成、元吉书信到来，命俺到御果园劫杀二主唐童。今乃黄道"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吉日，正好发兵。"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官！"
        },
        {
          "character": "众将官",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兵发御果园！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将官同应。〖二犯江儿水〗。众人同下。〖吹住〗。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "门官乙 （内同白） 啊咳……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官甲、门官乙同上。）"
        },
        {
          "character": "门官甲",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "家里打车。"
        },
        {
          "character": "门官乙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "外头合辙。"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官，官是也。"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官，也是官。"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "官请了。"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了官。"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀官吓！"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀官！"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我奉了二位千岁之命，看守御果园，说有一个单通在此经过，你我伺候他过"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "去，就交了差了。"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我不认得他？"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "等他来了，我说与你就是了。"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我打坐等着他。"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "等着他"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（单通领众将官同上。〖江儿水〗。）"
        },
        {
          "character": "众将官",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "已到御果园。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹住〗。）"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "埋伏了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（单通下。）"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀官哪！你看见了没有？一个菠菜糖手里拿大菜瓜过去啦。"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得啦，那就是单通。"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那就是单通？"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗳。"
        },
        {
          "character": "门官乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我算交差啦。"
        },
        {
          "character": "门官甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我后面饮酒去。走！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官甲、门官乙同下。秦琼、谢映登、程咬金同上。）"
        },
        {
          "character": "秦琼",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "手持双锏坐黄骠，"
        },
        {
          "character": "谢映登",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "白马银枪逞英豪。"
        },
        {
          "character": "程咬金",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "上阵全凭加钢斧，"
        },
        {
          "character": "秦琼、谢映登、程咬金",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "赤胆忠心保唐朝。"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺秦琼。"
        },
        {
          "character": "谢映登",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺谢映登。"
        },
        {
          "character": "程咬金",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺程咬金。"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众家弟兄请了。"
        },
        {
          "character": "谢映登、程咬金",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有老主染病在床，命三位殿下在御果园箭射金钱，只用文官，不用武将，不"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "知所为何事？"
        },
        {
          "character": "程咬金",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "秦二哥，这样大事，你都不晓得？"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不晓得。"
        },
        {
          "character": "程咬金",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "附耳过来。"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "讲说什么？"
        },
        {
          "character": "程咬金",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "连我也不晓得。"
        },
        {
          "character": "谢映登",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且到临时再做道理。正是："
        },
        {
          "character": "谢映登",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "丹心扶社稷，"
        },
        {
          "character": "秦琼、程咬金",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "赤胆保明君。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼、谢映登、程咬金同下。徐绩上。）"
        },
        {
          "character": "徐绩",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "一片丹心扶社稷，两条眉锁庙堂忧。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官徐绩，今有老主染病在床，命三位殿下在御果园，箭射金钱，哪家射得，"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "即登大宝。"
        },
        {
          "character": "太监",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "道言未了，三家殿下来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李建成、李元吉、李世民同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "李世民 （同引子） 凤阁龙楼，万古千秋。"
        },
        {
          "character": "太监",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "万国衣冠祝圣明，四海宁靖庆生平。清香一炷朝天地，文武百官赞此行。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本御建成。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本御世民。"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本御元吉。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今日父王染病在床，命我弟兄三人去到御果园，箭射金钱，哪家射得，即登大"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宝。"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嘿！皇兄，还是你我射中方好。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这个自然。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "军师。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "车马可曾齐备？"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "齐备多时了。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐起驾！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监应。）"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "起驾。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖玉芙蓉〗。众人同下。花神上。）"
        },
        {
          "character": "花神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃花神是也。今有二主御果园有难，不免差二鬼前去护救。"
        },
        {
          "character": "花神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二鬼何在？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二小鬼同上。）"
        },
        {
          "character": "花神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有二主御果园有难，命你二人前去护救，不得有误。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二小鬼同应，花神、二小鬼同下。太监领李建成、李元吉、李世民、徐绩同上。）"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是御果园，哪家御弟先请。"
        },
        {
          "character": "李世民、李元吉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "还是皇兄先请。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀。还是我先射，如此看弓来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖片子〗。李建成射箭。）"
        },
        {
          "character": "李世民、李元吉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "皇兄怎么样了？"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弓不曾拉开，我小肠串气疼。我不行！看你们的吧！"
        },
        {
          "character": "李世民、李元吉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "没你的天份。"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇兄请。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我想，有兄就有弟，御弟请。"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此，看弓箭来。哎呀！"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "御弟怎么样了？"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我弓不曾拉开，掰了我的膀子。"
        },
        {
          "character": "李世民、李建成",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "没有你的天份。"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇兄请！"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇兄，御弟都不曾射着，小弟不射也就罢了。"
        },
        {
          "character": "李元吉、李建成",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哪有不射之理？"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既如此，看弓箭过来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李世民将金钱射掉。单通上。）"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里走！"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇兄。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "御弟。"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "单通杀红了眼了，连你我全杀起来了。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我到哪里藏躲？"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "后宫里跑吧！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李建成、李元吉同下，李世民追单通同上，单通用槊打李世民，二小鬼同上抱住槊。）"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里走！"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "单通慢动手！"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么人拉住俺单通？"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官徐绩。"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "当初降唐，为何不用俺单通。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "念结拜之情。"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，念结拜之情？也罢，俺与你割袍断义！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（单通下。）"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！看单通这厮与我割袍断义，这便如何是好？待俺袖占一课……"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吖哈有了，今有敬德在澄澄涧洗马，俺不免急急赶上前去，命他救驾便了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐绩下。李世民上。）"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀不好！看单通这厮追俺正紧，这便如何是好？吖呵也罢！不免下得马去，"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "藏在花棵之下便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李世民下，单通上。）"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！看唐童这厮藏在花棵之下，俺不免下得马去，卸了铠甲，擒他便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（单通下。尉迟恭上。）"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊哈……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（醉花阴） 统领貔貅提鞭叫，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "我恨、恨乌鸦疆场也那乱扰；"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "两军前鞭枪齐搅。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "方显得英雄年少。"
        },
        {
          "character": "尉迟恭",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "金叶乌甲黑幞头，当初扶保刘武周。大战罗成回来路，难免敬德脸面羞。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，尉迟敬德。我与军师赌头争印，大战罗成。我若胜得罗成，他将军师牌印，"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "输与俺掌管。若俺胜不得罗成，将俺项上人头就输与他！哎！偏偏败下阵来，"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无有颜面去见军师。今当五月五日，乃是息兵的日期，俺不免去澄清涧洗马"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一回。呀！来此已是澄清涧，好一片清泉，待俺洗马一回。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖工尺上〗。）"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吖呵马呀！当年扶保刘武周，跳红尾涧的时节，你那威风劲往哪里去了？我与"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "军师赌头争印，大战罗成，偏偏的你就败下阵来。我对你说，再要上得阵去，"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将你那口张的大大的，你那么一口，叨下他马来。赢了军师牌印，挂在你的胸"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前，你也威风、威风，煞气、煞气！记住了，记住了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖马叫声〗。）"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，看这孽畜也使起性儿来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（喜迁莺） 这马儿心中焦躁，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "乍鬃尾，如狼似豹。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "哮也么哮。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "好叫俺，怒发冲霄。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "方显得，赌赛功高。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看天气炎热，不免把俺的身体也沐浴沐浴。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖工尺上〗。徐绩上。〖吹住〗。）"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "敬德，敬德！"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！什么人大胆，叫我一声敬德，待我看来。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吖！原来是军师，你到此何事？"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二主御果园有难，命你前去救驾。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你把此话来哄谁，分明把俺诓上岸去，想要这个买卖儿，那是万万的不能。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你若不信，这有军令状。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在哪里？"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我与你扯碎！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐绩撕碎军令状，下。）"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哇呀……哎呀！二主有难，俺不免前去救驾便了！我赶，赶！赶！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（水仙子） 赶那厮无处逃，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "怎、怎、怎，怎把那军状撕碎了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "快、快、快，快去救驾莫迟疑。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "备、备、备，备不上乌骓马鞍桥。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "这、这、这，这的是韂马单鞭救驾走。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（尉迟恭下。秦琼上。）"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺秦琼。二主御果园有难，赶上前去救驾便了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦琼下。单通追李世民同上，尉迟恭上，将单通打下。谢映登上。）"
        },
        {
          "character": "谢映登",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二主有难，赶去救驾便了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（谢映登下。单通追李世民同上。）"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "单通，饶恕孤家，封你为段国公。"
        },
        {
          "character": "单通",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "长国公也不饶！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（尉迟恭上，将单通打下。）"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！你看单通这厮，我家千岁封他为段国公，他听到哪里去了，说什么长国"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公也不饶。呔！单通啊单通，你黑爷爷将你赶上，打你个长短不齐！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（尉迟恭下。程咬金上。）"
        },
        {
          "character": "程咬金",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺程咬金救驾哟！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程咬金下。尉迟恭追单通同上，将单通打死。李世民、秦琼、谢映登、程咬金、徐绩同上。）"
        },
        {
          "character": "秦琼、谢映登、程咬金、徐绩",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "主公醒来，主公醒来。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何人救驾？"
        },
        {
          "character": "秦琼、谢映登、程咬金、徐绩",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "敬德。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命他见孤。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "敬德快来。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来了，来了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（尉迟恭遮脸。）"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁命你见驾。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "军师，你看我赤身露体难以见驾。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我与你去奏。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你就去奏，见不得驾。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启千岁：敬德赤身露体，难以见驾。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢，将孤家龙袍赏与他遮盖身体。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "拿过来。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔！军师，千岁爷，龙袍小咱的身体大。顾了上半截顾不了下半截。"
        },
        {
          "character": "徐绩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遮了下半截见驾要紧。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "军师前行。嘿！遮下半截见驾要紧。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "敬德见驾来迟，愿我主千岁，千千岁。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "救孤功劳不小，封你为一字降唐鄂国公。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢万岁。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
