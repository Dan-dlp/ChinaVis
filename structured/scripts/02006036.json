          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙悟空、猪悟能同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "猪悟能→孙悟空",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
