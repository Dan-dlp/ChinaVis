      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二侍卫同上。）"
        },
        {
          "character": "二侍卫",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "堂上一呼，阶下百诺。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖水底鱼〗。廉颇、李贤同上。）"
        },
        {
          "character": "廉颇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是蔺相府。"
        },
        {
          "character": "廉颇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪位在？"
        },
        {
          "character": "二侍卫",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是廉老将军。"
        },
        {
          "character": "廉颇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你带我去见大人。"
        },
        {
          "character": "二侍卫",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "小人不敢自专，需要通禀。"
        },
        {
          "character": "廉颇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太啰嗦了。你我闯了进去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廉颇推倒二侍卫，廉颇、李贤同下。）"
        },
        {
          "character": "二侍卫",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "将军慢走，待我通禀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二侍卫同追下。）"
        }
      ],
      "interactions": [
