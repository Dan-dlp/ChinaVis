          "style_family": null,
          "text": "大庭广众之下，百般凌辱，以泄我心头之恨。"
        },
        {
          "character": "廉颇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "校尉们。今日站在街前，蔺相如到来，莫让他过去。"
        },
        {
          "character": "廉颇",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "恨赵王无皂白赏罚太滥，"
        },
        {
          "character": "廉颇",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "把一个白郎竟作高官。"
        },
        {
          "character": "廉颇",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "定名位我在后他反在前。"
        },
        {
          "character": "廉颇",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "屈服在书生下心实不甘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "廉颇→李贤",
          "turns": 2
        },
        {
          "edge": "李贤→廉颇",
          "turns": 2
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "白": 5
        },
        "singing_ratio": 0.0,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮原板"
        ]
      },
      "scene_feature": [
