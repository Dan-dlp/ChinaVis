    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "兵卒",
        "李贤",
        "蔺相如"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（蔺相如上。）"
        },
        {
          "character": "蔺相如",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "心儿里最可气将军廉颇，"
        },
        {
          "character": "蔺相如",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "任私意全不管百姓死活。"
        },
        {
          "character": "蔺相如",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "国不和又恐怕敌人知觉。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李贤上。）"
        },
        {
          "character": "李贤",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "可笑那廉将军性烈如火，"
        },
        {
          "character": "李贤",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "无端地起下了平地风波。"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "门上哪位在？"
        },
        {
          "character": "兵卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么人？"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "烦劳通禀：下大夫李贤求见。"
        },
        {
          "character": "兵卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "候着。"
        },
        {
          "character": "兵卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启大人：下大夫李贤求见。"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见大人。"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大夫少礼。请坐。"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可恼呀，可恼。"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大夫因何烦恼？"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闻得那廉颇老儿与大人作对，下官心甚不平。"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一殿为臣，哪有此事。外人之言，不可听信。"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官非听过耳之言，亲见廉颇挡道，大人回避，难道怕他不成？"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我且问你，廉将军厉害得过秦王么？"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "秦王那样厉害，六国诸侯，谁人不怕。廉将军怎比得呢？"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想本公在秦庭之上，归我玉璧。渑池会中逼他击缶。那时兵似兵山，将似将海，"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本公一毫不惧。偏偏今日害怕廉将军吗？"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既不害怕，避他何为？"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本公并非怕他，诚恐赵国受累。我再问你，秦王想吞赵不想？"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么不想，他是想吞不敢吞。"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么不敢？"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怕大人与廉将军。"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "着哇！自古常言：两虎相斗，必有一伤。我和廉将军争闹，教秦国闻知，若得"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "了赵国，无论何人都要受辱。我且问你，到那时还能争强夺气吗？我把国家看"
        },
        {
          "character": "蔺相如",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得重，私仇何用挂在心。情愿让廉颇，不愿亡赵国。"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听了这些教训，大臣都要先公而后私。下官闻此金玉之言，不禁五体投地。似"
        },
        {
          "character": "李贤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那般口谈国利民福，其实是自私自利，岂不愧煞。就此告别了。"
        },
        {
          "character": "李贤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "实服了蔺相如真有韬略，"
        },
        {
          "character": "李贤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为国家敌外人甘让廉颇。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李贤下。）"
        },
        {
          "character": "蔺相如",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我当初也不过区区门客，"
        },
        {
          "character": "蔺相如",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "又何必妄自尊不顾赵国。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（蔺相如下。）"
        }
      ],
      "interactions": [
        {
          "edge": "蔺相如→李贤",
