      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴稚卿、李慧娘同上。）"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "这一时唬得我三魂不见，"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "心中好一似滚油煎。"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "手拉裴生花墙外，"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "应忠二次杀你来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廖应忠追裴稚卿、李慧娘同上，同转场。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李慧娘拉裴稚卿上椅子，李慧娘戴鬼脸，廖应忠吓倒。李慧娘、裴稚卿裴同下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廖应忠起身。）"
        },
        {
          "character": "廖应忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看裴生身旁，好似慧娘鬼魂。打鬼，打鬼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廖应忠下。）"
        }
