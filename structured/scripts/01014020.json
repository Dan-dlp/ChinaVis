          "character": "李慧娘",
          "line_type": "西皮正板",
          "musical_style": "西皮正板",
          "style_family": "西皮",
          "text": "拔宝剑杀得我命丧黄泉。"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮正板",
          "musical_style": "西皮正板",
          "style_family": "西皮",
          "text": "蒙判爷赐宝扇对我来言。"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮正板",
          "musical_style": "西皮正板",
          "style_family": "西皮",
          "text": "我不免到书馆成就姻缘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李慧娘走浪头三次，俏步转身戴鬼脸。三锣。李慧娘下。）"
        }
      ],
