    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "李慧娘",
        "裴稚卿"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴稚卿上。）"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "那一日在西湖闲游散闷，"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "又谁知贾平章他知我名。"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "留至在书馆内攻读书文。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李慧娘上。）"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "阎王殿前把我差，"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "去到书馆赴阳台。"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "开门来！"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，黑夜之间，是何人叫门？"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "开门来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴稚卿开门。李慧娘进门。裴稚卿两旁张望。）"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "并无有人，想是书童进来，待我将门闭上。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴稚卿进门，与李慧娘对面。）"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，你从哪里进来的呀？"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我从门里进来的。"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我为何不曾看见？"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "灯影之下，你怎能看得分明？"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是何人，前来做甚？"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我是府中侍女，特来与你解闷来了。"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "裴生说话真奇怪，"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "细听奴家说开怀："
        },
        {
          "character": "李慧娘",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "奴为你懒把绣鞋穿。"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "谁知你是一个无义郎才。"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "奴为你懒用茶和饭"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "只道书生是青云客"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你住了吧！黑夜之间，你是一女子，来到我的书馆，倘若叫人看见，多有不便！"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴为你懒用茶和饭"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只道书生是青云客"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "倘若被人来看见，"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "叫我怎样把话言？"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "奴为你懒用茶和饭"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "只道书生是青云客"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你快走了去吧！"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "有慧娘，用目观，"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "看看裴生好容颜。"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "不顾羞耻拉衣衫。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李慧娘做拉头三次。）"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "裴生不从婚姻事，"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "眼前就有大祸端。"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你若不从，眼前就有杀身大祸！"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦喝是了，想是那平章，叫你前来调戏与我。我若从了，那平章岂能将我饶恕？"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你快快走了出去！"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我且问你，那日你游西湖，见一佳人，给你丢下绢帕，你可记得？"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那是慧娘，我是怎生不记得？"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你可想见此人么？"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那是自然。"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你远看……"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无有人呀！"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你近觑……"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "莫非你就是慧娘？"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不敢！"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待我掌灯细细看来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴稚卿取灯照李慧娘。）"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "果然不差，请坐。"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告辞！"
        },
        {
          "character": "裴稚卿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你往哪里去？"
        },
        {
          "character": "李慧娘",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "倘被人看见，多有不便！"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "慧娘说话理不端，"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "细听小生说根源"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我与你成就了姻缘事"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我二人上牙床倒凤颠鸾。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴稚卿、李慧娘同入帐，同下。）"
        }
      ],
