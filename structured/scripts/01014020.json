      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（裴稚卿上，李慧娘随上。）"
        },
        {
          "character": "裴稚卿",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "惊死人来唬死人，"
        },
        {
          "character": "李慧娘",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "苦苦求他为何情？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廖应忠追上。李慧娘、裴稚卿、廖应忠同冲场。裴稚卿、李慧娘同下。）"
        },
        {
          "character": "廖应忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看裴生身旁有一人影，不知他是何人。待我点起火把来杀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廖应忠持火把。裴稚卿、李慧娘同上。裴稚卿、李慧娘、廖应忠同翻跟头，末场撰虎攒下。）"
        }
