      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四绿文堂、四大铠、周仓、旗牌、关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "三江口鏖兵决战。捉拿曹贼交令还。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽坐。）"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "平生志性烈如钢，读春秋暗习阴阳，使青龙上将命丧，炎汉中盖世无双。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某，汉寿亭侯关。只因三江口赤壁鏖兵，火烧战船，曹贼兵败。吾奉军师之命，\n埋伏华容小道，阻挡曹操。\n小校带马！"
        },
        {
          "character": "关羽",
          "line_type": "西皮慢原板",
          "musical_style": "西皮慢原板",
          "style_family": "西皮",
          "text": "楚汉相争数十载，\n王莽起意篡龙台。\n五百年前接下来。\n犹如同母共娘胎。"
        },
        {
          "character": "关羽",
          "line_type": "西皮垛板",
          "musical_style": "西皮垛板",
          "style_family": "西皮",
          "text": "北地曹操领兵来。\n满营将官俱有差；\n因此上打赌满胸怀。\n耀武扬威到此来。\n不知曹贼来不来。"
        },
        {
          "character": "光武中兴国号改、弟兄桃园三结拜、东吴孙权守疆界、我家军师挂了帅、不差关某心不爱、绿袍罩定黄金铠、叫小校将人马下了寨、四绿文堂、四大铠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来在华容道。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "放起烟墩，曹操到此，速报我知。⑴"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖慢长锤〗。曹操领许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同上。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "曹孟德在马上长思短叹，⑵\n手捶胸眼落泪口怨苍天。\n实指望取荆州来夺江南。\n诸葛亮那妖道诡计多端；\n那蒋干引庞统来献连环；\n哪晓得诸葛亮扭转先天。\n只剩下一十八骑残兵败将好不惨然！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "于禁 （同西皮散板） 丞相发笑为哪般？"
        },
        {
          "character": "曹操",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "我笑周郎见识呆，\n诸葛亮用兵无大才。\n你我主将无处葬埋。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内喊声，鼓声。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "曹操",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "一言未尽人马喊，\n想必是此地有安排。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，看看什么旗号。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同看。）"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是关公旗号。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢天谢地。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "到了绝地，还谢甚么天地？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们哪里知道，当初那关公，在许昌许我三不死，难道一次也不饶么？"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "我们杀不得了。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用你们杀了。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "也战不得了。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也不用你们战了。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么样？"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们在此养伤。待老夫向前百般哀告于他，或可放你我主将逃走，也未可知？"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相小心了。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我知道。"
        },
        {
          "character": "曹操",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "听说是来了关美髯，\n许昌一别君侯有几年。"
        },
        {
          "character": "忽然一计上眉间、走向前把礼见、旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启爷：曹操到。"
        },
        {
          "character": "关羽",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "耳边厢又听得人厮马闹，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽上高台。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，君侯请了。"
        },
        {
          "character": "关羽",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "皱蚕眉睁凤眼仔细观瞧。"
        },
        {
          "character": "狭路上莫不是冤家来到、曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我乃旧日故交，今逢怎说“冤家”二字？"
        },
        {
          "character": "关羽",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "奉军命谁认你旧日故交。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗐，我曹操倒运，这样的好朋友，都不认了。哎呀，罢了罢了。"
        },
        {
          "character": "关羽",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "汉朝中论奸雄就是曹操，"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢岂敢。"
        },
        {
          "character": "关羽",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "他一派假殷勤笑内藏刀。\n俺今日用命时你何须发笑？\n奉军命捉拿你谁肯恕饶。"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "曹孟德听一言满脸赔笑，\n尊一声汉君侯细听根苗：\n实指望扫江东得胜还朝。\n烧得我主将们无处奔逃。\n望君侯念旧情放我奔逃。"
        },
        {
          "character": "下江南领八十三万人马不少、又谁知小周郎多端计巧、只剩下一十八骑残兵来到、关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小校查来。"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹操人马站齐了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同站。）"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一五，一十，十五，一、二、三。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我也是在数的。"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启爷！连曹操在内，共有一十八骑残兵败将。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不多？"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不多。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不少？"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不少。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "军师啊，军师！你枉能会算，却不能所料。慢说他一十八骑残兵败将，他就是\n十八只猛虎，我何惧哉！"
        },
        {
          "character": "关羽",
          "line_type": "西皮过板",
          "musical_style": "西皮过板",
          "style_family": "西皮",
          "text": "料着他好一似鱼儿吞钓，⑶\n伤弓鸟纵插翅也难脱逃。"
        },
        {
          "character": "曹操",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "想当初待君侯恩高义好，\n上马金下马银酒宴多姣；\n望君侯释放我性命一条。"
        },
        {
          "character": "官封你汉寿亭侯爵禄不小、关羽",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "你虽然待我的恩高义好，\n我也曾报过你十大功劳。\n将印信挂高梁封金辞曹。"
        },
        {
          "character": "斩颜良诛文丑立功报效、曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我也曾送文凭差人去到，\n临行时在灞桥赠君红袍。"
        },
        {
          "character": "关羽",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "休提起送文凭令人可恼，\n杀孔秀刺孟坦王植被枭；\n谢丞相空人情不在心梢。"
        },
        {
          "character": "诛卞喜斩秦琪文凭才到、曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "在灞桥许下我云阳相报，\n你本是大丈夫怎忘故交？\n为何不饶这头一遭。"
        },
        {
          "character": "你许饶曹三不死、关羽",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "非是我忘却了云阳相报，\n因为你这奸雄罪恶难逃。\n挟天子令诸侯势压群僚。\n你这奸贼起逆心欲篡汉朝。\n来来来受吃我青龙钢刀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周仓用刀指。曹操哭。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "曹孟德马上泪涟涟，\n尊一声汉寿亭侯听我言：\n百般哀告也枉然。\n你枉有个名儿天下传。"
        },
        {
          "character": "往日里恩情无半点、杀曹操不过污秽一席地、关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": "往日里恩情无半点、杀曹操不过污秽一席地、关羽",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "往日里杀人不眨眼，\n铁打心肠软如棉。\n前思后想是枉然。\n宁可人头挂高杆。\n释放曹贼回中原。"
        },
        {
          "character": "背地里只把军师怨、罢罢罢关某岂作无义汉、叫小校摆下一字长蛇阵、曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么变了卦了？\n来，看看甚么阵势？"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "此乃一字长蛇大阵。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀好了！君侯有释放你我之心，走了吧！"
        },
        {
          "character": "曹操",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "多蒙君侯施恩典，\n才得活命回中原。\n整顿人马再下江南。"
        },
        {
          "character": "老天若遂我的愿、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "不要来了！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张辽拱手。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我不来了。"
        }
      ],
      "interactions": [
