        "singing_ratio": 0.125,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮散板"
        ]
      }
    },
    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "关平",
        "关羽",
        "刘备",
        "刘封",
        "初起首破黄巾功劳不小",
        "四大铠",
        "四文堂",
        "奉军令埋伏在华容小道",
        "张飞",
        "往日威名谁不晓",
        "旗牌",
        "糜竺",
        "糜芳",
        "老母亲赐清泉改换容貌",
        "自幼儿读《春秋》韬略颇晓",
        "诸葛亮",
        "赵云",
        "过五关斩六将立保皇嫂"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、四大铠、诸葛亮、刘备同上。）"
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "鹬蚌相持把兵斗，"
        },
        {
          "character": "诸葛亮",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "我做渔翁得利收。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "主公。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请坐。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生，众将可能成功？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将俱能成功，唯有二将军不能成功。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "倘备二弟有犯军规，望先生谅情一二。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "亮夜观天星，曹贼未合身死，故命二将军前去，做个人情耳。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，先生神算世所罕有，备当面谢过。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞、赵云、关平、刘封、糜竺、糜芳同上。）"
        },
        {
          "character": "张飞、赵云、关平、糜竺、糜芳",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启师爷：末将等奉命战败曹兵，得来马匹器械，特来交令。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将之功。见过主公。"
        },
        {
          "character": "张飞、赵云、关平、糜竺、糜芳",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见主公。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列公少礼。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌上。）"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二千岁回营。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "旗牌",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽上。）"
        },
        {
          "character": "关羽",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "中军帐曾打赌牙关咬碎，\n到如今犯军令怎敢有违。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽欲跪又起。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗳！"
        },
        {
          "character": "关羽",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "生或死又何惧听候军规。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二将军得胜回营，且喜立此盖世之功，除普天下之大害。看酒过来，合宜远接\n庆贺。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳！"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听他言好叫我满面羞愧，"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "莫非怪山人不曾远接？"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "暗地里咬银牙皱断蚕眉。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那曹操有多少人马？"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "剩残兵十八骑有头无尾，"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想是内中无有曹操？"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "正午时华容道来了孟德。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可曾擒来？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎！"
        },
        {
          "character": "关羽",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "顺人情释放了特来请罪，\n军师爷又何必苦苦叮追？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔！"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "昔日里汉高祖丁公斩罪，\n到今日犯军令任凭是谁。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "押下去！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢军师。正是："
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "拼将一死酬知己，致今千秋仰义名。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽下。张飞焦躁，搓手。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刀下留人。\n啊，先生，我桃园结义，誓同生死，望先生容过一次，待他立功赎罪。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "着哇！"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看在主公金面，容过就是。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咱张飞谢军师恕过咱二哥之恩。\n来，将咱二哥请回来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽上。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢军师不斩之恩。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看在主公金面，记过一次。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢大哥。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你带兵三千，暗袭襄阳，将功赎罪。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。\n马来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四绿文堂引关羽同下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生，孤二弟此去，可能成功？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大功必成。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "备仗先生妙算，得众将军之威武，战败曹兵，可得汉室诸土，皆赖列公之力也。"
        },
        {
          "character": "诸葛亮、张飞、赵云、关平、刘封、糜竺、糜芳",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "主公洪福。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，准备酒宴，与先生、众将贺功。"
        },
        {
          "character": "诸葛亮、张飞、赵云、关平、刘封、糜竺、糜芳",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主公。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "赤壁鏖兵用火攻，烧退曹贼百万兵。"
        },
        {
          "character": "诸葛亮",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "周郎枉费千般计，"
        },
        {
          "character": "张飞、赵云、关平、刘封、糜竺、糜芳",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "神机妙算好先生。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖尾声〗。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "——————————"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "⑴单唱《挡曹》的唱法："
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "关羽 （内西皮导板） 暗地里笑诸葛做事颠倒，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、四大铠、周仓、马童、关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "出大言欺压咱藐视吾曹。\n为不平斩熊虎怒诛土豪。\n走范阳才结拜生死故交。"
        },
        {
          "character": "关羽",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "酒未寒斩华雄初使宝刀。\n古城下斩蔡阳匹马单刀。\n可恨诸葛藐吾曹。\n今日里主意定捉拿奸曹。"
        },
        {
          "character": "自幼儿读《春秋》韬略颇晓、老母亲赐清泉改换容貌、初起首破黄巾功劳不小、过五关斩六将立保皇嫂、往日威名谁不晓、奉军令埋伏在华容小道、四大铠、四文堂",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "来此华容道。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "放起烟火，曹贼到此，速报我知。"
        }
      ],
