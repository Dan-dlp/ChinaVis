    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "四文堂",
        "曹仁",
        "曹操"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹操、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同上。）"
        },
        {
          "character": "曹操",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "曹操兵败走华容，\n正与关公狭路逢。\n放开金锁走蛟龙。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内呐喊声。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "曹操",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "耳边又听鼓咚咚，\n想是曹操命该终。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、曹仁同上，曹仁下马。）"
        },
        {
          "character": "曹仁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "末将曹仁，迎接丞相。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹子孝，嗐，孤几与汝不能相见了！"
        },
        {
          "character": "曹仁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闻得丞相兵败，末将镇守南郡，不敢远离。特在附近迎接，丞相恕罪。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今已到南郡，正好歇马。汝何罪之有？就此兵撤南郡。"
        },
        {
          "character": "曹仁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。\n众将官，兵回南郡。"
        },
        {
          "character": "四文堂",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹仁、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁、四文堂同扯斜，分开。曹操进城，下。）"
        }
      ],
      "interactions": [
        {
          "edge": "曹操→曹仁",
          "turns": 3
        },
        {
          "edge": "曹仁→曹操",
          "turns": 2
        },
        {
          "edge": "曹仁→四文堂",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
