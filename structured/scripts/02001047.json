        {
          "character": "海潮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我山人出洞看来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（力士上，走，下。）"
        },
        {
          "character": "海潮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
        },
        {
          "character": "海潮",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "睁慧眼在洞前仔细来观，\n却原来小王翦叩焚香烟。\n孙伯龄杀得他免战高悬。\n方能够秦始皇一统江山。\n叫一声众弟子细听我言。"
        },
        {
          "character": "海潮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众徒儿，"
        },
        {
          "character": "兵行至燕国中身临大难、叩求我遣能人将他扶助、观罢了信香烟进洞打坐、清风、明月",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "师父。"
        },
        {
          "character": "海潮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为师方才观看，香烟过去，却是你师兄王翦，兵至燕国，被天台山孙膑，杀得\n他免战高悬，叩求山人，遣能人下山，破却孙膑，方能进兵。也罢，唤你师兄\n上殿。"
        },
        {
          "character": "清风、明月",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有请师兄。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（毛蕡上。）"
        },
        {
          "character": "毛蕡",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "弃凡学道在深山，八卦炉中看仙丹。"
        },
        {
          "character": "毛蕡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参拜师父。"
        },
        {
          "character": "海潮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一旁坐下。"
        },
        {
          "character": "毛蕡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。师父唤弟子上殿，有何法旨？"
        },
        {
          "character": "海潮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方才山人，心血来潮，掐指一算，却原来是你师弟王翦，兵至燕国，被孙膑杀\n得大败，因此唤你出来，命你下山，扶助秦国，大战孙膑。"
        },
        {
          "character": "毛蕡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "师父，那孙膑法理高强，徒儿非是瘸夫的对手。"
