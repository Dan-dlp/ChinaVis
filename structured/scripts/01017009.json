    {
      "scene_index": 7,
      "label": "第七场",
      "characters_present": [
        "张任"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套引赵云同上，转场，同下。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠、魏延同上，过桥，张任追上。）"
        },
        {
          "character": "张任",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！那贼败下阵去，待我赶上。\n吓！来此已是金雁桥。此桥高大，待我卸甲过桥。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张任脱甲、换靴，上桥。赵云上，枪刺张任，张任翻跟头躲过，与赵云对快枪。张任下，赵云追下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张任上，黄忠、魏延、赵云同追上，群场开打。黄忠、魏延、赵云同下。张飞上，起打。黄忠、魏延、赵"
        }
      ],
      "interactions": [],
      "stats": {
