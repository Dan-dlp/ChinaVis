      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤、呼延赞同上。龙形、虎形同暗上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "赵匡胤 （唢呐二黄散板）人困马乏难交战，"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唢呐二黄散板）只见小将睡雕鞍。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（三笑） 哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唢呐二黄散板）只见猛虎护着他。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "呼延赞 （唢呐二黄散板）梦儿里只见我父到，"
        },
        {
          "character": "呼延赞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唢呐二黄散板）只见昏王睡鞍桥。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（龙形阻。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "呼延赞 （三笑） 哈哈！哈哈！啊哈哈……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（唢呐二黄散板）只见火龙上九霄。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（呼延赞下马。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "呼延赞 （唢呐二黄散板）山呼万岁将臣饶。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "耳边厢又听得山呼万岁，"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "想必是孤国中发来救兵。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "猛然间睁开了丹凤眼"
        },
        {
          "character": "呼延赞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁！"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "又只见小将跪至在马前。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "诓孤下马难上难。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "在马上擒王擒不住"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "万岁爷不必心害怕，"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "呼延赞保你坐中华。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "你若是保孤坐中华，"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "何不对天把誓发？"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "万岁爷命我把誓发，"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "日月三光照着咱。"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "死在千军万马踏！"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "呼延赞保主有假意"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "一见小将把誓发，"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "不由孤王笑哈哈。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "呼延赞保主有假意"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢！"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呼延赞保主有假意"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "金棍挑起小冤家。"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "左思右想不下马"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "走向前来参王驾，"
        },
        {
          "character": "赵匡胤",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "孤王传旨且平身。"
        },
        {
          "character": "呼延赞",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "杀父仇人哪一个？"
        },
