      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（毛蕡、王翦、五雷孕妇同上，同摆阵。孙膑上，入阵。）"
        },
        {
          "character": "孙膑",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "盼想家园难得见，\n寸断肝肠不安然。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（毛遂上。）"
        },
        {
          "character": "毛遂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三哥，小弟盗了金丹来了。"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "盗了多少？"
        },
        {
          "character": "毛遂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "两粒半。"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "与兄一粒，青牛一粒，剩下半粒，贤弟衔在口内。无有太极图，也是枉然。"
        },
        {
          "character": "毛遂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三哥请看。"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好哇！"
        },
        {
          "character": "孙膑",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见图犹如天开眼，\n贤弟恩情重如山。\n（孙膑起，杀。毛蕡、王翦、五雷孕妇同暗下。孙膑用图照。王翦、毛蕡同上，同开打。孙膑打死毛蕡，毛\n蕡下。孙膑擒王翦。太上老君、王禅同暗上。）"
        },
        {
          "character": "打开了太极祥光现、孙膑",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "阵中逃出了大罗神仙。"
        },
        {
          "character": "太上老君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢。他乃奉敕旨之人，不可伤他。"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看在师父面上，饶尔去罢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王翦下。）"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参拜师父。"
        },
        {
          "character": "太上老君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "毛遂，我的太极图呢？"
        },
        {
          "character": "毛遂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢太极图。"
        },
        {
          "character": "王禅",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "毛遂，还我金丹。"
        },
        {
          "character": "毛遂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "金丹，被我三哥吞在肚内了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "太上老君 （同笑） 哈哈哈！"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢师父搭救。"
        },
        {
          "character": "太上老君",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回营去罢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王禅、太上老君同下。）"
        },
        {
          "character": "孙膑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟随我来。"
        },
        {
          "character": "孙膑",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
