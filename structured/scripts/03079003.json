    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "刘彻",
        "卜式"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卜式赶羊群上。）"
        },
        {
          "character": "卜式",
          "line_type": "二黄三眼板",
          "musical_style": "二黄三眼板",
          "style_family": "二黄",
          "text": "我炎汉承天运江山一统，"
        },
        {
          "character": "卜式",
          "line_type": "二黄三眼板",
          "musical_style": "二黄三眼板",
          "style_family": "二黄",
          "text": "恨匈奴寇边庭窥伺华中。"
        },
        {
          "character": "卜式",
          "line_type": "二黄三眼板",
          "musical_style": "二黄三眼板",
          "style_family": "二黄",
          "text": "为输财救边患才得荣封。"
        },
        {
          "character": "卜式",
          "line_type": "二黄三眼板",
          "musical_style": "二黄三眼板",
          "style_family": "二黄",
          "text": "依旧是布衣草履、上苑牧羊、沐雨栉风。"
        },
        {
          "character": "卜式",
          "line_type": "二黄三眼板",
          "musical_style": "二黄三眼板",
          "style_family": "二黄",
          "text": "只要那匈奴灭哪怕贫穷！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、大太监引刘彻同上。）"
        },
        {
          "character": "刘彻",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "旌旗日暖龙蛇动，"
        },
        {
          "character": "刘彻",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "宫殿风微燕雀高。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘彻观羊群，卜式跪。）"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣、卜式接驾，吾皇万岁！"
        },
        {
          "character": "刘彻",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "卜爱卿牧群羊备尽辛劳。"
        },
        {
          "character": "刘彻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "刘彻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卜卿，自你到上林以来，羊群日见肥壮，卿家真乃畜牧之能人也！"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：世间万事，同为一理。若以臣牧羊之道，治理百姓，使其善者蕃殖，"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不善者斥去，勿使害群，此乃治国之本。况臣出身畜牧，羊群肥壮，何足挂"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "齿！"
        },
        {
          "character": "刘彻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "言之极是。卿家经世大才，岂可久事畜牧？孤有意封卿为缑氏令，卿意如何？"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小臣不愿为官，愿在上苑，随侍圣驾。"
        },
        {
          "character": "刘彻",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不必推辞，明日候旨上任去吧！"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "刘彻",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "大材岂可小材用，"
        },
        {
          "character": "卜式",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "感恩何以报九重？"
        },
        {
          "character": "刘彻",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "御香缥缈龙蛇动，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、大太监、刘彻同下。）"
        },
        {
          "character": "卜式",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "竭忠保国显英雄。"
        }
      ],
      "interactions": [
        {
          "edge": "卜式→刘彻",
          "turns": 7
        },
        {
          "edge": "刘彻→卜式",
          "turns": 7
        }
      ],
      "stats": {
