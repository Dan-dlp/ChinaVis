    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "卜式"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖起初更鼓〗。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "卜式 （内二黄导板） 听谯楼打初更人声悄悄，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卜式上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "卜式 （回龙） 为国家秉忠心昼夜辛劳。"
        },
        {
          "character": "卜式",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "想当初输家财致身荣耀，"
        },
        {
          "character": "卜式",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "由上林迁缑氏又长成皋。"
        },
        {
          "character": "卜式",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "无有功勋报答圣朝。"
        },
        {
          "character": "卜式",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "自愧书生未习弓刀。"
        },
        {
          "character": "卜式",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "惜微躯贪利禄不算英豪！"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官，卜式。乃河南人氏，官拜齐王太傅。只恨匈奴之患未平，南越吕嘉又反，"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自愧书生不习戎马，刀兵扰攘，不知何日方得太平？下官身受国恩，岂能袖"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "手旁观，看水舟流？这！这！这！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（乱锤。）"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊呵有了！我不免上一本章，率领我子，及齐国善射习船之士，请缨杀贼，以"
        },
        {
          "character": "卜式",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "救国家。嗯，我就是这个主意！我就是这个主意啊！"
        },
        {
          "character": "卜式",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "男儿报国凭忠勇，"
        },
        {
          "character": "卜式",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "死到沙场是善终。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卜式修本。）"
        },
        {
          "character": "卜式",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "臣卜式冒死启奏九重："
        },
        {
          "character": "卜式",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "何况那匈奴未灭南越又反屡起边烽！"
        },
        {
          "character": "卜式",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "一心要平贼寇建立微功。"
        },
        {
          "character": "卜式",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "陆地干戈水上弓。"
        },
        {
          "character": "卜式",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "固边疆定山河誓死从戎。"
        },
        {
          "character": "卜式",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "但愿得纶音降早奏膺功。"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 10,
          "白": 1,
          "唱": 1
        },
        "singing_ratio": 0.5,
        "dominant_style_family": "二黄",
        "musical_styles": [
