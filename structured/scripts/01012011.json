          "text": "（大太监呈信，薛平贵看。）"
        },
        {
          "character": "薛平贵",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "宝钏，贤妻，哎呀妻吓！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "见书信不由孤泪流满面，"
        },
        {
          "character": "薛平贵",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "宝钏，贤妻，哎，妻吓！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "点点的珠泪儿洒落在胸前。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大太监、四太监同下。）"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮慢板",
          "musical_style": "西皮慢板",
          "style_family": "西皮",
          "text": "一字字一行行写得周全：\n拜上儿夫无义男。\n妻为你在寒窑受尽熬煎。\n迟来三天不能团圆。"
        },
        {
          "character": "薛平贵",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "王三姐，宝钏，吓吓吓，我的妻吓！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "夫妻们相逢难上难。\n猛然一计上心间。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大太监上。）"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "快宣公主把驾参。"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主上殿。"
        },
        {
          "character": "代战公主",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（代战公主上。）"
        },
        {
          "character": "代战公主",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "适才教场操兵转，\n又听得大王把咱宣。\n参王驾来问王安。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾妃见驾，大王千岁！"
        },
        {
          "character": "宫娥摆驾银安殿、薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千千岁！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐座。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。大王宣咱家上殿，有何国事议论？"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主连日操兵辛苦，孤王备得有宴，与公主同饮。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此待咱家把盏，宫娥看酒伺候。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆下就是。\n内侍看酒。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大太监允。）"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "夫妻们对坐饮琼浆，\n她怎知血书袖内藏。\n怕的是南朝动刀枪。"
        },
        {
          "character": "江山虽然孤执掌、代战公主",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大王爷但把宽心放，\n细听咱家说端详：\n咱一人能挡百万儿郎。"
        },
        {
          "character": "哪怕南朝兵将广、薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "公主虽然韬略广，\n一人怎挡百万郎？"
        },
        {
          "character": "代战公主",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一来是大王爷洪福大，\n咱家精心礼该当。\n这杯酒愿大王福寿绵长。"
        },
        {
          "character": "宫娥女将酒忙斟上、薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "公主敬酒王心爽，\n多吃几杯有何妨。"
        },
        {
          "character": "宫娥女将酒忙斟上、薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主连日操兵辛苦，孤王要把敬你三大杯。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王，咱家这酒，比不得从前。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "从前能饮多少？"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "从前有百杯之量。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如今呢？"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "五十双杯。"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "还是一样！\n内侍看酒。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵敬酒，代战公主饮酒，醉。）"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主醉了！"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你也醉了！"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一见公主醉银安，\n中了平贵巧机关。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵换衣。）"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "番邦令箭别腰间。"
        },
        {
          "character": "不辞公主跨雕鞍、大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "倘若公主问道大王，如何回答？"
        },
        {
          "character": "薛平贵",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "难舍公主十分贤。\n字字行行写一篇：\n孤王亲自去阅边。\n带领人马赶三关；\n西凉国改为女儿川。\n公主醒来对她言，孤去阅边。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（薛平贵下。）"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主醒来！"
        },
        {
          "character": "代战公主",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "时才酒醉银安殿，"
        },
        {
          "character": "代战公主",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不见大王在哪边。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王往哪里去了？"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "阅边去了。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可留下什么？"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有书信一封，公主请看。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "侍咱家看来。"
        },
        {
          "character": "代战公主",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "上写春秋四季天，\n孤王亲自去阅边。\n带领人马赶三关；\n西凉改作女儿川。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，是了，"
        },
        {
          "character": "代战公主",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "原来大王回长安。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叫咱家带兵追赶。\n内侍，吩咐马达、江海，全身披挂，教场伺候。"
        },
        {
          "character": "公主若念夫妻爱、公主不念夫妻恩、看罢书信心思算、大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公主有令：吩咐马达、江海，全身披挂，教场伺候。"
        },
        {
          "character": "代战公主",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大王做事礼不端，\n不该私自回长安。\n追赶大王问一番。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（代战公主、大太监同下。）"
        }
      ],
