      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马达、江海同骑马上。）"
        },
        {
          "character": "马达",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "家住在北国，"
        },
        {
          "character": "江海",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "说话不利落，"
        },
        {
          "character": "马达",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "吃的是牛羊肉，"
        },
        {
          "character": "江海",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "骑的是大骆驼。"
        },
        {
          "character": "马达",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马达。"
        },
        {
          "character": "江海",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "江海。"
        },
        {
          "character": "马达",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "江海",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "马达、江海",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "公主发兵，在此伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同上，代战公主上。）"
        },
        {
          "character": "代战公主",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "点动兵和将，追赶无义男！"
        },
        {
          "character": "马达、江海",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见公主！"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。人马可齐？"
        },
        {
          "character": "马达、江海",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俱巳齐备。"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐，巴图鲁，兵发头关！"
        },
        {
          "character": "马达、江海",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "巴图鲁，兵发头关。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
