        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套同允。）"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "偃旗息鼓，杀奔都城去者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（共叔段、四龙套同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "念": 1,
          "白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "公子吕",
        "共叔段",
        "军卒",
        "卷旗息鼓暗催趱",
        "可叹你正青春尘埃血溅",
        "四下手",
        "四红龙套",
        "太叔段",
        "寤生",
        "我和你同胞谊有甚长短",
        "拿住你并不要开刀问斩",
        "竟要谋朝将国篡",
        "老母后多溺爱她的见识太浅"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四红龙套、四将、公子吕、寤生同上。）"
        },
        {
          "character": "寤生",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "母后爱子有偏见，\n萧墙之内起祸端。\n可叹手足自相残。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（军卒上。）"
        },
        {
          "character": "军卒",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "奉了君侯命，昼夜不消停。"
        },
        {
          "character": "军卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叩见千岁。"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。书信可曾送到？"
        },
        {
          "character": "军卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "已然送到。"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太叔怎生言讲？"
        },
        {
          "character": "军卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太叔言道：拜上国母，照书行事。"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好贼子！"
        },
        {
          "character": "寤生",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听一言来怒冲冠，\n贼子做事理不端。\n再与卿家把话言。"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公子吕。"
        },
        {
          "character": "竟要谋朝将国篡、公子吕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐众将，只打卿家的旗号，就在这鄢邑埋伏，擒拿太叔者！"
        },
        {
          "character": "寤生",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "无知竖子敢造反，\n纸上何能把兵谈。\n克段于鄢莫停骖。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。四下手、二将、共叔段同上。）"
        },
        {
          "character": "共叔段",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "母后书信将我宣，\n三军踊跃跨雕鞍。\n休要惊动百姓观。"
        },
        {
          "character": "卷旗息鼓暗催趱、四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "前面有人马挡道！"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看是何人旗号？"
        },
        {
          "character": "四下手",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是公子吕的旗号。"
        },
        {
          "character": "太叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，公子吕的旗号！哎也——骑虎之势，难以收歇。\n众将官，杀上前去！"
        },
        {
          "character": "太叔段",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "势成骑虎难回挽，\n岂肯休兵转回还。\n三军与爷向前趱——"
        },
        {
          "character": "太叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "太叔段",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "又见征尘遮满天！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（公子吕、寤生引四红龙套同上。）"
        },
        {
          "character": "公子吕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！太叔休得无理，主公在此！"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸呸呸！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（公子吕、寤生、四红龙套同冲杀。共叔段败，下。公子吕、寤生、四红龙套同追下。共叔段急上。）"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "共叔段",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "马到悬崖收缰晚，\n祸已临头后悔难。"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了吓罢了！我只道是公子吕的人马，岂知兄侯并未朝周，亲身在此，这却怎\n么处？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖内喊声〗。）"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，四面车马围困，有何颜面见得兄侯，不如自刎一死，免遭羞辱。苍天哪\n天！此乃母后误我也。"
        },
        {
          "character": "共叔段",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "不听贤妻良言劝，\n欲见兄面又羞惭。"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢！"
        },
        {
          "character": "共叔段",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "枉在人间走一番。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（共叔段自刎，死。寤生、公子吕、四红龙套同上。）"
        },
        {
          "character": "四红龙套",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "太叔自刎。"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闪开了。\n哎呀！"
        },
        {
          "character": "寤生",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "见贤弟自刎身肝肠痛断，\n不由人放悲声珠泪涟涟。\n你争什么社稷夺什么江山！\n痴贤弟却不该起下兵端。\n又何必萌短见自刎身残！"
        },
        {
          "character": "寤生",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟吓……"
        },
        {
          "character": "寤生",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "恨不得拚一死同赴黄泉！"
        },
        {
          "character": "我和你同胞谊有甚长短、老母后多溺爱她的见识太浅、拿住你并不要开刀问斩、可叹你正青春尘埃血溅、公子吕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "主公事已至此，哭也无益。只得将太叔好为安葬，也就是了。"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此皆国母所误也。\n来，将太叔尸首，用黄绫裹定，棺殓埋葬，不可轻慢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四红龙套抬共叔段同下。）"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，公子吕。"
        },
        {
          "character": "公子吕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在！"
        },
        {
          "character": "寤生",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你去到宫中，将此书呈与国母观看，请国母到颖地安居，说我发下誓言：不\n及黄泉，无相见也。"
        },
        {
          "character": "公子吕",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（公子吕下。）"
        }
      ],
