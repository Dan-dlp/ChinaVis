    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "共叔段",
        "卫氏"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（共叔段、卫氏同上。）"
        },
        {
          "character": "共叔段",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "丹心天地惨，黄泉路途遥。"
        },
        {
          "character": "卫氏",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "溺爱反成害，恩情一旦抛。"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃共叔段鬼魂是也。"
        },
        {
          "character": "卫氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃卫云环鬼魂是也。"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可叹母后，在颖地离宫，思儿想媳，你我夫妻不免前去托梦，劝解一番。"
        },
        {
          "character": "卫氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": "共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请。正是："
        },
        {
          "character": "共叔段",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "鹃血啼残三月雨，"
        },
        {
          "character": "卫氏",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "梦魂惊断五更风。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（共叔段、卫氏同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "共叔段→卫氏",
          "turns": 4
        },
        {
          "edge": "卫氏→共叔段",
          "turns": 3
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "念": 3,
          "白": 5
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "二宫女",
        "共叔段",
        "卫氏",
        "未报恩来世里重亲慈范",
        "武姜",
        "看不明拭一拭昏花老眼",
        "莫非是母子们梦里相见"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女同上，同站门。武姜上。）"
        },
        {
          "character": "武姜",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "身似羁囚，思姣儿，珠泪双流。"
        },
        {
          "character": "武姜",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "生离最是苦，死别何伤乎！可叹年垂暮，有子不如无。"
        },
        {
          "character": "武姜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哀家姜氏，只因溺爱次子共叔段，反累他夫妻双亡。可恨寤生，将我迁入颖地\n居住，举目无亲。思想起来，好不惨伤人也。"
        },
        {
          "character": "武姜",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "姜国母居颖地长吁短叹，\n思皇儿昼夜里珠泪不干。\n但不知何日里得转故园。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖起更鼓〗。）"
        },
        {
          "character": "武姜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "尔等退下。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女同下。）"
        },
        {
          "character": "武姜",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "居离宫冷清清无依无伴，\n思姣儿睡不稳月照栏杆。\n有谁人怜念我孤影形单？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（共叔段、卫氏同上。）"
        },
        {
          "character": "共叔段",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "风飘飘冷飕飕阴风惨淡，\n想当初在宫中奉母承欢。"
        },
        {
          "character": "卫氏",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "这时候只落得阴阳路判，\n进寝宫见国母且莫心酸。"
        },
        {
          "character": "共叔段、卫氏",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "母后醒来！"
        },
        {
          "character": "武姜",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "梦儿里只听得有人呼唤，"
        },
        {
          "character": "武姜",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "武姜",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "又只见灯光下双影蹁跹。"
        },
        {
          "character": "看不明拭一拭昏花老眼、共叔段",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后！"
        },
        {
          "character": "卫氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "婆母！"
        },
        {
          "character": "共叔段、卫氏",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "唉，母亲哪！"
        },
        {
          "character": "武姜",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "却原来是姣儿叔段、爱媳云环。\n你夫妻双双拜色笑承欢。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "共叔段 （回龙） 儿死在九泉下魂魄不安。"
        },
        {
          "character": "武姜",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "悲切切劝母后不必悲惨，\n悔不该谋兄位自惹祸端。\n因此上到离宫劝解一番。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（武姜哭。）"
        },
        {
          "character": "卫氏",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "这也是天命定数有修短，\n劝母后切莫要终日泪涟。\n千古来有谁人百岁同餐？"
        },
        {
          "character": "未报恩来世里重亲慈范、武姜",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "听他言不由我心中悲惨，\n分明是我的儿站立面前。\n纵然是在阴曹娘也心甘。"
        },
        {
          "character": "莫非是母子们梦里相见、共叔段",
          "line_type": "反二黄摇板",
          "musical_style": "反二黄摇板",
          "style_family": "二黄",
          "text": "娘在阳儿在阴两厢隔断，\n母子们要相逢难上加难。"
        },
        {
          "character": "卫氏",
          "line_type": "反二黄摇板",
          "musical_style": "反二黄摇板",
          "style_family": "二黄",
          "text": "天将明儿要归不必惨念，\n郑君侯指日里重会慈颜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（共叔段、卫氏同下。二宫女同上。）"
        },
        {
          "character": "二宫女",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "国母醒来。"
        },
        {
          "character": "武姜",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "适才间见姣儿肝肠痛断，"
        },
        {
          "character": "武姜",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "叔段！云环！唉儿吓！"
        },
        {
          "character": "武姜",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "醒来时又听得玉漏声残。\n相劝我言和语甚是悲惨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女同下。）"
        },
        {
          "character": "武姜",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "但不知何日里才得回还。"
        }
      ],
