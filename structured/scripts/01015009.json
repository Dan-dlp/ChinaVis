    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "妖怪",
        "猪八戒"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（猪八戒上，妖怪追上。）"
        },
        {
          "character": "妖怪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！你是何人？擅敢盗俺的宝贝。"
        },
        {
          "character": "猪八戒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你休得胡言，宝铃取你。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（猪八戒摇铃，妖怪笑。）"
        },
        {
          "character": "猪八戒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么不响吓？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（妖怪摇铃。）"
        },
        {
          "character": "妖怪",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看宝铃。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（猪八戒下，众人追下。）"
        }
      ],
      "interactions": [
        {
          "edge": "妖怪→猪八戒",
          "turns": 1
        },
        {
