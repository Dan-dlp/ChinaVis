      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞上。）"
        },
        {
          "character": "张飞",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "大哥去借兵，未见转回程。"
        },
        {
          "character": "中军",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "刘使君到。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。刘备上。）"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥回来了，你辛苦了，请至后面。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备下。四龙套、四上手同上，同下。赵云上。）"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，三将军。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张飞背面。）"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咳。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵云下。）"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住，我道大哥，此番借兵，定必是天神的一般，不料是一个黄毛孺子！嘿！"
        }
      ],
      "interactions": [
        {
          "edge": "张飞→中军",
          "turns": 1
        },
        {
