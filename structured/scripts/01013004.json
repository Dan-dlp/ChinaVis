        },
        {
          "character": "赵云",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告辞。"
        },
        {
          "character": "公孙瓒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "备得有酒，与贤弟痛饮。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐州危在旦夕，备不敢久停，告辞了。"
        },
        {
          "character": "刘备",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "多蒙仁兄恩量宽，"
        },
        {
          "character": "刘备",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "借兵三千将一员。"
        },
        {
          "character": "刘备",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "哪怕典韦小儿男。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备下。）"
        },
        {
          "character": "公孙瓒",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "人来与爷把门掩，"
        },
        {
          "character": "公孙瓒",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "怕的是刘玄德借将不还。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
