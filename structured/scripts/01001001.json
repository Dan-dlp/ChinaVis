          "text": "（四龙套、司马懿、司马师、司马昭同上。报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "西城乃是空城。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。）"
        },
        {
          "character": "司马师、司马昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "如何？"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官复夺西城！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同允。四上手引赵云同上，两下会阵。）"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来将通名。"
        },
        {
          "character": "赵云",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "常山赵云。"
        },
        {
          "character": "司马懿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "收兵，收兵！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、司马懿、司马师、司马昭同下。四上手、赵云同下。）"
        }
      ],
