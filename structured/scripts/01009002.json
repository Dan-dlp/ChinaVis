          "character": "马谡",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "丞相快把令传下"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "想起先帝托孤话，"
