          "character": "诸葛亮",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "将身跪在宝帐下"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我心中好似快刀扎。"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我今一死倒也罢"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "将身跪在宝帐下"
        },
        {
          "character": "诸葛亮",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
