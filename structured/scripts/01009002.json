        {
          "character": "诸葛亮",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "马谡！"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "参谋！"
        },
