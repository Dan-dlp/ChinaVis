        {
          "character": "柴荣",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄重相会，"
        },
        {
          "character": "赵匡胤",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "胜似万两金。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（柴荣、赵匡胤同下。）"
        }
      ],
