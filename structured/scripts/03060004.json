    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "劝贤弟从今后情性要改",
        "弟兄们今相会好有一比",
        "柴大哥比刘备仁义四海",
        "柴荣",
        "董家桥打五虎各自分界",
        "赵匡胤",
        "院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、院子、赵匡胤、柴荣同上。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长，你我相会，好有一比。"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "比作何来？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "久旱逢甘雨，"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他乡遇故知。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好个“他乡遇故知”！"
        },
        {
          "character": "柴荣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "花亭上摆酒宴珍馐美菜，\n兄一杯弟一盏畅叙开怀。\n我这里上怀庆官封王来。\n有愚兄当保你位列三台。"
        },
        {
          "character": "董家桥打五虎各自分界、劝贤弟从今后情性要改、赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄们久分别今蒙盛待，\n好一似浮云散晴天现开。"
        },
        {
          "character": "弟兄们今相会好有一比、柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "比作何来？"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "比前朝三大贤胜似同胎。"
        },
        {
          "character": "柴大哥比刘备仁义四海、柴荣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "赵二弟比关公扶保帝台。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "眼前若有三弟在，\n亚赛那张翼德猛烈将才。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤停杯沉思。）"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟为何不饮？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "非是小弟停杯不饮。你我今日相会，不知三弟身落何处？"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "愚兄也曾修书，命人去到榆次县迎接三弟满门，同享荣华。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长！"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大哥仁德世罕见，\n迎接三弟享福绵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤停杯沉思。）"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟为何又停杯不饮？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将宴撤去，弟兄花园散步。"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将宴撤去！"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "酒席筵前谢御宴，"
        },
        {
          "character": "柴荣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "相邀贤弟到花园。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "长随官对对前引道，"
        },
        {
          "character": "柴荣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄们游玩花亭前。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "八角亭盖的琉璃瓦，"
        },
        {
          "character": "柴荣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "地下铺的是八宝砖。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "那一厢修的是跑马射箭道，"
        },
        {
          "character": "柴荣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "箭射红日夺魁元。"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "玉石栏杆雕花朵，"
        },
        {
          "character": "柴荣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "风吹牡丹卷珠帘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鱼妖自下场门暗上。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "来在鱼池用目看，\n只见水内浪滔天。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "水内什么响亮？"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是鱼妖戏水。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是新有，还是旧有？"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是旧有。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看弓箭伺候！"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（院子取弓箭递赵匡胤。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "玄郎未到尔先到，\n狭路相逢怎肯饶？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵匡胤射箭。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只见鱼妖带箭逃。"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谯楼几鼓？"
        },
        {
          "character": "院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "才打三鼓。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告辞！"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里去？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹娘台前问安。"
        },
        {
          "character": "柴荣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！随愚兄上殿朝王见驾。"
        },
        {
          "character": "赵匡胤",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "鱼妖本是池中物，"
        },
        {
          "character": "柴荣",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "得会风云上九重。"
        },
        {
          "character": "赵匡胤、柴荣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（柴荣、赵匡胤、院子同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "赵匡胤→柴荣",
          "turns": 20
