          "style_family": "西皮",
          "text": "不由得豪杰笑开怀。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "只杀得儿郎苦悲哀。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "尸骨堆山无有葬埋。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "小唐童被某"
        },
        {
          "character": "单雄信",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "把胆吓坏，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "二次被擒也应该。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "要报仇二十年投胎某再来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、李世民、徐勣、罗成、程咬金、尉迟恭同上。〖吹打〗。众人同祭。）"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看酒来！"
        },
        {
          "character": "李世民",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一杯酒儿满满酾，"
        },
        {
          "character": "李世民",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "尊声将军听言来："
        },
        {
          "character": "李世民",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "愿你转世早投胎。"
        },
        {
          "character": "李世民",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "王今奉你一斗酒"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "唐童假意把我待，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "花言巧语说开怀。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "报仇还要再投胎。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我与你冤仇难分解"
        },
        {
          "character": "徐勣",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一杯水酒杯中酾，"
        },
        {
          "character": "徐勣",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "叫声五弟听明白："
        },
        {
          "character": "徐勣",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "且莫埋怨愚兄来。"
        },
        {
          "character": "徐勣",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "今日被擒是天意"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "徐勣休得巧言盖，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "阴阳八卦你安排。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "你是个人面兽心怀！"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "结义情由你忘怀"
        },
        {
          "character": "罗成",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "人来看过杯中赛，"
        },
        {
          "character": "罗成",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "尊声五哥听开怀："
        },
        {
          "character": "罗成",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "愿你魂灵到天台。"
        },
        {
          "character": "罗成",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我今奉你一斗酒"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住口！"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我今奉你一斗酒"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "见罗成把我的牙咬坏，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "大骂无义小奴才！"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "同心起义巧安排。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "某家接你到家来。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "我为你修盖瓦楼台；"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "我为你花费许多财；"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "我为你受了许多灾。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮紧板",
          "musical_style": "西皮紧板",
          "style_family": "西皮",
          "text": "管叫你乱箭穿身死无有葬埋。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（罗成怒，欲打。程咬金劝。）"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "一杯酒儿满满酾，"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "尊一声五哥听明白："
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "管叫你灵魂赴天台。"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "你今饮了杯中酒"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赴天台？好，酒来！"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "二杯酒儿杯中酾，"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "小弟言来听开怀："
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "保你阴灵到蓬莱。"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "你若饮了二杯酒"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到蓬莱？看酒来！"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "三杯酒，捧上来，"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "我与五哥同心怀。"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "将他一个一个俱把刀开，把我丢开。"
        },
        {
          "character": "程咬金",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "你今饮了三杯酒"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "把你丢开？好呀！"
        },
        {
          "character": "单雄信",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你今饮了三杯酒"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "这句话儿真爽快，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "叫咬金把酒斟上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（单雄信饮酒。）"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "满营将官俱都在，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "为何不见栋梁材？"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "问一声秦二哥今何在？"
        },
        {
          "character": "程咬金",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "二哥押粮未回来。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "哭一声秦二哥，叫一声好汉哥哥！"
        },
        {
          "character": "单雄信",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "嗳嗳嗳呀，我的好汉哥呀！"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "贾家楼，曾结拜，"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "惟有你我同心怀。"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "叫唐童快把刀来开！"
        },
        {
          "character": "单雄信",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我今饮了三斗酒"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "尉迟恭听令！"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "命你将雄信斩首。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，击鼓。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（尉迟恭斩单雄信。龙形上，小童持绳上，缚龙形，同下。）"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "后帐备宴，与众卿贺功！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
