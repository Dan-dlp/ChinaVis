      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（任堂惠上，起霸。）"
        },
        {
          "character": "任堂惠",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "乔装改扮逞英豪，只为金兰旧故交。"
        },
        {
          "character": "任堂惠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，任堂惠，奉了元帅将令，暗地保护焦赞，就此趱行者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（任堂惠下。）"
