          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不可违误。"
        },
        {
          "character": "任堂惠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（任堂惠下。）"
        },
        {
          "character": "杨延昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "掩门。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人自两边分下。）"
