        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（代战公主上马，四红龙套同走圆场。四白龙套引高嗣继同上，会阵。）"
        },
        {
          "character": "代战公主",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
