        {
          "character": "高嗣继",
          "line_type": "唱",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "只见青龙头上翻。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
