      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（高嗣继上，起霸。）"
        },
        {
          "character": "高嗣继",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "头戴银盔明灿亮，身穿铠甲似秋霜。胯下一骑白龙马，上阵手持素银枪。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四白龙套暗同上。）"
        },
        {
          "character": "高嗣继",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，高嗣继。奉了王丞相将令，追赶平贵。可恨代战公主，战又不战，降又不"
        },
        {
          "character": "高嗣继",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "降，岂肯容她猖狂？"
        },
        {
          "character": "高嗣继",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四白龙套同允。）"
        },
        {
          "character": "高嗣继",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "迎敌者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四白龙套同允。高嗣继上马，高嗣继、四白龙套同下。）"
        }
      ],
      "interactions": [],
      "stats": {
