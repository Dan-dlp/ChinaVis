        {
          "character": "高嗣继",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "老爷名叫高嗣继，"
        },
        {
          "character": "高嗣继",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "我保王允坐华夷！"
        },
        {
          "character": "代战公主",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "听说来了高嗣继，"
        },
        {
          "character": "代战公主",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "咱家与你见高低！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四红龙套、四白龙套、马达、江海同钻烟筒，自两边分下。高嗣继、代战公主同起打，自两边分下。）"
        }
