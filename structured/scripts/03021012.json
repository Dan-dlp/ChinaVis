          "line_type": "唱",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "孤王上前忙遮拦。"
        },
        {
          "character": "代战公主",
          "line_type": "唱",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "既然保你坐江山，"
        },
        {
          "character": "薛平贵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
