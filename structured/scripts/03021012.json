        {
          "character": "马达、江海",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "鸽子回来啦！"
        },
        {
          "character": "代战公主",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想是大王有难。马达、江海！"
        },
        {
          "character": "马达、江海",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
