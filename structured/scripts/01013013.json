    },
    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "四下手",
        "马金定"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马金定上，四下手抬巴杰同上。）"
        },
        {
          "character": "马金定",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这是怎么啦？"
        },
        {
          "character": "四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "适才大爷在郊外演习拳棒，偶遇骆宏勋，言语不合，被骆宏勋一剑刺死了。"
        },
        {
          "character": "马金定",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将你大爷先抬在后面，等我去找他去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马金定、四下手同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "马金定→四下手",
          "turns": 1
        },
        {
          "edge": "四下手→马金定",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 2,
          "白": 2,
          "同白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "二农夫",
        "农夫甲",
        "马金定",
        "骆宏勋"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二农夫同上，同耕地。骆宏勋、余千同上。）"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "巴杰被我刺死，看那面定是他母亲赶来了，这便怎么处？\n那边有两个农人，不免借他二人衣帽穿戴，混他一时再作道理。\n二位请了。二位衣帽借我等一用，以救我二人性命。我等感恩非浅。"
        },
        {
          "character": "二农夫",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "拿去穿戴。我二人躲在一旁。"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二农夫同下。马金定上。）"
        },
        {
          "character": "马金定",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请问二位，可见两个汉子过去么？"
        },
        {
          "character": "农夫甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "往东南去了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马金定下。）"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位请上，受我一拜。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "骆宏勋→二农夫",
          "turns": 1
        },
        {
          "edge": "二农夫→骆宏勋",
          "turns": 1
