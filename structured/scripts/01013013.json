  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "余千",
        "骆宏勋"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（骆宏勋上。）"
        },
        {
          "character": "骆宏勋",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "久离家园，思老母，珠泪涟涟。"
        },
        {
          "character": "骆宏勋",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "离别家乡已有年，母居地北子天南。功名富贵由天定，思想高堂泪不干。"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我，骆宏勋。只因求取功名，来在都门，已有几载，怎奈机缘不遇，终日奔忙。\n老母现在山东，是我意欲回家探望。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（余千暗上。）"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来。"
        },
        {
          "character": "余千",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "与爷带马。"
        },
        {
          "character": "余千",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "骆宏勋",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "叫人来与爷忙带马，\n披星戴月转回家。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（骆宏勋下，余千下。）"
        }
      ],
      "interactions": [
        {
          "edge": "骆宏勋→余千",
          "turns": 2
        },
        {
          "edge": "余千→骆宏勋",
          "turns": 2
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 5,
          "白": 4,
          "唱": 1
        },
        "singing_ratio": 0.2,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮摇板"
        ]
      }
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "巴杰"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手、巴杰同上。）"
        },
        {
          "character": "巴杰",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "膂力高强，爱拳棒，练习刀枪。"
        },
        {
          "character": "巴杰",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "父母身居在绿林，生来力大有千斤。全家霸占酸枣岭，谁不闻名胆战惊。"
        },
        {
          "character": "巴杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，巴杰。祖居酸枣岭下，自幼好习拳棒，今日闲暇无事。\n庄丁们！庄外操练一番。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手同转场。）"
        },
        {
          "character": "巴杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大家操练一番。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手同操练。）"
        },
        {
          "character": "巴杰",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈，哈哈，呵哈哈，哈哈哈，哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四下手、巴杰同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 6,
          "白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "四下手",
        "巴杰",
        "董元",
        "骆宏勋"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（董元上。）"
        },
        {
          "character": "董元",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在下董元。奉了花寨主之命，沿途开店迎接骆公子。就此走走。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（骆宏勋、余千同上。）"
        },
        {
          "character": "骆宏勋",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "催马加鞭往前闯，见一老丈在路旁。"
        },
        {
          "character": "董元",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那厢来的敢是骆公子么？"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我与你素不相识，你怎生知我名姓？"
        },
        {
          "character": "董元",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "公子有所不知，小人名叫董元，奉了我家寨主花镇芳之命，沿途开了店房等候\n骆公子，不料竟自遇着了。"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "花家寨离此还有多少远的路程？"
        },
        {
          "character": "董元",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "还有一百余里。"
        },
        {
          "character": "骆宏勋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此你与我带路。"
        },
        {
          "character": "骆宏勋",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "老丈与我把路带，\n直奔花家寨上来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（骆宏勋下，余千下。巴杰、四下手同上，董元闯过，下。）"
        },
        {
          "character": "巴杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方才是什么人由此闯过？"
        },
        {
          "character": "四下手",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "是花家寨的董元。"
        },
        {
          "character": "巴杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叫他转来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（董元上。）"
        },
        {
          "character": "董元",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见巴公子。"
        },
        {
          "character": "巴杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我且问你，你匆匆忙忙闯过我的操场，不知为了何事？"
        },
        {
          "character": "董元",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是我奉了寨主之命，迎接扬州骆公子，故而从此经过。"
        },
        {
          "character": "巴杰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "起过了。\n想那骆公子，乃是我的仇人到了。我岂肯放他过去。\n众庄丁！赶上前去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
