        {
          "character": "许仕林",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢母亲。"
        },
        {
          "character": "白素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那旁有块顽石，我儿坐下。"
        },
        {
          "character": "白素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓！哪里来的一身荣耀？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许仕林坐。）"
        },
        {
          "character": "许仕林",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿得中头名状元，故而这身荣耀。"
        },
        {
          "character": "白素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿就该奏明圣上，搭救为娘，才是道理。"
        },
        {
          "character": "许仕林",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿上殿连奏数本，圣上不准也是枉然。"
        },
        {
          "character": "白素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这也是为娘命该如此。"
        },
        {
          "character": "许仕林",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗳，母亲，将当年受苦之事，说与孩儿知道。"
        },
        {
          "character": "白素贞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿坐在一旁，听为娘将受苦之事，说与我儿知道。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "未开言不由人珠泪双流，"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "叫一声仕林儿细听从头："
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "劝为娘勤修炼自有出头。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "悔不该贪红尘始下山头。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "借雨伞结丝罗我把他赘。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "是为娘显法身惹下忧愁。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为娘的盗灵芝用尽心谋。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "又谁知那秃驴洩漏计谋。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "现神通用法术欲把娘收。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "实指望遇儿父到老白头。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "听信了那法海一片奸谋。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为娘的悔不该水漫山头。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为娘的与儿父再转杭州。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "狠心父将为娘就塔内押收！"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我的儿吓……"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "但愿得儿夫妻到老百头。"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "切莫学儿的父无义无情！"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "黑风仙他本是为娘道友"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "峨眉山同修道千年已久"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "在西湖遇儿父初瞻山斗"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "都只为端午日同饮药酒"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "在床前将儿父灵魂嚇走"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "儿的父上金山烧香行走"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "那法海他那里早已算就"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "实指望遇儿父天长地久"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "又谁知儿的父谗言听就"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为娘的我也曾水内职斗"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "到后来与儿父断桥又会"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "为娘的产我儿只得满月"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "但愿得儿夫妻天长地久，天长地久"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "切莫学儿的父心如禽兽"
        },
        {
          "character": "塔神",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "白氏仙姑回避了！"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "母子们才相逢就要分手，"
        },
        {
          "character": "白素贞",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "揭谛神呼唤我哪得容留。"
        },
        {
          "character": "白素贞",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "我儿！"
        },
        {
          "character": "许仕林",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "母亲！"
        },
        {
          "character": "白素贞",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "仕林！"
        },
        {
          "character": "许仕林",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "亲娘！"
        },
        {
          "character": "白素贞",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "我的儿吓……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（白素贞下。）"
        },
        {
          "character": "许仕林",
          "line_type": "叫头",
          "musical_style": null,
          "style_family": null,
          "text": "老娘亲吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（许仕林带马，下。）"
        }
