        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "张苞，命你将你父的尸首搬回阆中安葬去罢。"
        },
        {
          "character": "张苞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张苞下。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关兴听令：命你带领三千人马，抵挡吴兵。"
        },
        {
          "character": "关兴",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关兴下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "从前不听先生言，损兵折将也枉然。马到临崖收缰晚，船到江心……"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "补漏难哪……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备哭。）"
        },
        {
          "character": "刘备",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "事到临头才知悔，"
        },
        {
          "character": "刘备",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "自己错了埋怨谁？"
        },
        {
          "character": "刘备",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "乌江岸前把命逼。"
        },
        {
          "character": "刘备",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "他人的奸诈有谁知？"
        },
        {
          "character": "刘备",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "还望先生费心机。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生哪。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "楚霸王他不听范增语"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "曹孟德中原成大器"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "阿斗年幼终何用"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "主公不必泪悲啼，"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "为臣言来奏主知："
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "鞠躬尽瘁死而后已。"
        },
        {
          "character": "诸葛亮",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "蒙主公三顾之恩义"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "叹先生说此话世间稀，"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "二皇儿近前来细听端的："
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "他保阿斗立帝基。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备下位。）"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "手搀先生泪悲啼。"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "还望先生牢记心里。"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "第二要恢复汉室基。"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "四百载基业化灰泥。"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "孤还有紧要事嘱咐你"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "头一件扫荡中原地"
        },
        {
          "character": "刘备",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "哭一声懦弱的汉献帝"
        },
        {
          "character": "赵云",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "万岁还须保龙体，"
        },
        {
          "character": "赵云",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "臣等保主不敢欺。"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "回头又见赵四弟，"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你的功劳王尽知。"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "又谁知今日两分离。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位卿家。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自从患难来相聚"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马良"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马谡"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵云"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "邓芝"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "费祎"
        },
        {
          "character": "诸葛亮",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "邓芝！"
        },
        {
          "character": "邓芝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马良！"
        },
        {
          "character": "马良",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "众位卿家请站起，"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "叫声邓芝、马良和费祎。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马谡，马谡，马谡！"
        },
        {
          "character": "马谡",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦——"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "言过其实是马谡！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生！"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你、你、你……用他必须要查端的。"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "等等愚兄一路随。"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "霎时间难接我的咽喉气！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备三吐血。）"
        },
        {
          "character": "刘备",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "无常到万事休一命归西。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备死。）"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎、诸葛亮",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（同二黄摇板） 一见龙驾归了西，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "文武百官泪悲啼。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位将军、大人，不必悲恸，暂将龙驾移了下去。"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "呵……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备下。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位将军，歇兵三日，齐奉榇棺，退还成都便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "费祎 （同哭） 主公啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
