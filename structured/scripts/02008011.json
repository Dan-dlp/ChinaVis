      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李刚上。）"
        },
        {
          "character": "李刚",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "三杯酒，两朵花，乌鸦头上叫札札。叫的只管叫，札的只管札，闲是闲非休管"
        },
        {
          "character": "李刚",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "他。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "抓地虎。将那汉子挖下心肝，大王宴酒。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（抓地虎上。）"
        },
        {
          "character": "抓地虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王。那汉子不见了。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔，着打！"
        },
        {
          "character": "抓地虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人有交。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "交与何人？"
        },
        {
          "character": "抓地虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "交与丫鬟。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叫丫鬟来。"
        },
        {
          "character": "抓地虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟走来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟上。）"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟叩头。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟。剥皮厅那一汉子哪里去了。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不知。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "着打。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫环有交。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "交与何人？"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "交与太夫人。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请太夫人。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请太夫人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（班氏上。）"
        },
        {
          "character": "班氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请我何事？"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大王有请。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿拜见母亲。"
        },
        {
          "character": "班氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。坐下。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿告坐。母亲。那一汉子哪里去了？"
        },
        {
          "character": "班氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那就是你常常思念的李广兄长来了。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "噢，那个就是我李广兄长么？可容我兄弟一会？"
        },
        {
          "character": "班氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丫鬟。请大老爷。"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请大老爷。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李广上。）"
        },
        {
          "character": "李广",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "只因龙国母，终日长挂怀。"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这就是李广兄长？"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这是李刚兄弟？"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小弟一拜。"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄也有一拜。"
        },
        {
          "character": "李广",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "今日一见，"
        },
        {
          "character": "李刚",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "喜笑颜开。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李广、李刚同笑。）"
        },
        {
          "character": "班氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你弟兄且敍衷怀，为娘上房备宴，一家欢饮。"
        },
        {
          "character": "李广、李刚",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "老母请退。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（班氏、丫鬟同下。）"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长。闻你保定周朝，为何一人逃奔？"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只因谗臣当道，兄保定国母天涯逃走，又被猛虎冲散，误被兄弟拿住。也不知"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国母的下落如何？"
        },
        {
          "character": "李刚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长宽住几日，慢慢打听国母的下落便了。请至后堂。"
        },
        {
          "character": "李广",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄弟请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖尾声〗。李广、李刚同下。）"
        }
      ],
