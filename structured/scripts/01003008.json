      ]
    },
    {
      "scene_index": 4,
      "label": "第四场",
      "characters_present": [
        "包拯",
        "地方",
        "李后",
        "王朝"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、包拯、王朝、马汉同上。风旗上，过场，下。）"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启爷：狂风刮去轿顶！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "驻轿！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怪道吓，怪道！"
        },
        {
          "character": "包拯",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "霎时一阵狂风到，"
        },
        {
          "character": "包拯",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "刮去轿顶为那条？"
        },
        {
          "character": "包拯",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "定有恶棍与土豪。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传地方。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想是妖魔魍魉到"
        },
        {
          "character": "王朝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传地方。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（地方上。）"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "地方叩见大人！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。此桥何名？"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵州桥。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前面什么庙？"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天齐庙。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打扫天齐庙，老夫宿堂。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位随我来！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传地方。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伺候大人。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这有铜锣一面，命你去到庙前庙后，庙左庙右，高声喝叫喧说：老夫在此宿堂，"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有冤枉者前来伸诉！"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咋咋咋！"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，别的老爷，怕人家打官司；这位大人筛住锣，叫人家打官司！“官差不"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自由”，待我敲起来。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎！庙前庙后，百姓听者：今有包大人，陈州散粮而回，打此经过，在天齐庙"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宿堂。有什么冤枉，前去伸诉！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "众人 （内同白） 没有冤枉。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们没有冤枉，我也没有冤枉。我到那边去。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎！庙左庙右，百姓听者：今有包大人，陈州散粮而回，打此经过，在天齐庙"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宿堂。有什么冤枉，前去诉伸！"
        },
        {
          "character": "李后",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "破瓦寒窑，有一瞎婆，有二十载的含冤！"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你等着！"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我说新开店，总有生意，我先拿她挡挡差。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回禀大人的话：今有破瓦寒窑，有一瞎婆，有二十载的冤枉！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带进来。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咋！瞎老太太，出来凉快凉快。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李后上。）"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来了！"
        },
        {
          "character": "李后",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "身又衰，腿又软，儿在朝中登金殿，"
        },
        {
          "character": "李后",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "娘在寒窑受熬煎。仁宗儿，何日得见？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小哥，唤我何事？"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你方才说有二十载的冤枉。包大人在天齐庙宿堂，有什么冤枉，前去伸诉。"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "敢是那老包他来了？"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不要胡说！我们叫他“包大人”，他还不愿意呢，你怎么叫他“老包”？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我叫他“老包”，还是奉承他了！"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你不奉承他，你是奉承我地方二十板子！"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "取笑了！带路。"
        },
        {
          "character": "李后",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "只为伸诉含冤，"
        },
        {
          "character": "李后",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "含冤浑身有口也难言。"
        },
        {
          "character": "李后",
          "line_type": "二黄平板",
          "musical_style": "二黄平板",
          "style_family": "二黄",
          "text": "急忙诉这奇冤。"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "包拯在哪里？包拯在哪里？"
        },
        {
          "character": "行一步到庙前、地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "跪下了，跪下了！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哽！胆大瞎婆，见了老夫，为何不跪？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "当跪者则跪，不当跪者，我是不跪！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好一个“当跪则跪”！有何冤枉，一一诉来。"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你若真包，我就伸诉；你若假包，说也枉然！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你双目不明，怎知真假？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "真包脑后，有一异相。老身一摸，便知分晓。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来！"
        },
        {
          "character": "王朝、马汉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "包大人下位来了，上前来摸！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李后摸地方。）"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你这狗才，敢来哄我！"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我们家里没有那个风水！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待老夫离位。"
        },
        {
          "character": "王朝、马汉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "包大人下位来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李后摸包拯。）"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "包拯！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿吓！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "瞎婆，你好言差！有何冤枉，一一诉来。"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "包相吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍同下。）"
        },
        {
          "character": "李后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "你那里休道我言语太差，"
        },
        {
          "character": "李后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "听哀家把前情细说根芽："
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家住那里？"
        },
        {
          "character": "李后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "家住在汴梁城龙凤阁下，"
        },
        {
          "character": "李后",
          "line_type": "二黄快三眼",
          "musical_style": "二黄快三眼",
          "style_family": "二黄",
          "text": "我本是普天下，万国九州，万民之中，第一人家。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "姓什名谁？"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我名叫采荷女陪王伴驾，"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "昭阳院李丹凤就是哀家。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "当今万岁，是你什么人？"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "仁宗儿他是我亲生养下，亲生养下，我的儿吓……"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾皇万岁！"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "不孝的名儿万古扬！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此事从何而起？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只因癸未年间，老身身怀六甲。宫中有一刘妃，与内侍郭槐，定下一计。在老"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "王面前，讨下收生待劳旨意。将金丝狸猫，剥去皮尾，换去太子。奏于老王，"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "道哀家产生妖魔鬼怪。老王大怒，将哀家推出午门问斩。多亏满朝文武保奏，"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "死罪以免，活罪难饶，将哀家打入冷宫。他二人一计不成，又生二计，约定八"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "月十五，火焚冷宫。只见火光一起，不知那位神圣，将哀家救在这，破瓦寒窑"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来了！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此事有几载了？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此事有二十余载了。"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "恨刘妃与郭槐收生讨下，"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "他要害老身命染黄沙。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你双目不明，怎知老夫到此？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我在长街乞讨，听众百姓，一个个都道你……"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "道我何来？"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "道你为官好吓！"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "都道你为官时时清正，"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "日断阳来夜断阴。"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "子子孙孙在朝门。"
        },
        {
          "character": "李后",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你若是断明了我的冤仇恨"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传地方。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（地方上。）"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伺候大爷。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐瞎婆一矮坐，暖茶一盏。"
        },
        {
          "character": "地方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咋！老太太这边来。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁吓万岁，若有此事，怎坐得大宋天子？"
        },
        {
          "character": "包拯",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "吃王爵禄当报效，"
        },
        {
          "character": "包拯",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "汉萧何造律法笔尖如刀。"
        },
        {
          "character": "包拯",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "我岂肯袖手观假装不晓？"
        },
        {
          "character": "包拯",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "枉受了朝廷禄身立功高。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "也罢！不免将瞎婆搀扶正位，倘若她受起老夫一拜，定是真皇后；她若受不起"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫一拜，再将她拿下。来！将瞎婆扶在正位。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（王朝允。）"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "瞎婆你要坐稳了！"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "用手儿整整乌纱帽，"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "身上抖抖滚龙袍。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "接驾来迟望恕饶！"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "走上前来我就忙跪倒"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "包相平身。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "见她稳坐身不倒，"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "唬得包拯似汗浇。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "二次撩袍我就忙跪倒。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "国太千岁受臣朝！"
        },
        {
          "character": "李后",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我好心焦！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "国太，"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "尊国太免心焦，"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "为臣把本奏当朝。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "拿住那刘妃郭槐剐万刀；"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "摘去了乌纱我就脱蟒袍！"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "圣上准了臣的本"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "圣上不准臣的本"
        },
        {
          "character": "李后",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "用手儿取出无价宝，"
        },
        {
          "character": "李后",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "文正拿去仔细瞧。"
        },
        {
          "character": "李后",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "一本一本把本奏当朝。"
        },
        {
          "character": "李后",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "千刀万剐我的恨才消！"
        },
        {
          "character": "李后",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "回得朝去把本表"
        },
        {
          "character": "李后",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "但愿拿住郭槐贼"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "用手儿接过无价宝，"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "为臣接驾转回朝。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "国太请上臣的八抬轿"
        },
        {
          "character": "李后",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "从今后再不住这破瓦窑。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李后、地方同下。）"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "开道！"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "看起来还是君无道，"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "才中那刘妃郭槐计笼牢。"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "拿住那刘妃郭槐剐万刀。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍同下。）"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "这样的奇巧事，尔就遇老包！"
        }
      ],
