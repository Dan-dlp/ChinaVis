          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "轻移莲步到书房，"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "且听恩人说端详。"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴家张氏，赵恩人正在书房饮酒，不免去到窗外，听他讲些什么。正是："
        },
        {
          "character": "张氏",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "要知心腹事，但听口中言。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀且住，适才在关前，被崔龙拿住，多亏张氏嫂嫂叫俺一声丈夫，真乃难得"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊难得。哎呀，讲什么难得，若是俺玄郎的妻子叫了别人一声丈夫，我就是这"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "一刀……"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "一句言语错出唇，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "墙内说话墙外听。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "酒醉的人儿话不清。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "不饮酒来假装醉"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "听一言来吃一惊，"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "羞得脸上起红云。"
        },
        {
          "character": "张氏",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "不如一死丧残生。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张氏下。〖起三更鼓〗。华佗上。）"
        },
        {
          "character": "华佗",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "闷坐松林下，修道数百年。三国行医术，自称华佗仙。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃华佗是也，只因赤须龙在曹府被困，特地前来讨一封号，来此已是。"
        },
        {
          "character": "华佗",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "不用忧来不用愁，宝刀割去肉龙瘤。阳世之间无用处，抛在长江顺水流。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何方妖道在此摆来摆去？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫道华佗。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前来则甚？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "修炼多少年代？"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "数百余年了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可算得一洞老神仙。"
        },
        {
          "character": "华佗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。正是："
        },
        {
          "character": "华佗",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "不是真龙开金口，焉得蓬莱一洞仙。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（华佗下。〖起四更鼓〗。张氏上。）"
        },
        {
          "character": "张氏",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "人死如灯灭，犹如汤泼雪。若要还阳转，海底捞明月。"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴乃张氏鬼魂是也，只因闻听赵公子之言，羞愧难当，回房自缢身死，方知他"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "日后有九五之尊，不免去至书房，向他讨一封号。来此已是，待我进去。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何处鬼魂在此摆来摆去？"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奴乃张氏鬼魂是也。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到此何事？"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前日打从华山经过，缺一圣母，就封你以为茶花圣母，归位去吧。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（金童、玉女同上。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "金童、玉女送她归位。"
        },
        {
          "character": "张氏",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张氏、金童、玉女同下。〖起五更鼓〗。）"
        },
        {
          "character": "曹小姐",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "走哇。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹小姐上。）"
        },
        {
          "character": "曹小姐",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忙将大嫂事，报与二哥知。"
        },
        {
          "character": "曹小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二哥快快开门。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬醒，开门。）"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤妹何事？"
        },
        {
          "character": "曹小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嫂嫂悬梁自尽了。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你且回房去吧。"
        },
        {
          "character": "曹小姐",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "唉，嫂嫂哇……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹小姐下。）"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长醒来。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "茶花圣母归了位，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "三国华佗受封回。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "贤弟为何两泪垂？"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄散板",
          "musical_style": "二黄散板",
          "style_family": "二黄",
          "text": "猛然睁开丹凤眼"
        },
        {
          "character": "曹彬",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "唉，嫂嫂哇……"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟为何落泪？"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我家嫂嫂悬梁自尽了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有这等事。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内呐喊声。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪里人马呐喊？"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待小弟府门打探再来回报。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有劳贤弟。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曹彬下，上。）"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄长大事不好了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事惊慌？"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有崔龙带领人马，将府门围住。口口声声要拿兄长上殿。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟今乃什么日期？"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "八月十四日。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日呢？"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "中秋之日了。"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此说来，俺玄郎也有出头之日了。"
        },
        {
          "character": "曹彬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想你这光棍之家，还有什么出头之日不成？"
        },
        {
          "character": "赵匡胤",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贤弟呀。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "休道我光棍家根本无有，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "请台座听玄郎细说从头："
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "想当年俺玄郎江湖上走，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "柴大哥贩雨伞郑恩卖油。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "胜似那一母生心意相投。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "柴大哥上淮庆官封王侯。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "修书信接玄郎全家来投。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "鱼池内起怪风妖魔出头。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "俺玄郎一见是妖魔出头。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "又听得谯楼上鼓打三筹。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（胡琴过门。）"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "次日里柴大哥朝房待漏，"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "郭王爷一见俺火上浇油。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "多亏了柴大哥一本保留。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "不用兵不用将独下燕州。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "多亏了贤弟你将我收留。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "偶然间得二梦大不相投。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "执宝刀照左臂割去肉瘤。"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "某一言未出口就要斩首"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "悔不该在金殿夸下海口"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "在关前遇崔龙蒙你搭救"
        },
        {
          "character": "赵匡胤",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "今夜晚在书房一觉醒后"
        },
        {
