      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（万历上。）"
        },
        {
          "character": "万历",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "时才内侍报连声，"
        },
        {
          "character": "万历",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "午门外反了马文成。"
        },
        {
          "character": "万历",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "一同定计退雄兵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（国太上。）"
        },
        {
          "character": "国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "马芳领兵到朝门，"
        },
        {
          "character": "国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "好叫老身心内惊。"
        },
        {
          "character": "万历",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见母后。"
        },
        {
          "character": "国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿少礼，一旁坐下。"
        },
        {
          "character": "万历",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。启禀母后：今有马芳带领人马，反到皇城，如何是好？"
        },
        {
          "character": "国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我把你这奴才。先前为娘怎样嘱咐于你，执意不听，至有今日，事已至此，快"
        },
        {
          "character": "国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "快宣亚父杨波上殿，一同定计便了。"
        },
        {
          "character": "万历",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宣亚父杨波上殿。"
        },
        {
          "character": "内侍",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁有旨：亚父杨波上殿。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨波上。）"
        },
        {
          "character": "杨波",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "忽听内侍宣一声，"
        },
        {
          "character": "杨波",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "午门外来了保国臣。"
        },
        {
          "character": "杨波",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "国太宣臣为何情？"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣杨波见驾，国太千岁。"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "迈步且把金殿进"
        },
        {
          "character": "国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "亚父平身，赐坐。"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。将臣宣上殿来，有何国事议论？"
        },
        {
          "character": "国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有你义子马芳，带领人马，反到皇城，要想一退兵之计。"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣子马芳，性情高傲，武艺超群，老臣实无良计。"
        },
        {
          "character": "国太",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不好了。"
        },
        {
          "character": "万历",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "听一言来心内惊，"
        },
        {
          "character": "万历",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "背转身来自思忖。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（万历跪。）"
        },
        {
          "character": "万历",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "还求亚父定计行。"
        },
        {
          "character": "杨波",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "自从盘古到如今，"
        },
        {
          "character": "杨波",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "哪有君王来跪臣。"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：事到如今，并无别计，请将臣捆绑城楼，项带剑枷，倘若马芳不肯"
        },
        {
          "character": "杨波",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "退兵，即刻就将为臣斩首城楼，那马芳念在父子之情，或可收兵。"
        },
        {
          "character": "万历、国太",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "好，内侍带马敌楼。"
        },
        {
          "character": "国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "内侍臣摆驾敌楼进，"
        },
        {
          "character": "国太",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "观看马芳发来的兵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "马芳 （内西皮导板） 探马儿不住待飞来报，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四大铠、马昆、马玉、二夫人、马芳同上。）"
        },
        {
          "character": "马芳",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "海岱门前撤吊桥。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四大铠、马昆、马玉、二夫人、马芳同大转场。）"
        },
        {
          "character": "马芳",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "未兴兵先放三声炮，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马芳转场。）"
        },
        {
          "character": "马芳",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "保驾的夫人赛凤摇。"
        },
        {
          "character": "马芳",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "四杆彩旗脑后飘。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "都只为我父坐监牢。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "某学关公来挡曹。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "左右的前锋官把帅保"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "马文成顾不得全忠孝"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "此一去好比华容道"
        },
        {
          "character": "万历",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "旌旗不住城下飘，"
        },
        {
          "character": "万历",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "倒叫孤皇心内焦。"
        },
        {
          "character": "万历",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "为何兴兵犯九朝？"
        },
        {
          "character": "万历",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "低头便把将军叫"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "老王晏驾龙归沧，"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我朝出了奸贼李良。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "太后无故禁昭阳。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "人马一齐到朝堂。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "如何无故斩忠良？"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "再与太后说端详："
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "你不念当年保国忠良。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "封条锁在宫门上"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "多亏贾妃搬兵将"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "到如今太平江山你安享"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "问得昏王无话讲"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "昏王信用贼奸党"
        },
        {
          "character": "国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "亚父快把城楼上，"
        },
        {
          "character": "国太",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "速与哀家作主张。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "勒住丝缰来观定，"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "城楼上只见老爹尊。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "倒叫豪杰痛伤情。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "三件大事要应承。"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若叫我退兵，却也不难，必须要依我三件大事。"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "项带剑枷身边捆"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "若叫我退兵不甚要紧"
        },
        {
          "character": "万历",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但不知哪三件？"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "第一件，要将我父头上剑枷摘去，官复原职。"
        },
        {
          "character": "万历",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "第二件？"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "第二件，榆林郡人马，听调不听宣。"
        },
        {
          "character": "万历",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这第三件？"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "第三件，要将徐赞放出城来，任凭我父子发落。"
        },
        {
          "character": "万历",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三件大事件件依从，快快收兵。"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁！"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "三件大事皆应允，"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "倒叫豪杰喜在心。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "就在此地札大营。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "他是君来我是臣。"
        },
        {
          "character": "马芳",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "人马杀上午朝门。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、四大铠、马昆、马玉、二夫人同下。）"
        },
        {
          "character": "马芳",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "且看那万岁爷怎样施行。"
        }
