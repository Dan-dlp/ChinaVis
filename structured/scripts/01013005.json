          "text": "（四龙套、四上手、马昆、马玉、马芳同上。）"
        },
        {
          "character": "马芳",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "点动人和马，兵发紫禁城。"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马昆、马玉，人马可曾齐备？"
        },
        {
          "character": "马昆、马玉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俱巳齐备。"
        },
        {
          "character": "马芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "起兵前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。众人同下。）"
