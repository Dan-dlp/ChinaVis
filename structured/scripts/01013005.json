    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "万历",
        "低头便把将军叫",
        "内侍",
        "到如今太平江山你安享",
        "国太",
        "多亏贾妃搬兵将",
        "封条锁在宫门上",
        "左右的前锋官把帅保",
        "昏王信用贼奸党",
        "杨波",
        "此一去好比华容道",
