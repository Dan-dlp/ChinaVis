    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "卢俊义",
        "曾大虎",
        "燕青"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（曾大虎、曾氏四虎同上。⑴）"
        },
        {
          "character": "曾大虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，大虎。奉了师爷之命，把守庄门，就此前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众梁山兵、燕青、林冲、卢俊义同上。）"
        },
        {
          "character": "卢俊义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上前叫庄！"
        },
        {
          "character": "燕青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔，开庄！"
        },
        {
          "character": "曾大虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么人叫庄？"
        },
        {
          "character": "燕青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "梁山卢爷拜。"
        },
        {
          "character": "曾大虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大开庄门！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众梁山兵、燕青、林冲、卢俊义同进庄。众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "曾大虎→卢俊义",
