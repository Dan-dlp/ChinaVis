  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "卢俊义",
        "燕青"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众梁山兵、四女将、阮小二、阮小五、燕青、李逵、林冲、卢俊义同上。〖点绛唇〗。）"
        },
        {
          "character": "卢俊义",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "水泊梁山义气广，替天行道美名扬。一箭之仇若不报，旗倒火焚忠义堂。"
        },
        {
          "character": "卢俊义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某，卢俊义。可恨史文恭，箭射晁大哥，众家哥弟纷纷议论，要报一箭之仇，"
        },
        {
          "character": "卢俊义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "因此挂我为帅，攻取曾头市。我想史文恭，与我同堂学艺，我不免先去顺说于"
        },
        {
          "character": "卢俊义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他。"
        },
        {
          "character": "卢俊义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "燕青上站！"
        },
        {
          "character": "燕青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "卢俊义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吩咐众家哥弟，曾头市去者！"
        },
        {
          "character": "燕青",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众家哥弟，曾头市去者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "卢俊义→燕青",
          "turns": 2
        },
        {
          "edge": "燕青→卢俊义",
          "turns": 1
        }
      ],
      "stats": {
