    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "卢俊义",
        "史文恭",
        "阮小二",
        "阮小五"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史文恭上，仆地又起，走小圆场。〖水声〗。阮小二、阮小五自下场门同摇船上。）"
        },
        {
          "character": "阮小二、阮小五",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "打鱼哟！"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！船家！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（阮小二、阮小五见是史文恭，暗喜。）"
        },
        {
          "character": "阮小二、阮小五",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "干什么？"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "渡俺过去。"
        },
        {
          "character": "阮小二",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打鱼船不渡人。"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我多把银钱。"
        },
        {
          "character": "阮小二",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多把银钱哪？好，你等会儿。"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "搭了扶手。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史文恭上船。史文恭、阮小二、阮小五同走圆场。）"
        },
        {
          "character": "阮小二、阮小五",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "拿来！"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要什么？"
        },
        {
          "character": "阮小二、阮小五",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "钱哪。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史文恭摸身上，未带银子。）"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "船家，渡我过去，再把银钱。"
        },
        {
          "character": "阮小二、阮小五",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "不成！船家不打过河钱。"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "身旁不曾带着钱；渡我过去，多把银钱。"
        },
        {
          "character": "阮小二、阮小五",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "不成啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史文恭见情况不对，故意。）"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位方便方便。"
        },
