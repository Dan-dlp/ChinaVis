    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "鲁肃"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鲁肃上。）"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "辞别了周公瑾忙出宝帐，"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 2,
          "唱": 1
        },
        "singing_ratio": 1.0,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮原板"
        ]
      }
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "刘备",
        "刘封",
        "奉命来说不出这长篇大论",
        "此一番见吴侯把话来论",
        "蒙厚意备酒筵肃当愧领",
        "诸葛亮",
        "辅刘琦守荆襄名正言顺",
        "鲁肃"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套引刘备同上。）"
        },
        {
          "character": "刘备",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "坐守荆州，每日里，为国忧愁。"
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "周郎定计设牢笼，美人之计害孤穹。弄假成真结鸾凤，夫妻幸喜出樊笼。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤，刘备。可恨周瑜，设下美人之计，将孤诓到东吴，陷害于我；不料弄假成\n真，竟成姻眷。且喜郡主保定孤家转回荆州。想那周郎，此计不成定不能与我\n甘休；还须要提防一二。正是："
        },
        {
          "character": "刘备",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "天不从人意，枉自费心机！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘封上。）"
        },
        {
          "character": "刘封",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "忙将东吴事，禀报父王知。"
        },
        {
          "character": "刘封",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启父王：鲁肃过江来了。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "鲁肃又过江来了？有请诸葛先生。"
        },
        {
          "character": "刘封",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请诸葛先生！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（诸葛亮上。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "袖内八卦早算定，鲁肃又讨荆州城。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见主公！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生少礼、请坐。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "鲁肃今日又过江来，不知何意？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "昨日孙权，表主公为荆州牧，乃是惧怕曹操方用此计。而曹操又封周瑜为南郡\n太守，此欲叫我两家自相吞并；他于中取利。今鲁肃前来，定是周郎既受太守\n之职，徒有虚名、而无其地；是以又来索讨荆州。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既然如此，当以何言答对？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那鲁肃到此，不提荆州之事便罢，若提荆州，主公便放声痛哭；哭到悲切之时，\n亮自出来解劝。亮且在屏风之后躲避。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（诸葛亮下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请鲁大夫。"
        },
        {
          "character": "刘封",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请鲁大夫。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。鲁肃上。）"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇叔！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大夫！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备、鲁肃相互见礼。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大夫请坐。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇叔今日做了东吴女婿，便是肃之主人，如何敢坐？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "子敬与孤，素日交好，何必太谦。请坐。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告坐。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不知子敬驾到，备有失远迎，当面恕罪！"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "肃来得鲁莽，皇叔海涵。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来，看宴侍候！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。）"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到此又要叨扰！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大夫请。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇叔请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "肃今奉吴侯之命，特为荆州一事而来。皇叔借住荆州已经多日，未蒙见还。今\n日孙刘两家既为秦晋之好，当看在这亲情的面上，早早交付，以践前言。谅皇\n叔断无推辞了。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉，大夫呀！"
        },
        {
          "character": "刘备",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "未曾开言两泪淋，\n尊一声鲁子敬细听分明：\n思想起刘景升好叫我恸哭伤情。\n竟将这荆襄地尽献曹营。\n又谁知那奸曹下了绝情。\n将刘琮母子们杀害丧生。\n叫孤家怎不念那姓刘之人？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（诸葛亮上。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "闻听来了鲁子敬，\n急忙上前礼相迎。"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生来了，请坐。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有坐。呀大夫，你看我主公在此恸哭流涕，你可知我主公哭的缘故么？"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "肃却不知。"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想我主公，当初借荆州之时，曾经言道：待等取了西川便还荆州。但是仔细想\n来，刘景升是我主公同宗兄弟；那益州刘璋，也是我主公之弟，一般俱是汉朝\n骨肉。倘若兴动人马，夺了他的城池，岂不被天下之人唾骂！若是不还荆州，\n于尊舅面上甚不好看。若不取西川、还了荆州，叫我主公何处安身？因此进退\n两难，是以恸哭不止。为今之计，敢烦子敬，回转东吴，见了吴侯，将此悲情\n烦恼转告；再容几时，以图良策！"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "话虽如此。倘吴侯不允，如之奈何？"
        },
        {
          "character": "诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吴侯既以胞妹聘嫁于我主，焉有不允的道理？大夫再领几杯！"
        },
        {
          "character": "鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "先生呐！"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "见皇叔哭刘表感叹不尽，\n这才是仁德主仗义之人。\n但只是苦了我鲁肃一人。"
        },
        {
          "character": "辅刘琦守荆襄名正言顺、奉命来说不出这长篇大论、诸葛亮",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "子敬，你真乃是妙人也！"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "妙不妙你那里"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "自然分明。\n辞皇叔别先生即刻登程。"
        },
        {
          "character": "蒙厚意备酒筵肃当愧领、刘备",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "子敬为人真可敬，\n刘备倒做了失信人。\n且将孤为难事细说分明。"
        },
        {
          "character": "此一番见吴侯把话来论、鲁肃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "皇叔不必细叮咛，"
        },
        {
          "character": "此一番见吴侯把话来论、鲁肃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（旗牌带马上。）"
        },
        {
          "character": "鲁肃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "见了吴侯诉详情。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（鲁肃下。）"
        },
        {
          "character": "诸葛亮",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "鲁肃此番转回程，\n只恐周郎不甘心。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（刘备、诸葛亮同下。）"
        }
      ],
