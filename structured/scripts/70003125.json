    {
      "scene_index": 6,
      "label": "第六场",
      "characters_present": [
        "于禁",
        "庞德",
        "报子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、于禁同上。）"
        },
        {
          "character": "于禁",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "兵扎罾口川，犹如铁桶般。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（庞德、四下手同上。）"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见元帅。"
        },
        {
          "character": "于禁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "庞将军到此何事？"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才差人暗探敌人动静，荆州兵马，移驻高阜之上，其中有诈。"
        },
        {
          "character": "于禁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽移营，何诈之有？"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想这七军屯于川口，地势甚低，而今秋雨连绵，江水暴涨。倘若关羽决口放水，"
        },
        {
          "character": "于禁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎！移营方定，军士辛苦，再若移动，那关羽乘势截杀，如何抵挡？"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兵贵神速，不可迟疑。关羽杀来，有某抵挡。"
        },
        {
          "character": "于禁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "说什么迟疑不迟疑，分明是你危言耸听，贪功好胜。"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "元帅！某以七军为重，何言贪功好胜？元帅不肯移营，俺庞德愿将本部军马，"
        },
        {
          "character": "于禁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "容某思之。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启元帅，襄江决口，直灌我营。"
        },
        {
          "character": "于禁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官！速速离营！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（水声冲众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "于禁→庞德",
          "turns": 6
        },
        {
          "edge": "庞德→于禁",
