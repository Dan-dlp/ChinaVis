    {
      "scene_index": 7,
      "label": "第七场",
      "characters_present": [
        "周仓"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（马童、关平同上，过场，同下。）"
        },
        {
          "character": "周仓",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "好大水也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周仓执排上，擒七军众人同下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 2,
          "内白": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      }
    },
    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "于禁",
        "众将",
        "关平",
        "关羽",
        "周仓",
        "庞德"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众将、马童、关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关平上。）"
        },
        {
          "character": "关平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "于禁被擒。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "绑进帐来。"
        },
        {
          "character": "关平",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "绑进帐来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二兵卒押于禁同上。）"
        },
        {
          "character": "于禁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯啊！于禁归降来迟，死罪呀，死罪！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！大胆于禁，关某兴兵至此，尔竟敢猖狂。来将于禁打入囚车，解回荆州，\n待某擒住曹操，一齐斩首。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二兵卒押于禁同下。周仓上。）"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "庞德被擒。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "押进帐来。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "押进帐来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二兵士押庞德同上。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下站可是庞德？"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "然！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既已被擒，为何不跪？"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺乃堂堂英雄，岂肯屈膝于你。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今日被擒，可知关某威名？"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽！今日之事，只因于禁不听某言，致有此败。那日若不是他鸣金收兵，只\n怕你早做了俺的刀头之鬼。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大胆！"
        },
        {
          "character": "关羽",
          "line_type": "风入松",
          "musical_style": null,
          "style_family": null,
          "text": "庞德出言太猖狂，\n敢说刀法比我强。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "斩！"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢！庞德乃马超将军帐下旧将，勇猛非常，劝他归降，岂不又添一员猛将？"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这……"
        },
        {
          "character": "众将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "君侯三思。"
        },
        {
          "character": "庞德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某宁死不降。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "斩！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周仓推庞德同下，周仓上。）"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "斩首已毕。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将他自带皮榇，盛殓他的尸首，埋葬起来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关羽出位。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今日七军已灭，樊城指日可破，皆众位将军之功。"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "末将等何功之有。君侯谋略灭七军，于禁被擒，庞德被斩，声威大震，君侯可\n称威震华夏矣！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "威震华夏？"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "威震华夏。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "关羽 （三笑） 哈哈哈！"
        },
        {
          "character": "众将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "后帐摆宴，与众将贺功。"
        },
        {
          "character": "众将",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢君侯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "关羽 （沽美酒） 奉君命镇荆襄，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "全凭着青龙偃月英名好。"
        },
        {
          "character": "众将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（沽美酒） 保大哥展土开疆。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
