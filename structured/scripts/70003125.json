      }
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "关羽",
        "周仓",
        "赵累"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小马童引关羽同上。）"
        },
        {
          "character": "关羽",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "赤面雄心，须似乌，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（周仓上，亮相。）"
        },
        {
          "character": "关羽",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "绿袍锦甲，逞威武。秉烛达旦天下晓，汉室美髯一丈夫。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见父王！"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少礼。"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "威镇荆州统雄兵，运筹帷幄鬼神惊。东吴君臣俱丧胆，智压曹瞒百万军。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "桃园结义，玄德兄、翼德弟，誓同生死。某奉大哥之命，威镇荆襄九郡。前者\n曹仁失机兵败，曹操定不干休。也曾命赵累将军，探听魏军动静，未见回报。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵累上。）"
        },
        {
          "character": "赵累",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "探得机密事，回报君侯知。"
        },
        {
          "character": "赵累",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀君侯：今有曹操，挂于禁为帅，统领七路人马。庞德以为先锋，自带皮榇\n一口，要与君侯决一死战。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参谋紧守大营。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵累下。）"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！庞德小儿，不过是马超帐下一员小将，何敢出此狂言？庞德呀，庞德！\n任你英勇无敌手，难逃关某偃月刀。\n周将！"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "排开阵式，迎敌者！"
        },
        {
          "character": "周仓",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咋，排开阵式，迎敌者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "周仓→关羽",
          "turns": 3
        },
        {
          "edge": "关羽→周仓",
          "turns": 3
        },
        {
          "edge": "关羽→赵累",
