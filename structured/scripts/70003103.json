    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "工匠丁"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四工匠抬刀、枪、剑同上。刘备、关羽、张飞、苏双、张世平、吕常、方雄同上，观看兵器，称赞。）"
        },
        {
          "character": "工匠丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！稀奇，稀奇！一阵大风，从草内钻出一条小青蛇，可怜它死在这冷艳锯"
        },
        {
          "character": "工匠丁",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "刀头之上。口内吐出鲜血，真如画在刀头之上，诸位义士请看。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "恭喜关兄，贺喜关兄！青龙钻踪冷艳锯刀头之上，口现红光，冷艳锯堪称青龙"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "偃月刀。此乃大吉之兆也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "关羽 （三笑） 哈哈，哈哈，啊哈哈哈哈！"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢列位义士相赠青龙偃月刀名。关某得志，建功立业，展土辟疆，仰仗诸位"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "金言也！大家收拾马匹，明日一同投军，与国除患，安邦去者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "张飞 （同尾声） 风云聚会艳阳娇，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "桃园饮宴集英豪；"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "疆场上建立功劳。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
