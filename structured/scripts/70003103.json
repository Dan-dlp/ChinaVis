          "style_family": null,
          "text": "张家庄去者！"
        },
        {
          "character": "工匠乙、工匠丙、工匠丁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请哪！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "四工匠 （同梅花板） 叹苍生乱世，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "何时才得个太平年？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四工匠同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "工匠丁→工匠甲",
          "turns": 3
        },
        {
          "edge": "工匠甲→工匠乙",
          "turns": 1
        },
        {
          "edge": "工匠乙→工匠丙",
          "turns": 1
        },
        {
          "edge": "工匠丙→工匠丁",
          "turns": 1
        },
        {
