    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "关羽",
        "刘备",
        "四工匠",
        "四青袍",
        "小院子",
        "张飞"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍同上，同打扫桃园。）"
        },
        {
          "character": "四青袍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有请诸位义士。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "方雄 （内同白） 三位义士请哪！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "张飞 （内同白） 诸位义士请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（苏双、张世平、吕常、方雄、刘备、关羽、张飞同上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "刘备 （梅花板） 范阳巧遇关与张，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "心投意合同志向。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "关羽 （梅花板） 为不平把祸闯，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "逃灾避难走范阳。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "张飞 （梅花板） 刘关张异姓结拜一炉香。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "张飞 （同梅花板） 喜洋洋笑非常，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "豪杰良将聚一堂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（同笑） 哈哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。苏双、张世平、吕常、方雄、刘备、关羽、张飞同入席。）"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请问关二爷，因何来在范阳，三雄会见？赐教一遍，我们大家洗耳恭听。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位不嫌耳烦，容某下位手舞足蹈，叙说一遍。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请道其详。"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "平生志气刚，文武记胸膛。恨无出头日，明珠土内藏。"
        },
        {
          "character": "关羽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "宦臣掌朝政，汉室乱纲常，官吏天良丧，黎民遭祸殃。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽自幼磨穿铁砚，深通诗书。平生好打不平，那日正在酒肆之中沽饮，忽然"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "闯进一白发老者，遍体汗淋，痛哭流涕，惨不忍观。问其情由，老者言道：他"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "名张继昌，乃蒲州解良人氏，老妻去世，只有一女，名叫鸾姣。一日，熊府家"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人，前来提亲，张家不允。熊祥诈写假借约一张，告到解良苗信台前。想那苗"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "信，乃是熊太守门生，自然是官官相护，将张继昌父女抓到衙中，张鸾姣扣押"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "监中，张继昌用乱棍打下堂来。可怜张继昌年过花甲，上下衙门，叩告喊冤，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "均不准状。在酒肆之中，遇着关某，领他击鼓鸣冤。狗官又将张继昌暴打，那"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "时某上得堂去，与赃官辩理，问得狗官，哑口无言。狗子熊祥，向某威唬，某"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家一怒，当堂将熊祥打死。刀劈监牢，放出一伙被难囚犯，救了张氏父女，火"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "焚解良县衙。逃出城来，只听得后面，人声呐喊，官兵追赶而来。那时某身无"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寸铁，如何抵挡。幸喜路旁，有一圣母娘娘古庙。是某进庙躲藏，不多时间，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "又听得这哗啦啦一声响亮，火光冲天，乌烟四起！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四块玉） 他他他狐群追赶紧，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "某闯出了火海险境。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "那时某从烈火之中，闯出庙门，正遇熊虎，我二人话不投机，被某夺那厮宝剑，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "斩了熊虎，杀死一伙恶奴。我闯了此祸，山西地面不能存身，因此奔走范阳，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "巧遇刘、张二位义士。我三人言谈议论，志趣相同，结为金兰之好，又遇众"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "位义士相助，真乃万千之幸！这是关某从解良来到范阳一事。众位义士贻笑了，"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈哈！"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "关二爷真君子也！我等敬奉三杯。请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。苏双、张世平、吕常、方雄、刘备、关羽、张飞同饮酒。）"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请问刘兄贵乡何处？有何志向？愿闻其详。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "备就是这县郡大树楼桑人氏，姓刘名备，字玄德。我乃中山靖王之后，孝景皇"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "帝陛下之玄孙，祖父刘雄，父印刘宠，曾为涿郡太守，去世之后家业贫穷，只"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "落得织席贩履为生。幼读经纶，深通兵法，素怀大志，久欲上报国家，下安黎"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "庶，扫平外患，定国安邦。怎奈我时运不至，唉，真是苍天困煞英雄也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（叨叨令） 俺平生怀大志丈夫血性，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "愧煞我徒有宏图报国心。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "兀的是恨煞人也么哥。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "刘兄乃是汉室宗亲，素怀救国安民之心，令人钦佩！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夸奖了，哈哈哈哈！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位乡邻！咱张飞家世列位尽知。咱老张的志愿，与关、刘二兄，可算志同道"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "合，相同无二。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "张三爷！我们大家还未曾请教，张三爷你怎么自己就提起来了？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "列位义士问完关兄、刘兄，少不得就要问咱老张。咱张飞自己讲了出来，就免"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得诸位兄台多费唇舌了。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "快人快语，真乃英雄也！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咋，咋，咋！哎呀，列位义士抬爱了，哈哈哈哈！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小院子上。）"
        },
        {
          "character": "小院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启禀三位老爷：打造兵器的工匠来了。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "快快叫他们进来讲话。"
        },
        {
          "character": "小院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "四工匠 （内同白） 来了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四工匠同上。）"
        },
        {
          "character": "四工匠",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "全凭两膀臂力，老君炉内求金。"
        },
        {
          "character": "四工匠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见诸位义士！"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。"
        },
        {
          "character": "四工匠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请问刘、关、张三位义士，打造兵器，有多少钢铁？"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "折铁两千斤。"
        },
        {
          "character": "四工匠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "打什么兵器？"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "提龙双股剑。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丈八蛇矛枪。"
        },
        {
          "character": "关羽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三停冷艳锯。"
        },
        {
          "character": "四工匠",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "在哪里打造？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家院！领他们去到后园草地打造。"
        },
        {
          "character": "小院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "小院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "诸位随我来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小院子、四工匠同下。）"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "三位义士！我们必须多聚集些志同之人，前往投军方好。"
        },
        {
          "character": "刘备、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "那是自然！还须要招军买马。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（小院子上。）"
        },
        {
          "character": "小院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "庄外来了许多壮年汉子，带了许多兵器，良马数十骑，前来拜见刘、关、张与"
        },
        {
          "character": "小院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位义士来了。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我们何不出庄迎接！"
        },
        {
          "character": "苏双、张世平、吕常、方雄、关羽、张飞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "言得极是！大家一同出庄去者。请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
