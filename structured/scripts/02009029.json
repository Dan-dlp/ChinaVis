        "雷横"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱仝、雷横同上。）"
        },
        {
          "character": "朱仝、雷横",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "走吓！"
        },
        {
          "character": "朱仝",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "漏水沉沉静，"
        },
        {
          "character": "雷横",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "孤灯滴滴清。"
        },
        {
          "character": "朱仝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咱家朱仝。"
        },
        {
          "character": "雷横",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咱家雷横。"
        },
        {
          "character": "朱仝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哥吓，方才见一个赤发虬髯的汉子，怎么赶到这里，就不见了？"
        },
        {
          "character": "雷横",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我们再赶上前去。"
        },
        {
          "character": "朱仝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有理。"
        },
        {
          "character": "朱仝",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "饶他走上焰摩天，"
        },
        {
          "character": "雷横",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "脚下腾云须赶上。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（朱仝、雷横同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "雷横→朱仝",
          "turns": 4
        },
        {
          "edge": "朱仝→雷横",
          "turns": 4
        }
      ],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "同白": 1,
          "念": 3,
          "白": 5
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
