          "musical_style": null,
          "style_family": null,
          "text": "费、尤二卿！"
        },
        {
          "character": "费仲、尤浑",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太宰还朝，你等各要小心。"
        },
        {
          "character": "费仲、尤浑",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "闻仲",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "八龙套 （内同白） 有！"
        },
        {
          "character": "闻仲",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "将人马扎在皇城。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "八龙套 （内同白） 啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "闻仲 （内二黄导板） 将人马扎皇城休要罗唣，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（闻仲上。）"
        },
        {
          "character": "闻仲",
          "line_type": "二黄碰板",
          "musical_style": "二黄碰板",
          "style_family": "二黄",
          "text": "奉王命征北海得胜还朝。"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "在午门下麒麟忙登御道，"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "见凤阁与龙楼甚是萧条。"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "武班中不见了黄家英豪。"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "三呼万岁参见当朝。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣，太宰闻仲见驾，吾皇万岁！"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "文班中不见了比干元老"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "撩蟒袍端玉带品级台到"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太宰平身。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐绣墩。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太宰将征讨金鳌之事，一一奏来。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：臣奉命征讨金鳌，大兵一到，那贼不战自降，写下降书顺表，年年"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "进贡，岁岁来朝。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此乃太宰虎威。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我主洪福。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "费、尤二卿！"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣！"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "光禄寺大摆御宴，与太宰贺功。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为何拦阻？"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老臣进得朝来，为何不见比干丞相？"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太宰有所不知，只因新宫娘娘身染重病。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但不知是新病旧病？"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是旧病新犯。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就该请太医调治。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寡人已传太医调治，但是缺少一味药引。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "但不知缺何药引？"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "缺少玲珑透剔心为药引。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老臣幼年，也曾读过药书，未见有玲珑透剔心，是何药引？"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寡人亦是这样言讲，那新宫娘娘言道：满朝文武俱是血心，惟有比干丞相，乃"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是玲珑透剔心，寡人将他宣上金殿，赐他宝剑一口，乃是一句戏言，不想老太"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宰忠心耿耿，他竟剖心而亡了。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁怎讲？"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "剖心而亡了。"
        },
        {
          "character": "闻仲",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "太宰呀！"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "听说是老太宰剖心而丧，"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "我朝中又去了架海金梁。"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "老太宰呀！"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "可怜他忠心耿耿一命身亡。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：正宫国母，挖目烙手，因何而起？"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下殿角哭一声比干丞相，比干丞相"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太宰哪里知道，姜娘娘使她弟文焕，身藏短刀，在五凤楼前行刺，有心谋害寡"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人，因此将她挖目烙手。"
        },
        {
          "character": "闻仲",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "国母呀！"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "姜国母坐昭阳万民敬仰，"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "最可叹受惨刑命丧无常。"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "国母啊！"
        },
        {
          "character": "闻仲",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "可叹她身为国母受刑而亡。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：贾氏夫人坠楼而死，黄家父子反出五关，此事又从何而起？"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下金殿哭一声国母娘娘，国母娘娘"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "只因孤闻听贾氏夫人生得美貌，将她宣上摘星楼，奉陪孤王饮酒，谁之她羞愧"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "难当，竟自坠楼而亡。那黄家父子叛反孤家，保定太子，杀出朝歌。似这等不"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "忠不孝之人，提他作甚？"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我主江山一旦休矣！"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "贾氏夫人坠楼前，"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "黄家父子反五关。"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "下殿来再问那文武两班。"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "在金殿问昏君无言答辩"
        },
        {
          "character": "费仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见老太宰。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下站何人？"
        },
        {
          "character": "费仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上大夫费仲。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摘星楼可是尔所造？"
        },
        {
          "character": "费仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣上旨意，喏、喏、喏，小臣监造。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔！"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "摘星楼乃是尔造定，"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "害了多少栋梁臣。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "鞭来！"
        },
        {
          "character": "闻仲",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "金鞭一举追尔命，"
        },
        {
          "character": "闻仲",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "打死费仲再问来臣。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（费仲下。）"
        },
        {
          "character": "尤浑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见老太宰。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是何人？"
        },
        {
          "character": "尤浑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下大夫尤浑。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "炮烙、虿盆是尔监造？"
        },
        {
          "character": "尤浑",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣上旨意，喏、喏、喏，小臣监造。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔！"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "炮烙、虿盆尔监造，"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "害了无数女多娇。"
        },
        {
          "character": "闻仲",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "打死谗臣问当朝！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（尤浑下。）"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启万岁：新宫国母，为臣要见。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天色已晚，明日再见。"
        },
        {
          "character": "闻仲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老臣一定要见！"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！"
        },
        {
          "character": "纣王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "好一个胆大的太宰闻仲，"
        },
        {
          "character": "纣王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "敢在午门打大臣。"
        },
        {
          "character": "纣王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "要见妲己万不能。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
