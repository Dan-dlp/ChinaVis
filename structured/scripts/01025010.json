        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "鹅毛大雪冷难禁。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "一心要去救亲生。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "抬头闪目看分明："
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "它比别门大改形。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "楼下密摆箭雕翎。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "城右兵似一窝蜂。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "吸气吞声转身形。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "泄漏机关了不成。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "暗暗哀家告苍穹。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "行动雪地有迹踪。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "被她识破不相应。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "必然又把毒计生。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "方与我儿免祸星。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "一步一扫往前行。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "皂河之内水成冰。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "祝告龙王在上听："
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "水化冰开显身形。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（龙王、四水卒、刘彦真暗同上。）"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "赵素娘正在伤心处，"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "一声响亮令人惊。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "见一幼子出水平。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "平坦之地放身形。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "若有差池母命倾。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "又听我儿哼一声。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（水卒、龙王暗同下。）"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "适才渺渺赴阴城，"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奸妃害我好苦情。"
        },
        {
          "character": "刘彦真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又见母后到来临。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "何人救我还阳境"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一见我儿转还生，"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哀家又喜又伤情。"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "伤的是湿衣着体冷难禁。"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "与我儿暂且挡雪并遮风。"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "细对为娘诉分明。"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "喜的是母子重相会"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "忙忙脱下衣一件"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奸妃怎样将你害"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "彦真跌跪珠泪倾，"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "多谢母后好恩情。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣说来母后听："
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "遇见西妃狠毒虫。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不料贼人动无名。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "说我前去把刺行。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "再三哀告不容情。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "霎时一命丧残生。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为儿进了冤死城。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "彦真死后又复生。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "若问奸妃将儿害"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "昨日接母进宫廷"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣上前去接驾"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "手指孩儿高声骂"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不容儿说将儿绑"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叫人用酒把儿灌"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "心疼气紧难扎挣"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "多亏母后来搭救"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "听罢言来怒气生，"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "不由立刻动无名。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "胆敢欺压我子亲生。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "太后怎能擅留情。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "剥皮抽筋挖眼睛。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "剐骨熬油点天灯。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "不知奸妃怎待承？"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "你妹金定女俊英。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "兄妹二人一母生。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "公主、太子受苦情。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "快些寻路去逃生。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "识破机关命定倾。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "只落得路上受贫穷。"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "奸妃倚仗君王宠"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "有朝一日拿住你"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "千刀万剐难消恨"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "割了贼心不算帐"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "可叹还有金定女"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "叹我儿宫中为太子"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "为娘所养你们俩"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "到如今被她来作践"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "母子不可贪恋住"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "倘若被她来知晓"
        },
        {
          "character": "赵妃",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "可怜东宫皇太子"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "彦真不由放悲声，"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好似狼牙箭穿胸。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "实实难舍母子情。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "奸妃知道不容情。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一定害我命残生。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哭哭啼啼步难行。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "除非是花儿重开月又明。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为儿欲要逃生去"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "欲待母子常聚会"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "彦真必然遭擒获"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "罢罢罢，辞别母后寻路径"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "若要母子重相见"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见儿贪恋步难行，"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为娘好似箭穿胸。"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "害得我母子好苦情。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（土地上，引刘彦真同下。）"
        },
        {
          "character": "赵妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "趁早急出阳关境，"
        }
      ],
