        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "陷害与我为你身。"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "咱们俩结下冤仇似海深。"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "治死畜生免祸根。"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "手指狗子高声骂"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "你哪里来是接凤驾"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "狗子意高心胆大"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "不见冤家还自可"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "你对父王将言谏"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "今日见了冤家面"
        },
        {
          "character": "唐妃",
          "line_type": "西皮流水板",
          "musical_style": "西皮流水板",
          "style_family": "西皮",
          "text": "叫人来绑他把宫进"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "彦真跌跪泪纷纷，"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "望姨母高开天地恩。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "也该念我母昭阳伴驾人。"
        },
        {
          "character": "刘彦真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "虽然儿臣有过犯"
        },
        {
          "character": "唐妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唗！"
        },
        {
          "character": "唐妃",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "虽然儿臣有过犯"
        },
        {
          "character": "唐妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不提你母心不恼，"
        },
        {
          "character": "唐妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "提起你母恼在心。"
        },
        {
          "character": "唐妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "作践西宫不当人。"
        },
        {
          "character": "唐妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "她将俺贬在寒宫冷院门。"
        },
        {
          "character": "唐妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三宫六院谁不尊？"
        },
        {
          "character": "唐妃",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "定叫畜生命归阴！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监绑刘彦真，众人同下。）"
        }
      ],
