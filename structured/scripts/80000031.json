      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（童儿、皇甫讷同上。）"
        },
        {
          "character": "皇甫讷",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "皋公请我来相见，\n见了他人问根源。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前去通禀。"
        },
        {
          "character": "童儿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请家爷。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（东皋公上。）"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "童儿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇甫官人到了。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "说我出迎。"
        },
        {
          "character": "童儿",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家爷出迎。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇甫官人在哪里？"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皋公兄。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，皇甫官人。请到里面。请坐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（童儿暗下。）"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有坐。仁兄相约为了何事？"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伍将军到了，请来一会。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪个伍将军？"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "临潼斗宝伍子胥伍将军。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此人今在何处？"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在后面。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请来相见。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "候着。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请伍将军。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员上。）"
        },
        {
          "character": "伍员",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "父母冤仇恨，常挂一片心。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老丈何事？"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇甫官人到了，请来相见。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦，待我向前。\n皇甫兄在哪里？"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伍将军在哪里？"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇甫兄在哪里？"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，将军，这就是皇甫官人。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "岂敢。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇甫官人，这就是伍将军。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇甫兄！"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伍将军请坐。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有坐。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "久闻英名，风雷贯耳，今日一见，果然话不虚传！"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "愚下有如丧家之犬，何劳皇甫兄称赞。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "休得过谦。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，老丈。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇甫兄到此，有何妙计救我出关？"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "事到如今，并无别计，看你二人，面貌相似，就请皇甫官人扮作将军模样，前\n去叫关，把关之人一见必定捉拿，皇甫兄，只管让他拿去。那时趁乱之际，将\n军岂不混出了昭关。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此连累皇甫兄受惊。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "受惊是小事，只恐一顿暴打呀。"
        },
        {
          "character": "伍员",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "着哇。"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不妨，我来救你。"
        },
        {
          "character": "皇甫讷",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你要来的！"
        },
        {
          "character": "东皋公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "要来的。看衣更换。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员、皇甫讷同下。伍员、皇甫讷换衣巾同上。）"
        },
        {
          "character": "伍员",
          "line_type": "西皮二六板",
          "musical_style": "西皮二六板",
          "style_family": "西皮",
          "text": "伍员在头上换儒巾，\n乔装改扮往东行。\n在那万马营中显奇能。\n运去时衰在荒村。\n莫非是五行八个字我的命生成？\n你是我子胥救命的恩人。\n一重恩当报你的九重恩。"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "皇甫兄请上受一礼，"
        },
        {
          "character": "伍员",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "有劳你施下这全恩。\n来生犬马当报你的恩。"
        },
        {
          "character": "伍员",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "大胆且向虎山行。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（伍员下。）"
        },
        {
          "character": "皇甫讷",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "你若不去不要紧，\n遍体排牙诉不清。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（东皋公、皇甫讷同下。）"
        }
