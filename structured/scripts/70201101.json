        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小姐出堂。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。\n后堂传话，请小姐出堂。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵艳容上，哑奴随上。）"
        },
        {
          "character": "赵艳容",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "杜鹃枝头泣，血泪暗悲啼。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹万福。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "告坐。啊，爹爹，唤儿出堂，有何吩咐？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才为父下得朝来，闻听人言，道我儿叫那家人赵忠一声丈夫。不知可有此事？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹此言差矣，儿亲眼见夫被校尉杀死；想那赵忠，他是甚等样人，女儿岂能\n叫他一声丈夫。并无此事。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来如此。也罢，待为父与我儿灯下修本，改过匡家之罪也就是了。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此乃爹爹恩德。\n哑奴，溶墨伺候！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（哑奴磨墨。）"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "老爹爹发恩德将本修上，\n明早朝上金殿面奏吾皇。\n观此本免了儿一门祸殃。"
        },
        {
          "character": "倘若是有道君皇恩浩荡、秦王",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监引秦王同上。）"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "灯和月正交辉长街步过，\n猛抬头又只见相府巍峨。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "门官接驾。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。相国可在府中？"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在书房修本，待门官通报。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用通报，退下。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官下。）"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍，掩灯而进！"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "内侍掩灯相府进，\n灯光之下一美人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵高示意，哑奴、赵艳容同暗下。）"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣赵高见驾，吾皇万岁。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家平身。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赐座。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢座。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家在此做甚？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在此修本。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上来，待寡人观看。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是为匡家之事，寡人一概不究。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我主真乃有道明君。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才灯光之下，见一女子，她是何人？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃老臣之女，匡扶之妻。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我想匡扶已死，岂不有误此女终身；寡人有意将她宣进宫去，同掌山河。不知\n卿家意下如何？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日早朝送进宫去。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此，卿家听封。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "封你为掌朝太师。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍，摆驾回宫！"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "内侍摆驾回宫廷，\n明日早朝会美人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监引秦王同下。哑奴、赵艳容同暗上。）"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊，坐下，坐下！"
        },
        {
          "character": "赵高",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈……"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，爹爹，适才圣驾到此所为何事？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才万岁到此，看了为父的本章言道：匡家之事，一概不究。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "真乃有道明君。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "着哇！有道明君。恭喜我儿，贺喜我儿。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，女儿喜从何来？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才万岁在灯光之下观见我儿。有意宣进宫去，同掌山河。岂不是一喜！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹你……你是怎样的回复圣旨呢？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日早朝送进宫去。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹呀！想你身为当朝首相，位列三台，连这羞恶之心，你……都无有了吗？"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "老爹爹在朝中官高爵显，\n却为何贪富贵不顾羞惭！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊，难道你不遵父命？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹呀！有道是先嫁由父母，后嫁由自身；此事只怕就由不得你了！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哼！怎么由不得我！"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "想当初嫁儿身已从父愿，\n到如今还叫儿列屋争妍！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊，难道你敢违抗圣旨？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹呀！慢说是圣旨，就是钢刀，将女儿的头斩了下来，也是断断不能依从的\n呀！"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "见此情我这里不敢怠慢，\n必须要定巧计才得安然。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（哑奴示意装疯。）"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "见哑奴她教我把乌云扯乱，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵艳容下。哑奴做手势埋怨赵高。赵艳容披衣上。）"
        },
        {
          "character": "赵艳容",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "喂呀……"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "抓花容脱绣鞋扯破了衣衫。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊，你敢是疯了么？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "听说疯我只得随机应变，\n倒卧在尘埃地就信口胡言。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "搀了起来。\n儿啊，起来，起来。儿啊，你当真疯了么？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "当真的疯了么？"
        },
        {
          "character": "赵艳容",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈，哈哈，啊哈哈哈哈！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我要上天，我要上天，我要上天！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，儿啊！天高无路上不去。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，上不去？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "上不去。"
        },
        {
          "character": "赵艳容",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "啊，啊哈哈哈哈！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我要入地，我要入地，我要入地！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，儿啊！地厚无门也下不去。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，下不去？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下不去。"
        },
        {
          "character": "赵艳容",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "啊，啊哈哈哈哈！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊，爹爹，你是我的……"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄正板",
          "musical_style": "反二黄正板",
          "style_family": "二黄",
          "text": "我这里假意儿懒睁杏眼，\n摇摇摆摆摆摇扭捏向前。\n我只得把官人……"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，我官人来了。\n官人在哪里？\n哎呀，官人哪！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄正板",
          "musical_style": "反二黄正板",
          "style_family": "二黄",
          "text": "一声来唤，一声来唤，我的夫哇！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "官人，这里来！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄正板",
          "musical_style": "反二黄正板",
          "style_family": "二黄",
          "text": "随我到红罗帐倒凤颠鸾。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打鬼，打鬼！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿啊，此乃太湖山石。"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄正板",
          "musical_style": "反二黄正板",
          "style_family": "二黄",
          "text": "那边厢又来了牛头马面，"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄正板",
          "musical_style": "反二黄正板",
          "style_family": "二黄",
          "text": "玉皇爷驾瑞彩接我上天。"
        },
        {
          "character": "赵艳容",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "啊，哈哈哈……"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "搀了回去！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（哑奴扶赵艳容同下。）"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嘿！不想她忽然得了疯癫之症，待我将此事启奏万岁。唉，好晦气也！"
        }
      ],
