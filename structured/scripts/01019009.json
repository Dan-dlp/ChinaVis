      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（阮小二、阮小五同上。）"
        },
        {
          "character": "阮小二",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我，追魂太岁阮小二。"
        },
        {
          "character": "阮小五",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我，短命二郎阮小五。"
        },
        {
          "character": "阮小五",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哥哥，你我奉了大哥之命扮做打鱼的模样，等候史文恭，你我就此前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（阮小二、阮小五同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "阮小二→阮小五",
          "turns": 1
        }
      ],
      "stats": {
        "line_counts": {
