      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（卢俊义、众人同上。）"
        },
        {
          "character": "卢俊义",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众弟兄，今晚要饱餐战饭，谨慎小心防备那贼前来劫寨。"
        },
        {
          "character": "李逵",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大家小心了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史文恭、众人同上，起打八股荡，史文恭败下。）"
        }
      ],
