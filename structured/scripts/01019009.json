    },
    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "史文恭",
        "阮小二",
        "阮小五"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（史文恭上，翻跟头。）"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卢俊义十分骁勇，待我逃走。"
        },
        {
          "character": "史文恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，渔船快快摆过来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（阮小二、阮小五同上。）"
