        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "时才间观花灯与民间乐，"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "观相府好一似龙楼凤阁。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见万岁！"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。相国可在府中？"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在表本。待蝼蚁通报。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不用通报，退下。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官下。）"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍摆驾。"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "内侍掩灯相府进，"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "灯光之下遇美人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵艳容、丫鬟同下。）"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赵高见驾，吾皇万岁！"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身，赐坐。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家在此则甚？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在此表本。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呈上来。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来邝府之事，寡人一概不究。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢万岁。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "时才灯光之下见一妇人，她是何人？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "乃是老臣小女。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤王意欲宣进宫去同掌山河，意下如何？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日早朝送进宫去。"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好！太师听封：封你掌朝太师之职。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主龙恩！"
        },
        {
          "character": "秦王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾回宫。"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "内侍摆驾回宫廷，"
        },
        {
          "character": "秦王",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "明日早朝看美人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（秦王下。赵艳容、丫鬟同上。）"
        },
        {
          "character": "赵艳容",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "有事在心头，终日眉头皱。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀，爹爹，圣驾到此为了何事？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁到此将邝府之事一概不究。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我主才是有道明君。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本来是有道明君。恭喜我儿，贺喜我儿！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "喜从何来？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "时才万岁见我儿生得美貌，有意带进宫去同掌山河。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹怎样回奏？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明日早朝送进宫去。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹啊，你身为当朝首相，位列三台，连这三纲五常都不晓得了么？"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "老爹爹说此话真个可骇，"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "怪不得骂名儿四海喧传。"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "岂肯做那失节妇遗臭万年？"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "你孩儿曾念过列女真传"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呵，难道不遵父命么？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹，又道是“先嫁由父母，后嫁自由身”。我看此事就用不着你了。"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "常言道“嫁鸡随鸡走”，"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "又道是“嫁犬犬同行”。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "难道说不遵圣名么？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹啊，慢说是圣命，就一把钢刀将儿首级割下也是不能遵命的了。"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "见此情一时间不能言断，"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "必须要生巧计才得安然。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（丫鬟比手教装疯。）"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "见丫奴在一旁挤眉绉眼，"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "莫非她叫我假装疯癫。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓！"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "我这里脱绣鞋扯破衣衫。"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "没奈何我只得青丝扯乱"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿敢是疯了么？"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "听说疯我乐得随机应变，"
        },
        {
          "character": "赵艳容",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "倒卧在尘埃地信口胡言。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀，你当真的疯了么？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么讲？"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "疯了么？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈……爹爹，孩儿要上天！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "天高上不去！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓吓吓吓……爹爹，我要入地！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "地厚无门下不去！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吓吓吓吓……爹爹，我那亲……"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "“亲”什么？"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "亲生的儿呵！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我这里假意儿来睁杏眼，"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "摇摇摆摆摇摇摆摆摇向前。"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我把他当做了夫君高唤，我的夫啊！"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹，来呀！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我和你红罗帐倒凤颠鸾。"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "丫头",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哑叭哑叭！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "赵高 （净白） 呸！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "我这里睁开眼天昏地暗，"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我的天！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "许多的怨鬼魂站立在门前。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "打鬼！"
        },
        {
          "character": "赵高",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀！那不是鬼，乃是太湖石。"
        },
        {
          "character": "赵艳容",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "太湖石呀！"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "那一旁来了个牛头、马面，"
        },
        {
          "character": "赵艳容",
          "line_type": "反二黄慢板",
          "musical_style": "反二黄慢板",
          "style_family": "二黄",
          "text": "玉皇爷驾祥云接我上天。"
        },
        {
          "character": "赵艳容",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈，吓，哈哈哈……"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵艳容下。）"
        },
        {
          "character": "赵高",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "闭门家中坐，祸从天上来！"
        }
      ],
