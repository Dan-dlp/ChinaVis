          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听罢言来我的魂飘荡，"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，苍天吓。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好一似利刃穿胸心痛伤。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二郎短剑把身亡。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四郎失落在番邦。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨大郎长枪阵前丧"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我三郎马踏为肉酱"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这一阵吓破了王的胆，"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可叹杨家众儿男。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "朕封你官上加职，职上加官。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老将军休得把孤怨"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老臣亦非嫌官小，"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "保国忠良无下梢。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨大郎身替孤王死，"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "朕封他龙华会上神。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "朕封他花花太岁神。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "朕封他逍遥快活神。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "在生封官，死后封神。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨二郎短剑伤了命"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨三郎马踏为肉酱"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四郎失落无音信"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叩头三呼把龙恩谢，"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回头来看见众儿郎。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨七郎一旁泪汪汪。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "忽然想起你们的娘。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "手扯袍铠暗神伤："
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回朝来还我人四双。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿甚么交还你的娘？"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "六郎儿在旁双流泪"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "五郎哭的如酒醉"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "送出我父子府门外"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "天波府交与你八员将"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄们为国把命丧"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "开言就把七郎叫，"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "五郎、六郎听朕封："
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨七郎朕封你火龙大将军。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "封你在朝并肩王。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨六郎朕封你三关为总镇"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "五郎别的官儿不封你"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨五郎跪尘埃泪双流，"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想起保国的忠良没有下场头。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二哥短剑把身亡；"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "四哥失落在番邦。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杀来杀去杀自家。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "箭箭射的白莲花。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "要把这金刀削头发。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨六郎朕封你三关为总镇"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "五郎别的官儿不封你"
        },
        {
          "character": "杨延德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，万岁爷呀！"
        },
        {
          "character": "杨延德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨六郎朕封你三关为总镇"
        },
        {
          "character": "杨延德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "五郎别的官儿不封你"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "臣要到五台去出家。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大哥身替宋王死"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三哥马踏为肉酱"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "今日杀来明日杀"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刀刀割去心上肉"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨五郎解破其中意"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "在上面辞别万岁爷的驾"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "五将军说的哪里话，"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "说甚么五台去出家。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "忍心去了头上发。"
        },
        {
          "character": "宋太宗",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你不念父母年高大"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "昔日里庄王求莲华，"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "相遇一女貌如花。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "百雀寺里去出家。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到后来功德圆满作菩萨。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "臣要到五台去出家。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "她不愿皇宫招驸马"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "父王劝她心不转"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为臣辞别了贤王驾"
        },
        {
          "character": "赵德芳",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "五将军说话理太差，"
        },
        {
          "character": "赵德芳",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "说什么五台去出家。"
        },
        {
          "character": "赵德芳",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "保驾回朝把官加。"
        },
        {
          "character": "赵德芳",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叔王江山全仗你"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "打罢春来又复秋，"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "夕阳桥下水东流。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哪一个为国能到头？"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叔王江山全仗你"
        },
        {
          "character": "杨延德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎！"
        },
        {
          "character": "杨延德",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叔王江山全仗你"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "儿要到五台去把禅修。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "自古多少忠良将"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "在一旁辞别了年迈的父"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "𠳶！"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自古多少忠良将"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在一旁辞别了年迈的父"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "骂一声五郎没来由，"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "说什么五台把禅修。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "七郎他还是小娃娃。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回到火塘寨上作田家。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "天波府哭坏了你的妈。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "六郎他还年纪幼"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "父子们辞别了宋王爷的驾"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "别下了为父倒还罢"
        },
        {
          "character": "宋太宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老将军舍了罢。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，万岁。老臣八个孩儿，到幽州赴会，只剩得六郎、七郎，五郎又要出家，"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "叫老臣难以割舍。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为父的带领你兄弟八个，"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "犹如那八只虎闯到边关。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "死的死走的走三儿命还。"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "延德儿为甚么又去修禅？"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好比那风前烛瓦上霜能过几年？"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见过你老娘亲再了尘缘。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，我的儿吓！"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "赴番邦双龙会替王假扮"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "延昭儿延嗣儿年幼识浅"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你来看为父的天可怜鉴"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "既出家随为父保驾回转"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "汉朝有个张子房，"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "求仙修道细参详。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "忠臣良将无下场。"
        },
        {
          "character": "杨延德",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "儿在五台渡慈航。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（长老上。）"
        },
        {
          "character": "长老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "五台山，众僧伺候了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "众僧人 （内同白） 哦。"
        },
        {
          "character": "宋太宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "五台山寺主。"
        },
        {
          "character": "长老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫僧在。"
        },
        {
          "character": "宋太宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听孤王旨意：五将军，乃是寡人的爱卿，五台山出家，孤王回朝，发库银五十"
        },
        {
          "character": "宋太宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万，以为功课，金刀落发。"
        },
        {
          "character": "长老",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贫僧领旨。"
        },
        {
          "character": "宋太宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "五将军出家，受寡人一拜。"
        },
        {
          "character": "杨继业、杨延昭、杨延嗣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "又道君不拜臣。"
        },
        {
          "character": "赵德芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小王也有一拜。"
        },
        {
          "character": "杨继业、杨延昭、杨延嗣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大不拜小。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "延德儿，为父也有一拜。"
        },
        {
          "character": "杨延昭、杨延嗣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "父不拜子。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "六郎，七郎，你们手足之情，多拜几拜。"
        },
        {
          "character": "杨延昭、杨延嗣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "孩儿知道。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨延昭、杨延嗣同拜。）"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请驾回宫。"
        },
        {
          "character": "宋太宗",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾。"
        },
        {
          "character": "赵德芳",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咦。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（宋太宗、赵德芳同下。）"
        },
        {
          "character": "杨延嗣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹请转回，到天波府，拜上年迈娘亲，恕孩儿不孝之罪。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "五郎，延德，还记得你的娘亲？若是舍不得母亲，可随为父回去，到天波府，"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "见过你年迈母亲，再来出家也罢。"
        },
        {
          "character": "杨延嗣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "自古道出家容易还家难，孩儿有万死之罪。"
        },
        {
          "character": "杨继业",
          "line_type": "哭",
          "musical_style": null,
          "style_family": null,
          "text": "哎儿吓！"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大海孤舟折了桅，"
        },
        {
          "character": "杨继业",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "长大毛羽各自飞。"
        },
        {
          "character": "杨继业",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "五郎！延德！哎，难得见的儿吓！"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "六郎，七郎。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "断线风筝不得回"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "燕子衔泥空费力"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨延昭"
        },
        {
          "character": "杨延嗣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "爹爹。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "随为父这里来。"
        },
        {
          "character": "杨延昭、杨延嗣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "是。"
        },
        {
          "character": "杨继业",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎哎！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
