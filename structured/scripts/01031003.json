    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "苍海公"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（苍海公穿短衣、腰插太锥上。）"
        },
        {
          "character": "苍海公",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "准备窝弓擒猛虎，安排香饵钓鳌鱼。"
        },
        {
          "character": "苍海公",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是博浪沙，远听得车马声响，不免登高一望。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（苍海公登高探望。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、四御林军上，车夫推假秦始皇上。）"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（苍海公跳下，拔锥打杀二太监，打死假秦始皇。四御林军拔刀相打，苍海公被擒。众人同下。）"
        }
      ],
      "interactions": [],
      "stats": {
