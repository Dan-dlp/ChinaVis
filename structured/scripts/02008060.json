    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "高能",
        "高院子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（高能上。）"
        },
        {
          "character": "高能",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "少年英雄未出头，不识烽烟何日休？"
        },
        {
          "character": "高能",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "凛凛威风四海闻，曾随祖父杀贼人。仙传秘授黑风帕，保定宋室锦乾坤。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，高能。祖父高旺，在宋王驾下为臣。俺只因奸臣挡道，退居林下。前日杨\n家姑母有信到来，被困番邦，围在沙河，内无粮草，外无救兵，着俺弟兄前去\n解围。俺也曾命人约会表兄卫小申，在青莲洞相会。\n来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（高院子上。）"
        },
        {
          "character": "高院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卫爷可曾请了？"
        },
        {
          "character": "高院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "早已请过了。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "几时起程？"
        },
        {
          "character": "高院子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "即日起程。"
        },
        {
          "character": "高能",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此准备器械干粮。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（高院子应，下。）"
        },
        {
          "character": "高能",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "但愿蝼蚁全扫尽，才得成功定太平。"
        }
      ],
      "interactions": [
        {
          "edge": "高院子→高能",
          "turns": 3
        },
        {
          "edge": "高能→高院子",
          "turns": 2
        }
      ],
      "stats": {
        "line_counts": {
