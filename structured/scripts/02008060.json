  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "倘若是在阵前不能取胜",
        "我赐你防身宝临阵使用",
        "护法",
        "杨仙童",
        "此去把番邦来扫尽",
        "毗卢大仙",
        "谒帝神将"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（谒帝神将、护法同上。）"
        },
        {
          "character": "护法",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "峰斧开山，丁甲第一班。"
        },
        {
          "character": "护法",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺乃毗卢大仙麾下护法神是也。今当甲辰日大仙陞坐之期，只得在此伺候。"
        },
        {
          "character": "谒帝神将、护法",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖小吹打〗。四童子引毗卢大仙同上。）"
        },
        {
          "character": "毗卢大仙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "俺今日驾祥云跨鹤邀游，\n满山顶生光华瑞云锦绣。\n这仙根有谁人参透机谋？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（毗卢大仙上高台，坐。）"
        },
        {
          "character": "毗卢大仙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "天上七星七宝台，仙花仙果满山栽。清风乍起祥云现，一派仙音瑞鸟来。"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾乃毗卢大仙是也。只因当年杨家玉芙蓉征西，路过花马天齐庙，产生一子，\n落地而亡。是我救上山来，取名仙童，传授兵法，武艺精通。今玉芙蓉被困番\n邦，危难之极，不免命仙童下山到双沙河，使他母子相认，日后辅保宋室。\n护法神。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（护法应。）"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唤杨仙童。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（护法应。）"
        },
        {
          "character": "护法",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨仙童哪里？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（杨仙童上。）"
        },
        {
          "character": "杨仙童",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "山中修法术，不愿染红尘。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弟子参见。"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢坐。师父唤弟子，有何法旨？"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你在山上习练兵法已成，你仙缘已满。现今你母被番邦，围困双沙河，使你救\n援，母子相逢，日后辅保宋室江山。"
        },
        {
          "character": "杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "弟子蒙师父慈悲，一心修炼，今又染红尘，岂不半途而废？"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此乃天数，不必推辞。听为师吩咐。"
        },
        {
          "character": "毗卢大仙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我今日在洞中把话来云，\n我命你到沙河救援你娘亲。\n随带着在身旁须要小心。\n全凭着此宝物定下输赢。"
        },
        {
          "character": "我赐你防身宝临阵使用、倘若是在阵前不能取胜、杨仙童",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叩谢了我师父养育恩情，\n此一去又不知何日相逢？"
        },
        {
          "character": "毗卢大仙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "仙缘本无儿的分，\n你又何必苦修行？\n好保宋室定乾坤。"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨仙童，此番下山，有花就采。"
        },
        {
          "character": "此去把番邦来扫尽、杨仙童",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "护法神。"
        },
        {
          "character": "谒帝神将、护法",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "毗卢大仙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "护送仙童下山。"
        },
        {
          "character": "谒帝神将、护法",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同唱〖清江引〗，同下。）"
        }
      ],
