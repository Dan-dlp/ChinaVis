    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "二郎神"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖急急风〗。四上手、金吒、木吒、哪吒、伽蓝、青龙、白虎、二郎神同上。）"
        },
        {
          "character": "二郎神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众神将，莲花塘去者。"
        },
        {
          "character": "二郎神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "（四上手、金吒、木吒、哪吒、伽蓝、青龙、白虎同允。四下手、四水卒、四水怪、老龙、母龙同上，同会"
        },
        {
          "character": "二郎神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "阵，同起打连环。母龙下枪花，打出手。四上手、金吒、木吒、哪吒、伽蓝、青龙、白虎、二郎神同败下。"
        },
        {
          "character": "二郎神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母龙耍大刀花，下。打十二股荡。孙悟空对老龙败下。母龙上，孙悟空打母龙下。孙悟空耍棍花，下。四上"
        },
        {
          "character": "二郎神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "手、金吒、木吒、哪吒、伽蓝、青龙、白虎、二郎神同上，同摆阵。四下手、四水卒、四水怪同翻跟头。布"
        },
        {
          "character": "二郎神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "景开幕，满台莲花灯彩。老龙形、母龙形同被擒。）"
        },
        {
          "character": "二郎神",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众神将，回复玉帝去者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。〖牌子〗。）"
        }
      ],
