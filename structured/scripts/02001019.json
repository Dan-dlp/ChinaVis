          "character": "杨戬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今日师叔发兵，命你我两厢伺候。"
        },
        {
          "character": "韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": "韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "（杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子分归两边站。四文堂、四大铠、四上手、姜子牙"
        },
        {
          "character": "韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "同上。）"
        },
        {
          "character": "姜子牙",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "昆仑嫡派，顺天命宇宙重开。甲子年，成汤衰败。戊午期周室运来。"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见师叔。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "站立两厢。"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": "姜子牙",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "两仪四象分阴阳，女娲炼石补上苍。三教共议封神榜，吾奉法旨灭成汤。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老夫姜子牙，前奉王命攻打潼关，不料被余化龙暗用瘟药将我军迷倒，多亏慈"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "航道人相救，方得无事。今日整齐兵将与他见个胜负。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众弟子听吾一令！"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "自三皇开关后乾坤荡荡，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "尧传舜舜传禹降至商汤。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "诛发妻杀亲子令人惨伤。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "粉壁墙题诗句触怒上苍。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "灭成汤兴周室国运永昌。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "保武王开山河一统无疆。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "用瘟药迷将士险把命亡。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "解三灾救八难多亏慈航。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "托上苍保佑着得胜疆场。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨戬。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "殷纣王宠妲己酒色淫荡"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "女娲庙去拈香欺灭神像"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "女娲氏聚齐了妖群一党"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有老夫奉法旨肩背神榜"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "临潼关余化龙兵多将广"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "感天恩不绝我周营兵将"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾今日整雄威重发兵将"
        },
        {
          "character": "杨戬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "仗玄功多变化奇才无两，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "移深山倒大海妙术高强。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "三尖刀嚎天犬带在身边。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "此一番去出兵谁人敢挡"
        },
        {
          "character": "杨戬",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "韦陀。"
        },
        {
          "character": "韦陀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你七世神通体天地恩养，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "自幼儿修道法显应无疆。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "建奇功吾将你威名表扬。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "降魔杵打神将天仙难挡"
        },
        {
          "character": "韦陀",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杨任。"
        },
        {
          "character": "杨任",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你在那紫阳洞修成法像，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "蒙师恩赐与你宝扇神枪。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "管教那余化龙无处躲藏。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "到阵前必须要神眼观望"
        },
        {
          "character": "杨任",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "金吒。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你本是将门子英雄上将，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "一朝君一朝臣子胜父强。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "必须要秉忠心扶保武王。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "今日里逢劫运乾坤改样"
        },
        {
          "character": "金吒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "木吒。"
        },
        {
          "character": "木吒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "兄刚强弟好汉血气勇壮，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "遇见那余化龙谨慎提防。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "方显你将门子非比寻常。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "与周室建奇功谁人不仰"
        },
        {
          "character": "木吒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哪吒。"
        },
        {
          "character": "哪吒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "你本是莲花体变化多广，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "乾坤圈火尖枪盖世无双。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "生三头并六臂无人能当。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "风炎轮如闪电霞光万丈"
        },
        {
          "character": "哪吒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "龙须虎。"
        },
        {
          "character": "龙须虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "周室兴成汤败刀兵不让，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "吾主爷行仁义兵伐商汤。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "享尧天乐舜日天下安康。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "但愿得干戈静万民欢畅"
        },
        {
          "character": "龙须虎",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "雷震子。"
        },
        {
          "character": "雷震子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "黄金棍重如山奥妙多广，"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "费辛劳兴周室保定家邦。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "功劳薄名不朽高载清香。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "兄与弟弟和兄富贵安享"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "众弟子传吾令回归营帐"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "杨戬"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "韦陀"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "杨任"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "龙须虎"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "金吒"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "木吒"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄原板",
          "musical_style": "二黄原板",
          "style_family": "二黄",
          "text": "哪吒"
        },
        {
          "character": "雷震子",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "这一阵使商纣国破家亡。"
        },
        {
          "character": "姜子牙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将官起兵前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。众人同下。）"
        }
      ],
      "interactions": [
        {
          "edge": "杨戬→韦陀",
          "turns": 1
        },
        {
          "edge": "韦陀→杨任",
