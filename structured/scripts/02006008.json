        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程咬金上。）"
        },
        {
          "character": "程咬金",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "奸王误国害忠良。"
        },
        {
          "character": "徐勣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我徐绩。"
        },
        {
          "character": "尉迟恭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某尉迟恭。"
        },
        {
          "character": "秦琼",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺秦琼。"
        },
        {
          "character": "程咬金",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咱程咬金。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "徐勣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可喜秦王平定高丽，回朝奏凯，圣上命我等一同到罗贤弟灵前祭奠，并将苏定"
        },
        {
          "character": "徐勣",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "方首级献于灵前。"
        },
        {
          "character": "尉迟恭、秦琼、程咬金",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "一言未了，想必殿下来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二内侍⑴一捧祭祀一背人头桶同上，李世民上。）"
        },
        {
          "character": "李世民",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "烽烟扫尽，痛擎夭摧折，屈坏着万里长城。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等接驾。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "愿殿下千岁千千岁。"
        },
        {
          "character": "李世民",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "扰攘烟尘起战争，专征独扫宇寰清。化家为国皇图永，一统山河乐太平。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤家秦王世民。为二位王兄王弟谗诤，将孤拘禁天牢。不想河北高丽反叛，父"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兄命三王元吉领兵征剿，保奏罗王兄为先锋，不发兵卒，只命单身出战，致他"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "马陷淤泥河，乱箭射死。不意被苏定方长驱直进，三王元吉逃回太原，父王命"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "孤出狱，立功赎罪。赖诸将协力，众士同心，平服了河北。今带苏定方首级，"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "同众公卿到罗王兄灵前祭奠。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众公卿！"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等有。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就此一同前往。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "跃马扬鞭驾轻车，"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "河北一带惨凄凄。"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤王奉旨拜灵祇。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（士卒上，报。）"
        },
        {
          "character": "士卒",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千岁驾到。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（罗春上，跪。）"
        },
        {
          "character": "罗春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣罗春接驾，愿殿下千岁千千岁。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "平身。"
        },
        {
          "character": "罗春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "千千岁。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罗王兄灵柩在哪里？"
        },
        {
          "character": "罗春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请在中堂。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家引孤进去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（罗春应，进。）"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆下祭礼。"
        },
        {
          "character": "二内侍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓。"
        },
        {
          "character": "二内侍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "（二内侍同摆祭礼并人头桶。李世民拜。徐勣、尉迟恭、秦琼、程咬金同扶住，同作揖让。徐勣、尉迟恭、"
        },
        {
          "character": "二内侍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "秦琼、程咬金同拜，同起。）"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊呀，罗王兄吓！"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想王兄相从已有年，"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "情同骨肉赛桃园。"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "旗开得胜非等闲。"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "害你屈死在河边。"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "思卿何日还阳间？"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "卿家开国功勋大"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只因误被奸王害"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "悲伤折我擎天柱"
        },
        {
          "character": "徐勣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拜灵前祭奠真悲惨，"
        },
        {
          "character": "徐勣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "止不住腮边泪涟涟。"
        },
        {
          "character": "徐勣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "被奸王害你一命丧黄泉。"
        },
        {
          "character": "徐勣",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可怜你是英雄汉"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哭一声贤弟干城将，"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你代我探主到牢房。"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "害你忠良年少亡。"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "冤遇奸王把你害"
        },
        {
          "character": "秦琼",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尉迟恭"
        },
        {
          "character": "程咬金",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "忙上前祷告心悲切，"
        },
        {
          "character": "程咬金",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "哭一声贤弟好惨伤。"
        },
        {
          "character": "程咬金",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "并胆同心扶大唐。"
        },
        {
          "character": "程咬金",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "可怜万箭丧郊荒。"
        },
        {
          "character": "程咬金",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "自从识荆来结义"
        },
        {
          "character": "程咬金",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "恨杀奸王来害你"
        },
        {
          "character": "罗春",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "稽首叩谢贤恩主，"
        },
        {
          "character": "罗春",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回身谢了伯父众贤良。"
        },
        {
          "character": "罗春",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不能同辅大唐王。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖内作响〗。）"
        },
        {
          "character": "李世民、徐勣、尉迟恭、秦琼、程咬金、罗春",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓，什么响？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（罗成浑身插箭流血手执白绫暗上，立孝堂后高桌上。）"
        },
        {
          "character": "罗成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "半空中跑坏了白龙马，"
        },
        {
          "character": "罗成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为闻吾主祭灵堂。"
        },
        {
          "character": "罗成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "感谢王恩天浩荡。"
        },
        {
          "character": "罗成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "阴阳间隔泪滂惶。"
        },
        {
          "character": "罗成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可怜我深陷淤泥魂渺茫。"
        },
        {
          "character": "罗成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "箭下难逃一命亡。"
        },
        {
          "character": "罗成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "太平千载庆大唐。"
        },
        {
          "character": "罗成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣启殿下：阴阳间隔，不便下云相见。敢蒙千岁亲临祭奠，为此驾云前来面谢。"
        },
        {
          "character": "罗成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣今已列星班，不敢久停，愿千岁善保龙体，以遂众望。各位兄长同心辅政，"
        },
        {
          "character": "罗成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "以助太平。"
        },
        {
          "character": "罗成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我儿你须孝养母亲，尽孝王事，就此去也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（罗成下。李世民、徐勣、尉迟恭、秦琼、程咬金、罗春同哭。）"
        },
        {
          "character": "程咬金",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎，你们为何方才不扯他下来，竟由他去了？"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罗贤侄过来。"
        },
        {
          "character": "罗春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你今在守孝，不便入朝。孤家将你父亲显灵之事，奏闻父王，必加追赠。俟你"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "服满入朝，荫袭你父之职便了。"
        },
        {
          "character": "罗春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢千岁。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍过来。"
        },
        {
          "character": "二内侍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将苏定方首级赉出号令。就此回朝复旨。"
        },
        {
          "character": "二内侍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "吓。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
