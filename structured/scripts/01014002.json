      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马师上，起霸。）"
        },
        {
          "character": "司马师",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "蜀、魏连年动刀兵，东荡西杀数十春。姜维用计心太狠，将吾围困铁笼心。"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾，大都督司马师。今有姜维，带领四十五万铁甲雄兵，将吾兵围困在铁笼山"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内，也曾命陈泰向西羌借兵，未见回来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（陈泰上。）"
        },
        {
          "character": "陈泰",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "千军容易得，一将更难求。"
        },
        {
          "character": "陈泰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见都督。"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "借兵一事如何？"
        },
        {
          "character": "陈泰",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老大王已经允准，大兵随后即至。"
        },
        {
          "character": "司马师",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好。一同接杀前去。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（司马师、陈泰同下。）"
        }
