        },
        {
          "character": "妲己",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "妾妃把盏。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖小吹打〗。妲己敬酒。牌子完。）"
        },
        {
          "character": "妲己",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁再饮几杯。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "寡人酒已够了。"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内臣撤去酒宴"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（吹打完。）"
        },
        {
          "character": "妲己",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启奏我主：不知今晚宿在哪一宫？"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "宿在寿仙宫。"
        },
        {
          "character": "妲己",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内臣打扫寿仙宫"
        },
        {
          "character": "二大太监",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二大太监同下。）"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "正是："
        },
        {
          "character": "纣王",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "朝欢暮乐在宫帷，哪管朝中是与非。"
        },
        {
          "character": "妲己",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "蒙恩万岁将妃宠，陪王伴驾更有谁？"
        },
        {
          "character": "纣王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "摆驾寿仙宫。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（纣王、妲己同下。）"
        }
      ],
