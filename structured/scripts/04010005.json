    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "任堂惠"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（任堂惠上，走边。）"
        },
        {
          "character": "任堂惠",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "披星戴月不辞劳，只为当年旧故交。焦赞发配沙门岛，暗地保护走一遭。"
        },
        {
          "character": "任堂惠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，任堂惠。只因焦二哥将奸贼王钦若的门婿杀死，发配沙门海岛。是俺乔装"
        },
        {
          "character": "任堂惠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "改扮，暗地保护焦二哥。看，天色不早，就此趱行者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（任堂惠下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 3,
          "念": 1
        },
        "singing_ratio": 0.0,
        "dominant_style_family": null,
        "musical_styles": []
      },
      "scene_feature": [
        0.0,
