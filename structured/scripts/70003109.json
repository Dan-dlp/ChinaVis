        {
          "character": "夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "前者关云长，斩了颜良，解了白马之围。曹丞相进朝启奏，我等在此伺候。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。四龙套、二旗牌、郭嘉、程昱、曹操同上。）"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相。"
