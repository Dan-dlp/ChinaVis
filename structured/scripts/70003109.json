        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢丞相。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众将可齐？"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俱已到齐。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "关羽可曾到此？"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "尚未到来。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（内喊声。）"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
