    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "徐母"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "闷坐草堂，自凄凉，怎不惨伤！"
        },
        {
          "character": "徐母",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "大儿四海访良朋，次子一命赴幽冥。可叹老身无伺奉，凄凉孤苦在家中。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老身徐庶之母。所生二个孩儿：长子徐庶，在外访友；次子徐广，不幸身亡。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "撇下老身，独守家中，好不伤感人也！"
        },
        {
          "character": "徐母",
          "line_type": "二黄正板",
          "musical_style": "二黄正板",
          "style_family": "二黄",
          "text": "老身生来命不强，"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "stage_direction": 5
        },
        "singing_ratio": 0.0,
        "dominant_style_family": "二黄",
        "musical_styles": [
          "二黄"
        ]
      },
      "scene_feature": [
        0.0,
        0.4,
        0.4,
        0.2,
        0.0,
