        0.0,
        0.2
      ]
    },
    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "家将",
        "徐母",
        "路人"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家将上。）"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "丞相差我颍州往，"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "迎接徐母进许昌。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，曹府家将是也。奉丞相之命，迎接徐庶之母进京。就此马上加鞭。"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "催马加鞭朝前闯，"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "抬头只见一村庄。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "借问一声：此地可有个徐老太太？"
        },
        {
          "character": "路人",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "哪个徐老太太？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐庶、徐广之母，徐老太太。"
        },
        {
          "character": "路人",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "前面黒漆门楼就是。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢多谢。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来此已是。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐老太太开门来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "门外有人把话讲，"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "莫非徐庶转回乡？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母开门。）"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是哪里来的？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "京都来的。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到此作甚？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "奉了我家主人，迎接徐老太太进京。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你可认识？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不相认。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老身正是。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是徐太太，小人扣头！"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "不消。你奉何人所差？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小人奉程大老爷与徐大老爷所差。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "程大老爷他是何人？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我家老爷姓程名昱，与徐大老爷同殿为官，结拜弟兄。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他二人官居何职？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俱是议郎。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "因何接我进京。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二位老爷，闻听徐二老爷亡故，恐老太太无人伺奉，特差小人接老太太进京，"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "同享荣华。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "可有书信？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "无有。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为何无有书信？"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "官差荣耀，修书不及。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "如此备车轮伺候。"
        },
        {
          "character": "家将",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "遵命。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（家将下。）"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好吓！"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "我儿官居为议郎，"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "迎接老身进许昌。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母下。家将上。）"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "门前备下车一轮，"
        },
        {
          "character": "家将",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "有请太太上京城。"
        },
        {
          "character": "徐母",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "来了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母上。）"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "家将引路将车上，"
        },
        {
          "character": "徐母",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "想起徐广两泪汪。"
        },
        {
          "character": "徐母",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀儿吓！你哥哥接为娘进京，同享荣华，你是怎的不来？徐广苦命儿吓！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐母、家将同下。）"
        }
      ],
      "interactions": [
