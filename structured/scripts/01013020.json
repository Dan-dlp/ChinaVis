  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "姜永志"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜永志上，趟马。）"
        },
        {
          "character": "姜永志",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "东京盗宝转回程，\n豪杰今日落美名。"
        },
        {
          "character": "姜永志",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，姜永志，人称花蝴蝶。是我在邓家堡夸下海口，去到东京宝藏库，要盗外\n国进贡的桃花玉马。且喜玉马到手，途中缺少盘费。前面已是铁头镇，待我去\n至大户人家，一来偷盗，二来采花。就此马上加鞭。"
        },
        {
          "character": "姜永志",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "催马加鞭往前趱，\n铁头镇前走一番。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜永志下。）"
        }
      ],
      "interactions": [],
      "stats": {
        "line_counts": {
          "内白": 1,
          "stage_direction": 4,
          "唱": 1
        },
        "singing_ratio": 0.5,
        "dominant_style_family": "西皮",
        "musical_styles": [
          "西皮摇板"
        ]
      }
    },
    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "丫鬟",
        "姜永志",
        "赵员外",
        "赵夫人",
        "赵小姐"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵员外、赵夫人同上。）"
        },
        {
          "character": "赵员外",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "向阳门外春常在，"
        },
        {
          "character": "赵夫人",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "积善之家庆有余。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵小姐上。）"
        },
        {
          "character": "赵小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见爹娘。"
        },
        {
          "character": "赵员外、赵夫人",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。今当中元佳节，大家畅饮一回。"
        },
        {
          "character": "赵员外、赵夫人",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "中元节一家人举杯畅饮，\n我二老终日里快乐安宁。"
        },
        {
          "character": "赵小姐",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但愿得二爹娘身体强胜，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜永志上，扒拦杆下。）"
        },
        {
          "character": "赵小姐",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又听得谯楼上更鼓齐响。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵员外、赵夫人同下。）"
        },
        {
          "character": "赵小姐",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "叫丫鬟暂退去将门掩定，\n卸梳妆入罗帷睡卧沉沉。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜永志上，拨门。）"
        },
        {
          "character": "赵小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是何人？来到我的卧房？"
        },
        {
          "character": "姜永志",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我乃绿林好汉，行至此地，缺少盘费，要与你借些金银。"
        },
        {
          "character": "赵小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "箱中现有金银，拿些使用，快快走去。"
        },
        {
          "character": "姜永志",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好一个绝色女子。我说那一女子，你若与我成却好事，我便即走。"
        },
        {
          "character": "赵小姐",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你快快走去，如若延迟，我便喊叫。"
        },
        {
          "character": "姜永志",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你若喊叫，我便杀你。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵小姐喊。姜永志杀死赵小姐，搜财帛。）"
        },
        {
          "character": "姜永志",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "明人不作暗事，将花蝴蝶一朵留在此地，待我喊叫。\n呔！你家有贼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（姜永志下。丫鬟上。）"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请员外夫人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵员外、赵夫人同上。）"
        },
        {
          "character": "赵员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "何事？"
        },
        {
          "character": "丫鬟",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有贼人将小姐杀死，留下花蝴蝶一朵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "赵夫人 （同哭） 儿啊！"
        },
        {
          "character": "赵员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "今有包公在此下马，待我前去投告便了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵员外、赵夫人、丫鬟同下。）"
        }
      ],
