      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、欧阳春同上。）"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "趱行呐。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、欧阳春同转场。）"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "俺，欧阳春。押解镖车淮安交纳。\n众好汉，趱行者！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、欧阳春同转场。店家上，接镖旗。）"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将俺镖旗插在店门外。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（欧阳春下。）"
        },
        {
          "character": "店家",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "咋！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍、欧阳春同下。卢方、展昭同上。）"
        },
        {
          "character": "卢方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现有镖旗，欧大哥定在里面。\n店家哪里？"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（店家上。）"
        },
        {
          "character": "店家",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来了。"
        },
        {
          "character": "卢方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "欧老英雄，可在里面？"
        },
        {
          "character": "店家",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "在这儿啦。\n有请老英雄。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（欧阳春上。）"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是贤弟。"
        },
        {
          "character": "卢方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥请坐。"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此位是？"
        },
        {
          "character": "卢方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这就是御猫展雄飞。\n来，贤弟见过欧大哥。"
        },
        {
          "character": "展昭",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是北侠。"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是南侠。久仰了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（徐庆、蒋平同上。）"
        },
        {
          "character": "徐庆、蒋平",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "弟兄们均在此地。请坐。"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "为何不见五弟？"
        },
        {
          "character": "卢方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想必来也。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（白玉堂上。）"
        },
        {
          "character": "白玉堂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位兄长。"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请坐。你等为何这等打扮？"
        },
        {
          "character": "卢方",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥有所不知，今有大胆贼人，盗去桃花玉马，临行留下花蝴蝶一朵，万岁命\n包大人捉拿。赵员外家中小姐被杀，盗去金银，临行也留蝴蝶。想这两桩奇案\n是一人所作。大哥久闯江湖，定知此人来历。"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "愚兄略知一二。"
        },
        {
          "character": "卢方、蒋平、徐庆、白玉堂、展昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大哥请讲。"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此人姓姜，名永志，人称花蝴蝶。每逢偷盗，定要采花。一日三餐邓家堡，与\n邓车交好。众位贤弟，方才所言，定是此人了。"
        },
        {
          "character": "卢方、蒋平、徐庆、白玉堂、展昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "既然如此，待我等前去。"
        },
        {
          "character": "欧阳春",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢，后面用了酒饭，大家一同前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
