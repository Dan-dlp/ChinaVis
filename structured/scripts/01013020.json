    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "包拯",
        "卢方",
        "太监",
        "展昭",
        "徐庆",
        "白玉堂",
        "蒋平",
        "衙役",
        "赵员外",
        "门官"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四龙套、卢方、蒋平、徐庆、白玉堂、展昭、包拯同上。）"
        },
        {
          "character": "包拯",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "铜锣开道人呐喊，"
        },
        {
          "character": "包拯",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "谁人不知包青天。\n三口铜铡神鬼寒。\n捉恶霸，断土豪，灭却赃官。\n夜断乌盆伸过冤。\n地府阴曹铡判官。\n有那屈死枉魂速来伸冤。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（门官上，接包拯、四龙套、卢方、蒋平、徐庆、白玉堂、展昭同进城，同下，同上。）"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卑职参见老大人。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此地民情如何？"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "官是清官，民是顺民。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "回衙理事。"
        },
        {
          "character": "门官",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多谢大人。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵员外上。）"
        },
        {
          "character": "赵员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "冤枉！"
        },
        {
          "character": "衙役",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "堂口有人喊冤。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "带上来！"
        },
        {
          "character": "赵员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见包年兄。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是赵年兄，可有状纸？"
        },
        {
          "character": "赵员外",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "状纸呈上。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "暂且请回，三日后听审。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（赵员外下。）"
        },
        {
          "character": "太监",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "圣旨下。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "接旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监上。）"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "圣旨下，跪，宣读诏曰：今有大胆贼人，在宝藏库盗去外国进来的桃花玉马，\n临行之时，留下花蝴蝶一朵，命包拯派人从速严拿，解京治罪，望诏谢恩呐！"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万万岁！后堂备酒，与公公接风。"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "王命在身，不能久停。告辞了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监下。）"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "转堂。"
        },
        {
          "character": "卢方、蒋平、徐庆、白玉堂、展昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "既有圣旨到来，必须设法捉拿贼寇。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "此番圣旨到来，那铁头镇，赵家杀死女子一案，定是此人无疑了。"
        },
        {
          "character": "卢方、蒋平、徐庆、白玉堂、展昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "待我等前去拿获。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢，卢方、展昭听令，命你二人扮作犯人解差模样，私访贼人，不得有误。"
        },
        {
          "character": "卢方、展昭",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徐庆、蒋平听令，命你二人，扮作扮作一僧一道，捉拿贼人，不得有误。"
        },
        {
          "character": "徐庆、蒋平",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "白玉堂听令。命你各处暗访，不得有误。"
        },
        {
          "character": "白玉堂",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": "包拯",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大家一同前往。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
