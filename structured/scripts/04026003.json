    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "关兴",
        "张苞",
        "黄忠"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "黄忠 （内西皮导板） 黄忠马上哈哈笑，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠上。）"
        },
        {
          "character": "黄忠",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "我主爷宠爱少英豪。\n反道我老将无略韬；\n取东川谁不服英豪；\n夏侯渊一命丧荒郊；\n敌将闻名望风逃。\n耳边听得马嘶叫——\n来了关兴与张苞。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张苞、关兴同上。）"
        },
        {
          "character": "张苞、关兴",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见老将军。"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你二人赶来作甚？"
        },
        {
          "character": "张苞、关兴",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "奉皇伯将令，请老将军回营；恐阵前有失。"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呸！"
        },
        {
          "character": "黄忠",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "二小将把话讲差了，\n说什么有失把命抛！\n踏平江东保汉朝！\n也不图封侯爵禄高。\n你就说我无用的老黄忠要立功劳！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠下。）"
        },
        {
          "character": "张苞",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "老将说话真性傲，"
        },
        {
          "character": "关兴",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "相随保护莫辞劳。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张苞、关兴同下。）"
        }
      ],
      "interactions": [
