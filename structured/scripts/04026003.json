  "scenes": [
    {
      "scene_index": 1,
      "label": "第一场",
      "characters_present": [
        "关兴",
        "军士",
        "刘备",
        "太监",
        "张苞",
        "暂陪朕坐解愁闷",
        "黄忠"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四军士、太监引刘备同上。）"
        },
        {
          "character": "刘备",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "风吹旌旗遮日影，\n关兴张苞出御营。\n闷坐御营心不宁。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠上。）"
        },
        {
          "character": "黄忠",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "忆昔当年长沙镇，\n转眼不觉有数春。\n一心要把东吴平！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠见刘备，施礼。）"
        },
        {
          "character": "刘备",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "老将军免礼且平身。"
        },
        {
          "character": "暂陪朕坐解愁闷、黄忠",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "既兴兵何必泪常倾！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张苞、关兴同上。）"
        },
        {
          "character": "张苞、关兴",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见皇伯。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "胜负如何？"
        },
        {
          "character": "张苞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣与吴兵交战，不想谭雄暗放冷箭，射死战马；若非关兴搭救，险遭不测。"
        },
        {
          "character": "关兴",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣刀劈谢旌，活捉谭雄，现在帐外。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "绑上来！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（军士绑谭雄同上。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好贼！"
        },
        {
          "character": "刘备",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "孙权与孤冤仇深，\n孤定把东吴一扫平。\n斩他的首级挂营门！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（军士押谭雄同下，斩毕，军士同上。）"
        },
        {
          "character": "军士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "斩首已毕。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将贼的首级祭奠二千岁灵前；洒下热血，以祭死马。"
        },
        {
          "character": "军士",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔呼呀！朕今出兵与二弟、三弟报仇，幸得二虎侄头阵取胜，管叫那吴兵丧胆。\n内侍摆筵，朕与二侄贺功。"
        },
        {
          "character": "张苞、关兴",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢皇伯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠咳嗽。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老将军还在？"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "臣。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你也来呀。"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "谢主公。"
        },
        {
          "character": "刘备",
          "line_type": "西皮原板",
          "musical_style": "西皮原板",
          "style_family": "西皮",
          "text": "庆功会上把酒饮，\n想起了桃园结拜情。\n又谁知中途两离分！"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唉！想当年与尔父桃园结义以来，得徐州、入襄阳、取西川，皆是尔父之力，\n不想一旦下世去了！可叹五虎上将，所余无几，皆是老迈无用了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠一震。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看酒来，朕与贤侄把盏。"
        },
        {
          "character": "刘备",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "父是雄才儿英俊，\n这斗水酒庆功勋。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠离坐。）"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老了哇，老了！"
        },
        {
          "character": "黄忠",
          "line_type": "西皮散板",
          "musical_style": "西皮散板",
          "style_family": "西皮",
          "text": "主公言语实难听，\n他道老将我无能。"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！想那关兴、张苞，乃子侄之辈，在阵前擒来谭雄，不过是小小的功劳；\n主公在酒席筵前，夸之不已，反道昔年五虎上将，尽是老迈无用！有了，俺不\n免单人独骑，暗出御营，去到东吴的营盘，定要生擒孙权，活捉潘璋，刀劈他\n几员上将，看看我老是不老！"
        },
        {
          "character": "黄忠",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "太公八十掌帅印，\n廉颇八十领雄兵；\n俺黄忠岂是无本领——"
        },
        {
          "character": "黄忠",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "再学走马取定军！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠下。太监上。）"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "黄老将军怒出御营，直奔东吴而去。"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探。"
        },
        {
          "character": "太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（太监下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊？汉升为何怒出御营，直奔东吴而去？……哦，哦，是了！想是朕方才言语\n冒昧，怒恼了汉升，因此暗出御营，要斩将立功。哎！恐他阵前有失。\n二虎侄速速将老将军赶回，不得违误！"
        },
        {
          "character": "张苞、关兴",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "得令。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张苞、关兴同下。）"
        },
        {
          "character": "刘备",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将筵撤下。"
        },
        {
          "character": "刘备",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "适才朕言错出唇，\n不想激怒黄汉升。\n闷坐御营等信音。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
