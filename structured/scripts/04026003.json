    {
      "scene_index": 8,
      "label": "第八场",
      "characters_present": [
        "军士",
        "冷箭伤人实可恼",
        "潘璋",
        "黄忠"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠上，四军士、潘璋同追上。）"
        },
        {
          "character": "黄忠",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "勒马横刀怒冲霄。\n大骂潘璋尔听道：\n冲锋对敌是英豪。\n大胆吴寇敢放刁！"
        },
        {
          "character": "冷箭伤人实可恼、潘璋",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "黄忠老儿不服老，\n敢在阵前逞英豪。\n劝你马前归顺了。\n少若迟延命难逃。"
        },
        {
          "character": "黄忠",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "黄忠今日遭圈套！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（关兴、张苞同上，与潘璋起打。黄忠下，关兴、张苞同下。）"
        },
        {
          "character": "军士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "黄忠被关兴、张苞救去！"
        },
        {
          "character": "潘璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "追！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
