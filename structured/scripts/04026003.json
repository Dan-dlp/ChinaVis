          "character": "马忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参见元帅，胜负如何？"
        },
        {
          "character": "潘璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大败而归！"
        },
        {
          "character": "马忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "待末将抵挡一阵。"
        },
        {
          "character": "潘璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小心了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
