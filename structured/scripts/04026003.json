    {
      "scene_index": 5,
      "label": "第五场",
      "characters_present": [
        "军士",
        "潘璋",
        "黄忠"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四军士引潘璋同上。）"
        },
        {
          "character": "潘璋",
          "line_type": "西皮摇板",
          "musical_style": "西皮摇板",
          "style_family": "西皮",
          "text": "探马不住飞来报，\n黄忠老儿逞英豪。"
        },
        {
          "character": "潘璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某，东吴大将潘璋。前与吕蒙定计，夺取荆州，杀了关羽；吴侯见喜，将关羽\n的刀马赏赐与某。那赤兔马不食草料而死；这青龙刀，自到我手，未斩一将。\n今日黄忠怒踹我营，岂能容他猖狂。\n众将官！"
        },
        {
          "character": "军士",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "潘璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "杀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠上。）"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来将通名！"
        },
        {
          "character": "潘璋",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "东吴大将潘璋！"
        },
        {
          "character": "黄忠",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看刀！"
        },
        {
          "character": "黄忠",
          "line_type": "西皮快板",
          "musical_style": "西皮快板",
          "style_family": "西皮",
          "text": "怒发冲冠钢牙咬，\n尔敢使青龙偃月刀！\n气得黄忠眼花了！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（黄忠、潘璋同起打，潘璋、四军士同败下，黄忠追下。）"
        }
      ],
      "interactions": [
