      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张辽、许褚、夏侯惇、夏侯渊同上。）"
        },
        {
          "character": "张辽",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "气盖中华，"
        },
        {
          "character": "许褚",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "保定邦家，"
        },
        {
          "character": "夏侯惇",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "操练兵将，"
        },
        {
          "character": "夏侯渊",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "威振川娃，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "夏侯渊 （同点绛唇） 管叫他心惧怕。"
        },
        {
          "character": "张辽",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "威风凛凛振，"
        },
        {
          "character": "许褚",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "昂昂杀气生！"
        },
        {
          "character": "夏侯惇",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "站立辕门外，"
        },
        {
          "character": "夏侯渊",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "单听将令行。"
        },
        {
          "character": "张辽、许褚、夏侯惇、夏侯渊",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "俺！"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "张辽。"
        },
        {
          "character": "许褚",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "许褚。"
        },
        {
          "character": "夏侯惇",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夏侯惇。"
        },
        {
          "character": "夏侯渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "夏侯渊。"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "许褚、夏侯惇、夏侯渊",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相有令，命我等披挂整齐，各带人马，在教场以助雄威，惊吓那西川张松，"
        },
        {
          "character": "张辽",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我等在此伺候！"
        },
        {
          "character": "张辽、许褚、夏侯惇、夏侯渊",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程昱、贾诩、荀攸、满庞同上。）"
        },
        {
          "character": "程昱",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "少小须勤学，"
        },
        {
          "character": "贾诩",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "文章可立身。"
        },
        {
          "character": "荀攸",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "满朝朱紫贵，"
        },
        {
          "character": "满庞",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "尽是读书人。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "下官程昱。"
        },
        {
          "character": "贾诩",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贾诩。"
        },
        {
          "character": "荀攸",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "荀攸。"
        },
        {
          "character": "满庞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "满庞。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "各位大人请了。"
        },
        {
          "character": "贾诩、荀攸、满庞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请了。"
        },
        {
          "character": "程昱",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相命我等教场伺候。请！"
        },
        {
          "character": "贾诩、荀攸、满庞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "请。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四文堂、曹操同上，中军上。）"
        },
        {
          "character": "曹操",
          "line_type": "点绛唇",
          "musical_style": null,
          "style_family": null,
          "text": "职掌兵权，霸占中原，领人马，扫尽狼烟，篡汉随吾愿。"
        },
        {
          "character": "程昱、贾诩、荀攸、满庞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "少礼。"
        },
        {
          "character": "程昱、贾诩、荀攸、满庞",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢丞相。"
        },
        {
          "character": "张辽、许褚、夏侯惇、夏侯渊",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "末将打恭！"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "站立两厢！"
        },
        {
          "character": "曹操",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "南征北战胆气豪，胸怀智谋比人高。只因张松逞才干，特集文武唬儿曹。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "本爵，姓曹，名操，字孟德。只因张松到此，我看这厮，甚是狂傲。今日特聚"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "文武，以伏他心。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "中军！"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "文武官员，可曾到齐？"
        },
        {
          "character": "中军",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "到齐多时。"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "传张松进帐！"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相有令，张松进帐。"
        },
        {
          "character": "张松",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "来也！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张松上。）"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好一个曹孟德威风不小，"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "集文武特叫我张松观瞧。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "武一旁披铠甲盔缨飘飘。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "兵与卒各执着剑戟枪刀。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "才知道俺张松枉来一遭。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "文一边端朝笏身穿朱皂"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将一概持斧钺白光照耀"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "俺张松观一遍只当不晓"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我有心不会他转回川道"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "张松入帐！"
        },
        {
          "character": "张松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又听得众将官喊声更高。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "知奸相行霸道祸已自招。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看一看曹孟德怎样开销。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "悔只悔我不该错投此道"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我只得气昂昂大帐进了"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你见本爵，立而不跪，念你是远来之使，不加罪于你。尔今初到许昌，别无可"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "观，今日特集文武，齐至教场，你看老夫的威风，比尔西蜀如何？"
        },
        {
          "character": "张松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这个！"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "唔！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张松冷笑。）"
        },
        {
          "character": "张松",
          "line_type": "笑",
          "musical_style": null,
          "style_family": null,
          "text": "哈哈哈！"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哼！老夫到处战无不胜，攻无不取，无敌于天下，顺吾者昌，逆吾者亡！你倒"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "笑起老夫来了。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "骂一声小张松忒以狂诈，"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "敢在这教场上耻笑于咱。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又恐怕众文武道我量狭。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "古怪的猿猴背狗须乱轧。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "竟敢在我面前狂口自夸。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我本当传将令将你斩杀"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "看张松形容异身材不大"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他纵有满腹才全是自大"
        },
        {
          "character": "张松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "相爷英名，西蜀皆知！是战不能胜，攻不能取，无颜于天下！"
        },
        {
          "character": "曹操",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎见得？"
        },
        {
          "character": "张松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你且听道！"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "曹丞相你不必说话太傲，"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可记得在潼关遇着马超？"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只杀得曹丞相割须弃袍。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "濮阳城被吕布用火来烧。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "华容道求关公才得脱逃。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "战必胜攻必取莫大功劳！"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "战渭南夺船舟避箭跑掉"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "在宛城遇张绣子侄丧了"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "在赤壁遇周郎火攻计巧"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这都是曹丞相威风不小"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "骂一声小张松说话太错，"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "休得要在教场胡言乱说。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你再说老夫我待人如何？"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大将军谁无有胜败之错"
        },
        {
          "character": "张松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "丞相待人，名扬天下，人人皆知！待我说来，你且听了！"
        },
        {
          "character": "张松",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大将军谁无有胜败之错"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想当年献钢刀行刺董卓，"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "各州县画图形将你捕捉。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "陈公台弃县令随你逃脱。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杀他的一满门命见阎罗！"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "为什么恩不报反把头割？"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "真果是量似海恩如江河。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "行至在中牟县巧言瞒过"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "吕伯奢他待你哪些有错"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "白门楼陈公台被你拿获"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这都是丞相你待人不错"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "张松贼说此话忒以猖狂，"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "竟敢在我面前说短道长。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "也免得这畜生任嘴逞狂。"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叫人来将张松赶出大帐"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "可笑那曹孟德无才无量，"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他把我张永年当做平常。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又谁知曹孟德一味逞强。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "回西蜀见主公再作商量。"
        },
        {
          "character": "张松",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不料想这一遭枉来许昌。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（张松下。）"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我本是调文武叫他害怕，"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不料想气得我心火难压！"
        },
        {
          "character": "曹操",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "任凭他作何为走遍天涯。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。〖尾声〗。）"
        }
