        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老将何必把势斗"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "某与庄王结仇寇"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将军若肯卸甲胄"
        },
        {
          "character": "大将甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "住了！"
        },
        {
          "character": "大将甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老将何必把势斗"
        },
        {
          "character": "大将甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某与庄王结仇寇"
        },
        {
          "character": "大将甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将军若肯卸甲胄"
        },
        {
          "character": "大将甲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "勒马停蹄骂反寇，"
        },
        {
          "character": "大将甲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "越椒匹夫听原由："
        },
        {
          "character": "大将甲",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "管叫你一命丧荒丘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（斗越椒打大将甲。）"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "昏王无道结仇寇，"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "某家言来听根由："
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "越椒早晚坐龙楼。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大将甲下。大将乙上。）"
        },
        {
          "character": "大将乙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "丧家之犬学虎走，"
        },
        {
          "character": "大将乙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "泥鳅也想变龙游。"
        },
        {
          "character": "大将乙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哈巴狗儿怎能滚绣球！"
        },
        {
          "character": "大将乙",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "山鸡焉敢把凤凰斗"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老爷勇战无对手，"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿住庄王报冤仇。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（斗越椒、大将乙同开打，大将乙下，斗越椒下。楚庄王上。）"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "两下交兵日色不透，"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "尸横遍野血水流。"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿住了逆贼把筋抽。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（楚庄王上高坡。斗贲凰上。）"
        },
        {
          "character": "斗贲凰",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "战鼓咚咚如雷吼，"
        },
        {
          "character": "斗贲凰",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "旌旗招展半空游。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（大将甲、大将乙同上，大将甲、大将乙、斗贲凰同开打，大将甲、大将乙同下。）"
        },
        {
          "character": "斗贲凰",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二将败阵走荒丘。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（斗贲凰追下。）"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只杀得天昏地暗迷宇宙，"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "这乌鸦也不敢把翅收。"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿住了逆贼剔骨熬油。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（斗越椒上。）"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "豪杰阵前把志斗，"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不知庄王何处投。"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "高坡上一人戴冕旒。"
        },
        {
          "character": "斗越椒",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "箭射庄王一命休。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（斗越椒射。土地上，拥护。三朝臣、苏从同上，斗越椒下。土地下。）"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "越椒本是英雄后，"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一杆金枪赛龙游。"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杀得孤王无处投。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "报！"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启大王：斗越椒要战！"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "再探！"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子下。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "报子",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "大胆越椒太逞雄，"
        },
        {
          "character": "报子",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "藐视孤王理难容。"
        },
        {
          "character": "报子",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "欺压我国少英雄。"
        },
        {
          "character": "报子",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "免战高悬兵休动"
        },
        {
          "character": "报子",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三朝臣"
        },
        {
          "character": "苏从",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "大王受惊了！"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "适才孤王，在高坡之上，亲自擂鼓助阵。不想那斗越椒，暗放一箭。不是众卿"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "家保护，险遭不测。"
        },
        {
          "character": "三朝臣、苏从",
          "line_type": "同念",
          "musical_style": null,
          "style_family": null,
          "text": "圣天子百灵拥护，"
        },
        {
          "character": "楚庄王",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "大将军八面威风！"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有人训说越椒来降，孤无忧也。"
        },
        {
          "character": "朝臣甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "他乃叛逆之臣，说他则甚？"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众卿家，不是这样讲。倘若外国闻知，我国君臣厮杀，其理不周。"
        },
        {
          "character": "三朝臣",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "真乃仁德之君。"
        },
        {
          "character": "苏从",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老臣愿往，训说越椒来降。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老将军若去，须要小心。"
        },
        {
          "character": "苏从",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨。"
        },
        {
          "character": "苏从",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "好一个仁德楚庄王，"
        },
        {
          "character": "苏从",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "君臣厮杀理不当。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（苏从下。）"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "训说越椒兵休动，"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "去了老将名苏从。"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "东荡西除逞英雄。"
        },
        {
          "character": "楚庄王",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "也是我一时赏罚不公平。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（苏从上。）"
        },
        {
          "character": "苏从",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "越椒反贼逆王命，"
        },
        {
          "character": "苏从",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "辜负我主羡恩荣。"
        },
        {
          "character": "苏从",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老臣交旨。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "老将军，说降一事如何？"
        },
        {
          "character": "苏从",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "逆贼无礼，要与大王，决一死战。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！这逆贼真乃可恶。待孤出下榜文，招聚天下英雄好汉，定要灭却此贼。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众卿家，后帐歇息去罢！"
        },
        {
          "character": "三朝臣、苏从",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "谢大王！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（三朝臣、苏从同下。）"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "御林军，取黄绫照伺侯。"
        },
        {
          "character": "四龙套",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哦。"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "“庄王榜示”。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。）"
        },
        {
          "character": "楚庄王",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "将这榜文悬挂营门以外，有人揭榜，速报孤王知道。掩门。"
        },
        {
          "character": "四龙套",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "呵呵呵。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（楚庄王、四龙套同下。）"
        }
      ],
