        },
        {
          "character": "城隍",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "奉了玉帝旨，"
        },
        {
          "character": "土地",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "迎接窦太真。"
        },
        {
          "character": "城隍",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请了！"
        },
        {
          "character": "城隍",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你我奉了玉帝敕旨，迎接窦太真归位，就此前往！"
        },
        {
          "character": "土地",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "请！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（众人同下。）"
        }
      ],
      "interactions": [
