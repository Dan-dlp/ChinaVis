    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "大太监",
        "李世",
        "李世民",
        "李元吉",
        "李建成",
        "李淳风",
        "李渊",
        "窦太真",
        "袁天罡"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二宫女扶窦太真同上。）"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想皇儿不由人泪珠滚滚，"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "倒叫我年迈人好不伤情。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "众文武保皇儿洛阳出征。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又谁知有数年未见回程。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "思皇儿昼夜里何曾安宁。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但不知何日里才见儿身！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四太监、大太监引李渊同上。）"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "内侍臣忙带路望儿楼进，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李渊上楼。）"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "叫御妻快醒来王有话云。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "耳边厢只听得有人唤定，"
        },
        {
          "character": "窦太真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "却原来是万岁来到楼厅。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我本当下床榻实难扎挣！"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "劝梓童放宽心免去愁容。"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "御妻你的病体怎么样了？"
        },
        {
          "character": "窦太真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎，万岁呀！"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "自那日朝驾归身染重病，"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三更时梦皇儿回转宫廷。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "把一座锦江山付与他人。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "逼反了满朝中文武群臣。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "众皇儿保主公驾坐龙廷。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "他要夺我主爷锦绣乾坤。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到如今已数载未回宫廷。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "怎比那世民儿一片孝心。"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "但不知我皇儿何日回程？"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "万岁爷啊！"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想起了陈后主不理朝政"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "杨广贼贪酒色为君不正"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到后来那昏王丧了性命"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "只恨那洛阳贼打来战本"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "世民儿奉圣旨兵将带定"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有建成与元吉不能孝顺"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到如今妾妃我心中不定"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "劝御妻休把那皇儿思念，"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听为王把此事细说根源："
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "将江山国家事付他承担。"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "若是那世民儿把朝回转"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "谢罢了万岁爷的龙恩典，"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不由我窦太真心内痛酸。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（城隍、土地自两边暗分上。）"
        },
        {
          "character": "窦太真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "我心中好似万刀穿。"
        },
        {
          "character": "窦太真",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来了！"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "又只见城隍在面前站，"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "那、那、那、那土地笑盈盈站立一边。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（窦太真三唔噜。）"
        },
        {
          "character": "窦太真",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "无常到万事休命丧黄泉。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（窦太真死。）"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，御妻呀！"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一见梓童命丧了，"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不由孤王心内焦。"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "宣上先生问根苗。"
        },
        {
          "character": "李渊",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "内侍与孤传旨诏"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁有旨：宣先生进宫。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "李淳风 （内同白） 领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（袁天罡、李淳风同上。）"
        },
        {
          "character": "袁天罡",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听说万岁圣旨宣，"
        },
        {
          "character": "李淳风",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "想是国太归了天。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（袁天罡、李淳风同上楼。）"
        },
        {
          "character": "袁天罡、李淳风",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等见驾！"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀先生，国太归天去了！"
        },
        {
          "character": "袁天罡、李淳风",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "臣等早已算就，不敢泄漏。"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来如此。先生，国太死在楼上，如何是好？"
        },
        {
          "character": "袁天罡、李淳风",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "国太凤体，必须亲人方能背下楼去。"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "内侍臣宣你二位千岁上楼！"
        },
        {
          "character": "大太监",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁有旨：宣二位千岁上楼！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "李元吉 （内同白） 领旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李建成、李元吉同上。）"
        },
        {
          "character": "李建成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听说父王把旨传，"
        },
        {
          "character": "李元吉",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "上得楼来问根源。"
        },
        {
          "character": "李建成、李元吉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "参见父王！"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀皇儿，你、你、你母后死了哇！"
        },
        {
          "character": "李建成、李元吉",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀母后呀！"
        },
        {
          "character": "李建成",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一见母后丧了命，"
        },
        {
          "character": "李元吉",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "怎不教儿痛在心。"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你二人不必啼哭。适才二位先生奏道，你母后的凤体，必须亲人方能背下楼去。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启父王：儿建成将我母背下楼去。"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "好，皇儿背去！"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "母后，儿臣背你老人家来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（城隍指使土地打李建成。）"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呦！哎呦！"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你是怎么啦？"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "这也不知是哪个坏种打我！"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二皇儿你去背来！"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得啦，母后嫌你，她爱我疼我。你看我一背就下去。"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "看你的！"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣背你老人家来了。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（城隍指使土地打李建成。城隍、土地同下。）"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀！哎呀！"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你怎么啦？"
        },
        {
          "character": "李元吉",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "又是哪个坏种打来着！"
        },
        {
          "character": "李建成",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "得了！"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你二人闪开了！"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊先生，二位千岁不能背下楼去如何是好？"
        },
        {
          "character": "袁天罡、李淳风",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "万岁不必着急，少时自有亲人来到。"
        },
        {
          "character": "李世民",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "走哇！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二旗牌、李世民同上。二旗牌同下。）"
        },
        {
          "character": "李世民",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "奉了军师令，回朝面圣君。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李世民上楼。）"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿臣见驾，父王万岁！"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿是世民？"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿是世民！"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你回来了？"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿回来了。"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "儿呀，你、你、你母后死了哇！"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "现在哪里？"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你来看！"
        },
        {
          "character": "李世",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "民哎呀，母后呀！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李世民跪步。）"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一见母后命丧了，"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "不由孩儿心内焦。"
        },
        {
          "character": "李世民",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "母后呀！"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "母子们相逢在阴曹。"
        },
        {
          "character": "李世民",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "哭一声母后将儿抛了"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇儿不必啼哭，将你母后背下楼去，停在白虎殿内，文武百官穿孝百日；孝满"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "之期，孤将江山付与皇儿执掌就是。"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "启父王：儿臣将我母后背下楼去，父王再来传旨。"
        },
        {
          "character": "李渊",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "皇儿讲得有理。将你母后背下楼去罢！"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领旨！"
        },
        {
          "character": "李世民",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀，母后！孩儿世民背你老人家来了，啊、啊、啊……"
        },
        {
          "character": "李世民",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "啊啊啊！儿的娘啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（李世民哭。李世民背窦太真同下。众人同下。）"
        }
      ],
