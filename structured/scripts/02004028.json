    {
      "scene_index": 2,
      "label": "第二场",
      "characters_present": [
        "四青袍",
        "廖化",
        "张飞",
        "报子"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四札头、四青袍引张飞同上。）"
        },
        {
          "character": "张飞",
          "line_type": "引子",
          "musical_style": null,
          "style_family": null,
          "text": "威镇阆州，雄心贯斗牛。"
        },
        {
          "character": "张飞",
          "line_type": "念",
          "musical_style": null,
          "style_family": null,
          "text": "乌袍皂甲黑缨盔，丈八蛇矛逞雄威。虎牢关前战吕布，当阳桥下唬曹贼。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "某，汉将张翼德。自从桃园结义以来，血战数十余年，大哥驾坐西川，二哥镇"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "守荆州，俺奉军师将令，阆中守御。昨夜三更时分，偶得一梦，见一斗大红星，"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "从东南而起，呼啦啦坠落西北海底。也不知主何吉凶。阿嚏，阿嚏。哈，想"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "当日老张鼻孔发燥，弟兄们在徐州失散，到后来在古城才得团圆。今日鼻孔又"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来发燥，不知为着何情？"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "来！"
        },
        {
          "character": "四青袍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "伺候了。"
        },
        {
          "character": "四青袍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哦。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（报子上。）"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "报！"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "三千岁：廖化披头散发，急奔阆州而来。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请。"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哦。"
        },
        {
          "character": "报子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "有请廖将军。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廖化上。）"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "来至营门下雕鞍，"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "见了千岁把话言。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "廖化披头散发，为了何事？"
        },
        {
          "character": "廖化",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀三千岁吓！只因二千岁命丧玉泉山。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "怎么讲？"
        },
        {
          "character": "廖化",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "二千岁命丧玉泉山！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "张飞",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "二哥！兄长！哎呀桃园吓！"
        },
        {
          "character": "张飞",
          "line_type": "西皮导板",
          "musical_style": "西皮导板",
          "style_family": "西皮",
          "text": "听说二哥丧玉泉，"
        },
        {
          "character": "张飞",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "二哥！兄长！哎呀桃园吓！"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "环眼不住上下翻。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "乌牛白马祭上天。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "山崩地裂海水干。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二哥名丧玉泉山。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "廖化！"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二千岁因何把驾晏，"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一一从头说一番。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "当初桃园曾结义"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "一人在来三人在"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "到如今山海皆能见"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "东吴吕蒙巧机变，"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "白衣渡江占据关。"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "二千岁命丧玉泉山。"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "麦城受困救兵远"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呀！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "麦城受困救兵远"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听一言来怒冲冠，"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "手指东吴骂孙权。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "剥尔的皮来报仇冤！"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "麦城受困救兵远"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "廖化！"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "麦城受困救兵远"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你本是英雄一好汉，"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "就该四路把兵搬。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有朝见了尔的面"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "也曾四路把兵搬，"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "刘封、孟达谋江山。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "啊呀！"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "听说刘封谋江山，"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "老张七孔冒火烟。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "拿住亲手把眼剜。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "廖化！"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "你在此处莫久恋，"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "速到花关把兵搬。"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "有日见了奴才面"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "辞别千岁上雕鞍，"
        },
        {
          "character": "廖化",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "去到花关把兵搬。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（廖化下。）"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "廖化马走如闪电，"
        },
        {
          "character": "张飞",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "心急意乱奔西川。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "呔！三军的！"
        },
        {
          "character": "四青袍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "张飞",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "兵发西川。"
        },
        {
          "character": "四青袍",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哦！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。众人同下。）"
        }
      ],
