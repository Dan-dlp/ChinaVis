    {
      "scene_index": 3,
      "label": "第三场",
      "characters_present": [
        "众人",
        "孙悟空",
        "孤院庄严今瞻仰",
        "寿星",
        "禄星",
        "福星",
        "观音",
        "金吒",
        "镇元子",
        "龙女"
      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（八云童、四谒帝、四金刚、金吒、龙女、福星、禄星、寿星、观音同上。）"
        },
        {
          "character": "观音",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "驾离南海普陀岸，"
        },
        {
          "character": "观音",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "三星映照飞翔间。"
        },
        {
          "character": "观音",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "感应莲台法无边。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（孙悟空上。）"
        },
        {
          "character": "孙悟空",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "远观一派灿霞光，"
        },
        {
          "character": "孙悟空",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "算来有缘会慈航。"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "原来是菩萨。弟子悟空参见。"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "罢了。"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众位大仙稽首。"
        },
        {
          "character": "金吒、龙女、福星、禄星、寿星",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "悟空稽首。"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "悟空慌慌张张往哪里去？"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "菩萨，我师徒们路遇万寿山五庄观，因弟子一时无知，刨坏了镇元子大仙的人"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "参果树。恼怒了镇元子，将我师徒囚禁。弟子特地前来求菩萨慈悲。"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "吾正为此事而来。众位大仙同去走遭。"
        },
        {
          "character": "观音",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "速整云头须急往，"
        },
        {
          "character": "观音",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "咫尺天涯赖慈航。"
        },
        {
          "character": "观音",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "仙缘得遇佛有光。"
        },
        {
          "character": "观音",
          "line_type": "唱",
          "musical_style": null,
          "style_family": null,
          "text": "孤院庄严今瞻仰"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "镇元大仙，菩萨驾临，快些出迎。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。清风、明月、镇元子同上。）"
        },
        {
          "character": "镇元子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "多蒙菩萨降临，谨此奉迎法驾。请坐。"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且慢。先将果树救活了，然后再坐罢。"
        },
        {
          "character": "福星、禄星、寿星",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "妙吓。"
        },
        {
          "character": "镇元子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "众徒弟，打扫园内，按摆香案伺候。"
        },
        {
          "character": "福星、禄星、寿星",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "就请菩萨同行。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。众人同走圆场。）"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "果然人参果树倒坏在地。根已出现，叶落枝枯。"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "悟空。你将这符水放在树根之上，以水出为度。不犯五行之气。须用玉碗取出。"
        },
        {
          "character": "孙悟空",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "领法旨。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖江儿水〗。）"
        },
        {
          "character": "众人",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "树活了。"
        },
        {
          "character": "福星、禄星、寿星",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "果然树活，青枝绿叶，浓郁荫森。人参果蕊蕊垂垂。依然如旧。"
        },
        {
          "character": "镇元子",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "徒弟们。将人参果折下数枚，做个人参果会。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖吹打〗。众道士同献果。〖雁儿落〗。）"
        },
        {
          "character": "观音",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "仙树已活，我往普陀崖去者。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖沽美酒〗。观音下。〖清江引〗。众人自两边分下。）"
        }
      ],
