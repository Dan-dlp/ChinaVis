      ],
      "lines": [
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。四青袍、二差役、车夫、建文帝、严震直同上。）"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人役们！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "离城多远？"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "十里之遥。"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就此趱行者！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（〖牌子〗。众人同走圆场。）"
        },
        {
          "character": "程济",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "严老先生慢走！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "启爷：有一老道赶来。"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "想是程济赶来。我不寻他，他倒来赶我。\n人役们！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人马扎住，路旁等候便了！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "程济",
          "line_type": "内白",
          "musical_style": null,
          "style_family": null,
          "text": "走哇！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程济上。）"
        },
        {
          "character": "程济",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "疾走不觉路途远，\n奔得我两腿疼痛汗不干。"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我道是谁，原来是严老先生。请了！"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我道是谁，原来是程济。你赶来做甚？"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我特来贺喜。"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贺的什么喜？"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我想燕王为了建文帝，花费多少兵马钱粮，不曾拿获。如今被严老先生所擒，\n必得千金赏、万户侯，岂不可贺呀？"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "嗯！因功受赏，理所当然。我与兄台交厚，故意放你逃走，为何自投罗网？"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "深感你的恩情！多谢你的美意！"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "些许薄情，何足挂齿？"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "严震直啊，老匹夫！想你我当日一殿为臣，俱食朝廷的俸禄，同受皇家的深恩。\n不幸圣上失和，骨肉生变，为臣者理应秉定忠心，纠正朝纲才是。如今你不\n能替主分忧，反将主献与仇家，严震直啊老匹夫！你死在九泉，有何脸面去见\n那太祖高皇噢！"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哼！"
        },
        {
          "character": "程济",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你也曾食过他的俸禄在朝廊，\n你也曾封妻荫子门楣光。\n岂可事仇把旧主伤？\n全不念君王赐字授金章。\n岂不怕留骂名万古传扬？\n讲节操怎能比苏武牧羊？"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "贼子呀贼子！"
        },
        {
          "character": "程济",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "你焉能禄位功名永久长？"
        },
        {
          "character": "自古来忠臣相标榜、全不念身受恩重如山样、到如今媚新主大义全忘、谄媚人直同那鹦鹉学唱、这行为衣冠中禽兽一样、建文帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "苦哇！"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀且住！那旁囚车里面，乃是我主大师，我赶到此间，原为略尽君臣之义，\n不免向前相劝一番便了！"
        },
        {
          "character": "程济",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "大师！我主！哎呀大师呀！"
        },
        {
          "character": "程济",
          "line_type": "二黄导板",
          "musical_style": "二黄导板",
          "style_family": "二黄",
          "text": "自盘古到如今乾坤混乱！"
        },
        {
          "character": "程济",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "大师！我主！哎呀大师呀！"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人役们！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "有。"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "小心扎住者！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "啊！"
        },
        {
          "character": "程济",
          "line_type": "二黄慢板",
          "musical_style": "二黄慢板",
          "style_family": "二黄",
          "text": "哪有个帝王身上囚槛？\n难指望一统太平年。\n可怜主也曾把民安；\n可怜主失却了锦绣江山；\n可怜主穿只有补衲僧衫；\n可怜主皈佛教了却尘缘。\n落一个自怨自艾、自劝自慰、隐居深山。\n系缧绁好一似罪犯当官。\n倘不幸晴天霹雷、我主有险、微臣束手、心如箭攒。\n但愿主一路上清吉平安；\n但愿主得生路乐享田园。\n我程济死九泉也难心甘。"
        },
        {
          "character": "程济",
          "line_type": "哭头",
          "musical_style": null,
          "style_family": null,
          "text": "我那被屈含冤的主啊！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（四青袍同哭。）"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "我不许你哭！"
        },
        {
          "character": "程济",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "大限到怎能够妙手回天！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "差役甲 （同哭） 哎呀！"
        },
        {
          "character": "差役乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "什么事情，你们这么哭哇？"
        },
        {
          "character": "差役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你还没听见吗？"
        },
        {
          "character": "差役乙",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听见什么？"
        },
        {
          "character": "差役甲",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "听见什么？想这样的差事，你我还当它干什么？谁不是建文帝的臣子，哪个不\n是他的子民？吃他的粮饷长大的，还要拿他请功受赏，天理何在？良心何存？"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "你我不如各自散去了吧！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（同二黄摇板） 为人不把良心正，"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "后来如何把官升。"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "散啦！"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "人役们！"
        },
        {
          "character": "四青袍、二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "什么事情？"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "你们不遵国法，违令者斩！"
        },
        {
          "character": "二差役",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "什么，斩？剐都不怕你。先给你一下子，你别妄自尊大啦！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（二差役同打严震直，同下。四青袍同下。）"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "且住！看他君臣二人哭得可怜。人役们俱已离叛，我还有何脸面生在人世？也\n罢！不免拜谢老王爵禄之恩，寻个自尽了吧！"
        },
        {
          "character": "严震直",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "跌跪尘埃珠泪滚，\n吃什么爵禄报什么恩？\n子孙万代落骂名。"
        },
        {
          "character": "严震直",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "程济！"
        },
        {
          "character": "严震直",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "放你君臣远逃生。"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（严震直打车。）"
        },
        {
          "character": "严震直",
          "line_type": "三叫头",
          "musical_style": null,
          "style_family": null,
          "text": "我主！老王！罢！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（严震直自刎死。）"
        },
        {
          "character": "建文帝、程济",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀严尚书啊！"
        },
        {
          "character": "建文帝",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "一见尚书丧了命，\n你为小王轻了生。"
        },
        {
          "character": "程济",
          "line_type": "二黄摇板",
          "musical_style": "二黄摇板",
          "style_family": "二黄",
          "text": "谁叫你背主求荣图侥幸，\n报应循环天鉴明。"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "哎呀大师呀！尚书已死，众将已散，此时不走，等待何时！"
        },
        {
          "character": "建文帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "就此逃走了吧！"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "走了吧！"
        },
        {
          "character": "建文帝、程济",
          "line_type": "同唱",
          "musical_style": null,
          "style_family": null,
          "text": "闯破玉笼飞彩凤，\n挣开金锁走蛟龙。"
        },
        {
          "character": "程济",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "大师！"
        },
        {
          "character": "建文帝",
          "line_type": "白",
          "musical_style": null,
          "style_family": null,
          "text": "卿家！"
        },
        {
          "character": "程济、建文帝",
          "line_type": "同白",
          "musical_style": null,
          "style_family": null,
          "text": "走！走！走！"
        },
        {
          "character": null,
          "line_type": "stage_direction",
          "musical_style": null,
          "style_family": null,
          "text": "（程济、建文帝同下。）"
        }
      ],
